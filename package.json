{
  "name": "traveltribe",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/gen-llms.mjs",
    "build": "astro build",
    "gen:llms": "node scripts/gen-llms.mjs",
    "preview": "astro preview",
    "check:visual": "playwright test",
    "check:visual:update": "playwright test --update-snapshots",
    "check:visual:report": "playwright show-report tests/.html-report",
    "check:css": "stylelint \"src/**/*.{css,astro}\" --ignore-path .gitignore || true",
    "preview:test": "astro build && astro preview --port 4322",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/golos-text": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource-variable/onest": "^5.2.11",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@fontsource/onest": "^5.2.11",
    "@iconify-json/lucide": "^1.2.106",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^5.0.0",
    "astro-broken-links-checker": "^1.1.0",
    "astro-compress": "^2.4.1",
    "astro-icon": "^1.1.5",
    "astro-navbar": "^2.4.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "fontaine": "^0.8.0",
    "lefthook": "^2.1.6",
    "lint-staged": "^17.0.4",
    "patch-package": "^8.0.1",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
