{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/seasons/index.html",
        "http://localhost/calculator/index.html",
        "http://localhost/blog/index.html",
        "http://localhost/countries/index.html",
        "http://localhost/visa/index.html",
        "http://localhost/trips/index.html",
        "http://localhost/trips/may/index.html",
        "http://localhost/blog/japan-guide-2026/index.html",
        "http://localhost/blog/peru-guide-2026/index.html",
        "http://localhost/blog/bolivia-guide-2026/index.html",
        "http://localhost/blog/chile-guide-2026/index.html",
        "http://localhost/peru/index.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --headless"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.75 }],
        "categories:seo": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
