---
import '../styles/global.css';
import SwissHeader from '../components/SwissHeader.astro';
import CookieConsent from '../components/CookieConsent.astro';

// Golos Text (variable, единственный гротеск бренда) — self-hosted @font-face
// с font-display:optional (ниже, в <head>). Vite отдаёт хешированные URL
// (immutable-кэш). Заменяет прежний импорт @fontsource-variable/.../index.css
// (font-display:swap → FOUT → CLS). preload только cyrillic (основной язык RU).
import golosCyr from '@fontsource-variable/golos-text/files/golos-text-cyrillic-wght-normal.woff2';
import golosCyrExt from '@fontsource-variable/golos-text/files/golos-text-cyrillic-ext-wght-normal.woff2';
import golosLat from '@fontsource-variable/golos-text/files/golos-text-latin-wght-normal.woff2';
import golosLatExt from '@fontsource-variable/golos-text/files/golos-text-latin-ext-wght-normal.woff2';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ldJson?: object;
  preloadImage?: string;
  preloadImageSrcset?: string;
  preloadImageSizes?: string;
  noindex?: boolean;
  noTransitions?: boolean;
}

const {
  title,
  description = 'Бесплатный open source сервис для путешественников из России: таблица сезонов, виза, бюджет и калькулятор перелёта для 70+ направлений мира.',
  canonical = 'https://traveltribe.ru/',
  ogTitle = title,
  ogDescription = description,
  ogType = 'website',
  ogImage,
  ogImageAlt = 'TravelTribe — куда поехать: сезоны, визы и бюджет для 70+ направлений',
  ldJson,
  preloadImage,
  preloadImageSrcset,
  preloadImageSizes = '100vw',
  noindex = false,
  noTransitions = false,
} = Astro.props;

const OG_IMAGE = ogImage ?? 'https://traveltribe.ru/og-image.png?v=2';

// @font-face Golos с font-display:optional — swap не происходит, поэтому подмена
// шрифта не двигает вёрстку (CLS 0). unicode-range сохранён из fontsource:
// браузер тянет только нужный сабсет. При недогрузе на медленном первом заходе —
// fallback Helvetica без сдвига; на повторных страницах Golos уже в кэше.
const golosFontFace = [
  ['cyrillic-ext', golosCyrExt, 'U+0460-052F,U+1C80-1C8A,U+20B4,U+2DE0-2DFF,U+A640-A69F,U+FE2E-FE2F'],
  ['cyrillic', golosCyr, 'U+0301,U+0400-045F,U+0490-0491,U+04B0-04B1,U+2116'],
  ['latin-ext', golosLatExt, 'U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF'],
  ['latin', golosLat, 'U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD'],
].map(([, url, range]) =>
  `@font-face{font-family:'Golos Text Variable';font-style:normal;font-display:optional;font-weight:400 900;src:url(${url}) format('woff2-variations');unicode-range:${range}}`
).join('');

// Baseline entity graph — Organization + WebSite эмитятся на КАЖДОЙ
// странице, чтобы site-wide ссылки isPartOf:#website / publisher:#org
// резолвились (раньше определялись только на главной = висячие @id).
const ORG = {
  "@type": "Organization",
  "@id": "https://traveltribe.ru/#org",
  "name": "TravelTribe",
  "url": "https://traveltribe.ru/",
  "logo": "https://traveltribe.ru/brand-mark.svg",
  "founder": { "@id": "https://traveltribe.ru/about/#person" },
  "sameAs": ["https://t.me/traveltriberu", "https://github.com/nzaytsevmy/travel-seasons", "https://www.linkedin.com/in/nzaytsev/"],
};
const SITE = {
  "@type": "WebSite",
  "@id": "https://traveltribe.ru/#website",
  "name": "TravelTribe",
  "url": "https://traveltribe.ru/",
  "description": "Авторский тревел-блог из России: личные отчёты, визы, сезоны, бюджет 70+ направлений мира",
  "inLanguage": "ru-RU",
  "publisher": { "@id": "https://traveltribe.ru/#org" },
  "potentialAction": {
    "@type": "SearchAction",
    "target": { "@type": "EntryPoint", "urlTemplate": "https://traveltribe.ru/?s={search_term_string}" },
    "query-input": "required name=search_term_string",
  },
};
// Канонический Person — резолвит author/founder/#person на ВСЕХ страницах
// (раньше определялся только на /about/ = висячий @id везде остальном).
const PERSON = {
  "@type": "Person",
  "@id": "https://traveltribe.ru/about/#person",
  "name": "Никита Зайцев",
  "alternateName": "Nikita Zaytsev",
  "url": "https://traveltribe.ru/about/",
  "image": "https://traveltribe.ru/og-image.png",
  "jobTitle": "Travel writer · Product Manager",
  "description": "Путешественник, был на всех 7 континентах, посетил 60+ стран. Автор Telegram-канала @traveltriberu о путешествиях из России.",
  "knowsAbout": ["Путешествия из России", "Визы и пограничные правила", "Travel-бюджет и сезоны", "Тревел-фотография"],
  "nationality": { "@type": "Country", "name": "Россия" },
  "sameAs": ["https://t.me/traveltriberu", "https://www.linkedin.com/in/nzaytsev/", "https://github.com/nzaytsevmy"],
};
// Слить базовый граф со страничным; страничные дубли #org/#website отбросить.
// PERSON НЕ добавляем, если страница уже определяет свой #person (/about/ —
// там более полный Person; иначе был бы дубль @id).
const _ld = ldJson as any;
const _pageNodes = _ld
  ? (Array.isArray(_ld["@graph"]) ? _ld["@graph"] : Array.isArray(_ld) ? _ld : [_ld])
  : [];
const _baseIds = new Set(["https://traveltribe.ru/#org", "https://traveltribe.ru/#website"]);
const _pageHasPerson = _pageNodes.some(
  (n: any) => n && n["@id"] === "https://traveltribe.ru/about/#person"
);
const finalLd = {
  "@context": "https://schema.org",
  "@graph": [
    ORG,
    SITE,
    ...(_pageHasPerson ? [] : [PERSON]),
    ..._pageNodes.filter((n: any) => !(n && n["@id"] && _baseIds.has(n["@id"]))),
  ],
};
---
<!DOCTYPE html>
<html lang="ru" prefix="og: https://ogp.me/ns#">
<head>
  <meta charset="UTF-8" />

  <!-- Тёмная тема убрана 2026-05-23 — сайт только светлый (брендбук Swiss). -->

  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light" />
  <meta name="format-detection" content="telephone=no" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.json" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large, max-snippet:-1'} />
  <link rel="canonical" href={canonical} />
  <link rel="author" href="https://traveltribe.ru/about/" />
  <link rel="me" href="https://t.me/traveltriberu" />
  <link rel="alternate" type="application/rss+xml" title="TravelTribe RSS" href="/rss.xml" />

  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="TravelTribe" />
  <meta property="og:locale" content="ru_RU" />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:image" content={OG_IMAGE} />
  <meta property="og:image:secure_url" content={OG_IMAGE} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@traveltriberu" />
  <meta name="twitter:creator" content="@traveltriberu" />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={ogDescription} />
  <meta name="twitter:image" content={OG_IMAGE} />
  <meta name="twitter:image:alt" content={ogImageAlt} />
  <meta name="theme-color" content="#f4f2eb" />

  <!-- Только dns-prefetch для аналитики (грузится поздно). preconnect убран:
       PageSpeed флагует «unused preconnect» — eager-соединение крало канал у
       hero-картинки/шрифтов на медленном 4G (хуже LCP). -->
  <link rel="dns-prefetch" href="https://mc.yandex.ru" />
  <link rel="dns-prefetch" href="https://analytics.ahrefs.com" />

  <!-- Шрифты: один гротеск Golos Text (variable). @font-face с font-display:optional
       объявлен здесь (не через fontsource index.css со swap → это и давало CLS).
       preload cyrillic-сабсета — чтобы Golos успел в окно ~100мс и был виден с первого
       кадра. Newsreader/Onest убраны при Swiss-миграции 2026-05-23. JetBrains Mono — в global.css. -->
  <link rel="preload" as="font" type="font/woff2" href={golosCyr} crossorigin="anonymous" />
  <style set:html={golosFontFace}></style>

  <script type="application/ld+json" set:html={JSON.stringify(finalLd)} />

  {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
  {preloadImageSrcset && <link rel="preload" as="image" imagesrcset={preloadImageSrcset} imagesizes={preloadImageSizes} fetchpriority="high" />}

  <!-- Аналитика: базовая Яндекс.Метрика (обезличенная статистика + ПФ) и Ahrefs (cookieless)
       грузятся на production-домене для работы/улучшения Сайта (тот же законный интерес, что
       и техлоги хостинга). ВЕБВИЗОР (детальная запись сессий) — ТОЛЬКО после cookie-согласия
       (152-ФЗ). На localhost/preview не стартует. Main-thread (не partytown): Вебвизору нужен DOM. -->
  <script is:inline>
    (function () {
      var h = window.location.hostname;
      window.__analyticsEnabled = h === 'traveltribe.ru' || h === 'www.traveltribe.ru';
      function consent() { try { return localStorage.getItem('tt_consent'); } catch (e) { return null; } }
      var loaded = false;
      // withWebvisor=true только при согласии. Базовый счётчик (ПФ + трекинг кликов) — всегда.
      window.ttLoadAnalytics = function (withWebvisor) {
        if (loaded || !window.__analyticsEnabled) return;
        loaded = true;
        // Ahrefs Web Analytics (cookieless)
        var s = document.createElement('script');
        s.src = 'https://analytics.ahrefs.com/analytics.js';
        s.async = true; s.dataset.key = 'Vlc0xmPDRP3Rn1BkiDfn2A';
        document.head.appendChild(s);
        // Яндекс.Метрика 95832375 (webvisor — только при согласии)
        (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
        m[i].l=1*new Date();
        for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
        k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
        (window, document,'script','https://mc.yandex.ru/metrika/tag.js', 'ym');
        ym(95832375, 'init', {webvisor: !!withWebvisor, clickmap:true, accurateTrackBounce:true, trackLinks:true});
      };
      // Базовую аналитику грузим сразу; Вебвизор — если согласие уже дано.
      if (window.__analyticsEnabled) window.ttLoadAnalytics(consent() === 'granted');
      // Баннер показываем, пока выбор не сделан (предложить Вебвизор + проинформировать).
      window.__ttNeedConsent = window.__analyticsEnabled && consent() === null;
    })();
  </script>

  <!-- ClientRouter (SPA View Transitions) ОТКЛЮЧЁН по всему сайту 2026-05-21:
       давал класс Safari/SPA-багов (скрипты умирали при навигации, конфликт с
       bfcache на back/forward). Сайт статичный — нативные полные загрузки надёжнее,
       кастомных transition-анимаций не было. Все скрипты инициализируются на каждой
       полной загрузке (прямые вызовы init), astro:page-load-листенеры стали no-op. -->
</head>
<body>
  <!-- Skip-link for keyboard / screen reader users -->
  <a href="#main" class="skip-link">Перейти к контенту</a>

  <!-- Единое верхнее меню (Swiss) на всём сайте -->
  <SwissHeader />

  <slot />

  <!-- Реферальные/партнёрские ссылки (rel=sponsored / .aff-cta) открываем в новой
       вкладке + noopener — чтобы клик по партнёру не уводил человека с сайта.
       Внутренние и информационные ссылки не трогаем. Re-run после SPA-перехода. -->
  <script is:inline>
    var AFF = ['aviasales.ru', 'tpk.mx', 'pxf.io', 'platipomiru.com', 'drimsim.ru', 'cherehapa.ru', 'airalo.com', 'travelata.ru'];
    function _affHost(a) { try { return new URL(a.href).hostname.toLowerCase(); } catch (e) { return null; } }
    function _isAff(a, host) {
      if (!host || host.indexOf('traveltribe.ru') !== -1) return false;
      return a.rel.indexOf('sponsored') !== -1 || a.classList.contains('aff-cta') ||
        AFF.some(function (d) { return host === d || host.endsWith('.' + d); });
    }
    function _refLinksNewTab() {
      document.querySelectorAll('a[href^="http"]').forEach(function (a) {
        var host = _affHost(a);
        if (!_isAff(a, host)) return;                                      // только реферальные
        if (a.target !== '_blank') a.target = '_blank';
        if (!/\bnoopener\b/.test(a.rel)) a.rel = (a.rel + ' noopener').trim();
        if (a.rel.indexOf('sponsored') === -1) a.rel = (a.rel + ' sponsored').trim();  // доразметка bare-реф
      });
    }
    _refLinksNewTab();
    document.addEventListener('astro:page-load', _refLinksNewTab);
    // Трекинг партнёрских кликов в Метрику (цель outbound_link, партнёр в параметре).
    // Делегирование = 1 listener, ловит и динамически добавленные ссылки. ym грузится по
    // умолчанию (базовый счётчик), поэтому клики ловятся у всех. order_price — в UI Метрики.
    document.addEventListener('click', function (e) {
      var a = e.target.closest ? e.target.closest('a[href^="http"]') : null;
      if (!a) return;
      var host = _affHost(a);
      if (_isAff(a, host) && typeof window.ym === 'function') {
        window.ym(95832375, 'reachGoal', 'outbound_link', { partner: host });
      }
    }, true);
  </script>

  <!-- Cookie-баннер согласия (152-ФЗ) — на всём сайте, показывается до выбора -->
  <CookieConsent />

  <!-- Тёмная тема и её переключатель удалены 2026-05-23 (сайт только светлый). -->
</body>
</html>
