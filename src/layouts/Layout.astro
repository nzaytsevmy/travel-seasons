---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
  ldJson?: object;
  preloadImage?: string;
}

const {
  title,
  description = 'Бесплатный open source сервис для путешественников из России: таблица сезонов, виза, бюджет и калькулятор перелёта для 24 направлений мира.',
  canonical = 'https://traveltribe.ru',
  ogTitle = title,
  ogDescription = description,
  ogType = 'website',
  ogImage,
  ldJson,
  preloadImage,
} = Astro.props;

const OG_IMAGE = ogImage ?? 'https://traveltribe.ru/og-image.png';

const FONTS_URL = 'https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700;800&display=optional';
---
<!DOCTYPE html>
<html lang="ru" prefix="og: https://ogp.me/ns#">
<head>
  <meta charset="UTF-8" />

  <!-- FOUC: apply saved theme before first paint, no flash -->
  <script is:inline>
    (function () {
      var t = localStorage.getItem('theme');
      if (t === 'light' || (!t && window.matchMedia('(prefers-color-scheme: light)').matches)) {
        document.documentElement.classList.add('light-theme');
        document.body && document.body.classList.add('light-theme');
      }
    })();
  </script>

  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="manifest" href="/manifest.json" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonical} />

  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="TravelTribe" />
  <meta property="og:locale" content="ru_RU" />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:image" content={OG_IMAGE} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@traveltriberu" />
  <meta name="twitter:image" content={OG_IMAGE} />

  {ldJson && <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />}

  {preloadImage && <link rel="preload" as="image" href={preloadImage} />}

  <!-- Google Fonts — async, non-render-blocking -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href={FONTS_URL} />
  <link rel="stylesheet" href={FONTS_URL} media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href={FONTS_URL} /></noscript>

  <!-- Yandex Metrika — via Partytown (off-thread) -->
  <script type="text/partytown">
    (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
    m[i].l=1*new Date();
    for(var j=0;j<document.scripts.length;j++){if(document.scripts[j].src===r){return;}}
    k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
    (window,document,'script','https://mc.yandex.ru/metrika/tag.js','ym');
    ym(95832375,'init',{clickmap:true,trackLinks:true,accurateTrackBounce:true,webvisor:true});
  </script>
</head>
<body>
  <!-- Yandex Metrika noscript fallback -->
  <noscript>
    <div><img src="https://mc.yandex.ru/watch/95832375" style="position:absolute; left:-9999px;" alt="" /></div>
  </noscript>

  <slot />

  <!-- Theme toggle — runs after DOM is ready, re-runs on astro:page-load for View Transitions -->
  <script is:inline>
    function _initThemeToggle() {
      var btn = document.getElementById('themeToggle');
      if (!btn || btn._themeReady) return;
      btn._themeReady = true;

      function syncIcon() {
        var light = document.documentElement.classList.contains('light-theme');
        btn.textContent = light ? '☀' : '☾';
        btn.setAttribute('aria-label', light ? 'Тёмная тема' : 'Светлая тема');
      }

      syncIcon();

      btn.addEventListener('click', function () {
        var light = document.documentElement.classList.toggle('light-theme');
        document.body.classList.toggle('light-theme', light);
        document.body.style.display = 'none';
        void document.body.offsetHeight;
        document.body.style.display = '';
        localStorage.setItem('theme', light ? 'light' : 'dark');
        syncIcon();
      });
    }

    // Defer init until browser is idle — avoids forced layout during first paint
    _initThemeToggle();
    // Re-fires after each View Transitions navigation
    document.addEventListener('astro:page-load', _initThemeToggle);
  </script>
</body>
</html>
