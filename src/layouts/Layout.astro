---
import '../styles/global.css';
// Onest woff2 через Vite (?url → хешированный путь). font-display:optional
// объявляется ниже вручную — устраняет CLS от font-swap без size-adjust.
import onestCyrExt from '@fontsource-variable/onest/files/onest-cyrillic-ext-wght-normal.woff2?url';
import onestCyr from '@fontsource-variable/onest/files/onest-cyrillic-wght-normal.woff2?url';
import onestLatExt from '@fontsource-variable/onest/files/onest-latin-ext-wght-normal.woff2?url';
import onestLat from '@fontsource-variable/onest/files/onest-latin-wght-normal.woff2?url';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ldJson?: object;
  preloadImage?: string;
  noindex?: boolean;
  noTransitions?: boolean;
}

const {
  title,
  description = 'Бесплатный open source сервис для путешественников из России: таблица сезонов, виза, бюджет и калькулятор перелёта для 70 направлений мира.',
  canonical = 'https://traveltribe.ru/',
  ogTitle = title,
  ogDescription = description,
  ogType = 'website',
  ogImage,
  ogImageAlt = 'TravelTribe — куда поехать: сезоны, визы и бюджет для 70 направлений',
  ldJson,
  preloadImage,
  noindex = false,
  noTransitions = false,
} = Astro.props;

const OG_IMAGE = ogImage ?? 'https://traveltribe.ru/og-image.png?v=2';

// Baseline entity graph — Organization + WebSite эмитятся на КАЖДОЙ
// странице, чтобы site-wide ссылки isPartOf:#website / publisher:#org
// резолвились (раньше определялись только на главной = висячие @id).
const ORG = {
  "@type": "Organization",
  "@id": "https://traveltribe.ru/#org",
  "name": "TravelTribe",
  "url": "https://traveltribe.ru/",
  "logo": "https://traveltribe.ru/brand-mark.svg",
  "founder": { "@id": "https://traveltribe.ru/about/#person" },
  "sameAs": ["https://t.me/traveltriberu", "https://github.com/nzaytsevmy/travel-seasons", "https://www.linkedin.com/in/nzaytsev/"],
};
const SITE = {
  "@type": "WebSite",
  "@id": "https://traveltribe.ru/#website",
  "name": "TravelTribe",
  "url": "https://traveltribe.ru/",
  "description": "Авторский тревел-блог из России: личные отчёты, визы, сезоны, бюджет 70 направлений мира",
  "inLanguage": "ru-RU",
  "publisher": { "@id": "https://traveltribe.ru/#org" },
  "potentialAction": {
    "@type": "SearchAction",
    "target": { "@type": "EntryPoint", "urlTemplate": "https://traveltribe.ru/?s={search_term_string}" },
    "query-input": "required name=search_term_string",
  },
};
// Канонический Person — резолвит author/founder/#person на ВСЕХ страницах
// (раньше определялся только на /about/ = висячий @id везде остальном).
const PERSON = {
  "@type": "Person",
  "@id": "https://traveltribe.ru/about/#person",
  "name": "Никита Зайцев",
  "alternateName": "Nikita Zaytsev",
  "url": "https://traveltribe.ru/about/",
  "image": "https://traveltribe.ru/og-image.png",
  "jobTitle": "Travel writer · Product Manager",
  "description": "Путешественник, был на всех 7 континентах, посетил 60+ стран. Автор Telegram-канала @traveltriberu о путешествиях из России.",
  "knowsAbout": ["Путешествия из России", "Визы и пограничные правила", "Travel-бюджет и сезоны", "Тревел-фотография"],
  "nationality": { "@type": "Country", "name": "Россия" },
  "sameAs": ["https://t.me/traveltriberu", "https://www.linkedin.com/in/nzaytsev/", "https://github.com/nzaytsevmy"],
};
// Слить базовый граф со страничным; страничные дубли #org/#website отбросить.
// PERSON НЕ добавляем, если страница уже определяет свой #person (/about/ —
// там более полный Person; иначе был бы дубль @id).
const _ld = ldJson as any;
const _pageNodes = _ld
  ? (Array.isArray(_ld["@graph"]) ? _ld["@graph"] : Array.isArray(_ld) ? _ld : [_ld])
  : [];
const _baseIds = new Set(["https://traveltribe.ru/#org", "https://traveltribe.ru/#website"]);
const _pageHasPerson = _pageNodes.some(
  (n: any) => n && n["@id"] === "https://traveltribe.ru/about/#person"
);
const finalLd = {
  "@context": "https://schema.org",
  "@graph": [
    ORG,
    SITE,
    ...(_pageHasPerson ? [] : [PERSON]),
    ..._pageNodes.filter((n: any) => !(n && n["@id"] && _baseIds.has(n["@id"]))),
  ],
};
---
<!DOCTYPE html>
<html lang="ru" prefix="og: https://ogp.me/ns#">
<head>
  <meta charset="UTF-8" />

  <!-- FOUC: light is the default theme. Dark only when user explicitly opts in.
       Также применяется после ClientRouter swap, чтобы тема не слетала
       при SPA-навигации (Safari особенно чувствителен к этому). -->
  <script is:inline>
    (function () {
      function applyTheme() {
        var dark = localStorage.getItem('theme') === 'dark';
        document.documentElement.classList.toggle('dark-theme', dark);
        if (document.body) document.body.classList.toggle('dark-theme', dark);
      }
      applyTheme();
      // ClientRouter (Astro View Transitions): применять тему после swap
      document.addEventListener('astro:after-swap', applyTheme);
    })();
  </script>

  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="dark light" />
  <meta name="format-detection" content="telephone=no" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.json" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large, max-snippet:-1'} />
  <link rel="canonical" href={canonical} />
  <link rel="author" href="https://traveltribe.ru/about/" />
  <link rel="me" href="https://t.me/traveltriberu" />
  <link rel="alternate" type="application/rss+xml" title="TravelTribe RSS" href="/rss.xml" />

  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="TravelTribe" />
  <meta property="og:locale" content="ru_RU" />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:image" content={OG_IMAGE} />
  <meta property="og:image:secure_url" content={OG_IMAGE} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@traveltriberu" />
  <meta name="twitter:creator" content="@traveltriberu" />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={ogDescription} />
  <meta name="twitter:image" content={OG_IMAGE} />
  <meta name="twitter:image:alt" content={ogImageAlt} />
  <meta name="theme-color" content="#0c0a08" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#f8f5ef" media="(prefers-color-scheme: light)" />

  <!-- DNS prefetch + preconnect для third-party аналитики -->
  <link rel="dns-prefetch" href="https://mc.yandex.ru" />
  <link rel="preconnect" href="https://mc.yandex.ru" crossorigin />
  <link rel="dns-prefetch" href="https://analytics.ahrefs.com" />
  <link rel="preconnect" href="https://analytics.ahrefs.com" crossorigin />

  <!-- Editorial Magazine fonts: self-hosted через @fontsource (no Google Fonts request)
       Newsreader (variable italic + opsz) — заменяет Fraunces, editorial italic с длинными descenders
       Onest — sans от русского дизайнера, optimized кириллица, заменяет DM Sans
       JetBrains Mono — для дат, кодов, штампов, заменяет PT Mono
       Импорт в src/styles/global.css через @fontsource-variable пакеты. -->

  <style set:html={`
    @font-face{font-family:'Onest Variable';font-style:normal;font-display:optional;font-weight:100 900;src:url(${onestCyrExt}) format('woff2-variations');unicode-range:U+0460-052F,U+1C80-1C8A,U+20B4,U+2DE0-2DFF,U+A640-A69F,U+FE2E-FE2F}
    @font-face{font-family:'Onest Variable';font-style:normal;font-display:optional;font-weight:100 900;src:url(${onestCyr}) format('woff2-variations');unicode-range:U+0301,U+0400-045F,U+0490-0491,U+04B0-04B1,U+2116}
    @font-face{font-family:'Onest Variable';font-style:normal;font-display:optional;font-weight:100 900;src:url(${onestLatExt}) format('woff2-variations');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF}
    @font-face{font-family:'Onest Variable';font-style:normal;font-display:optional;font-weight:100 900;src:url(${onestLat}) format('woff2-variations');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
  `} />
  <link rel="preload" as="font" type="font/woff2" href={onestCyr} crossorigin />

  <script type="application/ld+json" set:html={JSON.stringify(finalLd)} />

  {preloadImage && <link rel="preload" as="image" href={preloadImage} />}

  <!-- Аналитика — только на production hostname (не на localhost / staging).
       Иначе Playwright/preview сервер накручивает визиты в метрике. -->
  <script is:inline>
    (function () {
      var h = window.location.hostname;
      window.__analyticsEnabled = h === 'traveltribe.ru' || h === 'www.traveltribe.ru';
    })();
  </script>

  <!-- Ahrefs Analytics — только в production -->
  <script type="text/partytown" is:inline>
    if (window.__analyticsEnabled) {
      var s = document.createElement('script');
      s.src = 'https://analytics.ahrefs.com/analytics.js';
      s.dataset.key = 'Vlc0xmPDRP3Rn1BkiDfn2A';
      document.head.appendChild(s);
    }
  </script>

  <!-- Yandex.Metrika — только в production (не на localhost) -->
  <script type="text/partytown" is:inline>
    if (window.__analyticsEnabled) {
      (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
      m[i].l=1*new Date();
      for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
      k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
      (window, document,'script','https://mc.yandex.ru/metrika/tag.js', 'ym');
      ym(95832375, 'init', {webvisor:true, clickmap:true, accurateTrackBounce:true, trackLinks:true});
    }
  </script>
  <noscript><div><img src="https://mc.yandex.ru/watch/95832375" style="position:absolute; left:-9999px;" alt="Yandex Metrika" aria-hidden="true" /></div></noscript>

  <!-- View Transitions API — плавные переходы между страницами -->
  {!noTransitions && <ClientRouter />}
</head>
<body>
  <!-- Skip-link for keyboard / screen reader users -->
  <a href="#main" class="skip-link">Перейти к контенту</a>

  <slot />

  <!-- Реферальные/партнёрские ссылки (rel=sponsored / .aff-cta) открываем в новой
       вкладке + noopener — чтобы клик по партнёру не уводил человека с сайта.
       Внутренние и информационные ссылки не трогаем. Re-run после SPA-перехода. -->
  <script is:inline>
    function _refLinksNewTab() {
      var AFF = ['aviasales.ru', 'tpk.mx', 'pxf.io', 'platipomiru.com', 'drimsim.ru', 'cherehapa.ru', 'airalo.com', 'travelata.ru'];
      document.querySelectorAll('a[href^="http"]').forEach(function (a) {
        var host;
        try { host = new URL(a.href).hostname.toLowerCase(); } catch (e) { return; }
        if (host.indexOf('traveltribe.ru') !== -1) return;                 // внутренние не трогаем
        var isRef = a.rel.indexOf('sponsored') !== -1 || a.classList.contains('aff-cta') ||
          AFF.some(function (d) { return host === d || host.endsWith('.' + d); });
        if (!isRef) return;                                                // только реферальные
        if (a.target !== '_blank') a.target = '_blank';
        if (!/\bnoopener\b/.test(a.rel)) a.rel = (a.rel + ' noopener').trim();
        if (a.rel.indexOf('sponsored') === -1) a.rel = (a.rel + ' sponsored').trim();  // доразметка bare-реф
      });
    }
    _refLinksNewTab();
    document.addEventListener('astro:page-load', _refLinksNewTab);
  </script>

  <!-- Theme toggle — light is default, button switches to dark and back.
       Re-init после ClientRouter swap: новая кнопка в DOM = новый listener. -->
  <script is:inline>
    function _initThemeToggle() {
      var btn = document.getElementById('themeToggle');
      if (!btn || btn._themeReady) return;
      btn._themeReady = true;

      function syncIcon() {
        var dark = document.documentElement.classList.contains('dark-theme');
        btn.textContent = dark ? '☀' : '☾';
        btn.setAttribute('aria-label', dark ? 'Светлая тема' : 'Тёмная тема');
      }

      syncIcon();

      btn.addEventListener('click', function () {
        var dark = document.documentElement.classList.toggle('dark-theme');
        document.body.classList.toggle('dark-theme', dark);
        // Safari hack: force repaint чтобы CSS variables применились мгновенно
        document.body.style.display = 'none';
        void document.body.offsetHeight;
        document.body.style.display = '';
        localStorage.setItem('theme', dark ? 'dark' : 'light');
        syncIcon();
      });
    }

    _initThemeToggle();
    // Re-init после каждого SPA-перехода через ClientRouter
    document.addEventListener('astro:page-load', _initThemeToggle);
  </script>
</body>
</html>
