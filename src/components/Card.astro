---
import { Image } from 'astro:assets';

interface Props {
  href?: string;
  title: string;
  sub: string;
  badge: string;
  visa: 'free' | 'evisa' | 'required';
  budget: 'low' | 'mid' | 'high';
  seasonBar: string[];
  price: string;
  imageUrl: string;
  imageAlt: string;
}

const {
  href = '/seasons',
  title,
  sub,
  badge,
  visa,
  budget,
  seasonBar,
  price,
  imageUrl,
  imageAlt,
} = Astro.props;

const VISA_CLASS  = { free: 'tag-free', evisa: 'tag-evisa', required: 'tag-visa' };
const VISA_LABEL  = { free: 'Без визы', evisa: 'eVisa',     required: 'Виза'     };
const BDG_CLASS   = { low:  'tag-low',  mid:   'tag-mid',   high:     'tag-high'  };
const BDG_LABEL   = { low:  '$ Дёшево', mid:   '$$ Средне', high:     '$$$ Дорого'};
const BAR_CLASS: Record<string, string> = { P:'s-P', G:'s-G', O:'s-O', B:'s-B', X:'s-X' };
---

<a href={href} class="card">
  <div class="card-thumb">
    <div class="card-thumb-img">
      <Image
        src={imageUrl}
        alt={imageAlt}
        width={600}
        height={300}
        format="webp"
        onerror="this.style.display='none'"
      />
    </div>
    <div class="card-thumb-overlay" aria-hidden="true"></div>
    <span class="card-badge">{badge}</span>
  </div>
  <div class="card-body">
    <div class="card-title">{title}</div>
    <div class="card-sub">{sub}</div>
    <div class="card-tags">
      <span class={`tag ${VISA_CLASS[visa]}`}>{VISA_LABEL[visa]}</span>
      <span class={`tag ${BDG_CLASS[budget]}`}>{BDG_LABEL[budget]}</span>
    </div>
    <div class="season-bar" aria-hidden="true">
      {seasonBar.map(s => <div class={`s ${BAR_CLASS[s]}`} aria-hidden="true"></div>)}
    </div>
  </div>
  <div class="card-footer">
    <div class="card-price">От <strong>{price}</strong></div>
    <div class="card-arrow" aria-hidden="true">→</div>
  </div>
</a>

<style>
.card {
  background: var(--bg); overflow: hidden;
  cursor: pointer; position: relative; display: block;
}
.card::before {
  content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold-dim), transparent);
  opacity: 0; z-index: 1;
  /* override global * transition — ::before uses opacity, not bg/color */
  transition: opacity 0.3s ease;
}
.card:hover { background: var(--bg3); }
.card:hover::before { opacity: 1; }

/* ─── THUMBNAIL ─── */
.card-thumb {
  height: 140px; position: relative;
  display: flex; align-items: flex-end; padding: 0.8rem; overflow: hidden;
}
.card-thumb-img {
  position: absolute; inset: 0; overflow: hidden;
  /* no bg/color transition needed here */
  transition: transform 0.4s ease;
}
.card:hover .card-thumb-img { transform: scale(1.04); }
.card-thumb-img img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* KEY FIX: overlay and badge now use CSS variables — respond to .light-theme toggle */
.card-thumb-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, var(--card-overlay) 0%, transparent 60%);
}
.card-badge {
  position: relative; font-size: 0.62rem; letter-spacing: 0.06em; text-transform: uppercase;
  background: var(--card-badge-bg); border: 1px solid rgba(201,151,58,0.25);
  color: var(--text-dim); padding: 0.22rem 0.55rem; border-radius: 2px;
  backdrop-filter: blur(8px);
}

/* ─── BODY ─── */
.card-body { padding: 1.1rem; }
.card-title { font-family: var(--ff-display); font-size: 1.4rem; font-weight: 400; margin-bottom: 0.15rem; line-height: 1.2; }
.card-sub { color: var(--text-faint); font-size: 0.72rem; margin-bottom: 0.9rem; letter-spacing: 0.04em; }
.card-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; margin-bottom: 0.9rem; }

/* ─── SEASON BAR (decorative only, aria-hidden) ─── */
.season-bar { display: flex; gap: 2px; }
.s { flex: 1; height: 5px; border-radius: 2px; transition: none; }
.s-P { background: #22c55e; }
.s-G { background: #4a9eff; }
.s-O { background: #f59e0b; }
.s-B { background: #ef4444; }
.s-X { background: rgba(201,151,58,0.15); }

/* ─── FOOTER ─── */
.card-footer {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0.85rem 1.1rem; border-top: 1px solid var(--line);
}
.card-price { font-size: 0.75rem; color: var(--text-dim); }
.card-price strong { color: var(--text); font-size: 0.88rem; }
.card-arrow {
  color: var(--text-faint);
  /* override global transition for transform */
  transition: transform 0.15s ease, color 0.25s ease;
}
.card:hover .card-arrow { transform: translateX(3px); color: var(--gold); }
</style>
