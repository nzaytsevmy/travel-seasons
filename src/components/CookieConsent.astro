---
// Cookie-баннер (152-ФЗ). Базовая обезличенная Метрика работает по умолчанию (законный
// интерес); баннер спрашивает согласие на ВЕБВИЗОР (детальная запись сессий) и информирует.
// Показывается, только если выбор ещё не сделан И аналитика разрешена (production-домен).
// position:fixed → вне потока → 0 CLS. Без агрессивного оверлея (требование Яндекса).
---
<div id="cookie-consent" class="cc" hidden role="region" aria-label="Согласие на использование cookie">
  <p class="cc-text">
    Сайт ведёт обезличенную статистику Яндекс.Метрики, чтобы понимать, какие материалы полезны.
    Для детальной записи сессий (Вебвизор) нужно ваше согласие. Подробнее — в
    <a href="/legal/privacy/">Политике конфиденциальности</a> и
    <a href="/legal/cookie/">Cookie-политике</a>.
  </p>
  <div class="cc-actions">
    <button type="button" id="cc-decline" class="cc-btn cc-btn-ghost">Отклонить</button>
    <button type="button" id="cc-accept" class="cc-btn cc-btn-solid">Принять</button>
  </div>
</div>

<style>
  .cc {
    position: fixed; left: 1rem; right: 1rem; bottom: 1rem; z-index: 60;
    max-width: 660px; margin-left: auto;
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem 1.5rem;
    background: var(--bg2); border: 1px solid var(--text-dim);
    padding: 0.95rem 1.1rem;
  }
  /* Скоуп-селектор .cc перебивает [hidden]{display:none} — возвращаем скрытие явно,
     иначе атрибут hidden не работает и баннер не убирается по «Принять»/«Отклонить». */
  .cc[hidden] { display: none; }
  .cc-text { flex: 1 1 280px; margin: 0; font-size: 0.82rem; line-height: 1.6; color: var(--text-dim); }
  .cc-text a { color: var(--gold); border-bottom: 1px solid rgba(142,102,24,0.35); }
  .cc-text a:hover { border-color: var(--gold); }
  .cc-actions { display: flex; gap: 0.6rem; flex: 0 0 auto; }
  .cc-btn {
    font: inherit; font-size: 0.82rem; line-height: 1; padding: 0.6rem 1.2rem;
    min-height: 44px; cursor: pointer; border: 1px solid var(--text-dim); background: transparent; color: var(--text-dim);
  }
  .cc-btn-solid { background: var(--gold); color: #fff; border-color: var(--gold); }
  .cc-btn-ghost:hover { border-color: var(--text); color: var(--text); }
  .cc-btn-solid:hover { background: var(--gold-dim); border-color: var(--gold-dim); }
  .cc-btn:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }
  @media (max-width: 520px) {
    .cc { left: 0.5rem; right: 0.5rem; bottom: 0.5rem; }
    .cc-actions { width: 100%; }
    .cc-btn { flex: 1; }
  }
</style>

<script is:inline>
  (function () {
    var el = document.getElementById('cookie-consent');
    if (!el) return;
    if (window.__ttNeedConsent) el.hidden = false;
    function decide(value) {
      try { localStorage.setItem('tt_consent', value); } catch (e) {}
      el.hidden = true;
      // Базовая Метрика уже работает. Согласие включает Вебвизор; запись стартует со
      // следующего перехода (флаг webvisor задаётся при init счётчика на загрузке страницы).
      if (value === 'granted' && typeof window.ttLoadAnalytics === 'function') window.ttLoadAnalytics(true);
    }
    var a = document.getElementById('cc-accept');
    var d = document.getElementById('cc-decline');
    if (a) a.addEventListener('click', function () { decide('granted'); });
    if (d) d.addEventListener('click', function () { decide('denied'); });
  })();
</script>
