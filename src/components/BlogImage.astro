---
import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---
<figure class="blog-img">
  <Image
    src={src}
    alt={alt}
    width={760}
    height={440}
    format="webp"
    quality={75}
    loading="lazy"
    style="width:100%;height:auto;max-height:500px;object-fit:cover;border-radius:6px;display:block;"
  />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
.blog-img { margin: 2rem 0; }
figcaption {
  margin-top: 0.5rem;
  font-size: 0.72rem;
  color: var(--text-faint);
  text-align: center;
  letter-spacing: 0.03em;
}
</style>
