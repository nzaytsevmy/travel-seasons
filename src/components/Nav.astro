---
import { Astronav, MenuItems, MenuIcon, Dropdown, DropdownItems } from 'astro-navbar';
const { active } = Astro.props;
const inHub = ['countries', 'visa', 'seasons', 'trips', 'cards'].includes(active);
---
<Astronav closeOnClick>
  <nav class="site-nav">
    <a href="/" class="logo" aria-label="TravelTribe — на главную">
      <svg class="logo-mark" viewBox="0 0 24 24" fill="none" width="22" height="22" aria-hidden="true">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.4" opacity="0.4"/>
        <path d="M 2.5 13.5 Q 12 9 21.5 13.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        <circle cx="12" cy="9" r="1.6" fill="currentColor"/>
        <path d="M 6 17 Q 12 14 18 17" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-dasharray="0.5 1.4" opacity="0.55"/>
      </svg>
      <span class="logo-text">Travel<span class="logo-text-accent">Tribe</span></span>
    </a>

    <MenuItems class="nav-links hidden">
      <a href="/" class={active === 'home' ? 'active' : ''} aria-current={active === 'home' ? 'page' : undefined}>Главная</a>

      <Dropdown class={`nav-dropdown ${inHub ? 'active' : ''}`}>
        <button type="button" class="nav-dropdown-trigger" aria-haspopup="true">
          Страны
          <svg class="caret" viewBox="0 0 12 7" width="10" height="6" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M1 1l5 5 5-5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <DropdownItems class="nav-dropdown-menu">
          <a href="/countries/" class={active === 'countries' ? 'active' : ''}>
            <strong>Кратко о странах</strong>
            <span>70 направлений — виза, сезоны, бюджет</span>
          </a>
          <a href="/visa/" class={active === 'visa' ? 'active' : ''}>
            <strong>Визы для россиян</strong>
            <span>Без визы / eVisa / обязательная — детально</span>
          </a>
          <a href="/seasons/" class={active === 'seasons' ? 'active' : ''}>
            <strong>Сезоны</strong>
            <span>Таблица 70×12 — когда лучше ехать</span>
          </a>
          <a href="/trips/" class={active === 'trips' ? 'active' : ''}>
            <strong>Календарь поездок</strong>
            <span>Что работает в каждом месяце 2026</span>
          </a>
        </DropdownItems>
      </Dropdown>

      <a href="/calculator/" data-astro-reload class={active === 'calculator' ? 'active' : ''} aria-current={active === 'calculator' ? 'page' : undefined}>Калькулятор</a>
      <a href="/packing/" class={active === 'packing' ? 'active' : ''} aria-current={active === 'packing' ? 'page' : undefined}>Чек-лист</a>
      <a href="/blog/" class={active === 'blog' ? 'active' : ''} aria-current={active === 'blog' ? 'page' : undefined}>Блог</a>
      <a class="nav-cta" href="https://t.me/traveltriberu" target="_blank" rel="noopener">Telegram →</a>
    </MenuItems>

    <div class="nav-right">
      <button id="themeToggle" class="theme-btn" aria-label="Переключить тему">☾</button>
      <MenuIcon class="burger-icon" />
    </div>
  </nav>
</Astronav>

<style>
  /* ───────────────────────────────────────────────────────────
     Nav — на основе astro-navbar
     state via library:
       MenuItems  → .astronav-items / toggle .hidden
       Dropdown   → <menu class="astronav-dropdown"> / .open
       DropdownItems → .dropdown-toggle / toggle .hidden
       MenuIcon   → #astronav-menu
  ─────────────────────────────────────────────────────────── */

  /* MenuItems wrapper — на desktop всегда виден, на mobile управляется .hidden */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    height: 100%;
  }
  .nav-links > a {
    display: inline-flex;
    align-items: center;
    height: 64px;
    color: var(--text-dim);
    text-decoration: none;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.15s;
  }
  .nav-links > a:hover,
  .nav-links > a.active { color: var(--gold); }
  .nav-links > a.active { font-weight: 500; }
  .nav-links > a.nav-cta {
    height: auto;
    padding: 0.5rem 0.95rem;
    border: 1px solid var(--gold-dim);
    border-radius: 3px;
    color: var(--gold);
    letter-spacing: 0.06em;
  }
  .nav-links > a.nav-cta:hover { background: rgba(201,151,58,0.1); }

  /* Dropdown — <menu> reset + same height as siblings */
  .nav-dropdown {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .nav-dropdown-trigger {
    display: inline-flex; align-items: center; gap: 5px;
    background: none; border: none; margin: 0; padding: 0;
    height: 64px;
    font: inherit; color: var(--text-dim);
    font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase;
    cursor: pointer;
    transition: color 0.15s;
    -webkit-appearance: none;
    appearance: none;
    -webkit-tap-highlight-color: transparent;
  }
  .nav-dropdown-trigger:hover,
  .nav-dropdown.active .nav-dropdown-trigger,
  .nav-dropdown.open .nav-dropdown-trigger { color: var(--gold); }
  .nav-dropdown-trigger .caret { transition: transform 0.2s ease; }
  .nav-dropdown.open .nav-dropdown-trigger .caret { transform: rotate(180deg); }

  /* DropdownItems — initial .hidden скрывает, toggle .hidden удаляется */
  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% - 6px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 280px;
    background: var(--bg2);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 14px 40px -10px rgba(0,0,0,0.25);
    padding: 0.4rem;
    flex-direction: column;
    z-index: 100;
  }
  .nav-dropdown-menu.hidden { display: none; }
  .nav-dropdown-menu:not(.hidden) { display: flex; }
  .nav-dropdown-menu a {
    display: flex; flex-direction: column; gap: 2px;
    padding: 0.7rem 0.95rem;
    border-radius: 4px;
    text-decoration: none;
    color: var(--text);
    transition: background 0.15s;
  }
  .nav-dropdown-menu a:hover { background: rgba(201,151,58,0.08); }
  .nav-dropdown-menu a.active { background: rgba(201,151,58,0.12); }
  .nav-dropdown-menu a strong {
    font-size: 0.92rem; font-weight: 600;
    letter-spacing: 0; text-transform: none;
    color: var(--text);
  }
  .nav-dropdown-menu a:hover strong { color: var(--gold); }
  .nav-dropdown-menu a span {
    font-size: 0.74rem;
    color: var(--text-faint);
    letter-spacing: 0.02em;
    text-transform: none;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: nowrap;
  }

  /* Burger — MenuIcon рендерит <button id="astronav-menu"> */
  :global(#astronav-menu) {
    display: none;
    background: none;
    border: 1px solid var(--line);
    border-radius: 3px;
    padding: 0;
    cursor: pointer;
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
  }
  :global(#astronav-menu svg) { width: 18px; height: 18px; display: block; }
  :global(.astronav-toggle.hidden) { display: none !important; }

  /* ── Desktop ≥881px ───────────────────────── */
  @media (min-width: 881px) {
    /* desktop: MenuItems всегда виден, .hidden от библиотеки игнорируется */
    .nav-links.hidden { display: flex !important; }
  }

  /* ── Mobile ≤880px ────────────────────────── */
  @media (max-width: 880px) {
    :global(#astronav-menu) { display: inline-flex; }

    /* MenuItems: dropdown panel под navbar */
    .nav-links {
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      height: auto;
      background: var(--bg);
      border-bottom: 1px solid var(--line);
      padding: 1rem 1.5rem 1.2rem;
      z-index: 99;
      box-sizing: border-box;
      animation: slideDown 0.2s ease;
    }
    .nav-links.hidden { display: none; }

    .nav-links > a,
    .nav-links .nav-dropdown,
    .nav-links .nav-dropdown-trigger {
      width: 100%;
      height: auto;
      padding: 0.85rem 0;
      font-size: 0.9rem;
      letter-spacing: 0.04em;
      text-align: left;
      justify-content: flex-start;
    }
    .nav-links > a {
      display: block;
      border-bottom: 1px solid var(--line);
    }
    .nav-links > a.nav-cta {
      margin-top: 0.6rem;
      border: 1px solid var(--gold-dim);
      border-radius: 3px;
      padding: 0.7rem 1rem;
      text-align: center;
    }

    /* Dropdown в mobile = accordion */
    .nav-links .nav-dropdown {
      flex-direction: column;
      align-items: stretch;
      border-bottom: 1px solid var(--line);
    }
    .nav-links .nav-dropdown-trigger {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      width: 100%;
      padding: 0.85rem 0;
    }
    .nav-links .nav-dropdown-trigger .caret { margin-left: auto; }

    .nav-links .nav-dropdown-menu {
      position: static;
      transform: none;
      min-width: 0;
      width: 100%;
      box-shadow: none;
      background: transparent;
      border: none;
      padding: 0 0 0.7rem 0.6rem;
    }
    .nav-links .nav-dropdown-menu a { padding: 0.6rem 0.5rem; border-radius: 4px; }
    .nav-links .nav-dropdown-menu a strong { font-size: 0.85rem; }
    .nav-links .nav-dropdown-menu a span { font-size: 0.7rem; }
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
