---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    <li><a href="/">Главная</a></li>
    {crumbs.map((c, i) => (
      <li>
        {i < crumbs.length - 1 && c.href
          ? <a href={c.href}>{c.label}</a>
          : <span aria-current="page">{c.label}</span>
        }
      </li>
    ))}
  </ol>
</nav>

<style>
/* Контейнер = контейнер шапки (SwissHeader .wrap: max-width 1280 + edge-гаттер),
   чтобы крошки вставали ровно под логотип на всех страницах и ширинах.
   Раньше был max-width:760 (под узкую колонку блога) → на широких программных
   страницах крошки висели по центру с большим отступом слева. */
.breadcrumbs {
  padding-block: 0.75rem;
  padding-inline: clamp(1.1rem, 3vw, 2.6rem);
  max-width: 1280px;
  margin: 0 auto;
}
ol {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
  align-items: center;
  font-size: 0.72rem;
  letter-spacing: 0.04em;
  color: var(--text-faint);
}
li + li::before {
  content: '/';
  margin-right: 0.3rem;
  color: var(--text-faint);
  opacity: 0.5;
}
/* Расширяем тап-зону ссылок крошек по вертикали без сдвига вёрстки
   (padding наращивает кликабельную область, отрицательный margin держит ряд). */
a { color: var(--text-faint); display: inline-block; padding: 0.55rem 0; margin: -0.55rem 0; }
a:hover { color: var(--gold); }
span { color: var(--text-dim); }
</style>
