---
// Прямые рейсы — editorial группировка по маршруту, compact rows.
// Использовать в MDX:
//   <FlightRoutes routes={[
//     { from: 'Москва', to: 'Пекин', flights: [
//       { airline: 'Аэрофлот', code: 'SU', duration: '7 ч 15 мин',
//         priceFrom: '20 748 ₽', priceUrl: 'https://aviasales...' },
//       { airline: 'Air China', code: 'CA', duration: '7 ч 30 мин',
//         priceFrom: '24 000 ₽' },
//     ] },
//   ]} caption="Прямые рейсы в 2026" />

interface Flight {
  airline: string;
  code?: string;
  duration: string;
  priceFrom: string;
  priceUrl?: string;
  priceUrlLabel?: string;
}

interface Route {
  from: string;
  to: string;
  flights: Flight[];
}

interface Props {
  routes: Route[];
  caption?: string;
}

const { routes, caption } = Astro.props;
---
<section class="flight-routes" role="region" aria-label={caption || 'Прямые рейсы'}>
  {routes.map((r) => (
    <div class="fr-group">
      <h4 class="fr-route">
        <span class="fr-city">{r.from}</span>
        <span class="fr-arrow" aria-hidden="true">→</span>
        <span class="fr-city">{r.to}</span>
      </h4>
      <ul class="fr-list">
        {r.flights.map((f) => (
          <li class="fr-row">
            <span class="fr-airline">
              {f.airline}
              {f.code && <span class="fr-code">{f.code}</span>}
            </span>
            <span class="fr-sep" aria-hidden="true">·</span>
            <span class="fr-duration">{f.duration}</span>
            <span class="fr-sep" aria-hidden="true">·</span>
            <span class="fr-price">
              <span class="fr-price-prefix">от</span>
              <strong>{f.priceFrom}</strong>
              {f.priceUrl && (
                <>
                  {' '}
                  <a class="fr-price-link" href={f.priceUrl} target="_blank" rel="nofollow noopener sponsored">
                    {f.priceUrlLabel || 'Aviasales'}
                  </a>
                </>
              )}
            </span>
          </li>
        ))}
      </ul>
    </div>
  ))}
</section>

<style>
  .flight-routes {
    margin: 2rem 0 2.5rem;
    border-top: 1px solid var(--line);
  }
  .fr-group {
    border-bottom: 1px solid var(--line);
    padding: 1.4rem 0 1.2rem;
  }
  .fr-route {
    font-family: var(--ff-display, 'Fraunces', 'Cormorant Garamond', Georgia, serif);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--text);
    margin: 0 0 0.85rem;
    letter-spacing: -0.01em;
    line-height: 1.2;
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .fr-city { white-space: nowrap; }
  .fr-arrow {
    color: var(--gold, #c9973a);
    font-size: 1.05em;
    font-weight: 300;
  }
  .fr-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .fr-row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.5;
    padding-left: 0.9rem;
    position: relative;
  }
  .fr-row::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gold-dim, #c9973a);
    opacity: 0.55;
  }
  .fr-airline {
    color: var(--text);
    font-weight: 400;
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
  }
  .fr-code {
    font-family: var(--ff-mono, 'JetBrains Mono', 'SF Mono', monospace);
    font-size: 0.72em;
    color: var(--text-faint);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .fr-sep {
    color: var(--text-faint);
    opacity: 0.6;
  }
  .fr-duration {
    color: var(--text-dim);
    font-variant-numeric: tabular-nums;
  }
  .fr-price {
    color: var(--text-dim);
    font-variant-numeric: tabular-nums;
  }
  .fr-price-prefix {
    color: var(--text-faint);
    margin-right: 0.15rem;
  }
  .fr-price strong {
    color: var(--text);
    font-weight: 500;
  }
  .fr-price-link {
    color: var(--gold, #c9973a);
    border-bottom: 1px dashed rgba(201, 151, 58, 0.35);
    margin-left: 0.15rem;
  }
  .fr-price-link:hover {
    color: var(--gold, #c9973a);
    border-bottom-color: var(--gold, #c9973a);
  }

  /* Mobile: одна группа на строку, разделители читаемые */
  @media (max-width: 640px) {
    .fr-route { font-size: 1.18rem; }
    .fr-row {
      font-size: 0.92rem;
      gap: 0.35rem;
    }
  }
</style>
