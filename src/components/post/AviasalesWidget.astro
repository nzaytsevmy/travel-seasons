---
// Aviasales / Travelpayouts CTA-блок.
// Раньше был iframe-embed через tp.media — async скрипт ненадёжен (document.write deprecated).
// Теперь — большая CTA-кнопка с deeplink: marker + destination_iata + sub_id для трекинга.
//
// Использование:
//   <AviasalesWidget />
//   <AviasalesWidget destination="DPS" title="Найти билеты на Бали" subid="hub-bali" />
import { aviasalesUrl } from '../../data/affiliate.js';

interface Props {
  destination?: string;       // IATA destination (опционально)
  origin?: string;            // IATA откуда (по умолчанию пусто)
  title?: string;             // Заголовок над кнопкой
  subid?: string;             // Sub ID для трекинга по странице
  buttonText?: string;        // Текст кнопки
}
const {
  destination = '',
  origin = '',
  title = 'Найти билеты',
  subid = '',
  buttonText = 'Открыть Aviasales →',
} = Astro.props;

// Ссылка через tpk.mx-обёртку: трекинг кликов (свежий sub-id на клик) + erid + .ru.
// destination/origin/sub_id уходят в целевой aviasales.ru-URL через &u=.
const params = new URLSearchParams();
if (origin) params.set('origin_iata', origin);
if (destination) params.set('destination_iata', destination);
if (subid) params.set('sub_id', subid);
const q = params.toString();
const href = aviasalesUrl(q ? `?${q}` : '');
---

<aside class="tp-cta" aria-label="Поиск билетов через Aviasales">
  <div class="tp-cta-text">
    <h3 class="tp-cta-title">{title}</h3>
    <p class="tp-cta-sub">Сравнить цены на Aviasales — все авиакомпании в одной выдаче, оплата российскими картами тоже работает.</p>
  </div>
  <a class="tp-cta-btn aff-btn" href={href} target="_blank" rel="noopener sponsored">
    <span>{buttonText}</span>
  </a>
  <p class="tp-cta-disc">Aviasales. Партнёрская ссылка, цена для тебя не меняется.</p>
</aside>

<style>
  .tp-cta {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "text  btn"
      "disc  disc";
    gap: 0.6rem 1.2rem;
    align-items: center;
    margin: 2.2rem 0;
    padding: 1.2rem 1.4rem;
    background: rgba(142,102,24,0.05);
    border: 1px solid var(--line);
    border-left: 3px solid var(--gold);
  }
  .tp-cta-text { grid-area: text; min-width: 0; }
  .tp-cta-title {
    font-family: var(--ff-display);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.25rem;
    letter-spacing: -0.01em;
  }
  .tp-cta-sub {
    margin: 0;
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.5;
  }
  /* База — глобальный .aff-btn; здесь только слот в сетке и виджет-специфика */
  .tp-cta-btn {
    grid-area: btn;
    padding: 0.7rem 1.2rem;
    font-size: 0.9rem;
    white-space: nowrap;
  }
  .tp-cta-disc {
    grid-area: disc;
    margin: 0;
    font-size: 0.7rem;
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }
  @media (max-width: 600px) {
    .tp-cta {
      grid-template-columns: 1fr;
      grid-template-areas: "text" "btn" "disc";
      padding: 1rem 1.1rem;
    }
    .tp-cta-btn { width: 100%; }
  }
</style>
