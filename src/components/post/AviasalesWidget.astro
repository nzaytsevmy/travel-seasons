---
// Aviasales / Travelpayouts CTA-блок.
// Раньше был iframe-embed через tp.media — async скрипт ненадёжен (document.write deprecated).
// Теперь — большая CTA-кнопка с deeplink: marker + destination_iata + sub_id для трекинга.
//
// Использование:
//   <AviasalesWidget />
//   <AviasalesWidget destination="DPS" title="Найти билеты на Бали" subid="hub-bali" />
import { TP_MARKER_FULL } from '../../data/affiliate.js';

interface Props {
  destination?: string;       // IATA destination (опционально)
  origin?: string;            // IATA откуда (по умолчанию пусто)
  title?: string;             // Заголовок над кнопкой
  subid?: string;             // Sub ID для трекинга по странице
  buttonText?: string;        // Текст кнопки
}
const {
  destination = '',
  origin = '',
  title = 'Найти билеты',
  subid = '',
  buttonText = 'Открыть Aviasales →',
} = Astro.props;

// Сборка deeplink. Travelpayouts marker уже включает sub-id, мы добавляем
// отдельный sub_id query-параметр для конкретной страницы.
const params = new URLSearchParams({
  marker: TP_MARKER_FULL,
  market: 'ru',
});
if (origin) params.set('origin_iata', origin);
if (destination) params.set('destination_iata', destination);
if (subid) params.set('sub_id', subid);
const href = `https://www.aviasales.ru/?${params.toString()}`;
---

<aside class="tp-cta" aria-label="Поиск билетов через Aviasales">
  <div class="tp-cta-text">
    <h3 class="tp-cta-title">{title}</h3>
    <p class="tp-cta-sub">Сравнить цены на Aviasales — все авиакомпании в одной выдаче, оплата российскими картами тоже работает.</p>
  </div>
  <a class="tp-cta-btn" href={href} target="_blank" rel="noopener sponsored">
    <span>{buttonText}</span>
  </a>
  <p class="tp-cta-disc">Партнёрская ссылка. Цена для тебя не меняется.</p>
</aside>

<style>
  .tp-cta {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "text  btn"
      "disc  disc";
    gap: 0.6rem 1.2rem;
    align-items: center;
    margin: 2.2rem 0;
    padding: 1.2rem 1.4rem;
    background: linear-gradient(135deg, rgba(201,151,58,0.08), rgba(201,151,58,0.02));
    border: 1px solid var(--gold-dim);
    border-radius: 10px;
  }
  .tp-cta-text { grid-area: text; min-width: 0; }
  .tp-cta-title {
    font-family: var(--ff-display);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.25rem;
    letter-spacing: -0.01em;
  }
  .tp-cta-sub {
    margin: 0;
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.5;
  }
  .tp-cta-btn {
    grid-area: btn;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.2rem;
    background: var(--gold-600, #c9973a);
    color: #fff !important;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    border-radius: 6px;
    text-decoration: none !important;
    transition: filter 0.15s, transform 0.06s;
    white-space: nowrap;
  }
  .tp-cta-btn:hover { filter: brightness(1.05); }
  .tp-cta-btn:active { transform: scale(0.98); }
  .tp-cta-disc {
    grid-area: disc;
    margin: 0;
    font-size: 0.7rem;
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }
  @media (max-width: 600px) {
    .tp-cta {
      grid-template-columns: 1fr;
      grid-template-areas: "text" "btn" "disc";
      padding: 1rem 1.1rem;
    }
    .tp-cta-btn { width: 100%; }
  }
</style>
