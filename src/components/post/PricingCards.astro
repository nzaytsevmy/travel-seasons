---
// Swiss comparison grid (BRANDBOOK §4/§5): hairlines, ноль radius/shadow.
// Transposed grid 2026: три ряда (head / price / features), колонки = тарифы.
// Container queries 12-8-4; без subgrid и display:contents.
interface Tier {
  tier: string;
  price: string;
  priceNote?: string;
  featured?: boolean;
  badge?: string;
  features: string[];
}

interface Props {
  tiers: Tier[];
  caption?: string;
}

const { tiers, caption } = Astro.props;
const colClass = `pricing-cards--cols-${tiers.length}`;
---
<div class="pricing-cards-wrap">
<div
  class={`pricing-cards ${colClass}`}
  role="region"
  aria-label={caption || 'Сравнение'}
>
  {tiers.map((t, i) => (
    <div class={`pc-head ${t.featured ? 'pc-cell--featured' : ''}`}>
      <span class="pc-idx">{String(i + 1).padStart(2, '0')}</span>
      <span class="pc-tier">{t.tier}</span>
      {(t.badge || t.featured) && <span class="pc-badge">{t.badge || 'Оптимально'}</span>}
    </div>
  ))}
  {tiers.map((t) => (
    <div class={`pc-price-wrap ${t.featured ? 'pc-cell--featured' : ''}`}>
      <div class="pc-price">{t.price}</div>
      {t.priceNote && <div class="pc-price-note">{t.priceNote}</div>}
    </div>
  ))}
  {tiers.map((t) => (
    <ul class={`pc-features ${t.featured ? 'pc-cell--featured' : ''}`}>
      {t.features.map((f) => (
        <li>
          <span class="pc-check" aria-hidden="true">
            <svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 8.5 6.5 12 13 4.5"></polyline>
            </svg>
          </span>
          <span>{f}</span>
        </li>
      ))}
    </ul>
  ))}
</div>
</div>

<style>
/* Обёртка = query container (сам контейнер нельзя стилизовать из @container) */
.pricing-cards-wrap {
  container-type: inline-size;
  container-name: pricing;
  margin: 2rem 0 2.5rem;
}

.pricing-cards {
  display: grid;
  margin: 0;
  border-top: 2px solid var(--line);
}

.pc-head,
.pc-price-wrap,
.pc-features {
  padding: 1.3rem 1.3rem 1.4rem;
  min-width: 0;
}

.pc-head {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 0.5rem;
  font-size: 0.7rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  align-self: end;
}

.pc-price-wrap {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  padding-top: 0;
  padding-bottom: 0.9rem;
  border-bottom: 1px solid var(--line);
}

.pc-features {
  list-style: none;
  padding-top: 0.9rem;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  align-self: start;
}

.pc-idx { font-weight: 700; color: var(--gold); font-variant-numeric: tabular-nums; }
.pc-tier { font-weight: 700; color: var(--text-dim); }
.pc-cell--featured .pc-tier { color: var(--gold); }
.pc-badge { font-size: 0.62rem; letter-spacing: 0.1em; font-weight: 700; color: var(--gold); }

.pc-price {
  font-size: clamp(1.4rem, 2.4vw, 1.8rem);
  font-weight: 800;
  color: var(--text);
  line-height: 1.1;
  letter-spacing: -0.01em;
  font-variant-numeric: tabular-nums lining-nums;
  text-wrap: balance;
}
.pc-cell--featured .pc-price { color: var(--gold); }
.pc-price-note { font-size: 0.76rem; color: var(--text-faint); }

.pc-features li {
  display: flex;
  gap: 0.55rem;
  align-items: flex-start;
  font-size: 0.88rem;
  line-height: 1.55;
  color: var(--text-dim);
}
.pc-check { flex: 0 0 auto; color: var(--gold); margin-top: 2px; }

.pc-cell--featured { border-left: 3px solid var(--gold); }

/* ── Мобайл (<560): 1 колонка ── */
@container pricing (max-width: 559px) {
  .pricing-cards { grid-template-columns: 1fr; }

  .pc-head,
  .pc-price-wrap,
  .pc-features {
    padding-left: 0;
    padding-right: 0;
    border-left: none;
  }

  .pc-head {
    padding-top: 1.2rem;
    border-top: 1px solid var(--line);
  }
  .pc-head:first-child { border-top: none; }
  .pc-cell--featured.pc-head {
    border-top: 2px solid var(--gold);
    margin-top: -1px;
  }
  .pc-head:first-child.pc-cell--featured { margin-top: 0; }
  .pc-features { padding-bottom: 1.2rem; }
}

/* ── Планшет (560–799): 2 колонки ── */
@container pricing (min-width: 560px) and (max-width: 799px) {
  .pricing-cards { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .pricing-cards > :nth-child(2n) { border-left: 1px solid var(--line); }
  .pricing-cards > .pc-cell--featured { border-left: 3px solid var(--gold); }
}

/* ── Десктоп (≥800): N колонок по числу тарифов ── */
@container pricing (min-width: 800px) {
  .pricing-cards--cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .pricing-cards--cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .pricing-cards--cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .pricing-cards--cols-5 { grid-template-columns: repeat(5, minmax(0, 1fr)); }

  .pricing-cards--cols-2 > :nth-child(2n),
  .pricing-cards--cols-3 > :not(:nth-child(3n+1)),
  .pricing-cards--cols-4 > :not(:nth-child(4n+1)),
  .pricing-cards--cols-5 > :not(:nth-child(5n+1)) {
    border-left: 1px solid var(--line);
  }
  .pricing-cards > .pc-cell--featured { border-left: 3px solid var(--gold); }
}
</style>
