---
// Swiss comparison grid (BRANDBOOK §4/§5): только hairlines, ноль radius/shadow/
// gradient/заливок/пилюль. Акцент — единственное бренд-золото (--gold #8e6618),
// эмфаза featured типографикой + золотой левой линейкой. Табличные цифры.
interface Tier {
  tier: string;
  price: string;
  priceNote?: string;
  featured?: boolean;
  badge?: string;
  features: string[];
}

interface Props {
  tiers: Tier[];
  caption?: string;
}

const { tiers, caption } = Astro.props;
---
<div class="pricing-cards" role="region" aria-label={caption || 'Сравнение'}>
  {tiers.map((t, i) => (
    <article class={`pc-card ${t.featured ? 'pc-card--featured' : ''}`}>
      <div class="pc-head">
        <span class="pc-idx">{String(i + 1).padStart(2, '0')}</span>
        <span class="pc-tier">{t.tier}</span>
        {(t.badge || t.featured) && <span class="pc-badge">{t.badge || 'Оптимально'}</span>}
      </div>
      <div class="pc-price-wrap">
        <div class="pc-price">{t.price}</div>
        {t.priceNote && <div class="pc-price-note">{t.priceNote}</div>}
      </div>
      <ul class="pc-features">
        {t.features.map((f) => (
          <li>
            <span class="pc-check" aria-hidden="true">
              <svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 8.5 6.5 12 13 4.5"></polyline>
              </svg>
            </span>
            <span>{f}</span>
          </li>
        ))}
      </ul>
    </article>
  ))}
</div>

<style>
.pricing-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  /* Общие ряды для ВСЕХ карточек: заголовок / цена / фичи. Карточки — subgrid этих
     рядов, поэтому цены и разделители выравниваются по горизонтали независимо от
     длины заголовка (1 vs 2 строки). subgrid — production-baseline 2026 (все движки). */
  grid-template-rows: auto auto auto;
  row-gap: 1rem;
  margin: 2rem 0 2.5rem;
  border-top: 2px solid var(--line);
}
.pc-card {
  display: grid;
  grid-template-rows: subgrid;
  grid-row: span 3;
  padding: 1.3rem 1.3rem 1.4rem;
  border-left: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}
.pc-card:first-child { border-left: none; }
.pc-card.pc-card--featured { border-left: 3px solid var(--gold); }

.pc-head {
  display: flex; align-items: baseline; flex-wrap: wrap; gap: 0.5rem;
  font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
}
.pc-idx { font-weight: 700; color: var(--gold); font-variant-numeric: tabular-nums; }
.pc-tier { font-weight: 700; color: var(--text-dim); }
.pc-card--featured .pc-tier { color: var(--gold); }
.pc-badge { font-size: 0.62rem; letter-spacing: 0.1em; font-weight: 700; color: var(--gold); }

.pc-price-wrap {
  display: flex; flex-direction: column; gap: 0.25rem;
  padding-bottom: 0.9rem;
  border-bottom: 1px solid var(--line);
}
.pc-price {
  font-size: clamp(1.4rem, 2.4vw, 1.8rem);
  font-weight: 800;
  color: var(--text);
  line-height: 1.1;
  letter-spacing: -0.01em;
  font-variant-numeric: tabular-nums lining-nums;
  text-wrap: balance;
}
.pc-card--featured .pc-price { color: var(--gold); }
.pc-price-note { font-size: 0.76rem; color: var(--text-faint); }

.pc-features {
  list-style: none; padding: 0; margin: 0;
  display: flex; flex-direction: column; gap: 0.5rem;
}
.pc-features li {
  display: flex; gap: 0.55rem; align-items: flex-start;
  font-size: 0.88rem; line-height: 1.55; color: var(--text-dim);
}
.pc-check { flex: 0 0 auto; color: var(--gold); margin-top: 2px; }

@media (max-width: 600px) {
  /* 1 колонка — выравнивать нечего, возвращаем простой flow (без subgrid). */
  .pricing-cards { grid-template-columns: 1fr; grid-template-rows: none; row-gap: 0; }
  .pc-card { display: flex; flex-direction: column; gap: 1rem; grid-row: auto; border-left: none; padding: 1.2rem 0; }
  .pc-card.pc-card--featured { border-left: none; border-top: 2px solid var(--gold); margin-top: -1px; }
}
</style>
