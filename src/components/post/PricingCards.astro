---
// Swiss comparison grid (BRANDBOOK §4/§5): hairlines only, no radius/shadow.
// Card-first layout: каждая колонка цельная карточка (head -> price -> features),
// с ровными рядами через subgrid на tablet/desktop.
interface Tier {
  tier: string;
  price: string;
  priceNote?: string;
  featured?: boolean;
  badge?: string;
  features: string[];
  ctaLabel?: string;   // per-row CTA: текст действия («Подобрать под даты →»)
  ctaHref?: string;    // per-row CTA: партнёрская ссылка (посимвольно, с erid)
}

interface Props {
  tiers: Tier[];
  caption?: string;
}

const { tiers, caption } = Astro.props;
const hasCta = tiers.some((t) => t.ctaHref);
const colClass = `pricing-cards--cols-${tiers.length}${hasCta ? ' pricing-cards--cta' : ''}`;
---
<div
  class={`pricing-cards ${colClass}`}
  role="region"
  aria-label={caption || 'Сравнение'}
>
  {tiers.map((t, i) => (
    <article class={`pc-card ${t.featured ? 'pc-card--featured' : ''}`}>
      <div class="pc-head">
        <span class="pc-idx">{String(i + 1).padStart(2, '0')}</span>
        <span class="pc-tier">{t.tier}</span>
        {(t.badge || t.featured) && <span class="pc-badge">{t.badge || 'Оптимально'}</span>}
      </div>
      <div class="pc-price-wrap">
        <div class="pc-price">{t.price}</div>
        {t.priceNote && <div class="pc-price-note">{t.priceNote}</div>}
      </div>
      <ul class="pc-features">
        {t.features.map((f) => (
          <li>
            <span class="pc-check" aria-hidden="true">
              <svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 8.5 6.5 12 13 4.5"></polyline>
              </svg>
            </span>
            <span>{f}</span>
          </li>
        ))}
      </ul>
      {hasCta && (
        <div class="pc-cta-wrap">
          {t.ctaHref && (
            <a class="pc-cta" href={t.ctaHref} rel="sponsored noopener" target="_blank">
              {t.ctaLabel || 'Подобрать →'}
            </a>
          )}
        </div>
      )}
    </article>
  ))}
</div>

<style>
.pricing-cards {
  display: grid;
  grid-template-columns: 1fr;
  margin: 2rem 0 2.5rem;
  border-top: 2px solid var(--line);
  row-gap: 0;
  column-gap: 0;
}

.pc-card {
  display: flex;
  flex-direction: column;
  border-bottom: 1px solid var(--line);
  padding: 1.2rem 0;
}

.pc-card--featured {
  border-top: 2px solid var(--gold);
  margin-top: -1px;
}

.pc-head,
.pc-price-wrap,
.pc-features {
  padding: 0 0.2rem;
  min-width: 0;
}

.pc-head {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  column-gap: 0.5rem;
  row-gap: 0.15rem;
  align-items: baseline;
  font-size: 0.7rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.pc-price-wrap {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  padding-top: 0.85rem;
  padding-bottom: 0.9rem;
  border-bottom: 1px solid var(--line);
  /* Container для cqi-масштаба цены. На .pc-price-wrap (а не .pc-card),
     чтобы не сломать subgrid-выравнивание рядов карточки. */
  container-type: inline-size;
}

.pc-features {
  list-style: none;
  padding-top: 0.9rem;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  align-self: start;
}

.pc-idx {
  font-weight: 700;
  color: var(--gold);
  font-variant-numeric: tabular-nums;
  grid-column: 1;
  align-self: start;
}
.pc-tier {
  font-weight: 700;
  color: var(--text-dim);
  grid-column: 2;
  min-width: 0;
}
.pc-card--featured .pc-tier { color: var(--gold); }
.pc-badge {
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  font-weight: 700;
  color: var(--gold);
  grid-column: 2;
}

.pc-price {
  /* cqi = доля ширины карточки: цена всегда умещается в одну строку,
     не переносясь в узких десктоп-колонках; clamp держит верх/низ. */
  font-size: clamp(1.2rem, 9.5cqi, 1.6rem);
  font-weight: 800;
  color: var(--text);
  line-height: 1.1;
  letter-spacing: -0.01em;
  font-variant-numeric: tabular-nums lining-nums;
  white-space: nowrap;
}
.pc-card--featured .pc-price { color: var(--gold); }
.pc-price-note { font-size: 0.76rem; color: var(--text-faint); }

.pc-features li {
  display: flex;
  gap: 0.55rem;
  align-items: flex-start;
  font-size: 0.88rem;
  line-height: 1.55;
  color: var(--text-dim);
}
.pc-check { flex: 0 0 auto; color: var(--gold); margin-top: 2px; }

/* Per-row CTA — тот же паттерн, что .sl-aff: gold + 2px underline, тач ≥44px */
.pc-cta-wrap { padding: 0.55rem 0.2rem 0; align-self: start; }
.pc-cta {
  display: inline-flex;
  align-items: center;
  min-height: 44px;
  font-weight: 700;
  font-size: 0.92rem;
  color: var(--gold);
  text-decoration: 2px underline var(--gold);
  text-underline-offset: 4px;
  letter-spacing: -0.005em;
}
.pc-cta:hover { color: var(--gold-dim); }

/* Tablet: 2 columns */
@media (min-width: 560px) {
  .pricing-cards {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: auto auto auto;
  }
  .pricing-cards--cta { grid-template-rows: auto auto auto auto; }

  .pc-card {
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span 3;
    padding: 1.25rem 1.3rem 1.35rem;
    border-left: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    border-top: none;
    margin-top: 0;
  }
  .pricing-cards--cta .pc-card { grid-row: span 4; }

  .pc-card:nth-child(2n + 1) { border-left: none; }
  .pc-card--featured { border-left: 3px solid var(--gold); }

  .pc-head,
  .pc-price-wrap,
  .pc-features,
  .pc-cta-wrap {
    padding-left: 0;
    padding-right: 0;
  }

  .pc-price-wrap { padding-top: 0; }
  .pc-features { padding-bottom: 0; }
}

/* Desktop: N columns by tier count (2..5) */
@media (min-width: 1024px) {
  .pricing-cards--cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .pricing-cards--cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .pricing-cards--cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .pricing-cards--cols-5 { grid-template-columns: repeat(5, minmax(0, 1fr)); }

  .pc-card { border-left: 1px solid var(--line); }
  .pricing-cards--cols-2 .pc-card:nth-child(2n + 1),
  .pricing-cards--cols-3 .pc-card:nth-child(3n + 1),
  .pricing-cards--cols-4 .pc-card:nth-child(4n + 1),
  .pricing-cards--cols-5 .pc-card:nth-child(5n + 1) {
    border-left: none;
  }

  .pc-card--featured { border-left: 3px solid var(--gold); }
}
</style>
