---
// PhotoGrid — masonry-style фотогалерея для photo-essay блоков в постах.
// Использование в .mdx:
//
//   import PhotoGrid from '../../components/post/PhotoGrid.astro';
//   import img1 from './_images/x.jpg';
//   import img2 from './_images/y.jpg';
//
//   <PhotoGrid images={[
//     { src: img1, alt: 'Описание', wide: true },
//     { src: img2, alt: 'Описание' },
//     ...
//   ]} caption="Опционально подпись" />
//
// Pattern: NatGeo / Conde Nast Traveler photo galleries 2026.
// CSS-grid auto-flow с возможностью «wide» элементов на 2 колонки.

import { Image } from 'astro:assets';

interface PhotoItem {
  src: ImageMetadata | string;
  alt: string;
  wide?: boolean;   // 2-column wide
  tall?: boolean;   // 2-row tall
  caption?: string;
}

interface Props {
  images: PhotoItem[];
  caption?: string;
}

const { images, caption } = Astro.props;
---
<figure class="photo-grid-figure">
  <div class={`photo-grid photo-grid--${Math.min(images.length, 6)}`}>
    {images.map((img, i) => (
      <a
        href={typeof img.src === 'string' ? img.src : img.src.src}
        class={`pg-cell ${img.wide ? 'pg-wide' : ''} ${img.tall ? 'pg-tall' : ''}`}
        target="_blank"
        rel="noopener"
        aria-label={`Открыть фото ${i + 1}: ${img.alt}`}
      >
        <Image
          src={img.src}
          alt={img.alt}
          widths={[400, 800, 1400]}
          sizes="(max-width: 700px) 100vw, (max-width: 1100px) 50vw, 33vw"
          formats={['avif', 'webp']}
          quality={70}
          loading="lazy"
        />
        {img.caption && <span class="pg-caption">{img.caption}</span>}
      </a>
    ))}
  </div>
  {caption && <figcaption class="pg-figcaption">{caption}</figcaption>}
</figure>

<style>
.photo-grid-figure {
  margin: 2.5rem 0 2.5rem;
}
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-auto-rows: minmax(160px, 1fr);
  gap: 6px;
  border-radius: var(--radius-4, 8px);
  overflow: hidden;
}
/* Layouts that look balanced for different counts */
.photo-grid--3 { grid-template-columns: repeat(3, 1fr); }
.photo-grid--4 { grid-template-columns: repeat(2, 1fr); }
.photo-grid--5,
.photo-grid--6 { grid-template-columns: repeat(3, 1fr); }

.pg-cell {
  position: relative;
  display: block;
  overflow: hidden;
  aspect-ratio: 4 / 3;
  background: var(--bg3);
  text-decoration: none;
}
.pg-cell.pg-wide { grid-column: span 2; }
.pg-cell.pg-tall { grid-row: span 2; aspect-ratio: 3 / 4; }
.pg-cell img,
.pg-cell picture {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.5s var(--ease-out, ease);
}
.pg-cell:hover img { transform: scale(1.04); }
.pg-cell::after {
  content: ""; position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0) 40%);
  opacity: 0; transition: opacity 0.2s ease;
  pointer-events: none;
}
.pg-cell:hover::after { opacity: 1; }
.pg-caption {
  position: absolute; left: 12px; right: 12px; bottom: 10px;
  font-size: 0.78rem; color: #fff; line-height: 1.4;
  text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  opacity: 0; transition: opacity 0.2s ease;
  pointer-events: none;
}
.pg-cell:hover .pg-caption { opacity: 1; }

.pg-figcaption {
  margin-top: 0.7rem;
  font-size: 0.82rem;
  color: var(--text-faint);
  text-align: center;
  font-style: italic;
}

/* Mobile — single column for clarity */
@media (max-width: 600px) {
  .photo-grid,
  .photo-grid--4 { grid-template-columns: repeat(2, 1fr); }
  .pg-cell.pg-wide { grid-column: span 2; }
  .pg-cell.pg-tall { grid-row: auto; aspect-ratio: 4 / 3; }
}
</style>
