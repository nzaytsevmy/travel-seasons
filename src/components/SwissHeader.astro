---
// Единый Swiss-хедер для всего сайта (брендбук). Самодостаточный: свои токены,
// Golos, бургер, active по текущему URL. Подключается один раз в Layout.astro.
// (Golos @font-face объявлен в Layout.astro — font-display:optional, один раз на сайт.)
const path = (Astro.url.pathname.replace(/\/+$/, '') || '/');
const is = (href) => {
  const h = (href.replace(/\/+$/, '') || '/');
  return h === '/' ? path === '/' : (path === h || path.startsWith(h + '/'));
};
const LINKS = [
  ['/countries/', 'Направления'],
  ['/visa/', 'Визы'],
  ['/seasons/', 'Сезоны'],
  ['/trips/', 'Поездки'],
  ['/calculator/', 'Калькулятор'],
  ['/compare/', 'Сравнить'],
  ['/packing/', 'Чек-лист'],
  ['/blog/', 'Блог'],
];
---
<header class="sw-head">
  <div class="wrap nav">
    <a class="wm" href="/">TravelTribe</a>
    <button class="burger" id="burger" type="button" aria-expanded="false" aria-controls="navmenu" aria-label="Открыть меню"><span></span><span></span><span></span></button>
    <nav id="navmenu" aria-label="Основное меню"><ul>
      {LINKS.map(([href, label]) => (
        <li><a href={href} class={is(href) ? 'on' : ''} aria-current={is(href) ? 'page' : undefined}>{label}</a></li>
      ))}
    </ul></nav>
  </div>
</header>

<style>
.sw-head{--paper:#f4f2eb;--ink:#1b1914;--gold:#8e6618;--hair:#cdc9bd;--line:#23211a;
  --ff:'Golos Text Variable','Golos Text',Helvetica,Arial,sans-serif;--edge:clamp(1.1rem,3vw,2.6rem);
  position:sticky;top:0;z-index:50;background:var(--paper);border-bottom:1px solid var(--line);
  font-family:var(--ff);color:var(--ink);font-variant-numeric:tabular-nums lining-nums}
.sw-head *{box-sizing:border-box}
.sw-head a{color:inherit;text-decoration:none}
.sw-head :focus-visible{outline:2px solid var(--gold);outline-offset:3px}
.sw-head .wrap{max-width:1280px;margin-inline:auto;padding-inline:var(--edge)}
.nav{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding-block:.9rem}
.wm{font-weight:700;font-size:1.05rem;letter-spacing:-.02em;text-transform:uppercase}
.nav ul{list-style:none;display:flex;gap:1.4rem;font-size:.72rem;font-weight:500;letter-spacing:.04em;text-transform:uppercase;padding:0;margin:0}
.nav ul li{margin:0}
.nav ul a{display:inline-flex;align-items:center;min-height:44px;text-decoration:underline 1px transparent;text-underline-offset:.22em;font-weight:500}
.nav ul a:hover,.nav ul a:focus-visible{text-decoration-color:var(--gold)}
.nav ul a.on{color:var(--gold);text-decoration-color:var(--gold)}
.burger{display:none;width:44px;height:44px;flex-direction:column;justify-content:center;align-items:center;gap:5px;background:none;border:none;cursor:pointer;padding:0;margin:-.4rem -.6rem -.4rem 0}
.burger span{display:block;width:24px;height:2px;background:var(--ink);transition:transform .2s ease,opacity .2s ease}
.sw-head.open .burger span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.sw-head.open .burger span:nth-child(2){opacity:0}
.sw-head.open .burger span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
@media(max-width:920px){
  .burger{display:flex}
  #navmenu{position:absolute;left:0;right:0;top:100%;background:var(--paper);border-bottom:1px solid var(--line);display:none;max-height:calc(100vh - 54px);overflow:auto}
  .sw-head.open #navmenu{display:block}
  .nav ul{flex-direction:column;gap:0;padding:.2rem var(--edge) 1rem}
  .nav ul li{border-top:1px solid var(--hair)}
  .nav ul a{min-height:52px;width:100%;font-size:.92rem;letter-spacing:.02em}
}
</style>

<script>
  const burger = document.getElementById('burger');
  const head = document.querySelector('.sw-head');
  if (burger && head) {
    const navmenu = head.querySelector('#navmenu');
    const setOpen = (o) => { burger.setAttribute('aria-expanded', String(o)); head.classList.toggle('open', o); burger.setAttribute('aria-label', o ? 'Закрыть меню' : 'Открыть меню'); };
    burger.addEventListener('click', () => setOpen(burger.getAttribute('aria-expanded') !== 'true'));
    if (navmenu) navmenu.addEventListener('click', (e) => { if (e.target.closest('a')) setOpen(false); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false); });
    document.addEventListener('click', (e) => { if (head.classList.contains('open') && !e.target.closest('.sw-head')) setOpen(false); });
  }
</script>
