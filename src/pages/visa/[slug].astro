---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Picture } from 'astro:assets';
import { DIRECTIONS } from '../../data/directions.js';
import { getVisaDetails, VISA_DETAILS } from '../../data/visa-details.js';
import { TP_LINKS, aviasalesRoute, cherehapaTravel } from '../../data/affiliate.js';
import StickyCta from '../../components/StickyCta.astro';
import { DATA_UPDATED, DATA_UPDATED_RU } from '../../data/meta.js';

const destPhotos = import.meta.glob('../../assets/destinations/*.jpg', { eager: true, import: 'default' });

export async function getStaticPaths() {
  return DIRECTIONS.map((d) => ({ params: { slug: d.slug }, props: { d } }));
}

const { d } = Astro.props;
const url = `https://traveltribe.ru/visa/${d.slug}/`;
const photo = destPhotos[`../../assets/destinations/${d.slug}.jpg`];

const VISA_LABELS = {
  free: 'Без визы',
  evisa: 'eVisa / упрощённая',
  required: 'Виза обязательна',
};

const visaSummary = {
  free: `${d.cases.nom} даёт россиянам безвизовый въезд. Достаточно загранпаспорта со сроком действия от 6 месяцев и обратного билета.`,
  evisa: `Для въезда ${d.cases.vP} нужна электронная виза (eVisa) или упрощённое разрешение. Оформляется онлайн до вылета, без визита в посольство.`,
  required: `Для поездки ${d.cases.vP} россиянам нужна полноценная виза. Оформляется через визовый центр или посольство страны, требуется пакет документов и личная подача с биометрией.`,
};

// CTR-заголовок зеркалит интент «нужна ли виза в X»: для безвиза прямо отвечает
// «не нужна» (а не вводящее в заблуждение «документы/цена»), для eVisa — «онлайн».
const VISA_TITLE = {
  free: `Виза ${d.cases.vP} не нужна россиянам в 2026 — безвиз`,
  evisa: `Виза ${d.cases.vP} 2026 — eVisa онлайн для россиян, цена`,
  required: `Виза ${d.cases.vP} для россиян 2026 — документы, цена, сроки`,
};

const flightFrom = d.price?.flight?.[0];
const hotelFrom = d.price?.hotel?.[0];

// Лучшие месяцы — из помесячного рейтинга направления
const RANK = { P: 4, G: 3, O: 2, B: 1, X: 0 };
const MONTH_NOM = ['Январь', 'Февраль', 'Март', 'Апрель', 'Май', 'Июнь',
  'Июль', 'Август', 'Сентябрь', 'Октябрь', 'Ноябрь', 'Декабрь'];
const bestMonths = MONTH_NOM
  .map((nom, i) => ({ nom, rank: RANK[d.r[i]] || 0, text: d.t[i] }))
  .filter(m => m.rank >= 3)
  .slice(0, 3);

// Документы / сбор / срок / пребывание по типу визы
const VISA_DOCS = {
  free: 'Загранпаспорт со сроком действия от 6 месяцев и пустой страницей, обратный билет, бронь жилья. Виза не нужна.',
  evisa: 'Загранпаспорт от 6 месяцев, скан паспорта и фото для онлайн-анкеты, оплата сбора картой. Посольство посещать не нужно.',
  required: 'Загранпаспорт от 6 месяцев, анкета, фото по требованиям страны, банковская выписка, справка с работы, бронь жилья и билеты, биометрия в визовом центре.',
};
const VISA_FEE = {
  free: 'Консульский сбор не взимается — въезд по штампу на границе бесплатный.',
  evisa: 'Сбор за eVisa обычно $20–80, оплата картой онлайн.',
  required: 'Консульский сбор от $35 (Шенген) до $200+ (Австралия, Великобритания, США), плюс сервисный сбор визового центра.',
};
const VISA_TERM = {
  free: 'Оформление не требуется — решение принимает офицер на границе за минуты.',
  evisa: 'eVisa одобряется обычно за 24–72 часа, иногда мгновенно.',
  required: 'Полноценная виза делается 5–15 рабочих дней. Подавать минимум за 2 месяца до вылета.',
};
const VISA_STAY = {
  free: 'Безвизовый въезд обычно даёт 30–90 дней пребывания.',
  evisa: 'eVisa обычно покрывает 30–90 дней, продление — на месте.',
  required: 'Срок пребывания указан в визе — от 15 дней до полугода в зависимости от типа.',
};

// Страновые verified-данные (visa-details.js) — цена/срок/оформление по конкретной
// стране, не generic по типу. Это закрывает «сколько стоит виза в X» answer-first.
const vd = getVisaDetails(d.slug, d.visa);
// Разделяем два разных факта: noVisa = визы НЕ нужно (только тег 'free'); feeFree = нет
// консульского сбора. Кипр (evisa, pro-visa) имеет cost:'бесплатно', но виза НУЖНА —
// нельзя писать «виза не нужна» по строке cost. hasSpecific = есть страновые данные →
// generic-хвосты ($20–80 / 24–72ч) не клеим поверх (иначе противоречие со страновой ценой).
const hasSpecific = !!VISA_DETAILS[d.slug];
const noVisa = d.visa === 'free';
const feeFree = /бесплатн/i.test(vd.cost);
const skipGenericTail = hasSpecific || !!vd.summary;
// Страновой summary (visa-details.js) переопределяет generic-по-типу, если задан.
// metaDesc — чистый обрез по границе слова (без середины слова в description).
const summary = vd.summary ?? visaSummary[d.visa];
const metaDesc = summary.length > 158 ? summary.slice(0, 155).replace(/\s+\S*$/, '') + '…' : summary;
const costAnswer = noVisa
  ? (feeFree
      ? `Виза ${d.cases.vP} не нужна — въезд бесплатный, ${vd.timing}. Консульский сбор не платится.`
      : `Виза ${d.cases.vP} не нужна, но за въезд берут сбор — ${vd.cost} (${vd.timing}).`)
  : `Стоимость визы ${d.cases.vP} — ${vd.cost}.${skipGenericTail ? '' : ' ' + VISA_FEE[d.visa]}`;
const stayAnswer = `Разрешённое пребывание ${d.cases.loc} — ${vd.duration}. Оформление: ${vd.timing}.`;
const termAnswer = `${vd.timing}.${skipGenericTail ? '' : ' ' + VISA_TERM[d.visa]}`;

// FAQ — генерируется из данных направления (YMYL: прямые ответы с цифрами)
const faqs = [
  { q: `Нужна ли виза ${d.cases.vP} для россиян в 2026?`, a: summary },
  { q: `Какие документы нужны для въезда ${d.cases.vP}?`, a: VISA_DOCS[d.visa] },
  { q: `Сколько стоит виза ${d.cases.vP}?`, a: costAnswer },
  { q: `Сколько оформляется виза ${d.cases.vP}?`, a: termAnswer },
  { q: `На сколько дней можно въехать ${d.cases.vP}?`, a: stayAnswer },
  {
    q: `Когда лучше ехать ${d.cases.vP}?`,
    a: bestMonths.length
      ? `Лучшие месяцы: ${bestMonths.map(m => m.nom).join(', ')}. ${bestMonths[0]?.text || ''}`.trim()
      : `Сезоны ${d.cases.loc} переменчивы — смотрите помесячный календарь ниже и таблицу сезонов.`,
  },
];
if (d.relatedPosts.length > 0) {
  faqs.push({
    q: `Есть личный опыт поездки ${d.cases.loc}?`,
    a: `Да, разборы с реальными ценами и маршрутами: ${d.relatedPosts.map(p => p.title).join('; ')}. Ссылки в разделе «Подробные гайды» ниже.`,
  });
}

const monthsTail = bestMonths.length ? ` Лучшие месяцы — ${bestMonths.map(m => m.nom).join(', ')}.` : '';
// Если есть страновой summary (уже включает цену/срок) — не дублируем costAnswer/stayAnswer.
const tldr = vd.summary ? `${summary}${monthsTail}` : `${summary} ${costAnswer} ${stayAnswer}${monthsTail}`;

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${url}#page`,
      "url": url,
      "name": `Виза ${d.cases.vP} для россиян 2026: документы, цена, сроки`,
      "description": summary,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "about": { "@type": "Country", "name": d.cases.nom },
      "datePublished": "2026-04-30",
      "dateModified": DATA_UPDATED,
      "author": { "@id": "https://traveltribe.ru/about/#person" },
      "publisher": { "@id": "https://traveltribe.ru/#org" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", ".quick-tldr"] },
      "mainEntity": { "@id": `${url}#faq` }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Визы", "item": "https://traveltribe.ru/visa/" },
        { "@type": "ListItem", "position": 3, "name": d.cases.nom, "item": url },
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${url}#faq`,
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<Layout
  title={vd.title ?? VISA_TITLE[d.visa]}
  description={metaDesc}
  canonical={url}
  ogTitle={vd.title ?? VISA_TITLE[d.visa]}
  ogDescription={metaDesc}
  ogType="article"
  ldJson={ldJson}
>
  <Breadcrumbs crumbs={[{ label: 'Визы', href: '/visa/' }, { label: d.cases.nom }]} />

  <main id="main" class="visa-wrap">
    <div class="dest-hero" style={`--g1:${d.visual.g1}; --g2:${d.visual.g2};`}>
      {photo ? (
        <Picture
          src={photo}
          alt={d.cases.nom}
          widths={[640, 960, 1400, 1920]}
          sizes="(max-width: 720px) 100vw, min(1200px, 100vw)"
          formats={['webp']}
          fallbackFormat="jpg"
          quality={78}
          loading="eager"
          fetchpriority="high"
          class="dest-hero-img"
        />
      ) : (
        <span class="dest-emoji" aria-hidden="true">{d.visual.emoji}</span>
      )}
      <div class="dest-hero-overlay"></div>
      <div class="dest-hero-badge">
        <span class="dest-hero-emoji" aria-hidden="true">{d.visual.emoji}</span>
        <span class="dest-hero-name">{d.cases.nom}</span>
      </div>
    </div>
    <header class="visa-header">
      <div class={`visa-tag visa-tag--${d.visa}`}>{VISA_LABELS[d.visa]}</div>
      <h1>Виза <em>{d.cases.vP}</em> в 2026 году</h1>
      <p class="visa-sub">{summary}</p>
      <p class="visa-byline">
        <a href="/about/" class="byline-author">Никита Зайцев</a> ·
        <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> ·
        <span class="byline-fresh">данные актуальны на {DATA_UPDATED_RU}</span>
      </p>
    </header>

    <section class="quick-tldr" aria-label="Кратко">
      <strong>Если коротко:</strong> {tldr}
    </section>

    <section class="visa-block">
      <h2>Кратко</h2>
      <ul class="visa-facts">
        <li><strong>Статус:</strong> {VISA_LABELS[d.visa]}</li>
        <li><strong>Стоимость визы:</strong> {noVisa && feeFree ? 'бесплатно (виза не нужна)' : vd.cost}</li>
        <li><strong>Разрешённое пребывание:</strong> {vd.duration}</li>
        <li><strong>Оформление:</strong> {vd.timing}</li>
        <li><strong>Регион:</strong> {d.group}</li>
        <li><strong>Бюджет на день:</strong> {d.budget === 'low' ? '$ — до $80' : d.budget === 'mid' ? '$$ — $80–250' : '$$$ — от $250'}</li>
        {flightFrom && <li><strong>Перелёт из Москвы от:</strong> ${flightFrom}</li>}
        {hotelFrom && <li><strong>Отель эконом от:</strong> ${hotelFrom}/ночь</li>}
      </ul>
    </section>

    <section class="visa-block">
      <h2>Сколько стоит виза {d.cases.vP} в 2026</h2>
      <p>{costAnswer}</p>
      <p>{stayAnswer}</p>
    </section>

    {d.visa === 'free' && (
      <section class="visa-block">
        <h2>Что нужно для въезда</h2>
        <ul class="visa-list">
          <li>Загранпаспорт со сроком действия минимум <strong>6 месяцев</strong> с даты въезда</li>
          <li><strong>Минимум 1 пустая страница</strong> для штампа</li>
          <li>Обратный билет (могут спросить на границе)</li>
          <li>Подтверждение брони отеля или приглашение</li>
          <li>Желательно — выписка с банковской карты или наличные на расходы</li>
        </ul>
        <p>Безвизовый режим обычно даёт <strong>30–90 дней</strong> пребывания. Если планируете дольше — оформляется временное проживание уже на месте.</p>
      </section>
    )}

    {d.visa === 'evisa' && (
      <section class="visa-block">
        <h2>Как оформить {vd.apply ? `визу ${d.cases.vP}` : 'eVisa'}</h2>
        <ul class="visa-list">
          {(vd.apply ?? [
            'Заполнить онлайн-анкету на официальном сайте миграционной службы страны',
            'Загрузить скан загранпаспорта (срок 6+ месяцев) и фото',
            'Оплатить консульский сбор картой (обычно $20–80)',
            'Дождаться одобрения по email — обычно 24–72 часа',
            'Распечатать одобрение и предъявить на въезде вместе с загранпаспортом',
          ]).map((step) => <li>{step}</li>)}
        </ul>
        {!vd.apply && (
          <p>Электронная виза удобнее обычной — нет очередей в посольстве, оплата принимается с большинства карт, иногда (Турция, Шри-Ланка, Камбоджа) можно оформить прямо в аэропорту прибытия.</p>
        )}
      </section>
    )}

    {d.visa === 'required' && (
      <section class="visa-block">
        <h2>Что нужно для оформления</h2>
        <ul class="visa-list">
          <li><strong>Загранпаспорт</strong> со сроком действия минимум 6 месяцев после даты возвращения</li>
          <li><strong>Анкета</strong> на сайте посольства/визового центра</li>
          <li><strong>Фотография</strong> по требованиям конкретной страны (часто отличается от Шенгена)</li>
          <li><strong>Банковская выписка</strong> — обычно $50–100 на день поездки</li>
          <li><strong>Справка с работы</strong> с зарплатой и должностью или ИП-документы</li>
          <li><strong>Бронь отеля</strong> и авиабилеты (часто можно неоплаченные)</li>
          <li><strong>Биометрия</strong> в визовом центре — личная подача обязательна</li>
        </ul>
        <p>Срок оформления обычно <strong>5–15 рабочих дней</strong>. Подавать минимум за 2 месяца до вылета. Стоимость консульского сбора — от $35 (Шенген) до $200+ (Австралия, Великобритания).</p>
      </section>
    )}

    <section class="visa-block">
      <h2>Когда лучше ехать</h2>
      <p>Лучшие месяцы {d.cases.vP} — когда совпадают хорошая погода, доступные цены и комфорт без толп.</p>
      <ul class="visa-months">
        {d.r.map((status, i) => {
          const m = ['январе','феврале','марте','апреле','мае','июне','июле','августе','сентябре','октябре','ноябре','декабре'][i];
          const slug = ['january','february','march','april','may','june','july','august','september','october','november','december'][i];
          const klass = status === 'P' ? 'peak' : status === 'G' ? 'good' : status === 'O' ? 'off' : status === 'B' ? 'bad' : 'closed';
          return (
            <li class={`visa-month visa-month--${klass}`}>
              <a href={`/trips/${slug}/${d.slug}/`}>
                <span class="vm-name">в {m}</span>
                <span class="vm-status"><span class="vm-dot" aria-hidden="true">●</span>{status === 'P' ? 'пик' : status === 'G' ? 'хорошо' : status === 'O' ? 'средне' : status === 'B' ? 'плохо' : 'закрыт'}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </section>

    {d.relatedPosts.length > 0 && (
      <section class="visa-block">
        <h2>Подробные гайды о {d.cases.prep}</h2>
        <ul class="visa-related">
          {d.relatedPosts.map((p) => (
            <li><a href={`/blog/${p.slug}/`}><strong>{p.title}</strong></a> — {p.kind === 'visa' ? 'детали по визе' : p.kind === 'season' ? 'про конкретный сезон' : 'личный опыт автора'}</li>
          ))}
        </ul>
      </section>
    )}

    <section class="visa-block visa-prep">
      <h2>Перед поездкой {d.cases.vP}</h2>
      <p class="visa-prep-lead">Что оформить заранее — собрал то, чем пользуюсь сам.</p>
      <ul class="visa-prep-list">
        <li>
          <strong>Медстраховка.</strong> {d.visa === 'required'
            ? 'Для визы её прикладывают к пакету документов — покрытие обычно от €30 000.'
            : 'Виза не нужна, но без страховки лечение за границей оплачиваешь из кармана.'} Сравнить полисы: <a href={TP_LINKS.cherehapa} rel="sponsored noopener" target="_blank">Cherehapa</a> — от 70&nbsp;₽/день, оплата картой РФ.
        </li>
        {flightFrom > 0 && d.iata && (
          <li>
            <strong>Перелёт.</strong> Билеты Москва → {d.cases.nom} от&nbsp;${flightFrom}. <a href={aviasalesRoute('MOW', d.iata)} rel="sponsored noopener" target="_blank">Найти на Aviasales</a> — сравнивает 100+ агентств за раз.
          </li>
        )}
        <li>
          <strong>Связь.</strong> eSIM вместо роуминга — подключается до вылета, без поиска местной симки. <a href={TP_LINKS.airalo} rel="sponsored noopener" target="_blank">Airalo</a> — от&nbsp;$5 за неделю.
        </li>
      </ul>
      
    </section>

    <section class="visa-block" id="faq">
      <h2>FAQ — виза {d.cases.vP}</h2>
      <div class="faq-block">
        {faqs.map(f => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <div class="faq-a"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </section>

    <section class="visa-block">
      <h2>Связанные ресурсы</h2>
      <ul class="visa-related">
        <li><a href={`/${d.slug}/`}>{d.cases.nom} 2026 — гид по стране</a> — регионы, когда ехать, бюджет поездки</li>
        <li><a href={`/packing/${d.slug}/`}>Чек-лист: что взять {d.cases.vP}</a> — одежда по погоде, документы, аптечка, техника</li>
        <li><a href="/seasons/">Таблица сезонов</a> — сравнение всех 70+ направлений по месяцам</li>
        <li><a href="/calculator/">Калькулятор бюджета</a> — посчитать стоимость поездки {d.cases.vP}</li>
        <li><a href="/blog/">Блог</a> — личные отчёты по странам</li>
        <li><a href="https://www.kdmid.ru/" target="_blank" rel="noopener nofollow">Консульский департамент МИД РФ</a> — официальные визовые требования и предупреждения, проверяйте перед поездкой</li>
      </ul>
      <p class="visa-disclaimer">Визовые правила меняются. Данные сверены на {DATA_UPDATED_RU}; перед поездкой обязательно проверьте актуальные требования на сайте посольства или консульства {d.cases.nom}.</p>
    </section>
  </main>

  <StickyCta href={cherehapaTravel(`visa_${d.slug.replaceAll('-', '_')}`)} label={d.visa === 'required' ? 'Страховка для визы — сравнить цены' : 'Оформить страховку в поездку'} />

  <Footer />
</Layout>

<style>
.visa-wrap { max-width: 720px; margin: 0 auto; padding: 0 2rem 5rem; }
.dest-hero {
  position: relative;
  height: clamp(220px, 36vw, 380px);
  margin: 0 -2rem 0;
  border-radius: 0;
  background: linear-gradient(135deg, var(--g1) 0%, var(--g2) 100%);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
  isolation: isolate;
}
