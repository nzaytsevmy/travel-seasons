---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { DIRECTIONS } from '../../data/directions.js';

export async function getStaticPaths() {
  return DIRECTIONS.map((d) => ({ params: { slug: d.slug }, props: { d } }));
}

const { d } = Astro.props;
const url = `https://traveltribe.ru/visa/${d.slug}/`;

const VISA_LABELS = {
  free: 'Без визы',
  evisa: 'eVisa / упрощённая',
  required: 'Виза обязательна',
};

const visaSummary = {
  free: `${d.cases.nom} даёт россиянам безвизовый въезд. Достаточно загранпаспорта со сроком действия от 6 месяцев и обратного билета.`,
  evisa: `Для въезда ${d.cases.vP} нужна электронная виза (eVisa) или упрощённое разрешение. Оформляется онлайн до вылета, без визита в посольство.`,
  required: `Для поездки ${d.cases.vP} россиянам нужна полноценная виза. Оформляется через визовый центр или посольство страны, требуется пакет документов и личная подача с биометрией.`,
};

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${url}#page`,
      "url": url,
      "name": `Виза ${d.cases.vP} для россиян 2026: документы, цена, сроки`,
      "description": visaSummary[d.visa],
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "about": { "@type": "Country", "name": d.cases.nom },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Визы", "item": "https://traveltribe.ru/visa/" },
        { "@type": "ListItem", "position": 3, "name": d.cases.nom, "item": url },
      ]
    }
  ]
};

const flightFrom = d.price?.flight?.[0];
const hotelFrom = d.price?.hotel?.[0];
---
<Layout
  title={`Виза ${d.cases.vP} для россиян 2026 — документы, цена, сроки`}
  description={visaSummary[d.visa].slice(0, 155)}
  canonical={url}
  ogTitle={`Виза ${d.cases.vP} для россиян 2026`}
  ogDescription={visaSummary[d.visa].slice(0, 155)}
  ogType="article"
  ldJson={ldJson}
>
  <Nav active="blog" />
  <Breadcrumbs crumbs={[{ label: 'Визы', href: '/visa/' }, { label: d.cases.nom }]} />

  <main id="main" class="visa-wrap">
    <header class="visa-header">
      <div class={`visa-tag visa-tag--${d.visa}`}>// {VISA_LABELS[d.visa]}</div>
      <h1>Виза <em>{d.cases.vP}</em> в 2026 году</h1>
      <p class="visa-sub">{visaSummary[d.visa]}</p>
    </header>

    <section class="visa-block">
      <h2>Кратко</h2>
      <ul class="visa-facts">
        <li><strong>Статус:</strong> {VISA_LABELS[d.visa]}</li>
        <li><strong>Регион:</strong> {d.group}</li>
        <li><strong>Бюджет на день:</strong> {d.budget === 'low' ? '$ — до $80' : d.budget === 'mid' ? '$$ — $80–250' : '$$$ — от $250'}</li>
        {flightFrom && <li><strong>Перелёт из Москвы от:</strong> ${flightFrom}</li>}
        {hotelFrom && <li><strong>Отель эконом от:</strong> ${hotelFrom}/ночь</li>}
      </ul>
    </section>

    {d.visa === 'free' && (
      <section class="visa-block">
        <h2>Что нужно для въезда</h2>
        <ul class="visa-list">
          <li>Загранпаспорт со сроком действия минимум <strong>6 месяцев</strong> с даты въезда</li>
          <li><strong>Минимум 1 пустая страница</strong> для штампа</li>
          <li>Обратный билет (могут спросить на границе)</li>
          <li>Подтверждение брони отеля или приглашение</li>
          <li>Желательно — выписка с банковской карты или наличные на расходы</li>
        </ul>
        <p>Безвизовый режим обычно даёт <strong>30–90 дней</strong> пребывания. Если планируете дольше — оформляется временное проживание уже на месте.</p>
      </section>
    )}

    {d.visa === 'evisa' && (
      <section class="visa-block">
        <h2>Как оформить eVisa</h2>
        <ul class="visa-list">
          <li>Заполнить онлайн-анкету на официальном сайте миграционной службы страны</li>
          <li>Загрузить скан загранпаспорта (срок 6+ месяцев) и фото</li>
          <li>Оплатить консульский сбор картой (обычно $20–80)</li>
          <li>Дождаться одобрения по email — обычно 24–72 часа</li>
          <li>Распечатать одобрение и предъявить на въезде вместе с загранпаспортом</li>
        </ul>
        <p>Электронная виза удобнее обычной — нет очередей в посольстве, оплата принимается с большинства карт, иногда (Турция, Шри-Ланка, Камбоджа) можно оформить прямо в аэропорту прибытия.</p>
      </section>
    )}

    {d.visa === 'required' && (
      <section class="visa-block">
        <h2>Что нужно для оформления</h2>
        <ul class="visa-list">
          <li><strong>Загранпаспорт</strong> со сроком действия минимум 6 месяцев после даты возвращения</li>
          <li><strong>Анкета</strong> на сайте посольства/визового центра</li>
          <li><strong>Фотография</strong> по требованиям конкретной страны (часто отличается от Шенгена)</li>
          <li><strong>Банковская выписка</strong> — обычно $50–100 на день поездки</li>
          <li><strong>Справка с работы</strong> с зарплатой и должностью или ИП-документы</li>
          <li><strong>Бронь отеля</strong> и авиабилеты (часто можно неоплаченные)</li>
          <li><strong>Биометрия</strong> в визовом центре — личная подача обязательна</li>
        </ul>
        <p>Срок оформления обычно <strong>5–15 рабочих дней</strong>. Подавать минимум за 2 месяца до вылета. Стоимость консульского сбора — от $35 (Шенген) до $200+ (Австралия, Великобритания).</p>
      </section>
    )}

    <section class="visa-block">
      <h2>Когда лучше ехать</h2>
      <p>Лучшие месяцы {d.cases.vP} — когда совпадают хорошая погода, доступные цены и комфорт без толп.</p>
      <ul class="visa-months">
        {d.r.map((status, i) => {
          const m = ['январе','феврале','марте','апреле','мае','июне','июле','августе','сентябре','октябре','ноябре','декабре'][i];
          const slug = ['january','february','march','april','may','june','july','august','september','october','november','december'][i];
          const klass = status === 'P' ? 'peak' : status === 'G' ? 'good' : status === 'O' ? 'off' : status === 'B' ? 'bad' : 'closed';
          return (
            <li class={`visa-month visa-month--${klass}`}>
              <a href={`/trips/${slug}/${d.slug}/`}>
                <span class="vm-name">в {m}</span>
                <span class="vm-status">{status === 'P' ? '🔥 пик' : status === 'G' ? '✅ хорошо' : status === 'O' ? '🟡 средне' : status === 'B' ? '⛔ плохо' : '❄️ закрыт'}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </section>

    <section class="visa-block">
      <h2>Связанные ресурсы</h2>
      <ul class="visa-related">
        <li><a href="/seasons/">Таблица сезонов</a> — сравнение всех 39 направлений по месяцам</li>
        <li><a href="/calculator/">Калькулятор бюджета</a> — посчитать стоимость поездки {d.cases.vP}</li>
        <li><a href="/blog/">Блог</a> — личные отчёты по странам</li>
      </ul>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.visa-wrap { max-width: 720px; margin: 0 auto; padding: 0 2rem 5rem; }
.visa-header { text-align: center; margin: 2.5rem 0 2.5rem; }
.visa-tag {
  display: inline-flex; align-items: center;
  font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
  border: 1px solid var(--line); padding: 0.3rem 0.85rem; border-radius: 20px;
  margin-bottom: 1rem;
}
.visa-tag--free { color: var(--peak-text); border-color: rgba(34,197,94,0.4); background: rgba(34,197,94,0.07); }
.visa-tag--evisa { color: var(--good-text); border-color: rgba(74,158,255,0.4); background: rgba(74,158,255,0.07); }
.visa-tag--required { color: var(--gold); border-color: rgba(201,151,58,0.4); background: rgba(201,151,58,0.08); }
.visa-header h1 {
  font-family: var(--ff-display); font-size: clamp(2.2rem, 5vw, 3.8rem);
  font-weight: 300; line-height: 1.1; letter-spacing: -0.01em;
}
.visa-header h1 em { color: var(--gold); font-style: italic; }
.visa-sub { color: var(--text-dim); font-size: 1rem; line-height: 1.7; margin: 1rem auto 0; max-width: 580px; }

.visa-block { margin-bottom: 2.5rem; }
.visa-block h2 {
  font-family: var(--ff-display); font-size: 1.5rem; font-weight: 400;
  color: var(--gold); margin-bottom: 1rem;
}
.visa-block p { color: var(--text-dim); line-height: 1.8; font-size: 0.95rem; margin-bottom: 0.8rem; }

.visa-facts, .visa-list, .visa-related { padding-left: 1.4rem; }
.visa-facts li, .visa-list li, .visa-related li {
  color: var(--text-dim); line-height: 1.8; margin-bottom: 0.45rem; font-size: 0.95rem;
}
.visa-facts li strong, .visa-list li strong { color: var(--text); }

.visa-related a { color: var(--gold); text-decoration: underline; text-decoration-color: rgba(201,151,58,0.5); text-underline-offset: 3px; }

.visa-months {
  list-style: none; padding: 0;
  display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 0.5rem; margin-top: 1rem;
}
.visa-month a {
  display: flex; justify-content: space-between; align-items: center; gap: 0.5rem;
  padding: 0.6rem 0.85rem; background: var(--bg2);
  border: 1px solid var(--line); border-radius: 4px;
  text-decoration: none; transition: border-color 0.15s, background 0.15s;
}
.visa-month a:hover { border-color: var(--gold-dim); background: var(--bg3); }
.vm-name { color: var(--text); font-size: 0.9rem; }
.vm-status { color: var(--text-faint); font-size: 0.78rem; }
.visa-month--peak .vm-status { color: #22c55e; }
.visa-month--good .vm-status { color: #4a9eff; }
.visa-month--off .vm-status { color: #f59e0b; }
.visa-month--bad .vm-status { color: #ef4444; }
</style>
