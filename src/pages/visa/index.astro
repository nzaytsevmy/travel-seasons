    color: var(--ink-soft);
  }
  .va-change-text strong { color: var(--ink); font-weight: 600; }

  /* Quick-filter chips */
  .va-filters {
    margin: 2rem 0 1rem;
    padding: 0.9rem 1rem;
    background: var(--paper-dark);
    border: 1px solid var(--line-doc);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .va-filters-label {
    font-family: var(--ff-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--stamp-red);
    text-transform: uppercase;
    flex: 0 0 auto;
  }
  .va-filters-chips {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }
  .va-chip {
    font-family: var(--ff-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.55rem 0.9rem;
    min-height: 36px;
    background: var(--paper);
    border: 1px solid var(--line-doc);
    color: var(--ink-soft);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .va-chip:hover {
    border-color: var(--ink);
    color: var(--ink);
  }
  .va-chip.va-chip--active {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .va-chip-divider {
    color: var(--sepia);
    opacity: 0.5;
    margin: 0 0.2rem;
  }

  /* Sources / verification block */
  .va-sources {
    margin: 3rem auto 2rem;
    max-width: 820px;
    padding: 1.5rem 0 1rem;
    border-top: 1px solid var(--ink);
    border-bottom: 1px dashed var(--line-doc);
  }
  .va-sources-head { margin-bottom: 1.3rem; }
  .va-sources-tag {
    display: inline-block;
    font-family: var(--ff-mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    color: var(--customs-blue);
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--customs-blue);
    background: var(--customs-blue-soft);
  }
  .va-sources-title {
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-style: italic;
    font-weight: 500;
    margin: 0.5rem 0 0;
    color: var(--ink);
    line-height: 1.1;
  }
  .va-sources-body {
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink-soft);
  }
  .va-sources-body p { margin: 0 0 1rem; }
  .va-sources-list {
    list-style: none;
    margin: 1rem 0;
    padding: 0;
  }
  .va-sources-list li {
    padding: 0.55rem 0 0.55rem 0.9rem;
    border-bottom: 1px dashed var(--line-doc-faint);
    position: relative;
    font-size: 0.95rem;
  }
  .va-sources-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.95em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--customs-blue);
    opacity: 0.6;
  }
  .va-sources-list li:last-child { border-bottom: none; }
  .va-sources-list strong { color: var(--ink); font-weight: 600; }
  .va-sources-list a {
    color: var(--stamp-red);
    border-bottom: 1px dashed currentColor;
    font-family: var(--ff-mono);
    font-size: 0.88em;
  }
  .va-sources-disclaimer {
    margin-top: 1.4rem !important;
    padding: 0.9rem 1.1rem;
    background: var(--stamp-red-soft);
    border-left: 3px solid var(--stamp-red);
    font-size: 0.92rem !important;
    font-style: italic;
  }
  .va-sources-disclaimer strong { color: var(--stamp-red); font-style: normal; font-weight: 600; }

  /* Related pillars */
  .va-related {
    margin: 4rem auto 2rem;
    max-width: 880px;
    padding-top: 2rem;
    border-top: 2px solid var(--ink);
  }
  .va-related-head { margin-bottom: 1.3rem; }
  .va-related-tag {
    display: inline-block;
    font-family: var(--ff-mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    color: var(--sepia);
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--sepia);
  }
  .va-related-title {
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-style: italic;
    font-weight: 500;
    margin: 0.5rem 0 0;
    color: var(--ink);
    line-height: 1.1;
  }
  .va-related-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .va-related-item {
    border-bottom: 1px dashed var(--line-doc);
  }
  .va-related-item:last-child { border-bottom: none; }
  .va-related-item a {
    display: grid;
    grid-template-columns: 44px 1fr auto;
    gap: 1.2rem;
    padding: 1rem 0.5rem;
    align-items: baseline;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s, color 0.2s;
  }
  .va-related-item a:hover {
    background: rgba(163, 55, 42, 0.04);
  }
  .va-related-item a:hover .va-related-name {
    color: var(--stamp-red);
  }
  .va-related-num {
    font-family: var(--ff-mono);
    font-size: 0.78rem;
    color: var(--sepia);
    letter-spacing: 0.06em;
  }
  .va-related-meta { min-width: 0; }
  .va-related-name {
    display: block;
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
    transition: color 0.2s;
  }
  .va-related-desc {
    display: block;
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: 0.92rem;
    color: var(--ink-soft);
    margin-top: 0.2rem;
    line-height: 1.4;
    font-style: italic;
  }
  .va-related-arrow {
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: 1.2rem;
    color: var(--stamp-red);
    font-style: italic;
  }

  /* ──────────────── CTA ROW — Telegram + Aviasales ──────────────── */
  .va-cta-row {
    display: flex;
    gap: 0.8rem;
    margin: 1.5rem 0 0;
    flex-wrap: wrap;
  }
  .va-cta {
    display: inline-flex;
    align-items: baseline;
    gap: 0.55rem;
    padding: 0.7rem 1.1rem;
    text-decoration: none;
    border: 1.5px solid currentColor;
    background: var(--paper);
    font-family: var(--ff-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }
  .va-cta--primary { color: var(--stamp-red); }
  .va-cta--primary:hover { background: var(--stamp-red); color: var(--paper); transform: translateY(-1px); }
  .va-cta--secondary { color: var(--customs-blue); }
  .va-cta--secondary:hover { background: var(--customs-blue); color: var(--paper); transform: translateY(-1px); }
  .va-cta-label { font-weight: 500; }
  .va-cta-arrow { font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif; font-size: 1.1em; font-style: italic; }
  .va-cta-meta {
    font-size: 0.7em;
    opacity: 0.7;
    letter-spacing: 0.04em;
    text-transform: none;
    font-style: italic;
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
  }

  /* ──────────────── STATS — три карточки реестра ──────────────── */
  .va-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin-bottom: 3rem;
    border: 1px solid var(--ink);
    background: var(--ink);
  }
  .va-stat {
    background: var(--paper);
    padding: 1.6rem 1.4rem 1.4rem;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .va-stat-mark {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    font-family: var(--ff-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.55rem;
    border: 1.5px solid currentColor;
    border-radius: 50%;
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    transform: rotate(-6deg);
  }
  .va-stat--free .va-stat-mark { color: var(--customs-blue); }
  .va-stat--evisa .va-stat-mark { color: var(--sepia); }
  .va-stat--required .va-stat-mark { color: var(--stamp-red); }

  .va-stat-num {
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: clamp(3rem, 6vw, 4.4rem);
    line-height: 1;
    font-weight: 500;
    color: var(--ink);
    margin-top: 0.6rem;
  }
  .va-stat-label {
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--ink-soft);
    margin-top: 0.2rem;
  }
  .va-stat-note {
    font-family: var(--ff-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    color: var(--sepia);
    margin-top: 0.55rem;
    text-transform: uppercase;
  }

  /* ──────────────── FAQ — Архивная справка ──────────────── */
  .va-faq {
    margin: 3rem 0;
    padding: 2rem 0 1.5rem;
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    position: relative;
  }
  .va-faq::before {
    content: "";
    position: absolute;
    top: 4px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--ink);
    opacity: 0.4;
  }
  .va-faq-head {
    text-align: center;
    margin-bottom: 1.8rem;
  }
  .va-faq-tag {
    display: inline-block;
    font-family: var(--ff-mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    color: var(--stamp-red);
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--stamp-red);
    background: var(--stamp-red-soft);
    margin-bottom: 0.9rem;
  }
  .va-faq-title {
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-style: italic;
    font-weight: 500;
    color: var(--ink);
    margin: 0;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .va-faq-list {
    max-width: 820px;
    margin: 0 auto;
  }
  .va-faq-item {
    border-bottom: 1px dashed var(--line-doc);
    padding: 0;
  }
  .va-faq-item:last-child {
    border-bottom: none;
  }
  .va-faq-item[open] {
    background: rgba(163, 55, 42, 0.02);
  }

  .va-faq-q {
    list-style: none;
    cursor: pointer;
    padding: 1.1rem 1rem 1rem 0.5rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: baseline;
    transition: background 0.2s;
  }
  .va-faq-q::-webkit-details-marker { display: none; }
  .va-faq-q:hover {
    background: rgba(163, 55, 42, 0.04);
  }

  .va-faq-num {
    font-family: var(--ff-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--sepia);
    flex: 0 0 auto;
  }
  .va-faq-q-text {
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
  .va-faq-q-mark {
    font-family: var(--ff-mono);
    font-size: 1.2rem;
    color: var(--stamp-red);
    transition: transform 0.25s ease;
    flex: 0 0 auto;
    line-height: 1;
  }
  .va-faq-item[open] .va-faq-q-mark {
    transform: rotate(45deg);
  }

  .va-faq-a {
    padding: 0 1rem 1.3rem calc(0.5rem + 2.8rem);
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 720px;
  }

  /* ──────────────── SEARCH — filing tray ──────────────── */
  .va-search-wrap {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 3rem;
    padding: 0.8rem 1rem;
    background: var(--paper-dark);
    border: 1px solid var(--line-doc);
    flex-wrap: wrap;
  }
  .va-search-label {
    flex: 0 0 auto;
  }
  .va-search-prefix {
    font-family: var(--ff-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--stamp-red);
    text-transform: uppercase;
  }
  .va-search-field {
    flex: 1;
    min-width: 200px;
    display: flex;
    align-items: center;
    position: relative;
  }
  .va-search-field input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px dashed var(--line-doc);
    color: var(--ink);
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: 1.05rem;
    padding: 0.4rem 1.6rem 0.4rem 0;
    outline: none;
    font-style: italic;
  }
  .va-search-field input::placeholder {
    color: var(--sepia);
    opacity: 0.6;
  }
  .va-search-field input:focus {
    border-bottom-color: var(--stamp-red);
  }
  .va-search-clear {
    position: absolute;
    right: 0;
    background: none;
    border: none;
    color: var(--sepia);
    cursor: pointer;
    font-size: 1.2rem;
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
  }
  .va-search-clear:hover { color: var(--stamp-red); background: var(--stamp-red-soft); }
  .va-empty {
    width: 100%;
    font-family: var(--ff-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--stamp-red);
    margin: 0.5rem 0 0;
  }

  /* ──────────────── CLASSIFIED SECTIONS ──────────────── */
  .va-section { margin-bottom: 3.5rem; }
  .va-section[hidden] { display: none; }

  .va-section-head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.4rem 1.6rem;
    align-items: start;
    padding-bottom: 1.3rem;
    border-bottom: 1px solid var(--ink);
    margin-bottom: 1.8rem;
  }

  /* Circular stamp for section number */
  .va-section-stamp {
    flex: 0 0 auto;
    width: clamp(86px, 12vw, 110px);
    height: clamp(86px, 12vw, 110px);
    border-radius: 50%;
    border: 2.5px solid currentColor;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    transform: rotate(-4deg);
    font-family: var(--ff-mono);
  }
  .va-section-stamp::after {
    content: "";
    position: absolute;
    inset: 6px;
    border: 1px dashed currentColor;
    border-radius: 50%;
    opacity: 0.6;
  }
  .vss-roman {
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: 1.5rem;
    font-style: italic;
    line-height: 1;
  }
  .vss-code {
    font-family: var(--ff-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    margin-top: 0.2rem;
  }
  .vss-count {
    font-family: var(--ff-mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    opacity: 0.7;
    margin-top: 0.1rem;
  }
  .vss-count::before { content: "· "; }
  .vss-count::after { content: " ·"; }

  .va-section--free .va-section-stamp { color: var(--customs-blue); }
  .va-section--evisa .va-section-stamp { color: var(--sepia); }
  .va-section--required .va-section-stamp { color: var(--stamp-red); }

  .va-section-meta { min-width: 0; }
  .va-section-iso {
    font-family: var(--ff-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    color: var(--sepia);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
  }
  .va-section-title {
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    margin: 0 0 0.6rem;
    color: var(--ink);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .va-section-desc {
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: clamp(0.95rem, 1.2vw, 1.06rem);
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
    max-width: 640px;
  }

  /* ──────────────── GRID OF CARDS ──────────────── */
  .va-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 0;
    border-top: 1px dashed var(--line-doc);
    border-left: 1px dashed var(--line-doc);
  }
  .va-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    position: relative;
    padding: 1rem 1rem 1.1rem;
    border-right: 1px dashed var(--line-doc);
    border-bottom: 1px dashed var(--line-doc);
    background: transparent;
    transition: background 0.25s ease, transform 0.55s cubic-bezier(0.2, 0.8, 0.2, 1);
    transform: perspective(900px) rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg));
    transform-style: preserve-3d;
    will-change: transform;
  }
  .va-card.is-tilting { transition: background 0.25s ease, transform 0s; }
  .va-card[hidden] { display: none; }
  .va-card:hover {
    background: rgba(163, 55, 42, 0.04);
  }
  /* Glare layer — пятно света следит за курсором */
  .va-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at var(--glare-x, 50%) var(--glare-y, 50%), rgba(255, 220, 180, 0.18), transparent 45%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.35s ease;
    z-index: 3;
    mix-blend-mode: lighten;
  }
  .va-card:hover::after { opacity: 1; }
  .va-card:hover .va-card-stamp {
    opacity: 1;
    transform: rotate(-6deg) scale(1.05);
  }
  /* Stamp cursor над cards — круглая печать с arrow вместо стандартного pointer */
  @media (hover: hover) {
    .va-card {
      cursor: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' viewBox='0 0 32 32'><circle cx='16' cy='16' r='13.5' fill='rgba(244,237,224,0.92)' stroke='%23a3372a' stroke-width='2'/><circle cx='16' cy='16' r='10' fill='none' stroke='%23a3372a' stroke-width='0.6' stroke-dasharray='1.6 1.6'/><text x='16' y='20.5' text-anchor='middle' font-family='monospace' font-size='12' font-weight='700' fill='%23a3372a'>→</text></svg>") 16 16, pointer;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .va-card { transition: background 0.25s; transform: none; }
    .va-card::after { display: none; }
  }

  .va-card-num {
    font-family: var(--ff-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: var(--sepia);
    margin-bottom: 0.6rem;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  /* EEAT — checkmark «был лично» */
  .va-card-visited {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    border: 1px solid var(--stamp-red);
    border-radius: 50%;
    font-family: 'Golos Text Variable', Helvetica, Arial, sans-serif;
    font-size: 0.62rem;
    font-weight: 600;
    color: var(--stamp-red);
    background: var(--paper);
    line-height: 1;
    font-style: normal;
    transform: rotate(-6deg);
  }
  .va-card--visited .va-card-name::after {
    content: "·";
    color: var(--stamp-red);
    margin-left: 0.25rem;
    font-weight: 400;
  }
  .va-card-photo {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    margin-bottom: 0.7rem;
    background: var(--paper-dark);
  }
  .va-card-photo img,
  .va-card-photo picture {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: filter 0.4s ease, transform 0.5s ease;
  }
  /* Sepia tint только на hover — на mobile тач = no filter, не тормозит INP */
  @media (hover: hover) {
    .va-card:hover .va-card-photo img { transform: scale(1.04); filter: sepia(0.12) saturate(0.95); }
  }
  .va-card-fallback {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    transition: filter 0.4s ease;
  }
  .va-card-emoji { font-size: 2.4rem; filter: drop-shadow(0 2px 6px rgba(0,0,0,0.15)); }

  /* Маленький штамп на карточке — индикатор визового кода */
  .va-card-stamp {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
