    const cards = document.querySelectorAll<HTMLElement>('.va-card');
    const sections = document.querySelectorAll<HTMLElement>('.va-section');
    const search = document.getElementById('visaSearch') as HTMLInputElement | null;
    const clearBtn = document.getElementById('visaSearchClear');
    const emptyState = document.getElementById('visaEmpty');
    const countLabel = document.getElementById('visaFilterCount');
    if (!cards.length) return;

    const q = (search?.value || '').trim().toLowerCase();
    let visible = 0;
    cards.forEach((card) => {
      const name = card.dataset.name || '';
      const visa = card.dataset.visa || '';
      const cost = card.dataset.cost || '';
      const isLong = card.dataset.durationLong === '1';
      const showSearch = !q || name.includes(q);
      const showVisa = filterState.visa === 'all' || visa === filterState.visa;
      const showCost = !filterState.cost || cost === filterState.cost;
      const showDuration = !filterState.durationLong || isLong;
      const show = showSearch && showVisa && showCost && showDuration;
      card.hidden = !show;
      if (show) visible++;
    });
    sections.forEach((g) => {
      const any = Array.from(g.querySelectorAll<HTMLElement>('.va-card')).some((c) => !c.hidden);
      g.hidden = !any;
    });
    if (emptyState) (emptyState as HTMLElement).hidden = visible > 0;
    if (clearBtn) (clearBtn as HTMLElement).hidden = q.length === 0;
    if (countLabel) {
      const strong = countLabel.querySelector('strong');
      if (strong) strong.textContent = String(visible);
    }
    // Sync URL — bookmarkable filter state (resilience)
    updateUrlFromFilterState();
  }

  function updateUrlFromFilterState() {
    const params = new URLSearchParams();
    if (filterState.visa !== 'all') params.set('visa', filterState.visa);
    if (filterState.cost) params.set('cost', filterState.cost);
    if (filterState.durationLong) params.set('dur', 'long');
    const qstr = params.toString();
    const newUrl = qstr ? `?${qstr}` : window.location.pathname;
    if (window.location.search !== `?${qstr}` && !(qstr === '' && window.location.search === '')) {
      window.history.replaceState({}, '', newUrl);
    }
  }

  function applyFilterStateFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const visa = params.get('visa');
    const cost = params.get('cost');
    const dur = params.get('dur');
    if (visa && ['free', 'evisa', 'required'].includes(visa)) filterState.visa = visa;
    if (cost && ['free', 'cheap', 'premium'].includes(cost)) filterState.cost = cost;
    if (dur === 'long') filterState.durationLong = true;
    // Update chip UI
    document.querySelectorAll<HTMLElement>('.va-chip').forEach((c) => {
      const isActive = (c.dataset.filter === filterState.visa)
        || (c.dataset.cost && c.dataset.cost === filterState.cost)
        || (c.dataset.duration === 'long' && filterState.durationLong);
      c.classList.toggle('va-chip--active', !!isActive);
      c.setAttribute('aria-pressed', String(!!isActive));
    });
    applyVisaFilters();
  }

  function initVisaSearch() {
    const cards = document.querySelectorAll('.va-card');
    const search = document.getElementById('visaSearch') as HTMLInputElement | null;
    const clearBtn = document.getElementById('visaSearchClear');
    if (!cards.length || !search) return;

    search.addEventListener('input', applyVisaFilters);
    if (clearBtn) clearBtn.addEventListener('click', () => { search.value = ''; applyVisaFilters(); search.focus(); });
  }

  // Сортировка карточек ВНУТРИ каждой секции (группировка по режиму визы сохраняется)
  function applySort() {
    document.querySelectorAll<HTMLElement>('.va-section').forEach((sec) => {
      const cards = Array.from(sec.querySelectorAll<HTMLElement>('.va-card'));
      if (!cards.length) return;
      cards.sort((a, b) => sortState.byCost
        ? (Number(a.dataset.costUsd) || 0) - (Number(b.dataset.costUsd) || 0)
        : (Number(a.dataset.ord) || 0) - (Number(b.dataset.ord) || 0));
      const parent = cards[0].parentElement;
      if (parent) cards.forEach((c) => parent.appendChild(c));
    });
  }

  // Event-delegation на document — robust против timing issues и SPA-навигации
  function initVisaFilters() {
    if ((window as any).__vaFiltersBound) return;
    (window as any).__vaFiltersBound = true;

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const chip = target.closest('.va-chip') as HTMLElement | null;
      if (!chip) return;

      const fVisa = chip.dataset.filter;
      const fCost = chip.dataset.cost;
      const fDur = chip.dataset.duration;
      const allChips = document.querySelectorAll<HTMLElement>('.va-chip');

      if (fVisa) {
        allChips.forEach((c) => {
          if (c.dataset.filter) { c.classList.remove('va-chip--active'); c.setAttribute('aria-pressed', 'false'); }
        });
        chip.classList.add('va-chip--active');
        chip.setAttribute('aria-pressed', 'true');
        filterState.visa = fVisa;
      }
      if (fCost) {
        if (filterState.cost === fCost) {
          filterState.cost = null;
          chip.classList.remove('va-chip--active');
          chip.setAttribute('aria-pressed', 'false');
        } else {
          allChips.forEach((c) => {
            if (c.dataset.cost) { c.classList.remove('va-chip--active'); c.setAttribute('aria-pressed', 'false'); }
          });
          chip.classList.add('va-chip--active');
          chip.setAttribute('aria-pressed', 'true');
          filterState.cost = fCost;
        }
      }
      if (fDur === 'long') {
        filterState.durationLong = !filterState.durationLong;
        chip.classList.toggle('va-chip--active', filterState.durationLong);
        chip.setAttribute('aria-pressed', String(filterState.durationLong));
      }
      if (chip.dataset.sort === 'cost') {
        sortState.byCost = !sortState.byCost;
        chip.classList.toggle('va-chip--active', sortState.byCost);
        chip.setAttribute('aria-pressed', String(sortState.byCost));
        applySort();
      }

      applyVisaFilters();
    });
  }

  // Share API — поделиться текущим состоянием реестра (mobile-first)
  function initShareBtn() {
    const btn = document.getElementById('visaShareBtn') as HTMLButtonElement | null;
    if (!btn) return;
    btn.addEventListener('click', async () => {
      const url = window.location.href;
      const title = 'Визовый реестр 2026 · TravelTribe';
      const text = 'Актуальная сводка визовых правил для россиян по 70+ направлениям.';
      if (navigator.share) {
        try { await navigator.share({ title, text, url }); } catch (e) { /* user cancelled */ }
      } else if (navigator.clipboard) {
        try {
          await navigator.clipboard.writeText(url);
          const orig = btn.querySelector('.va-cta-label');
          if (orig) { const txt = orig.textContent; orig.textContent = 'Скопировано'; setTimeout(() => { orig.textContent = txt; }, 1800); }
        } catch (e) { /* clipboard not available */ }
      }
    });
  }

  initVisaSearch();
  initVisaFilters();
  initShareBtn();
  // Apply URL-state filters на initial load (bookmarkable filters)
  if (window.location.search) applyFilterStateFromUrl();
  document.addEventListener('astro:page-load', () => { initVisaSearch(); initVisaFilters(); initShareBtn(); });

  // Scroll-reveal через IntersectionObserver — staggered появление секций и cards
  function initReveal() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const targets = document.querySelectorAll('[data-reveal]');
    if (!targets.length) return;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).classList.add('is-revealed');
          io.unobserve(e.target);
        }
      });
    }, { rootMargin: '-40px 0px', threshold: 0.06 });
    targets.forEach((el) => io.observe(el));

    // Cards staggered — каждая card получает свою задержку по индексу в grid'е
    document.querySelectorAll<HTMLElement>('.va-grid').forEach((grid) => {
      grid.querySelectorAll<HTMLElement>('.va-card').forEach((card, i) => {
        if (!card.hasAttribute('data-reveal')) card.setAttribute('data-reveal', '');
        card.style.setProperty('--reveal-delay', `${Math.min(i * 0.04, 0.6)}s`);
        io.observe(card);
      });
    });
  }

  // Card 3D tilt + glare — mouse-tracking через RAF, only on hover-capable
  function initTilt() {
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    document.querySelectorAll<HTMLElement>('.va-card').forEach((card) => {
      let rafId: number | null = null;
      const onMove = (e: MouseEvent) => {
        if (rafId !== null) cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(() => {
          const r = card.getBoundingClientRect();
          const x = (e.clientX - r.left) / r.width;   // 0..1
          const y = (e.clientY - r.top) / r.height;
          const tiltX = (0.5 - y) * 6;  // ±3deg
          const tiltY = (x - 0.5) * 6;
          card.style.setProperty('--tilt-x', `${tiltX}deg`);
          card.style.setProperty('--tilt-y', `${tiltY}deg`);
          card.style.setProperty('--glare-x', `${x * 100}%`);
          card.style.setProperty('--glare-y', `${y * 100}%`);
        });
      };
      card.addEventListener('mouseenter', () => {
        card.classList.add('is-tilting');
        card.addEventListener('mousemove', onMove);
      });
      card.addEventListener('mouseleave', () => {
        card.removeEventListener('mousemove', onMove);
        card.classList.remove('is-tilting');
        card.style.setProperty('--tilt-x', '0deg');
        card.style.setProperty('--tilt-y', '0deg');
      });
    });
  }

  initReveal();
  initTilt();
  document.addEventListener('astro:page-load', () => { initReveal(); initTilt(); });
</script>

