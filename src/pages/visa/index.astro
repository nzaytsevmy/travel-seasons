---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import { DIRECTIONS } from '../../data/directions.js';

const destPhotos = import.meta.glob('../../assets/destinations/*.jpg', { eager: true, import: 'default' });

const byVisa = { free: [], evisa: [], required: [] };
for (const d of DIRECTIONS) byVisa[d.visa].push(d);

const VISA_META = {
  free: {
    title: 'Без визы',
    code: 'БВ',
    iso: 'VISA-FREE',
    desc: 'Загранпаспорт от 6 месяцев. Штамп на границе. Никаких документов и оплат заранее.',
    section: 'I',
  },
  evisa: {
    title: 'Электронная виза',
    code: 'EV',
    iso: 'eVISA',
    desc: 'Оформляется онлайн до вылета через сайт миграционной службы. $20–80 · 1–3 дня.',
    section: 'II',
  },
  required: {
    title: 'Виза обязательна',
    code: 'ВЗ',
    iso: 'CONSULAR',
    desc: 'Через консульство или визовый центр. Биометрия, документы, $35–200+ · до 30 дней.',
    section: 'III',
  },
};

// EEAT — страны где Никита был лично (CLAUDE.md: Африка, Океания, Япония, США, Бали + близкое зарубежье)
const VISITED = new Set([
  'kenya', 'south-africa', 'tanzania',
  'australia-east', 'australia-north', 'new-zealand', 'bali',
  'japan', 'japan-hokkaido',
  'usa',
  'georgia', 'armenia', 'turkey', 'uae',
]);

// FAQ для AEO (AI Overviews / Perplexity / ChatGPT)
const FAQ_ITEMS = [
  {
    q: 'Куда россиянину можно без визы в 2026?',
    a: `Сейчас ${byVisa.free.length} направлений принимают по загранпаспорту: Турция (60 дней), Грузия (1 год), Армения (180 дней), ОАЭ (90 дней), Таиланд (60 дней), Китай (30 дней до 14.09.2026), Куба, Доминикана, Сербия, Аргентина, Бразилия, Мексика (180 дней) и другие. Полный список — в разделе I выше.`,
  },
  {
    q: 'Что такое eVisa и чем отличается от обычной визы?',
    a: `eVisa оформляется онлайн через сайт миграционной службы за 1–3 дня. Не нужно посольство, биометрия, фото на паспорт. Стоит $20–80. ${byVisa.evisa.length} стран дают россиянам eVisa: Индия, Шри-Ланка, Кения, Камбоджа, Мадагаскар и другие. Обычная виза — через консульство, биометрия, до 30 дней, $35–200+.`,
  },
  {
    q: 'Где взять визу быстро и дёшево в 2026?',
    a: 'Быстрые eVisa: Шри-Ланка (24 часа, $35), Камбоджа (24–72 часа, $36), Индия (3 дня, $25), Кения (2–7 дней, $51). Без визы и бесплатно: Грузия (1 год), Армения (180 дней), Узбекистан (30 дней), Турция (60 дней), Сербия (30 дней).',
  },
  {
    q: 'Какие страны больше всего отказывают россиянам?',
    a: 'Шенген (особенно Скандинавия, Польша, Прибалтика) — высокий процент отказов с 2022. США — стандартные процедуры, сильно зависит от истории поездок. Канада — проверки через консульства третьих стран (Варшава, Стамбул). UK — частые отказы. Япония — сейчас стабильно, требуется туроператор или поручительство.',
  },
  {
    q: 'Какие документы нужны для визы в 2026?',
    a: 'Минимум для большинства виз: загранпаспорт от 6 месяцев действия, фото 35×45 мм, анкета, подтверждение брони отеля и обратного билета, банковская справка из расчёта $50–100 на день. Для шенгена дополнительно — медстраховка от €30 000, справка с работы, выписка по счёту за 3 месяца.',
  },
  {
    q: 'Сколько действует виза и можно ли продлить?',
    a: 'eVisa обычно 30–90 дней без права продления — нужно выехать и въехать заново (если разрешён повторный въезд). Обычная виза: туристическая 30–180 дней, бизнес/учёба 1–5 лет. Продление — через миграционную службу страны пребывания, $20–100 за 30–60 дней.',
  },
];

// Популярные направления для конверсии — Aviasales deep-link
const POPULAR_DESTS = [
  { name: 'Турция',  iata: 'AYT', visa: 'без визы' },
  { name: 'Япония',  iata: 'TYO', visa: 'через турагентство' },
  { name: 'Грузия',  iata: 'TBS', visa: 'без визы' },
  { name: 'Китай',   iata: 'PEK', visa: 'без визы до 14.09.2026' },
];

// ISO 3166-1 alpha-3 для маленького кода под названием страны (визовый стиль)
const ISO_CODE = {
  'australia-east': 'AUS', 'australia-north': 'AUS', 'bali': 'IDN', 'sumatra-kalimantan': 'IDN', 'raja-ampat': 'IDN',
  'new-zealand': 'NZL', 'kenya': 'KEN', 'south-africa': 'ZAF', 'uae': 'ARE', 'turkey': 'TUR', 'egypt': 'EGY',
  'morocco': 'MAR', 'tanzania': 'TZA', 'madagascar': 'MDG', 'mauritius': 'MUS', 'seychelles': 'SYC',
  'iran': 'IRN', 'jordan': 'JOR', 'israel': 'ISR', 'japan': 'JPN', 'japan-hokkaido': 'JPN', 'south-korea': 'KOR',
  'thailand': 'THA', 'vietnam': 'VNM', 'india-goa': 'IND', 'sri-lanka': 'LKA', 'maldives': 'MDV',
  'georgia': 'GEO', 'armenia': 'ARM', 'kyrgyzstan': 'KGZ', 'uzbekistan': 'UZB', 'tajikistan': 'TJK',
  'kazakhstan': 'KAZ', 'abkhazia': 'ABH', 'china': 'CHN', 'hainan': 'CHN', 'hong-kong': 'HKG',
  'malaysia': 'MYS', 'philippines': 'PHL', 'cambodia': 'KHM', 'singapore': 'SGP', 'nepal': 'NPL',
  'switzerland': 'CHE', 'italy-north': 'ITA', 'italy-south': 'ITA', 'spain': 'ESP', 'greece': 'GRC',
  'croatia': 'HRV', 'serbia': 'SRB', 'finland': 'FIN', 'cyprus': 'CYP',
  'canada-rockies': 'CAN', 'canada-east': 'CAN', 'usa': 'USA',
  'mexico': 'MEX', 'cuba': 'CUB', 'dominican-republic': 'DOM', 'guatemala-belize': 'GTM', 'costa-rica-panama': 'CRI',
  'chile-patagonia': 'CHL', 'chile-fjords': 'CHL', 'peru': 'PER', 'bolivia': 'BOL', 'chile': 'CHL',
  'argentina': 'ARG', 'ecuador': 'ECU', 'brazil': 'BRA', 'antarctica': 'ATA', 'iceland': 'ISL', 'norway': 'NOR',
};

const VISA_TYPE_LABEL = { free: 'Без визы', evisa: 'eVisa', required: 'Виза обязательна' };
const url = 'https://traveltribe.ru/visa/';
const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#page`,
      "url": url,
      "name": "Визы для россиян 2026 — все направления TravelTribe",
      "description": `Визовый реестр 2026: ${DIRECTIONS.length} направлений. ${byVisa.free.length} без визы · ${byVisa.evisa.length} eVisa · ${byVisa.required.length} требуют визу. Документы, цены, сроки.`,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "mainEntity": { "@id": `${url}#itemlist` },
    },
    {
      "@type": "ItemList",
      "@id": `${url}#itemlist`,
      "name": `Визовый реестр TravelTribe 2026 — ${DIRECTIONS.length} направлений`,
      "numberOfItems": DIRECTIONS.length,
      "itemListElement": DIRECTIONS.map((d, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "TouristDestination",
          "@id": `https://traveltribe.ru/visa/${d.slug}/#destination`,
          "name": d.cases.nom,
          "url": `https://traveltribe.ru/visa/${d.slug}/`,
          "description": `Виза в ${d.cases.acc} для россиян 2026: ${VISA_TYPE_LABEL[d.visa]}.`,
          "touristType": VISA_TYPE_LABEL[d.visa],
        },
      })),
    },
    {
      "@type": "FAQPage",
      "mainEntity": FAQ_ITEMS.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Визы", "item": url },
      ]
    }
  ]
};
---
<Layout
  title="Визовый реестр 2026 — визы для россиян по 70 направлениям"
  description={`Визовый реестр 2026: ${byVisa.free.length} без визы · ${byVisa.evisa.length} eVisa · ${byVisa.required.length} требуют визу. Документы, цены, сроки.`}
  canonical={url}
  ogTitle="Визовый реестр 2026 · TravelTribe"
  ogDescription={`${byVisa.free.length} без визы · ${byVisa.evisa.length} eVisa · ${byVisa.required.length} требуют визу`}
  ldJson={ldJson}
>
  <Nav active="blog" />
  <Breadcrumbs crumbs={[{ label: 'Визы' }]} />

  <main id="main" class="visa-archive">

    {/* ─── ДЕКОРАТИВНЫЙ ШТАМП В ФОНЕ ─── */}
    <div class="va-stamp-bg" aria-hidden="true">
      <svg viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <path id="vaStampCircle" d="M 160, 160 m -120, 0 a 120,120 0 1,1 240,0 a 120,120 0 1,1 -240,0" />
        </defs>
        <circle cx="160" cy="160" r="138" fill="none" stroke="currentColor" stroke-width="2.5" />
        <circle cx="160" cy="160" r="120" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3 4" />
        <text font-family="PT Mono, monospace" font-size="13" letter-spacing="4" fill="currentColor">
          <textPath href="#vaStampCircle" startOffset="0%">TRAVELTRIBE · ВИЗОВЫЙ РЕЕСТР · 2026 · ПРОВЕРЕНО · </textPath>
        </text>
        <text x="160" y="148" text-anchor="middle" font-family="PT Mono, monospace" font-size="14" letter-spacing="2" fill="currentColor">14·05·2026</text>
        <line x1="100" y1="160" x2="220" y2="160" stroke="currentColor" stroke-width="1.5" />
        <text x="160" y="184" text-anchor="middle" font-family="PT Mono, monospace" font-size="11" letter-spacing="3" fill="currentColor">RU · 070</text>
      </svg>
    </div>

    {/* ─── DOCUMENT HEADER ─── */}
    <header class="va-doc-head" data-reveal>
      <div class="va-meta-line">
        <span>РЕГ. № 070—2026</span>
        <span class="va-meta-dot">·</span>
        <span>TT-VISA-RU</span>
        <span class="va-meta-dot">·</span>
        <span>Версия 14.05.2026</span>
      </div>

      <div class="va-classification">FILED UNDER · ВИЗОВЫЕ РЕЖИМЫ</div>

      <h1 class="va-title">
        <span class="va-title-line">Визовый</span>
        <span class="va-title-line va-title-line--italic">реестр</span>
        <span class="va-title-line va-title-line--small">для гражданина РФ</span>
      </h1>

      <p class="va-subtitle">
        Сводка по {DIRECTIONS.length} направлениям. Что нужно для въезда, сколько стоит, сколько ждать.
      </p>

      <div class="va-cta-row">
        <a class="va-cta va-cta--primary" href="https://t.me/traveltriberu?utm_source=traveltribe&utm_medium=visa-hero" target="_blank" rel="noopener">
          <span class="va-cta-label">Telegram-канал</span>
          <span class="va-cta-arrow">→</span>
        </a>
        <a class="va-cta va-cta--secondary" href="https://www.aviasales.ru/?marker=546042.Zz66f13c16ff6b488883a4127-546042&market=ru" target="_blank" rel="nofollow noopener sponsored">
          <span class="va-cta-label">Найти билеты</span>
          <span class="va-cta-meta">Aviasales</span>
        </a>
      </div>

      <div class="va-divider" aria-hidden="true">
        <span class="va-divider-line"></span>
        <span class="va-divider-glyph">✦</span>
        <span class="va-divider-line"></span>
      </div>
    </header>

    {/* ─── STATS PANEL — три «карточки реестра» ─── */}
    <section class="va-stats" aria-label="Сводка по визовым режимам" data-reveal>
      <div class="va-stat va-stat--free">
        <div class="va-stat-mark" aria-hidden="true">БВ</div>
        <div class="va-stat-num">{byVisa.free.length}</div>
        <div class="va-stat-label">без визы</div>
        <div class="va-stat-note">визу не оформлять</div>
      </div>
      <div class="va-stat va-stat--evisa">
        <div class="va-stat-mark" aria-hidden="true">EV</div>
        <div class="va-stat-num">{byVisa.evisa.length}</div>
        <div class="va-stat-label">eVisa</div>
        <div class="va-stat-note">онлайн, 1–3 дня</div>
      </div>
      <div class="va-stat va-stat--required">
        <div class="va-stat-mark" aria-hidden="true">ВЗ</div>
        <div class="va-stat-num">{byVisa.required.length}</div>
        <div class="va-stat-label">виза обязательна</div>
        <div class="va-stat-note">консульство · до 30 дней</div>
      </div>
    </section>

    {/* ─── FAQ — Часто спрашивают ─── */}
    <section class="va-faq" aria-label="Часто спрашивают" data-reveal>
      <header class="va-faq-head">
        <span class="va-faq-tag">FAQ · АРХИВНАЯ СПРАВКА</span>
        <h2 class="va-faq-title">Часто спрашивают</h2>
      </header>
      <div class="va-faq-list">
        {FAQ_ITEMS.map((item, idx) => (
          <details class="va-faq-item" open={idx === 0}>
            <summary class="va-faq-q">
              <span class="va-faq-num">{String(idx + 1).padStart(2, '0')}</span>
              <span class="va-faq-q-text">{item.q}</span>
              <span class="va-faq-q-mark" aria-hidden="true">+</span>
            </summary>
            <div class="va-faq-a">{item.a}</div>
          </details>
        ))}
      </div>
    </section>

    {/* ─── SEARCH — filing tray style ─── */}
    <section class="va-search-wrap" aria-label="Поиск страны">
      <label class="va-search-label" for="visaSearch">
        <span class="va-search-prefix">Запрос →</span>
      </label>
      <div class="va-search-field">
        <input type="search" id="visaSearch" placeholder="Япония, Турция, Грузия…" autocomplete="off" aria-label="Поиск страны" />
        <button type="button" class="va-search-clear" id="visaSearchClear" aria-label="Очистить" hidden>×</button>
      </div>
      <p class="va-empty" id="visaEmpty" hidden>В реестре не значится. Попробуй другое название.</p>
    </section>

    {/* ─── CLASSIFIED SECTIONS — три картотеки ─── */}
    {['free', 'evisa', 'required'].map((vt) => (
      <section class={`va-section va-section--${vt}`} data-section={vt} data-reveal>
        <header class="va-section-head">
          <div class="va-section-stamp" aria-hidden="true">
            <span class="vss-roman">{VISA_META[vt].section}</span>
            <span class="vss-code">{VISA_META[vt].code}</span>
            <span class="vss-count">{byVisa[vt].length}</span>
          </div>
          <div class="va-section-meta">
            <div class="va-section-iso">{VISA_META[vt].iso}</div>
            <h2 class="va-section-title">{VISA_META[vt].title}</h2>
            <p class="va-section-desc">{VISA_META[vt].desc}</p>
          </div>
        </header>

        <div class="va-grid">
          {byVisa[vt].map((d, idx) => {
            const photo = destPhotos[`../../assets/destinations/${d.slug}.jpg`];
            const iso = ISO_CODE[d.slug] || 'XXX';
            const num = String(idx + 1).padStart(3, '0');
            const visited = VISITED.has(d.slug);
            return (
              <a href={`/visa/${d.slug}/`} class={`va-card ${visited ? 'va-card--visited' : ''}`} data-name={d.cases.nom.toLowerCase()}>
                <div class="va-card-num">
                  № {num}
                  {visited && <span class="va-card-visited" title="Никита был лично">✓</span>}
                </div>
                <div class="va-card-photo">
                  {photo ? (
                    <Image src={photo} alt={d.cases.nom} widths={[280, 560]} sizes="(max-width: 700px) 50vw, 25vw" formats={['webp']} quality={70} loading="lazy" />
                  ) : (
                    <div class="va-card-fallback" style={`background: linear-gradient(135deg, ${d.visual.g1}, ${d.visual.g2})`}>
                      <span class="va-card-emoji" aria-hidden="true">{d.visual.emoji}</span>
                    </div>
                  )}
                  <div class="va-card-stamp" aria-hidden="true">{VISA_META[vt].code}</div>
                </div>
                <div class="va-card-body">
                  <h3 class="va-card-name">{d.cases.nom}</h3>
                  <div class="va-card-iso">{iso}</div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    {/* ─── FOOTER NOTE ─── */}
    <footer class="va-foot">
      <div class="va-divider" aria-hidden="true">
        <span class="va-divider-line"></span>
        <span class="va-divider-glyph">✦</span>
        <span class="va-divider-line"></span>
      </div>
      <p class="va-foot-text">
        Реестр актуален на <strong>14 мая 2026</strong>. Обновляется при изменении правил въезда раз в 4–6 недель.
      </p>
      <p class="va-foot-sig">Составитель — <a href="/about/">Никита Зайцев</a>, TravelTribe</p>
    </footer>
  </main>

  <Footer />
</Layout>

<script>
  function initVisaSearch() {
    const cards = document.querySelectorAll('.va-card');
    const sections = document.querySelectorAll('.va-section');
    const search = document.getElementById('visaSearch') as HTMLInputElement | null;
    const clearBtn = document.getElementById('visaSearchClear');
    const emptyState = document.getElementById('visaEmpty');
    if (!cards.length || !search) return;

    function apply() {
      const q = search!.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const name = (card as HTMLElement).dataset.name || '';
        const show = !q || name.includes(q);
        (card as HTMLElement).hidden = !show;
        if (show) visible++;
      });
      sections.forEach((g) => {
        const any = Array.from(g.querySelectorAll('.va-card')).some((c) => !(c as HTMLElement).hidden);
        (g as HTMLElement).hidden = !any;
      });
      if (emptyState) (emptyState as HTMLElement).hidden = visible > 0;
      if (clearBtn) (clearBtn as HTMLElement).hidden = q.length === 0;
    }

    search.addEventListener('input', apply);
    if (clearBtn) clearBtn.addEventListener('click', () => { search.value = ''; apply(); search.focus(); });
  }

  initVisaSearch();
  document.addEventListener('astro:page-load', initVisaSearch);

  // Scroll-reveal через IntersectionObserver — staggered появление секций и cards
  function initReveal() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const targets = document.querySelectorAll('[data-reveal]');
    if (!targets.length) return;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).classList.add('is-revealed');
          io.unobserve(e.target);
        }
      });
    }, { rootMargin: '-40px 0px', threshold: 0.06 });
    targets.forEach((el) => io.observe(el));

    // Cards staggered — каждая card получает свою задержку по индексу в grid'е
    document.querySelectorAll<HTMLElement>('.va-grid').forEach((grid) => {
      grid.querySelectorAll<HTMLElement>('.va-card').forEach((card, i) => {
        if (!card.hasAttribute('data-reveal')) card.setAttribute('data-reveal', '');
        card.style.setProperty('--reveal-delay', `${Math.min(i * 0.04, 0.6)}s`);
        io.observe(card);
      });
    });
  }

  // Card 3D tilt + glare — mouse-tracking через RAF, only on hover-capable
  function initTilt() {
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    document.querySelectorAll<HTMLElement>('.va-card').forEach((card) => {
      let rafId: number | null = null;
      const onMove = (e: MouseEvent) => {
        if (rafId !== null) cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(() => {
          const r = card.getBoundingClientRect();
          const x = (e.clientX - r.left) / r.width;   // 0..1
          const y = (e.clientY - r.top) / r.height;
          const tiltX = (0.5 - y) * 6;  // ±3deg
          const tiltY = (x - 0.5) * 6;
          card.style.setProperty('--tilt-x', `${tiltX}deg`);
          card.style.setProperty('--tilt-y', `${tiltY}deg`);
          card.style.setProperty('--glare-x', `${x * 100}%`);
          card.style.setProperty('--glare-y', `${y * 100}%`);
        });
      };
      card.addEventListener('mouseenter', () => {
        card.classList.add('is-tilting');
        card.addEventListener('mousemove', onMove);
      });
      card.addEventListener('mouseleave', () => {
        card.removeEventListener('mousemove', onMove);
        card.classList.remove('is-tilting');
        card.style.setProperty('--tilt-x', '0deg');
        card.style.setProperty('--tilt-y', '0deg');
      });
    });
  }

  initReveal();
  initTilt();
  document.addEventListener('astro:page-load', () => { initReveal(); initTilt(); });
</script>

