---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import { DIRECTIONS } from '../../data/directions.js';
import { getVisaDetails } from '../../data/visa-details.js';

const destPhotos = import.meta.glob('../../assets/destinations/*.jpg', { eager: true, import: 'default' });

const byVisa = { free: [], evisa: [], required: [] };
for (const d of DIRECTIONS) byVisa[d.visa].push(d);

const VISA_META = {
  free: {
    title: 'Без визы',
    code: 'БВ',
    iso: 'VISA-FREE',
    desc: 'Загранпаспорт от 6 месяцев. Штамп на границе. Никаких документов и оплат заранее.',
    section: 'I',
  },
  evisa: {
    title: 'Электронная виза',
    code: 'EV',
    iso: 'eVISA',
    desc: 'Оформляется онлайн до вылета через сайт миграционной службы. $20–80 · 1–3 дня.',
    section: 'II',
  },
  required: {
    title: 'Виза обязательна',
    code: 'ВЗ',
    iso: 'CONSULAR',
    desc: 'Через консульство или визовый центр. Биометрия, документы, $35–200+ · до 30 дней.',
    section: 'III',
  },
};

// EEAT — страны где Никита был лично (CLAUDE.md: Африка, Океания, Япония, США, Бали + близкое зарубежье)
const VISITED = new Set([
  'kenya', 'south-africa', 'tanzania',
  'australia-east', 'australia-north', 'new-zealand', 'bali',
  'japan', 'japan-hokkaido',
  'usa',
  'georgia', 'armenia', 'turkey', 'uae',
]);

// FAQ — 12 главных вопросов о визах
const FAQ_ITEMS = [
  {
    q: 'Куда россиянину можно без визы в 2026?',
    a: `Сейчас ${byVisa.free.length} направлений принимают по загранпаспорту: Турция (60 дней), Грузия (1 год), Армения (180 дней), ОАЭ (90 дней), Таиланд (60 дней), Китай (30 дней до 14.09.2026), Куба, Доминикана, Сербия, Аргентина, Бразилия, Мексика (180 дней) и другие. Полный список — в разделе I выше.`,
  },
  {
    q: 'Что такое eVisa и чем отличается от обычной визы?',
    a: `eVisa оформляется онлайн через сайт миграционной службы за 1–3 дня. Не нужно посольство, биометрия, фото на паспорт. Стоит $20–80. ${byVisa.evisa.length} стран дают россиянам eVisa: Индия, Шри-Ланка, Кения, Камбоджа, Мадагаскар и другие. Обычная виза — через консульство, биометрия, до 30 дней, $35–200+.`,
  },
  {
    q: 'Где взять визу быстро и дёшево в 2026?',
    a: 'Быстрые eVisa: Шри-Ланка (24 часа, $35), Камбоджа (24–72 часа, $36), Индия (3 дня, $25), Кения (2–7 дней, $51). Без визы и бесплатно: Грузия (1 год), Армения (180 дней), Узбекистан (90 дней), Турция (60 дней), Сербия (30 дней).',
  },
  {
    q: 'Какие страны больше всего отказывают россиянам?',
    a: 'Шенген (особенно Скандинавия, Польша, Прибалтика) — высокий процент отказов с 2022. США — стандартные процедуры, сильно зависит от истории поездок. Канада — проверки через консульства третьих стран (Варшава, Стамбул). UK — частые отказы. Япония — сейчас стабильно, требуется туроператор или поручительство.',
  },
  {
    q: 'Какие документы нужны для визы в 2026?',
    a: 'Минимум для большинства виз: загранпаспорт от 6 месяцев действия, фото 35×45 мм, анкета, подтверждение брони отеля и обратного билета, банковская справка из расчёта $50–100 на день. Для шенгена дополнительно — медстраховка от €30 000, справка с работы, выписка по счёту за 3 месяца.',
  },
  {
    q: 'Сколько действует виза и можно ли продлить?',
    a: 'eVisa обычно 30–90 дней без права продления — нужно выехать и въехать заново (если разрешён повторный въезд). Обычная виза: туристическая 30–180 дней, бизнес/учёба 1–5 лет. Продление — через миграционную службу страны пребывания, $20–100 за 30–60 дней.',
  },
  {
    q: 'Можно ли по российскому загранпаспорту в США в 2026?',
    a: 'Технически да — США выдают визы B1/B2 россиянам, но только через консульства в третьих странах (Варшава, Стамбул, Алматы, Белград). Сроки ожидания — 6–12 месяцев. Стоимость $185 + сбор третьей страны. Альтернатива — Канада (CA$100, 2–3 месяца через Варшаву) или Мексика (180 дней безвиз) с дальнейшим планом.',
  },
  {
    q: 'Какие визы дают мультивизу на 5 лет?',
    a: 'США B1/B2 — стандартно 5 лет (multi-entry), реально 10. Канада eTA — 5 лет (но short-stay). Япония — до 3 лет при повторных поездках. Шенген — после 3 коротких виз можно претендовать на 1–5 лет. ОАЭ — 5-летняя multi-entry для регулярных туристов. Конкретные сроки зависят от истории поездок и страны выдачи.',
  },
  {
    q: 'Что с EES и ETIAS — Шенгенским системой 2026?',
    a: 'EES (Entry/Exit System) — биометрическая регистрация на границе Шенгена. Запущена в октябре 2025. Заменяет штампы в паспорте: при первом въезде снимают отпечатки пальцев и фото лица, хранятся 3 года. ETIAS (Travel Authorization) — не для россиян; для граждан безвизовых стран. Россияне продолжают оформлять обычную шенгенскую визу.',
  },
  {
    q: 'Стоит ли оформлять Кипр или Болгарию вместо Шенгена?',
    a: 'Кипр — не Шенген, оформляется онлайн pro-visa бесплатно за 1 день. 90 дней пребывания. Болгария и Румыния с марта 2024 в Шенгене только частично (только воздух/море, не сухопутно). По кипрской pro-visa нельзя въехать в страны Шенгена — это отдельная зона.',
  },
  {
    q: 'Нужна ли биометрия на визу в 2026?',
    a: 'Шенген — да, обязательно при подаче (отпечатки + фото). Действует 5 лет. Великобритания — да, в визовых центрах. США — да, на интервью. Япония — нет для туристической визы. eVisa (Индия, Шри-Ланка, Камбоджа, Кения, Мадагаскар) — биометрия не нужна, только онлайн-анкета и сканы паспорта.',
  },
  {
    q: 'Что делать если отказали в визе?',
    a: 'Шенген: подать апелляцию в течение 15–30 дней или переоформить через другую страну (Италия, Греция чаще одобряют). США: повторно подавать через 1 месяц с улучшенным комплектом. Япония: исправить ошибку и попробовать через того же туроператора. Учти: в анкете честно указывать прошлые отказы — скрывать = автоматический отказ.',
  },
];

// Популярные направления для конверсии — Aviasales deep-link
const POPULAR_DESTS = [
  { name: 'Турция',  iata: 'AYT', visa: 'без визы' },
  { name: 'Япония',  iata: 'TYO', visa: 'через турагентство' },
  { name: 'Грузия',  iata: 'TBS', visa: 'без визы' },
  { name: 'Китай',   iata: 'PEK', visa: 'без визы до 14.09.2026' },
];

// ISO 3166-1 alpha-3 для маленького кода под названием страны (визовый стиль)
const ISO_CODE = {
  'australia-east': 'AUS', 'australia-north': 'AUS', 'bali': 'IDN', 'sumatra-kalimantan': 'IDN', 'raja-ampat': 'IDN',
  'new-zealand': 'NZL', 'kenya': 'KEN', 'south-africa': 'ZAF', 'uae': 'ARE', 'turkey': 'TUR', 'egypt': 'EGY',
  'morocco': 'MAR', 'tanzania': 'TZA', 'madagascar': 'MDG', 'mauritius': 'MUS', 'seychelles': 'SYC',
  'iran': 'IRN', 'jordan': 'JOR', 'israel': 'ISR', 'japan': 'JPN', 'japan-hokkaido': 'JPN', 'south-korea': 'KOR',
  'thailand': 'THA', 'vietnam': 'VNM', 'india-goa': 'IND', 'sri-lanka': 'LKA', 'maldives': 'MDV',
  'georgia': 'GEO', 'armenia': 'ARM', 'kyrgyzstan': 'KGZ', 'uzbekistan': 'UZB', 'tajikistan': 'TJK',
  'kazakhstan': 'KAZ', 'abkhazia': 'ABH', 'china': 'CHN', 'hainan': 'CHN', 'hong-kong': 'HKG',
  'malaysia': 'MYS', 'philippines': 'PHL', 'cambodia': 'KHM', 'singapore': 'SGP', 'nepal': 'NPL',
  'switzerland': 'CHE', 'italy-north': 'ITA', 'italy-south': 'ITA', 'spain': 'ESP', 'greece': 'GRC',
  'croatia': 'HRV', 'serbia': 'SRB', 'finland': 'FIN', 'cyprus': 'CYP',
  'canada-rockies': 'CAN', 'canada-east': 'CAN', 'usa': 'USA',
  'mexico': 'MEX', 'cuba': 'CUB', 'dominican-republic': 'DOM', 'guatemala-belize': 'GTM', 'costa-rica-panama': 'CRI',
  'chile-patagonia': 'CHL', 'chile-fjords': 'CHL', 'peru': 'PER', 'bolivia': 'BOL', 'chile': 'CHL',
  'argentina': 'ARG', 'ecuador': 'ECU', 'brazil': 'BRA', 'antarctica': 'ATA', 'iceland': 'ISL', 'norway': 'NOR',
};

const VISA_TYPE_LABEL = { free: 'Без визы', evisa: 'eVisa', required: 'Виза обязательна' };
const VERIFIED_AT = '2026-05-14'; // дата последней массовой сверки реестра
const VERIFIED_AT_PRETTY = '14 мая 2026';

// Helper-функции для filter-buckets — выполняются в frontmatter (regex здесь работает)
function costBucket(cost) {
  const lower = cost.toLowerCase();
  if (lower.indexOf('беспл') >= 0) return 'free';
  const digits = cost.replace(/[^\d]/g, ' ').trim().split(/\s+/)[0] || '0';
  const num = parseInt(digits, 10) || 0;
  return num > 0 && num <= 50 ? 'cheap' : 'premium';
}
function costUsd(cost) {
  const lower = cost.toLowerCase();
  if (lower.indexOf('беспл') >= 0) return 0;
  const num = parseInt(cost.replace(/[^\d]/g, ' ').trim().split(/\s+/)[0] || '0', 10) || 0;
  if (cost.indexOf('\u20ac') >= 0) return Math.round(num * 1.08);   // EUR -> USD
  if (cost.indexOf('\u20bd') >= 0 || /руб/i.test(cost)) return Math.round(num / 90); // RUB -> USD
  return num; // $ или без символа -> USD
}
function isLongDuration(dur) {
  const lower = dur.toLowerCase();
  if (lower.indexOf('год') >= 0 || lower.indexOf('без срока') >= 0) return true;
  const digits = dur.replace(/[^\d]/g, ' ').trim().split(/\s+/)[0] || '0';
  const num = parseInt(digits, 10) || 0;
  return num >= 60;
}
const url = 'https://traveltribe.ru/visa/';
const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#page`,
      "url": url,
      "name": "Визы для россиян 2026 — все направления TravelTribe",
      "description": `Визовый реестр 2026: ${DIRECTIONS.length} направлений. ${byVisa.free.length} без визы · ${byVisa.evisa.length} eVisa · ${byVisa.required.length} требуют визу. Документы, цены, сроки.`,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "mainEntity": { "@id": `${url}#itemlist` },
      "dateModified": `${VERIFIED_AT}T12:00:00+03:00`,
      "datePublished": "2025-09-15T00:00:00+03:00",
      "author": { "@type": "Person", "name": "Никита Зайцев", "url": "https://traveltribe.ru/about/" },
      "publisher": { "@type": "Organization", "name": "TravelTribe", "url": "https://traveltribe.ru/" },
    },
    {
      "@type": "ItemList",
      "@id": `${url}#itemlist`,
      "name": `Визовый реестр TravelTribe 2026 — ${DIRECTIONS.length} направлений`,
      "numberOfItems": DIRECTIONS.length,
      "itemListElement": DIRECTIONS.map((d, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": ["TouristDestination", "Place"],
          "@id": `https://traveltribe.ru/visa/${d.slug}/#destination`,
          "name": d.cases.nom,
          "url": `https://traveltribe.ru/visa/${d.slug}/`,
          "description": `Виза в ${d.cases.acc} для россиян 2026: ${VISA_TYPE_LABEL[d.visa]}.`,
          "touristType": VISA_TYPE_LABEL[d.visa],
        },
      })),
    },
    {
      "@type": "FAQPage",
      "mainEntity": FAQ_ITEMS.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Визы", "item": url },
      ]
    }
  ]
};
---
<Layout
  title="Визовый реестр 2026 — визы для россиян по 70+ направлениям"
  description={`Визы для россиян в 2026: ${byVisa.free.length} стран без визы, ${byVisa.evisa.length} с eVisa онлайн, ${byVisa.required.length} требуют визу. Стоимость, сроки оформления, нужные документы и куда подавать — по 70+ направлениям мира.`}
  canonical={url}
  ogTitle="Визовый реестр 2026 · TravelTribe"
  ogDescription={`${byVisa.free.length} без визы · ${byVisa.evisa.length} eVisa · ${byVisa.required.length} требуют визу`}
  ldJson={ldJson}
>
  <Breadcrumbs crumbs={[{ label: 'Визы' }]} />

  <main id="main" class="visa-archive">

    {/* ─── ДЕКОРАТИВНЫЙ ШТАМП В ФОНЕ ─── */}
    <div class="va-stamp-bg" aria-hidden="true">
      <svg viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <path id="vaStampCircle" d="M 160, 160 m -120, 0 a 120,120 0 1,1 240,0 a 120,120 0 1,1 -240,0" />
        </defs>
        <circle cx="160" cy="160" r="138" fill="none" stroke="currentColor" stroke-width="2.5" />
        <circle cx="160" cy="160" r="120" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3 4" />
        <text font-family="JetBrains Mono, monospace" font-size="13" letter-spacing="4" fill="currentColor">
          <textPath href="#vaStampCircle" startOffset="0%">TRAVELTRIBE · ВИЗОВЫЙ РЕЕСТР · 2026 · ПРОВЕРЕНО · </textPath>
        </text>
        <text x="160" y="148" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="14" letter-spacing="2" fill="currentColor">14·05·2026</text>
        <line x1="100" y1="160" x2="220" y2="160" stroke="currentColor" stroke-width="1.5" />
        <text x="160" y="184" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="3" fill="currentColor">RU · 070</text>
      </svg>
    </div>

    {/* ─── DOCUMENT HEADER ─── */}
    <header class="va-doc-head" data-reveal>
      <div class="va-meta-line">
        <span>РЕГ. № 070—2026</span>
        <span class="va-meta-dot">·</span>
        <span>TT-VISA-RU</span>
        <span class="va-meta-dot">·</span>
        <span>Версия 14.05.2026</span>
      </div>

      <div class="va-classification">FILED UNDER · ВИЗОВЫЕ РЕЖИМЫ</div>

      <h1 class="va-title">
        <span class="va-title-line">Визовый</span>
        <span class="va-title-line va-title-line--italic">реестр</span>
        <span class="va-title-line va-title-line--small">для гражданина РФ</span>
      </h1>

      <p class="va-subtitle">
        Сводка по {DIRECTIONS.length} направлениям. Что нужно для въезда, сколько стоит, сколько ждать.
      </p>

      <div class="va-cta-row">
        <a class="va-cta va-cta--primary" href="https://t.me/traveltriberu?utm_source=traveltribe&utm_medium=visa-hero" target="_blank" rel="noopener">
          <span class="va-cta-label">Telegram-канал</span>
          <span class="va-cta-arrow" aria-hidden="true">→</span>
        </a>
        <a class="va-cta va-cta--secondary" href="https://aviasales.tpk.mx/JCSPlC17?erid=2Vtzqxkn4LF&u=https%3A%2F%2Fwww.aviasales.ru%2F%3Fsub_id%3Dvisa_index" target="_blank" rel="nofollow noopener sponsored">
          <span class="va-cta-label">Найти билеты</span>
          <span class="va-cta-meta">Aviasales</span>
        </a>
        <a class="va-cta va-cta--secondary" href="https://cherehapa.tpk.mx/GmVWjhCN?erid=2VtzquZTwb5&u=https%3A%2F%2Fcherehapa.ru%2Ftravel%2F%3Fsub_id%3Dvisa_index" target="_blank" rel="nofollow noopener sponsored">
          <span class="va-cta-label">Оформить страховку</span>
          <span class="va-cta-meta">для визы и въезда</span>
        </a>
        <button type="button" class="va-cta va-cta--share" id="visaShareBtn" aria-label="Поделиться реестром">
          <span class="va-cta-label">Поделиться</span>
          <span class="va-cta-arrow" aria-hidden="true">↗</span>
        </button>
      </div>

      <p class="va-verified-banner" aria-label="Дата последней проверки реестра">
        <span class="va-verified-dot" aria-hidden="true"></span>
        Реестр проверен <strong>{VERIFIED_AT_PRETTY}</strong>. Перед поездкой сверьте через МИД РФ.
      </p>

      <div class="va-divider" aria-hidden="true">
        <span class="va-divider-line"></span>
        <span class="va-divider-glyph">✦</span>
        <span class="va-divider-line"></span>
      </div>
    </header>

    {/* ─── STATS PANEL — три «карточки реестра» ─── */}
    <section class="va-stats" aria-label="Сводка по визовым режимам" data-reveal>
      <div class="va-stat va-stat--free">
        <div class="va-stat-mark" aria-hidden="true">БВ</div>
        <div class="va-stat-num">{byVisa.free.length}</div>
        <div class="va-stat-label">без визы</div>
        <div class="va-stat-note">визу не оформлять</div>
      </div>
      <div class="va-stat va-stat--evisa">
        <div class="va-stat-mark" aria-hidden="true">EV</div>
        <div class="va-stat-num">{byVisa.evisa.length}</div>
        <div class="va-stat-label">eVisa</div>
        <div class="va-stat-note">онлайн, 1–3 дня</div>
      </div>
      <div class="va-stat va-stat--required">
        <div class="va-stat-mark" aria-hidden="true">ВЗ</div>
        <div class="va-stat-num">{byVisa.required.length}</div>
        <div class="va-stat-label">виза обязательна</div>
        <div class="va-stat-note">консульство · до 30 дней</div>
      </div>
    </section>

    {/* ─── HUB INTRO — вступительная статья ─── */}
    <section class="va-intro" data-reveal>
      <div class="va-intro-meta">
        <span class="va-intro-tag">ОБЗОР · ВИЗОВАЯ ОБСТАНОВКА · МАЙ 2026</span>
      </div>
      <h2 class="va-intro-title">Куда летать россиянам в 2026 — главное</h2>

      <div class="va-intro-body">
        <p class="va-intro-lede">
          С 2022 года визовая карта мира перерисовывается каждые 3–6 месяцев. Здесь — актуальный реестр на май 2026: <strong>{byVisa.free.length} стран принимают по загранпаспорту, {byVisa.evisa.length} дают eVisa онлайн, {byVisa.required.length} требуют полноценную визу</strong>. Реестр обновляется при изменении правил, последняя сверка — 14 мая 2026.
        </p>

        <p>
          <strong>Тренд 2026 — азиатские открытия.</strong> Китай с 14 сентября 2025 пустил россиян без визы на 30 дней (продлено до 14.09.2026, после ожидается переход в постоянный режим). Это первый раз с 1999 года, когда Китай открывал безвиз для России. Гонконг как специальный административный район даёт 14 дней без визы. Хайнань — 30 дней по общему китайскому режиму. Таиланд с 2024 даёт 60 дней вместо классических 30 — это позволяет полноценный wintering без visa-run в соседний Лаос.
        </p>

        <p>
          <strong>Шенген — медленный и дорогой.</strong> Стоимость подачи поднялась до €90 (с €80) с июня 2024. Сроки рассмотрения в Польше, Прибалтике, Скандинавии — 30–60 дней при процентном отказе 12–25%. Лучше работают Италия, Греция, Испания, Венгрия — там процент отказов ниже, выдают мультивизы на 6+ месяцев активным путешественникам. С октября 2025 действует EES (Entry/Exit System) — биометрическая регистрация на границе вместо штампов; первое прохождение занимает 5–10 минут.
        </p>

        <p>
          <strong>США и Канада — длинные сроки через третьи страны.</strong> Консульства США в России не работают с 2022. Россияне подают B1/B2 в Варшаве, Стамбуле, Алматы, Белграде — ожидание интервью 6–12 месяцев, стоимость $185 + сборы третьих стран. Канада дешевле (CA$100) и быстрее (2–3 месяца через Варшаву), но требует доказать связи с РФ и регулярные туристические поездки. Альтернатива для тех, кто хочет в Северную Америку быстро, — Мексика (180 дней безвиз) с возможностью наземного въезда в США/Канаду через границу.
        </p>

        <p>
          <strong>Что брать с собой — базовый комплект.</strong> Для всех виз — загранпаспорт от 6 месяцев действия с двумя пустыми страницами, фото 35×45 мм цветное, обратные билеты, бронь отеля (не возвратная букирование можно бесплатно — Booking, Agoda), банковская справка $50–100/день поездки. Для шенгена и Японии добавляется медстраховка от €30 000, справка с работы на бланке, выписка по счёту за 3 месяца. Для США и Канады — выписки за 6 месяцев, налоговая декларация, документы о собственности.
        </p>

        <p>
          <strong>Как читать этот реестр.</strong> Каждая карточка ниже показывает три факта: <em>срок пребывания</em> · <em>стоимость</em> · <em>срок оформления</em>. Эти данные — для туристической визы, не для бизнес/учёба/работа. На карточку с галочкой <span class="va-intro-check">✓</span> я был лично — могу подтвердить процесс. Все цены — на май 2026 в местной валюте оригинала.
        </p>
