---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import { DIRECTIONS } from '../../data/directions.js';

const destPhotos = import.meta.glob('../../assets/destinations/*.jpg', { eager: true, import: 'default' });

const byVisa = { free: [], evisa: [], required: [] };
for (const d of DIRECTIONS) byVisa[d.visa].push(d);

const VISA_META = {
  free: {
    title: 'Без визы',
    code: 'БВ',
    iso: 'VISA-FREE',
    desc: 'Загранпаспорт от 6 месяцев. Штамп на границе. Никаких документов и оплат заранее.',
    section: 'I',
  },
  evisa: {
    title: 'Электронная виза',
    code: 'EV',
    iso: 'eVISA',
    desc: 'Оформляется онлайн до вылета через сайт миграционной службы. $20–80 · 1–3 дня.',
    section: 'II',
  },
  required: {
    title: 'Виза обязательна',
    code: 'ВЗ',
    iso: 'CONSULAR',
    desc: 'Через консульство или визовый центр. Биометрия, документы, $35–200+ · до 30 дней.',
    section: 'III',
  },
};

// ISO 3166-1 alpha-3 для маленького кода под названием страны (визовый стиль)
const ISO_CODE = {
  'australia-east': 'AUS', 'australia-north': 'AUS', 'bali': 'IDN', 'sumatra-kalimantan': 'IDN', 'raja-ampat': 'IDN',
  'new-zealand': 'NZL', 'kenya': 'KEN', 'south-africa': 'ZAF', 'uae': 'ARE', 'turkey': 'TUR', 'egypt': 'EGY',
  'morocco': 'MAR', 'tanzania': 'TZA', 'madagascar': 'MDG', 'mauritius': 'MUS', 'seychelles': 'SYC',
  'iran': 'IRN', 'jordan': 'JOR', 'israel': 'ISR', 'japan': 'JPN', 'japan-hokkaido': 'JPN', 'south-korea': 'KOR',
  'thailand': 'THA', 'vietnam': 'VNM', 'india-goa': 'IND', 'sri-lanka': 'LKA', 'maldives': 'MDV',
  'georgia': 'GEO', 'armenia': 'ARM', 'kyrgyzstan': 'KGZ', 'uzbekistan': 'UZB', 'tajikistan': 'TJK',
  'kazakhstan': 'KAZ', 'abkhazia': 'ABH', 'china': 'CHN', 'hainan': 'CHN', 'hong-kong': 'HKG',
  'malaysia': 'MYS', 'philippines': 'PHL', 'cambodia': 'KHM', 'singapore': 'SGP', 'nepal': 'NPL',
  'switzerland': 'CHE', 'italy-north': 'ITA', 'italy-south': 'ITA', 'spain': 'ESP', 'greece': 'GRC',
  'croatia': 'HRV', 'serbia': 'SRB', 'finland': 'FIN', 'cyprus': 'CYP',
  'canada-rockies': 'CAN', 'canada-east': 'CAN', 'usa': 'USA',
  'mexico': 'MEX', 'cuba': 'CUB', 'dominican-republic': 'DOM', 'guatemala-belize': 'GTM', 'costa-rica-panama': 'CRI',
  'chile-patagonia': 'CHL', 'chile-fjords': 'CHL', 'peru': 'PER', 'bolivia': 'BOL', 'chile': 'CHL',
  'argentina': 'ARG', 'ecuador': 'ECU', 'brazil': 'BRA', 'antarctica': 'ATA', 'iceland': 'ISL', 'norway': 'NOR',
};

const url = 'https://traveltribe.ru/visa/';
const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#page`,
      "url": url,
      "name": "Визы для россиян 2026 — все направления TravelTribe",
      "description": `Визовый реестр 2026: ${DIRECTIONS.length} направлений. ${byVisa.free.length} без визы · ${byVisa.evisa.length} eVisa · ${byVisa.required.length} требуют визу. Документы, цены, сроки.`,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Визы", "item": url },
      ]
    }
  ]
};
---
<Layout
  title="Визовый реестр 2026 — визы для россиян по 70 направлениям"
  description={`Визовый реестр 2026: ${byVisa.free.length} без визы · ${byVisa.evisa.length} eVisa · ${byVisa.required.length} требуют визу. Документы, цены, сроки.`}
  canonical={url}
  ogTitle="Визовый реестр 2026 · TravelTribe"
  ogDescription={`${byVisa.free.length} без визы · ${byVisa.evisa.length} eVisa · ${byVisa.required.length} требуют визу`}
  ldJson={ldJson}
>
  <Nav active="blog" />
  <Breadcrumbs crumbs={[{ label: 'Визы' }]} />

  <main id="main" class="visa-archive">

    {/* ─── ДЕКОРАТИВНЫЙ ШТАМП В ФОНЕ ─── */}
    <div class="va-stamp-bg" aria-hidden="true">
      <svg viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <path id="vaStampCircle" d="M 160, 160 m -120, 0 a 120,120 0 1,1 240,0 a 120,120 0 1,1 -240,0" />
        </defs>
        <circle cx="160" cy="160" r="138" fill="none" stroke="currentColor" stroke-width="2.5" />
        <circle cx="160" cy="160" r="120" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3 4" />
        <text font-family="PT Mono, monospace" font-size="13" letter-spacing="4" fill="currentColor">
          <textPath href="#vaStampCircle" startOffset="0%">TRAVELTRIBE · ВИЗОВЫЙ РЕЕСТР · 2026 · ПРОВЕРЕНО · </textPath>
        </text>
        <text x="160" y="148" text-anchor="middle" font-family="PT Mono, monospace" font-size="14" letter-spacing="2" fill="currentColor">14·05·2026</text>
        <line x1="100" y1="160" x2="220" y2="160" stroke="currentColor" stroke-width="1.5" />
        <text x="160" y="184" text-anchor="middle" font-family="PT Mono, monospace" font-size="11" letter-spacing="3" fill="currentColor">RU · 070</text>
      </svg>
    </div>

    {/* ─── DOCUMENT HEADER ─── */}
    <header class="va-doc-head">
      <div class="va-meta-line">
        <span>РЕГ. № 070—2026</span>
        <span class="va-meta-dot">·</span>
        <span>TT-VISA-RU</span>
        <span class="va-meta-dot">·</span>
        <span>Версия 14.05.2026</span>
      </div>

      <div class="va-classification">FILED UNDER · ВИЗОВЫЕ РЕЖИМЫ</div>

      <h1 class="va-title">
        <span class="va-title-line">Визовый</span>
        <span class="va-title-line va-title-line--italic">реестр</span>
        <span class="va-title-line va-title-line--small">для гражданина РФ</span>
      </h1>

      <p class="va-subtitle">
        Сводка по {DIRECTIONS.length} направлениям. Что нужно для въезда, сколько стоит, сколько ждать.
      </p>

      <div class="va-divider" aria-hidden="true">
        <span class="va-divider-line"></span>
        <span class="va-divider-glyph">✦</span>
        <span class="va-divider-line"></span>
      </div>
    </header>

    {/* ─── STATS PANEL — три «карточки реестра» ─── */}
    <section class="va-stats" aria-label="Сводка по визовым режимам">
      <div class="va-stat va-stat--free">
        <div class="va-stat-mark" aria-hidden="true">БВ</div>
        <div class="va-stat-num">{byVisa.free.length}</div>
        <div class="va-stat-label">без визы</div>
        <div class="va-stat-note">визу не оформлять</div>
      </div>
      <div class="va-stat va-stat--evisa">
        <div class="va-stat-mark" aria-hidden="true">EV</div>
        <div class="va-stat-num">{byVisa.evisa.length}</div>
        <div class="va-stat-label">eVisa</div>
        <div class="va-stat-note">онлайн, 1–3 дня</div>
      </div>
      <div class="va-stat va-stat--required">
        <div class="va-stat-mark" aria-hidden="true">ВЗ</div>
        <div class="va-stat-num">{byVisa.required.length}</div>
        <div class="va-stat-label">виза обязательна</div>
        <div class="va-stat-note">консульство · до 30 дней</div>
      </div>
    </section>

    {/* ─── SEARCH — filing tray style ─── */}
    <section class="va-search-wrap" aria-label="Поиск страны">
      <label class="va-search-label" for="visaSearch">
        <span class="va-search-prefix">Запрос →</span>
      </label>
      <div class="va-search-field">
        <input type="search" id="visaSearch" placeholder="Япония, Турция, Грузия…" autocomplete="off" aria-label="Поиск страны" />
        <button type="button" class="va-search-clear" id="visaSearchClear" aria-label="Очистить" hidden>×</button>
      </div>
      <p class="va-empty" id="visaEmpty" hidden>В реестре не значится. Попробуй другое название.</p>
    </section>

    {/* ─── CLASSIFIED SECTIONS — три картотеки ─── */}
    {['free', 'evisa', 'required'].map((vt) => (
      <section class={`va-section va-section--${vt}`} data-section={vt}>
        <header class="va-section-head">
          <div class="va-section-stamp" aria-hidden="true">
            <span class="vss-roman">{VISA_META[vt].section}</span>
            <span class="vss-code">{VISA_META[vt].code}</span>
            <span class="vss-count">{byVisa[vt].length}</span>
          </div>
          <div class="va-section-meta">
            <div class="va-section-iso">{VISA_META[vt].iso}</div>
            <h2 class="va-section-title">{VISA_META[vt].title}</h2>
            <p class="va-section-desc">{VISA_META[vt].desc}</p>
          </div>
        </header>

        <div class="va-grid">
          {byVisa[vt].map((d, idx) => {
            const photo = destPhotos[`../../assets/destinations/${d.slug}.jpg`];
            const iso = ISO_CODE[d.slug] || 'XXX';
            const num = String(idx + 1).padStart(3, '0');
            return (
              <a href={`/visa/${d.slug}/`} class="va-card" data-name={d.cases.nom.toLowerCase()}>
                <div class="va-card-num">№ {num}</div>
                <div class="va-card-photo">
                  {photo ? (
                    <Image src={photo} alt={d.cases.nom} widths={[280, 560]} sizes="(max-width: 700px) 50vw, 25vw" formats={['webp']} quality={70} loading="lazy" />
                  ) : (
                    <div class="va-card-fallback" style={`background: linear-gradient(135deg, ${d.visual.g1}, ${d.visual.g2})`}>
                      <span class="va-card-emoji" aria-hidden="true">{d.visual.emoji}</span>
                    </div>
                  )}
                  <div class="va-card-stamp" aria-hidden="true">{VISA_META[vt].code}</div>
                </div>
                <div class="va-card-body">
                  <h3 class="va-card-name">{d.cases.nom}</h3>
                  <div class="va-card-iso">{iso}</div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    {/* ─── FOOTER NOTE ─── */}
    <footer class="va-foot">
      <div class="va-divider" aria-hidden="true">
        <span class="va-divider-line"></span>
        <span class="va-divider-glyph">✦</span>
        <span class="va-divider-line"></span>
      </div>
      <p class="va-foot-text">
        Реестр актуален на <strong>14 мая 2026</strong>. Обновляется при изменении правил въезда раз в 4–6 недель.
      </p>
      <p class="va-foot-sig">Составитель — <a href="/about/">Никита Зайцев</a>, TravelTribe</p>
    </footer>
  </main>

  <Footer />
</Layout>

<script>
  function initVisaSearch() {
    const cards = document.querySelectorAll('.va-card');
    const sections = document.querySelectorAll('.va-section');
    const search = document.getElementById('visaSearch') as HTMLInputElement | null;
    const clearBtn = document.getElementById('visaSearchClear');
    const emptyState = document.getElementById('visaEmpty');
    if (!cards.length || !search) return;

    function apply() {
      const q = search!.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const name = (card as HTMLElement).dataset.name || '';
        const show = !q || name.includes(q);
        (card as HTMLElement).hidden = !show;
        if (show) visible++;
      });
      sections.forEach((g) => {
        const any = Array.from(g.querySelectorAll('.va-card')).some((c) => !(c as HTMLElement).hidden);
        (g as HTMLElement).hidden = !any;
      });
      if (emptyState) (emptyState as HTMLElement).hidden = visible > 0;
      if (clearBtn) (clearBtn as HTMLElement).hidden = q.length === 0;
    }

    search.addEventListener('input', apply);
    if (clearBtn) clearBtn.addEventListener('click', () => { search.value = ''; apply(); search.focus(); });
  }

  initVisaSearch();
  document.addEventListener('astro:page-load', initVisaSearch);
</script>

<style>
  /* ═══════════════════════════════════════════════════════════════
     VISA ARCHIVE — Documentary / Passport Office aesthetic
     Type pairing: Fraunces (serif display) + PT Mono (state-document mono)
     Palette: paper cream + ink + visa-stamp red + customs blue
     ═══════════════════════════════════════════════════════════════ */

  .visa-archive {
    --paper: #f4ede0;
    --paper-dark: #ebe1cf;
    --ink: #1a1612;
    --ink-soft: #3e352a;
    --sepia: #7a6855;
    --stamp-red: #a3372a;
    --stamp-red-soft: rgba(163, 55, 42, 0.12);
    --customs-blue: #1e3a64;
    --customs-blue-soft: rgba(30, 58, 100, 0.12);
    --line-doc: rgba(26, 22, 18, 0.18);
    --line-doc-faint: rgba(26, 22, 18, 0.08);
    --ff-mono: 'PT Mono', 'Courier New', monospace;

    position: relative;
    max-width: 1240px;
    margin: 0 auto;
    padding: 2rem clamp(1rem, 4vw, 3rem) 4rem;
    background: var(--paper);
    color: var(--ink);
    overflow: hidden;
  }

  /* Paper grain texture overlay */
  .visa-archive::before {
    content: "";
    position: absolute; inset: 0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(122, 104, 85, 0.04) 1px, transparent 1.5px),
      radial-gradient(circle at 80% 70%, rgba(122, 104, 85, 0.05) 1px, transparent 1.5px),
      radial-gradient(circle at 50% 50%, rgba(122, 104, 85, 0.03) 1px, transparent 1.5px);
    background-size: 4px 4px, 6px 6px, 8px 8px;
    pointer-events: none;
    mix-blend-mode: multiply;
    opacity: 0.85;
    z-index: 0;
  }
  /* Subtle paper edge */
  .visa-archive::after {
    content: "";
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(122, 104, 85, 0.06), transparent 8%, transparent 92%, rgba(122, 104, 85, 0.06));
    pointer-events: none;
    z-index: 0;
  }
  .visa-archive > * { position: relative; z-index: 1; }

  /* Decorative giant stamp behind hero */
  .va-stamp-bg {
    position: absolute;
    top: 1rem; right: -3rem;
    width: clamp(220px, 30vw, 360px);
    height: clamp(220px, 30vw, 360px);
    color: var(--stamp-red);
    opacity: 0.07;
    transform: rotate(-9deg);
    pointer-events: none;
    z-index: 0;
  }
  .va-stamp-bg svg { width: 100%; height: 100%; }

  /* ──────────────── DOCUMENT HEADER ──────────────── */
  .va-doc-head {
    padding: 2rem 0 1rem;
    border-top: 2px solid var(--ink);
    border-bottom: 1px solid var(--line-doc);
    margin-bottom: 2.5rem;
  }
  .va-meta-line {
    font-family: var(--ff-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    margin-bottom: 1.4rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .va-meta-dot { color: var(--sepia); opacity: 0.6; }

  .va-classification {
    font-family: var(--ff-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--stamp-red);
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: inline-block;
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--stamp-red);
    background: var(--stamp-red-soft);
  }

  .va-title {
    font-family: 'Fraunces', 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2.8rem, 7vw, 5.2rem);
    line-height: 0.95;
    margin: 0 0 1.2rem;
    color: var(--ink);
    font-weight: 500;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144, "SOFT" 50;
  }
  .va-title-line { display: block; }
  .va-title-line--italic {
    font-style: italic;
    color: var(--stamp-red);
    font-variation-settings: "opsz" 144, "SOFT" 60;
  }
  .va-title-line--small {
    font-family: var(--ff-mono);
    font-size: 0.82rem;
    font-style: normal;
    color: var(--sepia);
    margin-top: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .va-subtitle {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1rem, 1.4vw, 1.18rem);
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 540px;
    margin: 0 0 1.6rem;
    font-style: italic;
    font-variation-settings: "opsz" 14;
  }

  .va-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 1.4rem 0 0;
  }
  .va-divider-line {
    flex: 1;
    height: 1px;
    background: var(--line-doc);
  }
  .va-divider-glyph {
    color: var(--stamp-red);
    font-size: 0.9rem;
    opacity: 0.8;
  }

  /* ──────────────── STATS — три карточки реестра ──────────────── */
  .va-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin-bottom: 3rem;
    border: 1px solid var(--ink);
    background: var(--ink);
  }
  .va-stat {
    background: var(--paper);
    padding: 1.6rem 1.4rem 1.4rem;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .va-stat-mark {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    font-family: var(--ff-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.55rem;
    border: 1.5px solid currentColor;
    border-radius: 50%;
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    transform: rotate(-6deg);
  }
  .va-stat--free .va-stat-mark { color: var(--customs-blue); }
  .va-stat--evisa .va-stat-mark { color: var(--sepia); }
  .va-stat--required .va-stat-mark { color: var(--stamp-red); }

  .va-stat-num {
    font-family: 'Fraunces', serif;
    font-size: clamp(3rem, 6vw, 4.4rem);
    line-height: 1;
    font-weight: 500;
    color: var(--ink);
    font-variation-settings: "opsz" 144;
    margin-top: 0.6rem;
  }
  .va-stat-label {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--ink-soft);
    margin-top: 0.2rem;
    font-variation-settings: "opsz" 18, "SOFT" 70;
  }
  .va-stat-note {
    font-family: var(--ff-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    color: var(--sepia);
    margin-top: 0.55rem;
    text-transform: uppercase;
  }

  /* ──────────────── SEARCH — filing tray ──────────────── */
  .va-search-wrap {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 3rem;
    padding: 0.8rem 1rem;
    background: var(--paper-dark);
    border: 1px solid var(--line-doc);
    flex-wrap: wrap;
  }
  .va-search-label {
    flex: 0 0 auto;
  }
  .va-search-prefix {
    font-family: var(--ff-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--stamp-red);
    text-transform: uppercase;
  }
  .va-search-field {
    flex: 1;
    min-width: 200px;
    display: flex;
    align-items: center;
    position: relative;
  }
  .va-search-field input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px dashed var(--line-doc);
    color: var(--ink);
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.05rem;
    padding: 0.4rem 1.6rem 0.4rem 0;
    outline: none;
    font-style: italic;
    font-variation-settings: "opsz" 16;
  }
  .va-search-field input::placeholder {
    color: var(--sepia);
    opacity: 0.6;
  }
  .va-search-field input:focus {
    border-bottom-color: var(--stamp-red);
  }
  .va-search-clear {
    position: absolute;
    right: 0;
    background: none;
    border: none;
    color: var(--sepia);
    cursor: pointer;
    font-size: 1.2rem;
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
  }
  .va-search-clear:hover { color: var(--stamp-red); background: var(--stamp-red-soft); }
  .va-empty {
    width: 100%;
    font-family: var(--ff-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--stamp-red);
    margin: 0.5rem 0 0;
  }

  /* ──────────────── CLASSIFIED SECTIONS ──────────────── */
  .va-section { margin-bottom: 3.5rem; }
  .va-section[hidden] { display: none; }

  .va-section-head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.4rem 1.6rem;
    align-items: start;
    padding-bottom: 1.3rem;
