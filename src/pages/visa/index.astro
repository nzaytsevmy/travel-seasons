---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import { DIRECTIONS } from '../../data/directions.js';

const destPhotos = import.meta.glob('../../assets/destinations/*.jpg', { eager: true, import: 'default' });

// Group by visa type for clearer scanning
const byVisa = { free: [], evisa: [], required: [] };
for (const d of DIRECTIONS) byVisa[d.visa].push(d);

const VISA_TITLE = {
  free: 'Без визы',
  evisa: 'Электронная виза (eVisa)',
  required: 'Виза обязательна',
};
const VISA_DESC = {
  free: 'Достаточно загранпаспорта со сроком 6+ месяцев. На границе ставят штамп.',
  evisa: 'Оформляется онлайн до вылета через сайт миграционной службы. $20–80, 1–3 дня.',
  required: 'Полноценная виза через консульство или визовый центр. Биометрия, документы, $35–200+.',
};

const url = 'https://traveltribe.ru/visa/';
const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#page`,
      "url": url,
      "name": "Визы для россиян 2026 — все направления TravelTribe",
      "description": `Визовая ситуация для россиян по ${DIRECTIONS.length} направлениям мира: безвиз, eVisa, обязательная виза. Документы, цены, сроки.`,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Визы", "item": url },
      ]
    }
  ]
};
---
<Layout
  title="Визы для россиян 2026 — все направления"
  description={`Визовая ситуация для россиян по ${DIRECTIONS.length} направлениям: безвиз, eVisa, обязательная виза. Документы и цены.`}
  canonical={url}
  ogTitle="Визы для россиян 2026"
  ogDescription={`${byVisa.free.length} безвиз · ${byVisa.evisa.length} eVisa · ${byVisa.required.length} требуют визу`}
  ldJson={ldJson}
>
  <Nav active="blog" />
  <Breadcrumbs crumbs={[{ label: 'Визы' }]} />

  <main id="main" class="visa-list-wrap">
    <header class="visa-list-header">
      <div class="section-eyebrow">// Визы для россиян</div>
      <h1>Где нужна <em>виза</em>, а где нет</h1>
      <p class="visa-list-tagline">{DIRECTIONS.length} направлений · обновляется при изменении правил</p>
      <div class="visa-list-stats">
        <div><strong>{byVisa.free.length}</strong><span>без визы</span></div>
        <div><strong>{byVisa.evisa.length}</strong><span>eVisa</span></div>
        <div><strong>{byVisa.required.length}</strong><span>требуют визу</span></div>
      </div>
      <div class="visa-search">
        <svg class="vs-icon" viewBox="0 0 20 20" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="9" r="6"></circle><line x1="14" y1="14" x2="18" y2="18"></line></svg>
        <input type="search" id="visaSearch" placeholder="Найти страну…" autocomplete="off" aria-label="Поиск страны" />
        <button type="button" class="vs-clear" id="visaSearchClear" aria-label="Очистить" hidden>×</button>
      </div>
      <p class="visa-empty" id="visaEmpty" hidden>Ничего не найдено. Попробуй другой запрос.</p>
    </header>

    {['free', 'evisa', 'required'].map((vt) => (
      <section class={`visa-group visa-group--${vt}`}>
        <h2><span class="vg-icon" aria-hidden="true">{vt === 'free' ? '✓' : vt === 'evisa' ? '◊' : '⚠'}</span>{VISA_TITLE[vt]}<span class="vg-count">{byVisa[vt].length}</span></h2>
        <p class="visa-group-desc">{VISA_DESC[vt]}</p>
        <div class="visa-list-grid">
          {byVisa[vt].map((d) => {
            const photo = destPhotos[`../../assets/destinations/${d.slug}.jpg`];
            return (
              <a href={`/visa/${d.slug}/`} class="visa-list-card" data-name={d.cases.nom.toLowerCase()}>
                <div class="vlc-media">
                  {photo ? (
                    <Image src={photo} alt={d.cases.nom} widths={[200, 400]} sizes="(max-width: 700px) 50vw, 25vw" formats={['avif', 'webp']} quality={68} loading="lazy" />
                  ) : (
                    <div class="vlc-fallback" style={`background: linear-gradient(135deg, ${d.visual.g1}, ${d.visual.g2})`}>
                      <span class="vlc-fallback-emoji" aria-hidden="true">{d.visual.emoji}</span>
                      <span class="vlc-fallback-pattern" aria-hidden="true"></span>
                    </div>
                  )}
                </div>
                <div class="vlc-name">{d.cases.nom}</div>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    <p class="visa-list-updated">Актуально на: 13 мая 2026 · обновляется каждые 4–6 недель</p>
  </main>

  <Footer />
</Layout>

<script>
  function initVisaSearch() {
    const cards = document.querySelectorAll('.visa-list-card');
    const groups = document.querySelectorAll('.visa-group');
    const search = document.getElementById('visaSearch') as HTMLInputElement | null;
    const clearBtn = document.getElementById('visaSearchClear');
    const emptyState = document.getElementById('visaEmpty');
    if (!cards.length || !search) return;

    function apply() {
      const q = search!.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const name = (card as HTMLElement).dataset.name || '';
        const show = !q || name.includes(q);
        (card as HTMLElement).hidden = !show;
        if (show) visible++;
      });
      groups.forEach((g) => {
        const any = Array.from(g.querySelectorAll('.visa-list-card')).some((c) => !(c as HTMLElement).hidden);
        (g as HTMLElement).hidden = !any;
      });
      if (emptyState) (emptyState as HTMLElement).hidden = visible > 0;
      if (clearBtn) (clearBtn as HTMLElement).hidden = q.length === 0;
    }

    search.addEventListener('input', apply);
    if (clearBtn) clearBtn.addEventListener('click', () => { search.value = ''; apply(); search.focus(); });
  }

  initVisaSearch();
  document.addEventListener('astro:page-load', initVisaSearch);
</script>

<style>
.visa-list-wrap { max-width: var(--container-wide, 1200px); margin: 0 auto; padding: 0 var(--container-edge, 2rem) var(--space-16, 4rem); }

.visa-list-header { text-align: center; margin: var(--space-10) 0 var(--space-12); }
.section-eyebrow { font-size: var(--text-xs); letter-spacing: var(--tracking-widest); text-transform: uppercase; color: var(--gold-600); margin-bottom: var(--space-3); }
.visa-list-header h1 {
  font-family: var(--ff-display);
  font-size: var(--text-6xl);
  font-weight: 700;
  line-height: var(--leading-tight);
  letter-spacing: var(--tracking-tight);
  margin: 0 auto;
}
.visa-list-header h1 em { color: var(--gold); font-style: italic; }
.visa-list-tagline {
  margin: var(--space-3) auto 0;
  color: var(--text-faint);
  font-size: var(--text-sm);
  letter-spacing: var(--tracking-wide);
}
.visa-list-stats {
  display: flex; justify-content: center; gap: var(--space-8);
  margin-top: var(--space-6);
  padding: var(--space-4) 0;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  max-width: 600px; margin-left: auto; margin-right: auto;
}
.visa-list-stats > div { display: flex; flex-direction: column; gap: 2px; align-items: center; }
.visa-list-stats strong {
  font-family: var(--ff-display);
  font-size: var(--text-3xl); font-weight: 700; color: var(--gold-600);
}
.visa-list-stats span {
  font-size: var(--text-xs); color: var(--text-faint);
  letter-spacing: var(--tracking-wide); text-transform: uppercase;
}

.visa-group { margin-bottom: var(--space-14); }
.visa-group h2 {
  display: flex; align-items: baseline; gap: var(--space-3);
  font-family: var(--ff-display);
  font-size: var(--text-3xl);
  font-weight: 700;
  margin: 0 0 var(--space-2);
  color: var(--text);
  letter-spacing: var(--tracking-tight);
}
.vg-icon {
  flex: 0 0 auto;
  display: inline-flex; align-items: center; justify-content: center;
  width: 2rem; height: 2rem;
  font-size: 1.1rem; font-weight: 700;
  border-radius: 50%;
  line-height: 1;
}
.vg-count {
  font-family: var(--ff-display);
  font-size: var(--text-base);
  font-weight: 500;
  background: rgba(201,151,58,0.1);
  color: var(--gold-600);
  padding: 0.25rem 0.65rem;
  border-radius: 999px;
  letter-spacing: 0;
  flex: 0 0 auto;
}
.visa-group--free h2 { color: var(--peak-text); }
.visa-group--free .vg-icon { background: rgba(34,197,94,0.15); color: var(--peak-text); }
.visa-group--evisa h2 { color: var(--good-text); }
.visa-group--evisa .vg-icon { background: rgba(74,158,255,0.15); color: var(--good-text); }
.visa-group--required h2 { color: var(--gold-700, var(--gold)); }
.visa-group--required .vg-icon { background: rgba(201,151,58,0.18); color: var(--gold); }
.visa-group-desc {
  color: var(--text-dim); font-size: var(--text-base);
  line-height: var(--leading-relaxed);
  margin: 0 0 var(--space-5);
  max-width: 600px;
}

.visa-list-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: var(--space-4);
}
.visa-list-card {
  display: flex; flex-direction: column;
  text-decoration: none; color: inherit;
  background: var(--bg2);
  border: 1px solid var(--line);
  border-radius: var(--radius-3, 10px);
  overflow: hidden;
  transition: transform var(--duration-base), border-color var(--duration-base), box-shadow var(--duration-base);
}
.visa-list-card:hover {
  transform: translateY(-4px);
  border-color: rgba(201,151,58,0.5);
  box-shadow: 0 18px 36px -18px rgba(0,0,0,0.45), 0 0 0 1px rgba(201,151,58,0.3);
}
.vlc-media { aspect-ratio: 4 / 3; overflow: hidden; position: relative; }
.vlc-media img, .vlc-media picture { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s var(--ease-out); }
.visa-list-card:hover .vlc-media img { transform: scale(1.05); }
.vlc-fallback {
  position: relative;
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.vlc-fallback-emoji {
  position: relative; z-index: 2;
  font-size: 3rem;
  filter: drop-shadow(0 4px 12px rgba(0,0,0,0.3));
  transition: transform 0.5s var(--ease-out);
}
.visa-list-card:hover .vlc-fallback-emoji { transform: scale(1.1) rotate(-3deg); }
.vlc-fallback-pattern {
  position: absolute; inset: 0;
  background-image:
    radial-gradient(circle at 25% 30%, rgba(255,255,255,0.12) 0%, transparent 25%),
    radial-gradient(circle at 75% 75%, rgba(255,255,255,0.08) 0%, transparent 30%);
  z-index: 1;
}
.vlc-name {
  padding: var(--space-3) var(--space-4);
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--text);
  line-height: var(--leading-snug);
  text-wrap: balance;
}
.visa-list-card:hover .vlc-name { color: var(--gold); transition: color var(--duration-fast); }

.visa-list-updated {
  margin-top: var(--space-10);
  font-size: var(--text-xs);
  color: var(--text-faint);
  text-align: center;
  letter-spacing: var(--tracking-wide);
  padding-top: var(--space-6);
  border-top: 1px solid var(--line);
}

/* ─── Search field для /visa/ ─── */
.visa-search {
  position: relative;
  max-width: 460px;
  margin: var(--space-5) auto 0;
}
.vs-icon {
  position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
  color: var(--text-faint);
  pointer-events: none;
}
.visa-search input {
  width: 100%;
  padding: 0.85rem 2.5rem 0.85rem 2.6rem;
  background: var(--bg2);
  border: 1px solid var(--line);
  border-radius: var(--radius-3, 10px);
  color: var(--text);
  font-size: var(--text-base);
  font-family: inherit;
  transition: border-color var(--duration-fast);
}
.visa-search input:focus { outline: none; border-color: rgba(201,151,58,0.5); }
.visa-search input::placeholder { color: var(--text-faint); }
.vs-clear {
  position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
  width: 28px; height: 28px;
  border: none; background: transparent;
  color: var(--text-faint);
  font-size: 1.5rem;
  cursor: pointer; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  line-height: 1;
}
.vs-clear:hover { background: var(--bg3); color: var(--text); }
.visa-empty {
  text-align: center;
  color: var(--text-dim);
  font-size: var(--text-base);
  margin: var(--space-8) auto;
  padding: var(--space-6);
  border: 1px dashed var(--line);
  border-radius: var(--radius-3, 10px);
  max-width: 460px;
}
.visa-group[hidden] { display: none; }
.visa-list-card[hidden] { display: none; }

@media (max-width: 600px) {
  .visa-list-grid { grid-template-columns: repeat(2, 1fr); }
  .visa-list-stats { gap: var(--space-5); }
}
</style>
