---
// Краткий hub для каждой страны: /<slug>/
// «Если коротко» — visa + сезоны + бюджет + связанные посты + FAQ.
//
// Pattern: /japan/ и /antarctica/ (вручную написанные хабы) служат
// эталоном. Этот файл генерирует аналогичные страницы для всех остальных
// направлений автоматически из DIRECTIONS data.
//
// URL conflicts: /japan/ и /antarctica/ — explicit static pages в Astro
// перебивают dynamic [slug]. Они исключены из getStaticPaths.

import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { Image, getImage } from 'astro:assets';
import { DIRECTIONS, MONTHS, VISITED } from '../data/directions.js';
import { PRICES } from '../data/prices.js';
import { getVisaDetails } from '../data/visa-details.js';
import { DATA_UPDATED, DATA_UPDATED_RU } from '../data/meta.js';
import AviasalesWidget from '../components/post/AviasalesWidget.astro';
import StickyCta from '../components/StickyCta.astro';
import BudgetBlock from '../components/BudgetBlock.astro';
import EssentialsCard from '../components/EssentialsCard.astro';
import MonthlyEvents from '../components/MonthlyEvents.astro';
import CountryMap from '../components/CountryMap.astro';
import { TP_LINKS, aviasalesRoute, tripsterDest } from '../data/affiliate.js';

// РФ-инвентарь жилья: на этих хабах вместо Островка — Яндекс Путешествия (сильнее по РФ).
const RU_STAY = new Set(['abkhazia', 'kamchatka', 'karelia', 'dagestan', 'altai']);
// Направления, где самостоятельные ездят за рулём — аренда авто как отдельный блок.
const CAR_RENTAL = new Set(['georgia', 'armenia', 'abkhazia', 'karelia', 'dagestan', 'altai', 'new-zealand', 'uae', 'bali']);
// Пакетный интент (чартер+отель): рядом с авторскими турами — сравнение пакетных.
const PACKAGE_TOUR = new Set(['turkey', 'egypt', 'uae', 'thailand', 'vietnam', 'hainan', 'cuba', 'dominican-republic', 'maldives']);
import { similarDestinations } from '../data/similar.js';
import { COMPARE_PAIRS } from '../data/compare-pairs.js';
import TripSaveButton from '../components/TripSaveButton.astro';
import { getGuide } from '../data/country-guides.js';
import { buildEssentialsFaq } from '../data/essentials-faq.js';
import { hasEssentials } from '../data/country-essentials.js';
import { hasCustoms } from '../data/country-customs.js';
import { hasHolidays } from '../data/country-holidays.js';
import { hasPois } from '../data/country-pois.js';

// Pre-import all destination photos (Vite needs static imports). glob lazy:
const destPhotos = import.meta.glob('../assets/destinations/*.jpg', {
  eager: true,
  import: 'default',
});
// Inline-фото гайда (Я.Диск, «был лично») — отдельная папка от обложек.
const inlinePhotos = import.meta.glob('../assets/destinations/inline/*.jpg', {
  eager: true,
  import: 'default',
});

export async function getStaticPaths() {
  // Reserved slugs — те что уже есть как кастомные pages.
  const reserved = new Set([
    'japan', 'antarctica',
    'blog', 'about', 'calculator', 'seasons', 'cards', 'trips', 'visa',
    '404', 'rss.xml', 'sitemap-images.xml', 'dzen-rss.xml',
  ]);
  return DIRECTIONS
    .filter(d => !reserved.has(d.slug))
    .map(d => ({ params: { slug: d.slug }, props: { d } }));
}

const { d } = Astro.props;
const yr = new Date().getFullYear();
// «Похожие направления» — превращает чтение одной страны в сессию из нескольких
// (глубина/dwell/last-click = ПФ + показы партнёрских CTA). Матч по визе/бюджету/вайбу/сезону.
const similar = similarDestinations(d.slug, 3);
const url = `https://traveltribe.ru/${d.slug}/`;

// Готовый разбор пары для /compare/ — только если курировано в compare-pairs.js
// (не создаём выдуманную ссылку на несуществующую страницу).
const comparePairDef = COMPARE_PAIRS.find((p) => p.a === d.slug || p.b === d.slug);
const compareOtherSlug = comparePairDef && (comparePairDef.a === d.slug ? comparePairDef.b : comparePairDef.a);
const compareOther = compareOtherSlug && DIRECTIONS.find((x) => x.slug === compareOtherSlug);
const compareUrl = comparePairDef ? `/compare/${comparePairDef.a}-vs-${comparePairDef.b}/` : `/compare/?a=${d.slug}`;

// Resolve cover photo if downloaded
const coverPath = `../assets/destinations/${d.slug}.jpg`;
const coverImage = destPhotos[coverPath];

// Hero LCP: ширины + responsive-preload (imagesrcset совпадает с <Image>, иначе
// браузер скачает не тот вариант). 768w добавлен под мобайл (раньше тянул 1024w).
const HERO_WIDTHS = [512, 768, 1024, 1600];
const heroPreload = coverImage
  ? await getImage({ src: coverImage, widths: HERO_WIDTHS, formats: ['webp'], quality: 72 })
  : null;

// Расширенный гайд (если заполнен в country-guides.js) — иначе базовый хаб
const guide = getGuide(d.slug);

// Inline-фото гайда, привязанные к секции (поле after). Возвращает
// разрешённый ассет + подпись для вставки сразу после нужного блока.
const photosAfter = (key) =>
  (guide?.photos || [])
    .filter((p) => p.after === key)
    .map((p) => ({ ...p, img: inlinePhotos[`../assets/destinations/inline/${p.file}.jpg`] }))
    .filter((p) => p.img);

const VISA_LABEL = { free: 'Без визы', evisa: 'eVisa', required: 'Виза обязательна' };
const BUDGET_LABEL = {
  low: '$ — до $80/день',
  mid: '$$ — $80–250/день',
  high: '$$$ — от $250/день',
};
const VISA_SUMMARY = {
  free: `${d.cases.nom} даёт россиянам безвизовый въезд (обычно 30–90 дней по загранпаспорту).`,
  evisa: `Для въезда ${d.cases.vP} россиянам нужна eVisa — оформляется онлайн до вылета, без посольства.`,
  required: `Для поездки ${d.cases.vP} нужна полноценная виза. Оформляется через визовый центр или посольство.`,
};
// Реальные верифицированные визовые специфики на страну (visa-details.js)
const vd = getVisaDetails(d.slug, d.visa);
// Никита был здесь лично? (E-E-A-T-сигнал в шапке; список — VISITED в directions.js)
const visited = VISITED.has(d.slug);
// Постраничная атрибуция кликов в кабинете TP (только латиница/цифры/_).
const subId = 'hub_' + d.slug.replaceAll('-', '_');

// Best months for this destination
const rank = { P: 4, G: 3, O: 2, B: 1, X: 0 };
const monthsRanked = MONTHS
  .map((m, i) => ({ ...m, status: d.r[i], text: d.t[i], rank: rank[d.r[i]] || 0 }));
const bestMonths = monthsRanked.filter(m => m.rank >= 3).slice(0, 3);
const worstMonths = monthsRanked.filter(m => m.rank <= 1).slice(0, 2);

const flightFrom = d.price?.flight?.[0];
const hotelFrom = d.price?.hotel?.[0];
const foodFrom = d.price?.food?.[0];
const weekTotal = flightFrom ? flightFrom + (hotelFrom || 0) * 7 + (foodFrom || 0) * 7 : null;
// Индекс в PRICES для глубокой ссылки на калькулятор с преселекцией страны
const priceIdx = d.price ? PRICES.findIndex(p => p.iata === d.price.iata && p.name === d.price.name) : -1;
const calcUrl = priceIdx >= 0 ? `/calculator/?r=${priceIdx}` : '/calculator/';

// FAQ generated from data
const faqs = [
  {
    q: `Нужна ли виза ${d.cases.vP} для россиян в ${yr}?`,
    a: `${vd.summary ?? VISA_SUMMARY[d.visa]} Срок пребывания: ${vd.duration}; стоимость: ${vd.cost}; оформление: ${vd.timing}.`,
  },
  {
    q: `Сколько стоит поездка ${d.cases.vP} в ${yr}?`,
    a: weekTotal
      ? `Эконом-вариант на 7 дней — от $${weekTotal} на человека (перелёт из Москвы $${flightFrom}, проживание от $${hotelFrom}/ночь, питание от $${foodFrom}/день). Бюджет на день: ${BUDGET_LABEL[d.budget]}.`
      : `Бюджет на день: ${BUDGET_LABEL[d.budget]}. Перелёт зависит от сезона и пересадок.`,
  },
  {
    q: `Когда лучше ехать ${d.cases.vP}?`,
    a: bestMonths.length
      ? `Оптимальные месяцы: ${bestMonths.map(m => m.nom).join(', ')}. ${bestMonths[0]?.text || ''}`
      : `${d.cases.nom} имеет переменчивые сезоны — смотри помесячный календарь ниже.`,
  },
];
// Доп. вопросы из расширенного гайда — и в видимый FAQ, и в schema (AEO)
if (guide?.faq?.length) faqs.push(...guide.faq);

// FAQ из бытовой практики (розетки/чаевые/экстренные/вода/такси/таможня) —
// renders только если EssentialsCard/CustomsCard для slug заполнены.
const essVp = d.cases?.vP || `в ${d.cases?.loc || d.cases?.nom || ''}`;
if (hasEssentials(d.slug) || hasCustoms(d.slug)) {
  faqs.push(...buildEssentialsFaq(d.slug, essVp));
}

// Изображения для schema (обложка + inline-фото) — ImageObject с финальными URL.
const SITE = 'https://traveltribe.ru';
const schemaImages = [];
if (coverImage) schemaImages.push(coverImage);
for (const p of (guide?.photos || [])) {
  const im = inlinePhotos[`../assets/destinations/inline/${p.file}.jpg`];
  if (im) schemaImages.push(im);
}
const imageNodes = schemaImages.map((im) => ({
  "@type": "ImageObject",
  "url": `${SITE}${im.src}`,
  "width": im.width,
  "height": im.height,
}));

// Анти-каннибализация: страна с глубоким блог-гайдом (kind:'guide') — голову
// запроса «{страна} для россиян» отдаём гайду, хаб уводим на регионы/сезоны,
// чтобы две страницы не делили один интент. Без гайда хаб остаётся головным.
const deepGuide = d.relatedPosts?.find((p) => p.kind === 'guide');
const hubTitle = deepGuide
  ? `${d.cases.nom} ${yr}: регионы, когда ехать и куда лететь`
  : `${d.cases.nom} ${yr} для россиян: когда ехать, цены, маршрут`;
const hubDesc = (deepGuide
  ? `${d.cases.nom}: регионы и куда лететь, когда ехать по месяцам${bestMonths.length ? ` — ${bestMonths.slice(0, 3).map((m) => m.nom).join(', ')}` : ''}, бюджет по сезонам. Полный гайд для россиян — отдельно.`
  : `${d.cases.nom} ${yr} для россиян: ${VISA_LABEL[d.visa].toLowerCase()} (${vd.duration}), когда ехать — ${bestMonths.map((m) => m.nom).join(', ')}, бюджет от $${weekTotal || 'N/A'}/нед.`).slice(0, 155);
const hubOgTitle = deepGuide
  ? `${d.cases.nom} ${yr} — регионы, сезоны, куда лететь`
  : `${d.cases.nom} ${yr} — когда ехать, цены, маршрут`;

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${url}#page`,
      "url": url,
      "name": hubTitle,
      "description": hubDesc,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "about": { "@type": "Country", "name": d.cases.nom },
      ...(imageNodes.length ? { "image": imageNodes, "primaryImageOfPage": imageNodes[0] } : {}),
      "datePublished": "2026-04-30",
      "dateModified": DATA_UPDATED,
      "author": { "@id": "https://traveltribe.ru/about/#person" },
      "publisher": { "@id": "https://traveltribe.ru/#org" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", ".sl-tldr"] },
      "mainEntity": { "@id": `${url}#faq` }
    },
    {
      "@type": "FAQPage",
      "@id": `${url}#faq`,
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Страны", "item": "https://traveltribe.ru/countries/" },
        { "@type": "ListItem", "position": 3, "name": d.cases.nom, "item": url },
      ]
    }
  ]
};
// Маршрут как ItemList (AEO: структурированные шаги гайда)
if (guide?.itinerary?.length) {
  ldJson["@graph"].push({
    "@type": "ItemList",
    "@id": `${url}#itinerary`,
    "name": `Маршрут — ${d.cases.nom}, 7–10 дней`,
    "itemListElement": guide.itinerary.map((s, i) => ({
      "@type": "ListItem", "position": i + 1, "name": s.t, "description": s.d,
    })),
  });
}
---
<Layout
  title={hubTitle}
  description={hubDesc}
  canonical={url}
  ogTitle={hubOgTitle}
  ogDescription={`${VISA_LABEL[d.visa]} · бюджет ${BUDGET_LABEL[d.budget].split('—')[0].trim()} · лучшие месяцы: ${bestMonths.slice(0,2).map(m => m.nom).join(', ')}`}
  ogType="article"
  ldJson={ldJson}
  preloadImageSrcset={heroPreload?.srcSet?.attribute}
  preloadImageSizes="100vw"
>
  <Breadcrumbs crumbs={[{ label: 'Страны', href: '/countries/' }, { label: d.cases.nom }]} />

  <main id="main" class="sl">
    {/* COVER PHOTO (если есть) — Swiss: фото как обложка с лёгким filter */}
    {coverImage && (
      <section class="sl-cover">
        <Image
          src={coverImage}
          alt={d.cases.nom}
          widths={HERO_WIDTHS}
          sizes="100vw"
          formats={['webp']}
          quality={72}
          loading="eager"
          fetchpriority="high"
        />
      </section>
    )}

    {/* MANIFEST — Swiss: 12-grid, idx/meta/H1/sub/vlist */}
    <section class="sl-manifest">
      <div class="sl-idx">01 / {d.group}<b>{d.cases.nom} {yr}</b></div>
      <div class="sl-meta">{d.region}<br /><b>Обновлено V.{yr}</b></div>
      <h1 class="sl-h1">{d.cases.nom} <span class="rd">{yr}</span></h1>
      <p class="sl-sub">{d.sub} — виза, сезоны, бюджет, маршруты для россиян. Без воды, с реальными цифрами.</p>
      {visited && <p class="sl-visited">Был здесь лично</p>}
      <TripSaveButton slug={d.slug} nom={d.cases.nom} />

      <div class="sl-vlist">
        <div class="sl-vi"><span><b>01</b> Виза</span><div>{VISA_LABEL[d.visa]}</div></div>
        <div class="sl-vi"><span><b>02</b> Бюджет</span><div>{BUDGET_LABEL[d.budget].split('—')[0].trim()}</div></div>
        {flightFrom ? (
          <div class="sl-vi"><span><b>03</b> Перелёт от</span><div>${flightFrom}</div></div>
        ) : (
          <div class="sl-vi"><span><b>03</b> Сроки визы</span><div>{vd.duration.split(/[,;(]/)[0].trim()}</div></div>
        )}
        <div class="sl-vi"><span><b>04</b> Лучше</span><div>{bestMonths[0] ? bestMonths[0].nom.charAt(0).toUpperCase() + bestMonths[0].nom.slice(1) : 'круглый год'}</div></div>
        {weekTotal ? (
          <div class="sl-vi"><span><b>05</b> Неделя от</span><div>${weekTotal}</div></div>
        ) : (
          <div class="sl-vi"><span><b>05</b> Стоимость визы</span><div>{vd.cost}</div></div>
        )}
        <div class="sl-vi"><span><b>06</b> Регион</span><div>{d.region}</div></div>
      </div>
    </section>

    {/* TLDR + BYLINE */}
    <section class="sl-section">
      <div class="sl-shead"><h2>Если коротко</h2></div>
      <p class="sl-tldr"><b>{(vd.summary ?? VISA_SUMMARY[d.visa]).replace(/\.$/, '')}.</b> Бюджет — <b>{BUDGET_LABEL[d.budget]}</b>. Лучшие месяцы: <b>{bestMonths.slice(0, 3).map(m => m.nom).join(', ') || '—'}</b>.{flightFrom && <> Перелёт из Москвы от <b>${flightFrom}</b>.</>} Подробности ниже + связанные посты с личным опытом.</p>
      <p class="sl-byline">
        <a href="/about/" class="byline-author">Никита Зайцев</a> ·
        <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> ·
        <span class="byline-fresh">данные актуальны на {DATA_UPDATED_RU}</span>
      </p>
    </section>

    {/* АНТИ-КАННИБАЛИЗАЦИЯ: голову запроса «{страна} для россиян» забирает
        глубокий гайд — хаб явно передаёт на него авторитет и юзера */}
    {deepGuide && (
      <section class="sl-section">
        <a href={`/blog/${deepGuide.slug}/`} class="sl-guidelink">
          <span class="sl-gl-k">Полный гайд по стране</span>
          <span class="sl-gl-t">{deepGuide.title} →</span>
        </a>
      </section>
    )}

    {/* QUICK ACTIONS — навигация по основным ресурсам страны */}
    <section class="sl-section">
      <div class="sl-shead"><h2>Главное о стране</h2></div>
      <div class="sl-actions">
        <a href={`/visa/${d.slug}/`} class="sl-action">
          <div class="sl-a-l">Виза</div>
          <div class="sl-a-v">{VISA_LABEL[d.visa]}</div>
          <div class="sl-a-s">Документы и сроки →</div>
        </a>
        <a href={calcUrl} class="sl-action">
          <div class="sl-a-l">Бюджет</div>
          <div class="sl-a-v">{BUDGET_LABEL[d.budget].split('—')[0].trim()}</div>
          <div class="sl-a-s">{weekTotal ? `от $${weekTotal} за неделю · ` : ''}Калькулятор →</div>
        </a>
        {bestMonths.length > 0 && (
          <a href={`/trips/${bestMonths[0].slug}/${d.slug}/`} class="sl-action">
            <div class="sl-a-l">Лучшие месяцы</div>
            <div class="sl-a-v">{bestMonths.slice(0, 3).map(m => m.nom.charAt(0).toUpperCase() + m.nom.slice(1)).join(' · ')}</div>
            {worstMonths.length > 0 && <div class="sl-a-s">Не лучшее: {worstMonths.map(m => m.nom).join(', ')}</div>}
          </a>
        )}
        {flightFrom && (
          <a href={d.price?.iata ? aviasalesRoute('MOW', d.price.iata) : '/calculator/'} class="sl-action" rel={d.price?.iata ? 'sponsored noopener' : undefined} target={d.price?.iata ? '_blank' : undefined}>
            <div class="sl-a-l">Перелёт от</div>
            <div class="sl-a-v">${flightFrom}</div>
            <div class="sl-a-s">{d.price?.iata ? 'Найти билет → ' : 'эконом, в одну сторону'}</div>
          </a>
        )}
      </div>
    </section>

    {/* РАСШИРЕННЫЙ ГАЙД — рендерится, если страна заполнена в country-guides.js */}
    {guide && (
      <>
        {guide.intro && (
          <section class="sl-section">
            <div class="sl-shead"><h2>Зачем ехать {d.cases.vP}</h2></div>
            <p class="sl-answer">{guide.intro}</p>
          </section>
        )}
        {guide.highlights?.length > 0 && (
          <section class="sl-section">
            <div class="sl-shead"><h2>Главные впечатления</h2></div>
            <ul class="sl-list">
              {guide.highlights.map((h) => <li><b>{h.t}</b> — {h.d}</li>)}
            </ul>
          </section>
        )}
        {photosAfter('highlights').map((p) => (
          <figure class="sl-figure">
            <Image src={p.img} alt={p.alt} widths={[640, 1024, 1520]} sizes="(max-width: 800px) 100vw, 760px" formats={['webp']} quality={72} loading="lazy" />
            <figcaption>{p.caption}</figcaption>
          </figure>
        ))}
        {guide.getThere && (
          <section class="sl-section">
            <div class="sl-shead"><h2>Как добраться {d.cases.vP}</h2></div>
            <p class="sl-answer">{guide.getThere}</p>
            {!guide.compare && !guide.noFlightCta && d.price?.iata && flightFrom && (
              <p class="sl-cta sl-cta--primary">
                <a href={aviasalesRoute('MOW', d.price.iata, subId)} class="aff-btn" rel="sponsored noopener" target="_blank">Сравнить билеты Москва — {d.cases.nom} от ${flightFrom} →</a>

                <span class="sl-trust">все авиакомпании в одной выдаче · оплата картами РФ</span>
              </p>
            )}
          </section>
        )}
        {guide.compare?.options?.length > 0 && (
          <section class="sl-section">
            <div class="sl-shead"><h2>{guide.compare.title}</h2></div>
            {guide.compare.intro && <p class="sl-answer">{guide.compare.intro}</p>}
            <div class="sl-comp">
              {guide.compare.options.map((o) => (
                <div class="sl-cc">
                  <div class="sl-cc-name">{o.name}</div>
                  {o.sub && <div class="sl-cc-sub">{o.sub}</div>}
                  <p class="sl-cc-for">{o.for}</p>
                  <a class="sl-aff sl-cc-cta" href={o.flightIata ? aviasalesRoute('MOW', o.flightIata, subId) : o.href} rel="sponsored noopener" target="_blank">{o.ctaLabel} →</a>
                </div>
              ))}
            </div>
            {guide.compare.note && <p class="sl-cc-mark"> — {guide.compare.note}</p>}
          </section>
        )}
        {CAR_RENTAL.has(d.slug) && (
          <section class="sl-section">
            <div class="sl-shead"><h2>Аренда авто</h2></div>
            <p class="sl-answer">Свои колёса {d.cases.loc} — это свобода маршрута: смотровые, пляжи и деревни, куда автобус не ходит.</p>
            <p class="sl-cta">
              <a href={TP_LINKS.economybookings} class="sl-aff" rel="sponsored noopener" target="_blank">Сравнить цены прокатов {d.cases.loc} →</a>

              <span class="sl-trust">один поиск по нескольким прокатным компаниям</span>
            </p>
          </section>
        )}
        {guide.stay?.length > 0 && (
          <section class="sl-section">
            <div class="sl-shead"><h2>Где остановиться</h2></div>
            <ul class="sl-list">
              {guide.stay.map((s) => <li><b>{s.t}</b> — {s.d}</li>)}
            </ul>
            <p class="sl-cta">
              {RU_STAY.has(d.slug) ? (
                <a href={TP_LINKS.yandexTravel} class="sl-aff" rel="sponsored noopener" target="_blank">Подобрать жильё {d.cases.loc} на Яндекс Путешествиях →</a>
              ) : (
                <a href={TP_LINKS.ostrovok} class="sl-aff" rel="sponsored noopener" target="_blank">Подобрать отель {d.cases.loc} на Островке →</a>
              )}

              <span class="sl-trust">оплата российскими картами · цены в ₽</span>
            </p>
          </section>
        )}
        {guide.itinerary?.length > 0 && (
          <section class="sl-section">
            <div class="sl-shead"><h2>Маршрут на 7–10 дней</h2></div>
            <ol class="sl-steps">
              {guide.itinerary.map((s, i) => (
                <li>
                  <span class="sl-step-n">{String(i + 1).padStart(2, '0')}</span>
                  <div class="sl-step-b"><b>{s.t}.</b> {s.d}</div>
                </li>
              ))}
            </ol>
          </section>
        )}
        {photosAfter('itinerary').map((p) => (
          <figure class="sl-figure">
            <Image src={p.img} alt={p.alt} widths={[640, 1024, 1520]} sizes="(max-width: 800px) 100vw, 760px" formats={['webp']} quality={72} loading="lazy" />
            <figcaption>{p.caption}</figcaption>
          </figure>
        ))}
        {guide.practical?.length > 0 && (
          <section class="sl-section">
            <div class="sl-shead"><h2>Деньги, связь и практика</h2></div>
            <ul class="sl-list">
              {guide.practical.map((s) => <li><b>{s.t}</b> — {s.d}</li>)}
            </ul>
            {guide.insuranceCta && (
              <p class="sl-cta">
                <a href={TP_LINKS.cherehapa} class="sl-aff" rel="sponsored noopener" target="_blank">Оформить страховку {d.cases.vP} →</a>
                
                <span class="sl-trust">{guide.insuranceNote || 'сравнение цен · оплата картами РФ'}</span>
              </p>
            )}
          </section>
        )}
        {guide.data?.length > 0 && (
          <section class="sl-section">
            <div class="sl-shead"><h2>{d.cases.nom} в цифрах — {yr}</h2></div>
            <table class="sl-dash">
              <tbody>
                {guide.data.map((row) => (
                  <tr><td>{row.k}</td><td class="r">{row.v}</td></tr>
                ))}
              </tbody>
            </table>
            {guide.dataNote && <p class="sl-dash-note">{guide.dataNote}</p>}
          </section>
        )}
        {guide.authorNote && <p class="sl-note">{guide.authorNote}</p>}
      </>
    )}

    {/* Карта (если есть POI) — после расширенного гайда, до календаря */}
    <CountryMap slug={d.slug} countryNom={d.cases.nom} />

    {/* MONTH CALENDAR — Swiss heat-grid 12 ячеек, цвет = ранг (без эмодзи по брендбуку) */}
    <section class="sl-section">
      <div class="sl-shead"><h2>{d.cases.nom} по месяцам — стоит ли ехать</h2></div>
      <div class="sl-heat">
        {monthsRanked.map((m) => {
          const cls = m.status === 'P' ? 'peak' : m.status === 'G' ? 'good' : m.status === 'O' ? 'off' : m.status === 'B' ? 'bad' : 'closed';
          return (
            <a href={`/trips/${m.slug}/${d.slug}/`} class={`sl-mh sl-mh--${cls}`} title={m.text || m.nom}>
              <span class="sl-mh-n">{m.nom.charAt(0).toUpperCase() + m.nom.slice(1, 3)}</span>
            </a>
          );
        })}
      </div>
      <div class="sl-heat-lg">
        <span><i class="sl-mh--peak"></i>пик</span>
        <span><i class="sl-mh--good"></i>хорошо</span>
        <span><i class="sl-mh--off"></i>нормально</span>
        <span><i class="sl-mh--bad"></i>не сезон</span>
        <span><i class="sl-mh--closed"></i>закрыто</span>
      </div>
    </section>

    {/* WHEN TO GO — читаемый помесячный разбор (реальные данные d.t) */}
    <section class="sl-section">
      <div class="sl-shead"><h2>Когда ехать {d.cases.vP} в {yr} — по месяцам</h2></div>
      <p class="sl-answer"><b>Коротко:</b> лучшие месяцы — {bestMonths.map(m => m.nom).join(', ') || '—'}{worstMonths.length ? `; хуже всего — ${worstMonths.map(m => m.nom).join(', ')}` : ''}. Ниже — погода, цены и сезон по каждому месяцу.</p>
      <ul class="sl-list">
        {monthsRanked.map((m) => (
          <li><b>{m.nom.charAt(0).toUpperCase() + m.nom.slice(1)}</b> — {m.text || '—'}</li>
        ))}
      </ul>
    </section>

    {/* События и праздники по месяцам — если данные заполнены */}
    <MonthlyEvents slug={d.slug} countryNom={d.cases.nom} countryNameVp={essVp} />

    {/* Бытовая практика */}
    <EssentialsCard slug={d.slug} countryName={d.cases.nom} />

    {/* PACKING CHECK-LIST */}
    <section class="sl-section">
      <div class="sl-shead"><h2>Что взять {d.cases.vP}</h2></div>
      <p class="sl-answer">Чек-лист по месяцам: одежда под погоду, документы, аптечка, техника, переходник. <a href={`/packing/${d.slug}/`} class="sl-link"><b>Открыть чек-лист {d.cases.gen || d.cases.prep || d.cases.nom} →</b></a></p>
    </section>

    {/* РФ-хабы без гид-секций: компакт-блок жильё/экскурсии/авто */}
    {RU_STAY.has(d.slug) && !guide?.stay?.length && (
      <section class="sl-section">
        <div class="sl-shead"><h2>Жильё и экскурсии</h2></div>
        <p class="sl-cta sl-cta--stack">
          <a href={TP_LINKS.yandexTravel} class="sl-aff" rel="sponsored noopener" target="_blank">Подобрать жильё {d.cases.loc} на Яндекс Путешествиях →</a>
          <a href={d.slug === 'abkhazia' ? tripsterDest('abkhazia') : TP_LINKS.tripster} class="sl-aff" rel="sponsored noopener" target="_blank">Экскурсии {d.cases.loc} с местными гидами →</a>
          {CAR_RENTAL.has(d.slug) && (
            <a href={TP_LINKS.economybookings} class="sl-aff" rel="sponsored noopener" target="_blank">Сравнить цены прокатов авто →</a>
          )}
          <span class="sl-trust">оплата российскими картами · цены и отзывы видно до оплаты</span>
        </p>
      </section>
    )}

    {/* RELATED POSTS */}
    {d.relatedPosts.length > 0 && (
      <section class="sl-section">
        <div class="sl-shead"><h2>Подробные гайды о {d.cases.prep}</h2></div>
        <ul class="sl-related">
          {d.relatedPosts.map((p) => (
            <li>
              <a href={`/blog/${p.slug}/`}>
                <b>{p.title}</b>
                <span>{p.kind === 'visa' ? 'про визу пошагово' : p.kind === 'season' ? 'про конкретный сезон' : 'личный опыт автора'}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* FAQ — Swiss-details без bg/радиуса */}
    <section class="sl-section">
      <div class="sl-shead"><h2>FAQ</h2></div>
      <div class="sl-faq">
        {faqs.map(f => (
          <details class="sl-faq-i">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <BudgetBlock slug={d.slug} />

    <AviasalesWidget title={`Найти билеты — ${d.cases.vP}`} subid={subId} />

    {/* Авторские туры (YouTravel) */}
    <section class="sl-section">
      <div class="sl-shead"><h2>Поехать с экспертом</h2></div>
      <p class={`sl-cta ${PACKAGE_TOUR.has(d.slug) ? 'sl-cta--stack' : ''}`}>
        <a href={TP_LINKS.youtravel} class="sl-aff" rel="sponsored noopener" target="_blank">Авторские туры {d.cases.vP} →</a>
        {PACKAGE_TOUR.has(d.slug) && (
          <a href={TP_LINKS.travelata} class="sl-aff" rel="sponsored noopener" target="_blank">Сравнить пакетные туры {d.cases.vP} →</a>
        )}
        <span class="sl-trust">маршрут, логистика и малая группа уже собраны</span>
      </p>
    </section>

    {/* RELATED LINKS */}
    {similar.length > 0 && (
      <section class="sl-section">
        <div class="sl-shead"><h2>Похожие направления</h2></div>
        <ul class="sl-related">
          {similar.map((r) => (
            <li><a href={`/${r.slug}/`}><b>{r.nom}</b></a> — {r.why}{r.goodNow ? ' · хорошо сейчас' : ''}</li>
          ))}
        </ul>
      </section>
    )}

    <section class="sl-section">
      <div class="sl-shead"><h2>Что почитать дальше</h2></div>
      <ul class="sl-related">
        <li><a href="/seasons/"><b>Сравнение всех 70+ направлений по сезонам</b></a></li>
        <li><a href={calcUrl}><b>Калькулятор бюджета поездки</b></a></li>
        <li><a href={`/trips/${MONTHS[new Date().getMonth()].slug}/${d.slug}/`}><b>{d.cases.nom} в {MONTHS[new Date().getMonth()].prep} {yr}</b></a></li>
        <li><a href={`/visa/${d.slug}/`}><b>Виза {d.cases.vP} — детально</b></a></li>
        <li><a href={compareUrl}><b>{compareOther ? `${d.cases.nom} или ${compareOther.cases.nom}` : `Сравнить ${d.cases.nom} с другим направлением`}</b></a></li>
        <li><a href="/countries/"><b>Все страны на сайте</b></a></li>
      </ul>
    </section>

    <p class="sl-updated">Актуально на: {DATA_UPDATED_RU} · обновляется каждые 4–6 недель</p>
  </main>

  {d.price?.iata && flightFrom ? (
    <StickyCta href={aviasalesRoute('MOW', d.price.iata, subId)} label={`Билеты ${d.cases.vP} от $${flightFrom} →`} />
  ) : RU_STAY.has(d.slug) && (
    <StickyCta href={TP_LINKS.yandexTravel} label={`Подобрать жильё ${d.cases.loc} →`} />
  )}

  <Footer />
</Layout>

<style>
.sl {
  --line-strong: #1b1914;
  --line-hair: var(--line);
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 clamp(1.1rem, 3vw, 2.6rem) clamp(2rem, 4vw, 4rem);
  font-family: var(--ff-display);
  font-variant-numeric: tabular-nums lining-nums;
  color: var(--text);
}

/* COVER PHOTO — Swiss: full-bleed, лёгкий фильтр, без overlay/scrunch */
.sl-cover {
  position: relative;
  margin: 0 calc(-1 * clamp(1.1rem, 3vw, 2.6rem)) clamp(1.6rem, 3vw, 2.4rem);
  aspect-ratio: 21 / 9;
  max-height: 460px;
  overflow: hidden;
}
.sl-cover :global(img),
.sl-cover :global(picture) {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  filter: grayscale(.06) contrast(1.02);
}

/* MANIFEST */
.sl-manifest {
  display: grid;
  grid-template-columns: repeat(12, minmax(0, 1fr));
  gap: 0 clamp(.8rem, 2vw, 1.6rem);
  padding: clamp(1rem, 2vw, 1.8rem) 0 clamp(1.2rem, 2.5vw, 2rem);
}
.sl-idx {
  grid-column: 1 / 5; grid-row: 1;
  font-size: .74rem; font-weight: 700;
  letter-spacing: .04em; text-transform: uppercase;
  color: var(--gold);
}
.sl-idx b {
  display: block; color: var(--text); font-size: .74rem;
  font-weight: 600; margin-top: .2rem;
}
.sl-meta {
  grid-column: 8 / 13; grid-row: 1;
  text-align: right; align-self: start;
  font-size: .8rem; color: var(--text-dim);
  line-height: 1.5;
}
.sl-meta b { color: var(--text); font-weight: 600; }
.sl-h1 {
  grid-column: 1 / 13; grid-row: 2;
  font-weight: 800;
  font-size: clamp(2.4rem, 7vw, 6.4rem);
  line-height: .94;
  letter-spacing: -.035em;
  margin: clamp(1.2rem, 2.5vw, 2rem) 0 0;
  text-wrap: balance;
}
.sl-h1 .rd { color: var(--gold); }
.sl-sub {
  grid-column: 1 / 9; grid-row: 3;
  font-size: clamp(1rem, 1.3vw, 1.18rem);
  color: var(--text);
  margin-top: 1.4rem;
  max-width: 56ch;
  line-height: 1.5;
}
.sl-visited {
  grid-column: 9 / 13; grid-row: 3;
  align-self: start; justify-self: end;
  margin-top: 1.4rem; height: max-content;
  font-size: .7rem; font-weight: 700;
  letter-spacing: .08em; text-transform: uppercase;
  color: var(--gold); border: 1px solid var(--gold);
  padding: .42rem .7rem; white-space: nowrap;
}

.sl-vlist {
  grid-column: 1 / 13; grid-row: 4;
  margin-top: 1.8rem;
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  border-top: 1px solid var(--line-strong);
  border-bottom: 1px solid var(--line-strong);
}
.sl-vi {
  padding: .85rem 1.2rem .95rem;
  border-right: 1px solid var(--line-hair);
}
.sl-vi:first-child { padding-left: 0; }
.sl-vi:last-child { border-right: none; }
.sl-vi span {
  display: block;
  font-size: .66rem; font-weight: 700;
  letter-spacing: .06em; text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: .35rem;
}
.sl-vi span b {
  color: var(--gold);
  margin-right: .35rem;
  font-weight: 700;
}
.sl-vi > div {
  font-weight: 800;
  font-size: .98rem;
  color: var(--text);
  line-height: 1.2;
  letter-spacing: -.005em;
}

@media (max-width: 760px) {
  .sl-idx, .sl-meta, .sl-h1, .sl-sub, .sl-vlist, .sl-visited {
    grid-column: 1 / -1; grid-row: auto;
  }
  .sl-meta { text-align: left; margin-top: .6rem; }
  .sl-visited { justify-self: start; margin-top: 1rem; }
  .sl-h1 { margin-top: 1.1rem; }
  .sl-vlist { grid-template-columns: repeat(2, 1fr); }
  .sl-vi:nth-child(2n) { border-right: none; }
  .sl-vi:nth-child(odd) { padding-left: 0; }
  .sl-vi:nth-child(n+3) { border-top: 1px solid var(--line-hair); }
}

/* SECTIONS */
.sl-section { margin-top: clamp(2.4rem, 5vw, 4rem); }
.sl-shead {
  border-top: 2px solid var(--line-strong);
  padding-top: .8rem;
  margin-bottom: 1.4rem;
}
.sl-shead h2 {
  font-weight: 800;
  font-size: clamp(1.4rem, 2.6vw, 2rem);
  letter-spacing: -.02em;
  line-height: 1.1;
  margin: 0;
  color: var(--text);
}

.sl-tldr {
  font-size: clamp(1rem, 1.3vw, 1.15rem);
  line-height: 1.55;
  color: var(--text);
  max-width: 76ch;
  padding: 0;
  margin: 0 0 1rem;
}
.sl-tldr b { color: var(--gold); font-weight: 800; }
.sl-answer {
  margin: 0 0 1rem;
  font-size: 1rem;
  line-height: 1.55;
  color: var(--text);
  max-width: 76ch;
}
.sl-answer b { color: var(--text); font-weight: 800; }
.sl-link { color: var(--gold); text-decoration: 1px underline var(--gold); text-underline-offset: 4px; font-weight: 700; }
.sl-byline { font-size: .76rem; color: var(--text-dim); margin: 0; letter-spacing: .01em; }
.sl-byline a { color: var(--text); text-decoration: 1px underline rgba(86,82,74,.4); text-underline-offset: 3px; }
.sl-byline a.byline-author { color: var(--gold); text-decoration: 1px underline var(--gold); }
.sl-guidelink {
  display: flex; flex-direction: column; gap: .15rem;
  padding: .8rem 1rem; min-height: 44px; justify-content: center;
  border-left: 3px solid var(--gold);
  background: color-mix(in srgb, var(--gold) 6%, transparent);
  text-decoration: none; color: var(--text);
}
.sl-guidelink:hover { background: color-mix(in srgb, var(--gold) 11%, transparent); }
.sl-gl-k { font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; color: var(--text-dim); }
.sl-gl-t { font-size: 1rem; font-weight: 700; color: var(--gold); }
.sl-byline .byline-fresh { color: var(--text-faint); }

/* QUICK ACTIONS — 4 hairline-card grid (visa/budget/months/flight) */
.sl-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid var(--line-strong);
  border-bottom: 1px solid var(--line-strong);
}
.sl-action {
  padding: 1rem 1.2rem 1.1rem;
  border-right: 1px solid var(--line-hair);
  text-decoration: none;
  color: var(--text);
  display: flex; flex-direction: column; gap: .25rem;
  min-height: 96px;
  transition: background .15s;
}
.sl-action:first-child { padding-left: 0; }
.sl-action:last-child { border-right: none; }
.sl-action:hover { background: rgba(142, 102, 24, 0.06); }
.sl-a-l { font-size: .66rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--text-dim); }
.sl-a-v { font-weight: 800; font-size: 1.05rem; letter-spacing: -.005em; color: var(--text); line-height: 1.2; }
.sl-a-s { margin-top: auto; padding-top: .4rem; font-size: .76rem; color: var(--gold); font-weight: 600; }

@media (max-width: 760px) {
  .sl-actions { grid-template-columns: repeat(2, 1fr); }
  .sl-action:nth-child(2n) { border-right: none; }
  .sl-action:nth-child(odd) { padding-left: 0; }
  .sl-action:nth-child(n+3) { border-top: 1px solid var(--line-hair); }
}

/* GUIDE LIST — hairline rows */
.sl-list {
  list-style: none; margin: 0; padding: 0;
  border-top: 1px solid var(--line-strong);
  border-bottom: 1px solid var(--line-strong);
}
.sl-list li {
  padding: .8rem 0 .85rem;
  border-top: 1px solid var(--line-hair);
  font-size: .96rem; line-height: 1.55;
  color: var(--text);
}
.sl-list li:first-child { border-top: none; }
.sl-list li b { color: var(--text); font-weight: 800; }

/* STEPS — numbered itinerary */
.sl-steps {
  list-style: none; margin: 0; padding: 0;
  border-top: 1px solid var(--line-strong);
  border-bottom: 1px solid var(--line-strong);
}
.sl-steps li {
  padding: .85rem 0;
  border-top: 1px solid var(--line-hair);
  display: grid;
  grid-template-columns: 2.6rem 1fr;
  gap: 0 .8rem;
}
.sl-steps li:first-child { border-top: none; }
.sl-step-n {
  font-family: var(--ff-display);
  font-size: .76rem; font-weight: 700; color: var(--gold);
  letter-spacing: .04em;
  padding-top: 2px;
}
.sl-step-b { font-size: .95rem; line-height: 1.55; color: var(--text); }
.sl-step-b b { color: var(--text); font-weight: 800; }

/* COMPARE */
.sl-comp {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  border-top: 1px solid var(--line-strong);
  border-bottom: 1px solid var(--line-strong);
}
.sl-cc {
  padding: 1rem 1.2rem 1.1rem;
  border-right: 1px solid var(--line-hair);
  display: flex; flex-direction: column;
}
.sl-cc:first-child { padding-left: 0; }
.sl-cc:last-child { border-right: none; }
.sl-cc-name { font-weight: 800; font-size: 1.05rem; letter-spacing: -.005em; color: var(--text); line-height: 1.2; }
.sl-cc-sub {
  margin-top: .2rem;
  font-size: .66rem; font-weight: 700;
  letter-spacing: .06em; text-transform: uppercase;
  color: var(--text-dim);
}
.sl-cc-for { flex: 1; margin: .5rem 0 .85rem; font-size: .88rem; line-height: 1.5; color: var(--text-dim); }
.sl-cc-cta { font-size: .82rem; }
.sl-cc-mark { margin: .7rem 0 0; font-size: .74rem; color: var(--text-faint); line-height: 1.5; }

/* DASH — данные «в цифрах» */
.sl-dash {
  width: 100%; border-collapse: collapse; font-size: .94rem;
  border-top: 1px solid var(--line-strong);
  border-bottom: 1px solid var(--line-strong);
}
.sl-dash td {
  padding: .7rem 0 .75rem;
  border-top: 1px solid var(--line-hair);
  vertical-align: baseline; color: var(--text); line-height: 1.5;
