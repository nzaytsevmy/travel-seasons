---
// Краткий hub для каждой страны: /<slug>/
// «Если коротко» — visa + сезоны + бюджет + связанные посты + FAQ.
//
// Pattern: /japan/ и /antarctica/ (вручную написанные хабы) служат
// эталоном. Этот файл генерирует аналогичные страницы для всех остальных
// направлений автоматически из DIRECTIONS data.
//
// URL conflicts: /japan/ и /antarctica/ — explicit static pages в Astro
// перебивают dynamic [slug]. Они исключены из getStaticPaths.

import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { Image, getImage } from 'astro:assets';
import { DIRECTIONS, MONTHS } from '../data/directions.js';
import { PRICES } from '../data/prices.js';
import { getVisaDetails } from '../data/visa-details.js';
import { DATA_UPDATED, DATA_UPDATED_RU } from '../data/meta.js';
import AviasalesWidget from '../components/post/AviasalesWidget.astro';
import BudgetBlock from '../components/BudgetBlock.astro';
import { TP_LINKS, aviasalesRoute } from '../data/affiliate.js';
import { getGuide } from '../data/country-guides.js';

// Pre-import all destination photos (Vite needs static imports). glob lazy:
const destPhotos = import.meta.glob('../assets/destinations/*.jpg', {
  eager: true,
  import: 'default',
});
// Inline-фото гайда (Я.Диск, «был лично») — отдельная папка от обложек.
const inlinePhotos = import.meta.glob('../assets/destinations/inline/*.jpg', {
  eager: true,
  import: 'default',
});

export async function getStaticPaths() {
  // Reserved slugs — те что уже есть как кастомные pages.
  const reserved = new Set([
    'japan', 'antarctica',
    'blog', 'about', 'calculator', 'seasons', 'cards', 'trips', 'visa',
    '404', 'rss.xml', 'sitemap-images.xml', 'dzen-rss.xml',
  ]);
  return DIRECTIONS
    .filter(d => !reserved.has(d.slug))
    .map(d => ({ params: { slug: d.slug }, props: { d } }));
}

const { d } = Astro.props;
const url = `https://traveltribe.ru/${d.slug}/`;

// Resolve cover photo if downloaded
const coverPath = `../assets/destinations/${d.slug}.jpg`;
const coverImage = destPhotos[coverPath];

// Hero LCP: ширины + responsive-preload (imagesrcset совпадает с <Image>, иначе
// браузер скачает не тот вариант). 768w добавлен под мобайл (раньше тянул 1024w).
const HERO_WIDTHS = [512, 768, 1024, 1600];
const heroPreload = coverImage
  ? await getImage({ src: coverImage, widths: HERO_WIDTHS, formats: ['webp'], quality: 72 })
  : null;

// Расширенный гайд (если заполнен в country-guides.js) — иначе базовый хаб
const guide = getGuide(d.slug);

// Inline-фото гайда, привязанные к секции (поле after). Возвращает
// разрешённый ассет + подпись для вставки сразу после нужного блока.
const photosAfter = (key) =>
  (guide?.photos || [])
    .filter((p) => p.after === key)
    .map((p) => ({ ...p, img: inlinePhotos[`../assets/destinations/inline/${p.file}.jpg`] }))
    .filter((p) => p.img);

const VISA_LABEL = { free: 'Без визы', evisa: 'eVisa', required: 'Виза обязательна' };
const BUDGET_LABEL = {
  low: '$ — до $80/день',
  mid: '$$ — $80–250/день',
  high: '$$$ — от $250/день',
};
const VISA_SUMMARY = {
  free: `${d.cases.nom} даёт россиянам безвизовый въезд (обычно 30–90 дней по загранпаспорту).`,
  evisa: `Для въезда ${d.cases.vP} россиянам нужна eVisa — оформляется онлайн до вылета, без посольства.`,
  required: `Для поездки ${d.cases.vP} нужна полноценная виза. Оформляется через визовый центр или посольство.`,
};
// Реальные верифицированные визовые специфики на страну (visa-details.js)
const vd = getVisaDetails(d.slug, d.visa);

// Best months for this destination
const rank = { P: 4, G: 3, O: 2, B: 1, X: 0 };
const monthsRanked = MONTHS
  .map((m, i) => ({ ...m, status: d.r[i], text: d.t[i], rank: rank[d.r[i]] || 0 }));
const bestMonths = monthsRanked.filter(m => m.rank >= 3).slice(0, 3);
const worstMonths = monthsRanked.filter(m => m.rank <= 1).slice(0, 2);

const flightFrom = d.price?.flight?.[0];
const hotelFrom = d.price?.hotel?.[0];
const foodFrom = d.price?.food?.[0];
const weekTotal = flightFrom ? flightFrom + (hotelFrom || 0) * 7 + (foodFrom || 0) * 7 : null;
// Индекс в PRICES для глубокой ссылки на калькулятор с преселекцией страны
const priceIdx = d.price ? PRICES.findIndex(p => p.iata === d.price.iata && p.name === d.price.name) : -1;
const calcUrl = priceIdx >= 0 ? `/calculator/?r=${priceIdx}` : '/calculator/';

// FAQ generated from data
const faqs = [
  {
    q: `Нужна ли виза ${d.cases.vP} для россиян в 2026?`,
    a: `${VISA_SUMMARY[d.visa]} Срок пребывания: ${vd.duration}; стоимость: ${vd.cost}; оформление: ${vd.timing}.`,
  },
  {
    q: `Сколько стоит поездка ${d.cases.vP} в 2026?`,
    a: weekTotal
      ? `Эконом-вариант на 7 дней — от $${weekTotal} на человека (перелёт из Москвы $${flightFrom}, проживание от $${hotelFrom}/ночь, питание от $${foodFrom}/день). Бюджет на день: ${BUDGET_LABEL[d.budget]}.`
      : `Бюджет на день: ${BUDGET_LABEL[d.budget]}. Перелёт зависит от сезона и пересадок.`,
  },
  {
    q: `Когда лучше ехать ${d.cases.vP}?`,
    a: bestMonths.length
      ? `Оптимальные месяцы: ${bestMonths.map(m => m.nom).join(', ')}. ${bestMonths[0]?.text || ''}`
      : `${d.cases.nom} имеет переменчивые сезоны — смотри помесячный календарь ниже.`,
  },
];
// Доп. вопросы из расширенного гайда — и в видимый FAQ, и в schema (AEO)
if (guide?.faq?.length) faqs.push(...guide.faq);

// Изображения для schema (обложка + inline-фото) — ImageObject с финальными URL.
const SITE = 'https://traveltribe.ru';
const schemaImages = [];
if (coverImage) schemaImages.push(coverImage);
for (const p of (guide?.photos || [])) {
  const im = inlinePhotos[`../assets/destinations/inline/${p.file}.jpg`];
  if (im) schemaImages.push(im);
}
const imageNodes = schemaImages.map((im) => ({
  "@type": "ImageObject",
  "url": `${SITE}${im.src}`,
  "width": im.width,
  "height": im.height,
}));

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${url}#page`,
      "url": url,
      "name": `${d.cases.nom} 2026 для россиян: виза, когда ехать, бюджет`,
      "description": `${d.cases.nom} 2026 для россиян: виза (${vd.duration}), когда ехать по месяцам, бюджет, проверенные данные.`,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "about": { "@type": "Country", "name": d.cases.nom },
      ...(imageNodes.length ? { "image": imageNodes, "primaryImageOfPage": imageNodes[0] } : {}),
      "datePublished": "2026-04-30",
      "dateModified": DATA_UPDATED,
      "author": {
        "@type": "Person",
        "@id": "https://traveltribe.ru/about/#person",
        "name": "Никита Зайцев",
        "url": "https://traveltribe.ru/about/",
        "jobTitle": "Travel writer",
        "knowsAbout": ["Путешествия", "Визы", "Travel-бюджет", "Сезоны"],
        "sameAs": ["https://t.me/traveltriberu", "https://www.linkedin.com/in/nzaytsev/", "https://github.com/nzaytsevmy"]
      },
      "publisher": { "@id": "https://traveltribe.ru/#org" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", ".quick-tldr"] },
      "mainEntity": { "@id": `${url}#faq` }
    },
    {
      "@type": "FAQPage",
      "@id": `${url}#faq`,
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Страны", "item": "https://traveltribe.ru/countries/" },
        { "@type": "ListItem", "position": 3, "name": d.cases.nom, "item": url },
      ]
    }
  ]
};
// Маршрут как ItemList (AEO: структурированные шаги гайда)
if (guide?.itinerary?.length) {
  ldJson["@graph"].push({
    "@type": "ItemList",
    "@id": `${url}#itinerary`,
    "name": `Маршрут — ${d.cases.nom}, 7–10 дней`,
    "itemListElement": guide.itinerary.map((s, i) => ({
      "@type": "ListItem", "position": i + 1, "name": s.t, "description": s.d,
    })),
  });
}
---
<Layout
  title={`${d.cases.nom} 2026 для россиян: виза, когда ехать, бюджет`}
  description={`${d.cases.nom} 2026 для россиян: ${VISA_LABEL[d.visa].toLowerCase()} (${vd.duration}), когда ехать — ${bestMonths.map(m => m.nom).join(', ')}, бюджет от $${weekTotal || 'N/A'}/нед.`.slice(0, 155)}
  canonical={url}
  ogTitle={`${d.cases.nom} 2026 — виза, когда ехать, бюджет`}
  ogDescription={`${VISA_LABEL[d.visa]} · бюджет ${BUDGET_LABEL[d.budget].split('—')[0].trim()} · лучшие месяцы: ${bestMonths.slice(0,2).map(m => m.nom).join(', ')}`}
  ogType="article"
  ldJson={ldJson}
  preloadImageSrcset={heroPreload?.srcSet?.attribute}
  preloadImageSizes="100vw"
>
  <Breadcrumbs crumbs={[{ label: 'Страны', href: '/countries/' }, { label: d.cases.nom }]} />

  <main id="main" class="quick-wrap">
    {/* HERO */}
    {coverImage ? (
      <section class="quick-hero quick-hero--photo">
        <Image
          src={coverImage}
          alt={d.cases.nom}
          widths={HERO_WIDTHS}
          sizes="100vw"
          formats={['webp']}
          quality={72}
          loading="eager"
          fetchpriority="high"
        />
        <div class="quick-hero-overlay"></div>
        <div class="quick-hero-content">
          <div class="quick-hero-eyebrow">// {d.group} · гид 2026</div>
          <h1 class="quick-hero-title">{d.cases.nom} <span class="quick-hero-year">2026</span></h1>
          <p class="quick-hero-sub">{d.region} — {d.sub}</p>
        </div>
      </section>
    ) : (
      <section class="quick-hero quick-hero--gradient" style={`--g1:${d.visual.g1}; --g2:${d.visual.g2};`}>
        <span class="quick-hero-emoji" aria-hidden="true">{d.visual.emoji}</span>
        <div class="quick-hero-content">
          <div class="quick-hero-eyebrow">// {d.group} · гид 2026</div>
          <h1 class="quick-hero-title">{d.cases.nom} <span class="quick-hero-year">2026</span></h1>
          <p class="quick-hero-sub">{d.region} — {d.sub}</p>
        </div>
      </section>
    )}

    {/* TLDR */}
    <section class="quick-tldr">
      <strong>Если коротко:</strong> {VISA_SUMMARY[d.visa]} Бюджет — <strong>{BUDGET_LABEL[d.budget]}</strong>. Лучшие месяцы: <strong>{bestMonths.slice(0, 3).map(m => m.nom).join(', ')}</strong>. {flightFrom && <>Перелёт из Москвы от <strong>${flightFrom}</strong>.</>} Подробности ниже + связанные посты с личным опытом.
    </section>
    <p class="quick-byline">
      <a href="/about/" class="byline-author">Никита Зайцев</a> ·
      <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> ·
      <span class="byline-fresh">данные актуальны на {DATA_UPDATED_RU}</span>
    </p>

    {/* QUICK FACTS grid */}
    <section class="quick-facts">
      <div class="qf-card">
        <div class="qf-label">Виза</div>
        <div class="qf-value qf-value--lg">{VISA_LABEL[d.visa]}</div>
        <a href={`/visa/${d.slug}/`} class="qf-link">Документы и сроки →</a>
      </div>
      <div class="qf-card">
        <div class="qf-label">Бюджет</div>
        <div class="qf-value qf-value--lg">{BUDGET_LABEL[d.budget].split('—')[0].trim()}</div>
        {weekTotal && <div class="qf-value-sub">от ${weekTotal} за неделю</div>}
        <a href={calcUrl} class="qf-link">Калькулятор поездки →</a>
      </div>
      <div class="qf-card">
        <div class="qf-label">Лучшие месяцы</div>
        <div class="qf-value">
          {bestMonths.slice(0, 3).map((m) => (
            <a href={`/trips/${m.slug}/${d.slug}/`} class="qf-month">{m.nom.charAt(0).toUpperCase() + m.nom.slice(1)}</a>
          ))}
        </div>
        {worstMonths.length > 0 && (
          <div class="qf-value-sub">Не лучшее время: {worstMonths.map(m => m.nom).join(', ')}</div>
        )}
      </div>
      {flightFrom && (
        <div class="qf-card">
          <div class="qf-label">Перелёт от</div>
          <div class="qf-value qf-value--lg">${flightFrom}</div>
          <div class="qf-value-sub">в одну сторону, эконом</div>
        </div>
      )}
    </section>

    {/* РАСШИРЕННЫЙ ГАЙД — рендерится, если страна заполнена в country-guides.js */}
    {guide && (
      <>
        {guide.intro && (
          <section class="quick-block">
            <h2>Зачем ехать {d.cases.vP}</h2>
            <p class="quick-answer">{guide.intro}</p>
          </section>
        )}
        {guide.highlights?.length > 0 && (
          <section class="quick-block">
            <h2>Главные впечатления</h2>
            <ul class="guide-list">
              {guide.highlights.map((h) => <li><strong>{h.t}</strong> — {h.d}</li>)}
            </ul>
          </section>
        )}
        {photosAfter('highlights').map((p) => (
          <figure class="guide-figure">
            <Image src={p.img} alt={p.alt} widths={[640, 1024, 1520]} sizes="(max-width: 800px) 100vw, 760px" formats={['webp']} quality={72} loading="lazy" />
            <figcaption>{p.caption}</figcaption>
          </figure>
        ))}
        {guide.getThere && (
          <section class="quick-block">
            <h2>Как добраться {d.cases.vP}</h2>
            <p class="quick-answer">{guide.getThere}</p>
            {!guide.compare && !guide.noFlightCta && d.price?.iata && flightFrom && (
              <p class="guide-cta">
                <a href={aviasalesRoute('MOW', d.price.iata)} class="aff-cta" rel="sponsored noopener" target="_blank">Сравнить билеты Москва — {d.cases.nom} от ${flightFrom}</a>
                <span class="ad-mark">реклама</span>
                <span class="guide-cta-trust">все авиакомпании в одной выдаче, оплата картами РФ</span>
              </p>
            )}
          </section>
        )}
        {guide.compare?.options?.length > 0 && (
          <section class="quick-block">
            <h2>{guide.compare.title}</h2>
            {guide.compare.intro && <p class="quick-answer">{guide.compare.intro}</p>}
            <div class="guide-compare">
              {guide.compare.options.map((o) => (
                <div class="gc-card">
                  <div class="gc-name">{o.name}</div>
                  {o.sub && <div class="gc-sub">{o.sub}</div>}
                  <p class="gc-for">{o.for}</p>
                  <a class="aff-cta gc-cta" href={o.flightIata ? aviasalesRoute('MOW', o.flightIata) : o.href} rel="sponsored noopener" target="_blank">{o.ctaLabel}</a>
                </div>
              ))}
            </div>
            {guide.compare.note && <p class="gc-mark"><span class="ad-mark">реклама</span> — {guide.compare.note}</p>}
          </section>
        )}
        {guide.stay?.length > 0 && (
          <section class="quick-block">
            <h2>Где остановиться</h2>
            <ul class="guide-list">
              {guide.stay.map((s) => <li><strong>{s.t}</strong> — {s.d}</li>)}
            </ul>
            <p class="guide-cta">
              <a href={TP_LINKS.ostrovok} class="aff-cta" rel="sponsored noopener" target="_blank">Подобрать отель {d.cases.loc} на Островке</a>
              <span class="ad-mark">реклама</span>
              <span class="guide-cta-trust">оплата российскими картами, цены в рублях</span>
            </p>
          </section>
        )}
        {guide.itinerary?.length > 0 && (
          <section class="quick-block">
            <h2>Маршрут на 7–10 дней</h2>
            <ul class="guide-list guide-list--steps">
              {guide.itinerary.map((s) => <li><strong>{s.t}.</strong> {s.d}</li>)}
            </ul>
          </section>
        )}
        {photosAfter('itinerary').map((p) => (
          <figure class="guide-figure">
            <Image src={p.img} alt={p.alt} widths={[640, 1024, 1520]} sizes="(max-width: 800px) 100vw, 760px" formats={['webp']} quality={72} loading="lazy" />
            <figcaption>{p.caption}</figcaption>
          </figure>
        ))}
        {guide.practical?.length > 0 && (
          <section class="quick-block">
            <h2>Деньги, связь и практика</h2>
            <ul class="guide-list">
              {guide.practical.map((s) => <li><strong>{s.t}</strong> — {s.d}</li>)}
            </ul>
            {guide.insuranceCta && (
              <p class="guide-cta">
                <a href={TP_LINKS.cherehapa} class="aff-cta" rel="sponsored noopener" target="_blank">Оформить страховку {d.cases.vP}</a>
                <span class="ad-mark">реклама</span>
                <span class="guide-cta-trust">{guide.insuranceNote || 'сравнение цен, оплата картами РФ'}</span>
              </p>
            )}
          </section>
        )}
        {guide.data?.length > 0 && (
          <section class="quick-block">
            <h2>{d.cases.nom} в цифрах — сколько стоит в 2026</h2>
            <table class="guide-data">
              <tbody>
                {guide.data.map((row) => (
                  <tr><th scope="row">{row.k}</th><td>{row.v}</td></tr>
                ))}
              </tbody>
            </table>
            {guide.dataNote && <p class="guide-data-note">{guide.dataNote}</p>}
          </section>
        )}
        {guide.authorNote && <p class="guide-note">{guide.authorNote}</p>}
      </>
    )}

    {/* MONTH CALENDAR — clickable */}
    <section class="quick-block">
      <h2>{d.cases.nom} по месяцам — стоит ли ехать</h2>
      <div class="quick-months">
        {monthsRanked.map((m) => {
          const cls = m.status === 'P' ? 'peak' : m.status === 'G' ? 'good' : m.status === 'O' ? 'off' : m.status === 'B' ? 'bad' : 'closed';
          const sym = m.status === 'P' ? '🔥' : m.status === 'G' ? '✅' : m.status === 'O' ? '🟡' : m.status === 'B' ? '⛔' : '❄️';
          return (
            <a href={`/trips/${m.slug}/${d.slug}/`} class={`qm qm--${cls}`}>
              <span class="qm-name">{m.nom.charAt(0).toUpperCase() + m.nom.slice(1)}</span>
              <span class="qm-status">{sym}</span>
            </a>
          );
        })}
      </div>
    </section>

    {/* WHEN TO GO — читаемый помесячный разбор (реальные данные d.t) */}
    <section class="quick-block">
      <h2>Когда ехать {d.cases.vP} в 2026 — по месяцам</h2>
      <p class="quick-answer"><strong>Коротко:</strong> лучшие месяцы — {bestMonths.map(m => m.nom).join(', ') || '—'}{worstMonths.length ? `; хуже всего — ${worstMonths.map(m => m.nom).join(', ')}` : ''}. Ниже — погода, цены и сезон по каждому месяцу.</p>
      <ul class="quick-monthtext">
        {monthsRanked.map((m) => (
          <li>
            <strong>{m.nom.charAt(0).toUpperCase() + m.nom.slice(1)}</strong>{' — '}{m.text || '—'}
          </li>
        ))}
      </ul>
    </section>

    {/* PACKING CHECK-LIST */}
    <section class="quick-block">
      <h2>Что взять {d.cases.vP}</h2>
      <p class="quick-answer">Чек-лист по месяцам: одежда под погоду, документы, аптечка, техника, переходник. <a href={`/packing/${d.slug}/`}><strong>Открыть чек-лист {d.cases.gen || d.cases.prep || d.cases.nom} →</strong></a></p>
    </section>

    {/* RELATED POSTS */}
    {d.relatedPosts.length > 0 && (
      <section class="quick-block">
        <h2>Подробные гайды {d.cases.loc}</h2>
        <ul class="quick-related">
          {d.relatedPosts.map((p) => (
            <li>
              <a href={`/blog/${p.slug}/`}>
                <strong>{p.title}</strong>
                <span>{p.kind === 'visa' ? 'про визу пошагово' : p.kind === 'season' ? 'про конкретный сезон' : 'личный опыт автора'}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* FAQ */}
    <section class="quick-block">
      <h2>FAQ</h2>
      <div class="faq-block">
        {faqs.map(f => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <div class="faq-a"><p>{f.a}</p></div>
          </details>
