---
// Главная — Swiss / International Typographic по BRANDBOOK.md (пилот миграции).
// Layout — только для <head>/SEO/schema/аналитики; визуал — самодостаточный Swiss,
// scoped, light-only (свои токены, не зависят от тёмной темы остального сайта).
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { DIRECTIONS } from '../data/directions.js';
import { TP_LINKS } from '../data/affiliate.js';
import { DATA_UPDATED_RU } from '../data/meta.js';
import authorPhoto from '../assets/author/nikita.jpg';

import { ACTIVITY_TAGS } from '../data/country-activity-tags.js';
const covers = import.meta.glob('../assets/destinations/*.jpg', { eager: true, import: 'default' });

const VISA_LABEL = { free: 'Безвиз', evisa: 'e-Visa', required: 'Виза' };
const VISA_CLASS = { free: 'free', evisa: 'evisa', required: 'visa' };
const VIBE_RU = { beach: 'Пляж', mountains: 'Горы', city: 'Город', nature: 'Природа' };
const VIBE_MAP = { beach:'beach', mountain:'mountains', altitude:'mountains', ski:'mountains', city:'city', culture:'city', food:'city', jungle:'nature', safari:'nature', dive:'nature', desert:'nature', photo:'nature' };
const MON_ABBR = ['', 'янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек'];
const fmt = (n) => n.toLocaleString('ru-RU');
const USD_RUB = 90, NIGHTS = 7; // курс ≈ЦБ; неделя на месте (как в /calculator/)
const roundK = (n) => Math.round(n / 1000) * 1000; // округление до тысячи — единое для таблицы и карточки
// Вся поездка в комфорте на одного: перелёт из Москвы + (отель+еда)×ночи. Источник — prices.js (USD).
const flightRub = (p) => roundK(p.flight[1] * USD_RUB);
const stayRub = (p) => roundK((p.hotel[1] + p.food[1]) * NIGHTS * USD_RUB);
const tripCost = (p) => flightRub(p) + stayRub(p);
const tier = (t) => (t < 100000 ? 'low' : t <= 200000 ? 'mid' : 'high'); // вся поездка с перелётом, ₽
function seasonLabel(r) {
  let idx = r.map((c, i) => (c === 'P' ? i + 1 : 0)).filter(Boolean);
  if (!idx.length) idx = r.map((c, i) => (c === 'G' ? i + 1 : 0)).filter(Boolean);
  if (!idx.length) return 'круглый год';
  const g = []; let s = idx[0], p = idx[0];
  for (let k = 1; k < idx.length; k++) { if (idx[k] === p + 1) p = idx[k]; else { g.push([s, p]); s = idx[k]; p = idx[k]; } }
  g.push([s, p]);
  return g.map(([a, b]) => (a === b ? MON_ABBR[a] : `${MON_ABBR[a]}–${MON_ABBR[b]}`)).join(', ');
}
// Все 70+ направлений на РЕАЛЬНЫХ данных: цена ВСЕЙ поездки с перелётом (prices.js, комфорт),
// виза (DIRECTIONS), месяцы (DIRECTIONS.r: P = пик), вайб (ACTIVITY_TAGS). Без выдумок.
const rows = DIRECTIONS.map((d) => {
  const budget = d.price?.flight ? tripCost(d.price) : null; // вся поездка с перелётом, ₽
  const cover = covers[`../assets/destinations/${d.slug}.jpg`];
  if (!budget || !d.r || !cover) return null;
  const vibe = [...new Set((ACTIVITY_TAGS[d.slug] || []).map((t) => VIBE_MAP[t]).filter(Boolean))];
  const vibeRu = vibe.length ? vibe.map((v) => VIBE_RU[v]).join(' · ') : (d.sub || '');
  // r — коды сезона по 12 месяцам: P пик / G хороший / O так себе / B плохо / X закрыто
  return { slug: d.slug, nom: d.cases.nom, visa: d.visa, budget, r: d.r, vibe, vibeRu, cover, season: seasonLabel(d.r) };
}).filter(Boolean); // порядок = релевантность (DIRECTIONS); сортировка по цене — переключателем на клиенте

const MONTHS_PREP = ['', 'январе','феврале','марте','апреле','мае','июне','июле','августе','сентябре','октябре','ноябре','декабре'];
const month = new Date().getMonth() + 1;
const monthWord = MONTHS_PREP[month];
const inSeason = (codes, mo) => codes[mo - 1] === 'P' || codes[mo - 1] === 'G'; // пик или хороший (shoulder)
const nowRows = rows.filter((r) => inSeason(r.r, month));
const nowNames = nowRows.slice(0, 6).map((r) => r.nom);
const plural = (n) => (n % 10 === 1 && n % 100 !== 11 ? 'направление' : (n % 10 >= 2 && n % 10 <= 4 && (n % 100 < 10 || n % 100 >= 20) ? 'направления' : 'направлений'));
const nowWord = plural(nowRows.length);

// Бали — реальный пример для превью «Калькулятор бюджета» (комфорт, с перелётом)
const baliP = DIRECTIONS.find((d) => d.slug === 'bali')?.price;
const baliFlight = baliP ? flightRub(baliP) : 0;
const baliStay = baliP ? stayRub(baliP) : 0;
const baliTrip = baliFlight + baliStay;
const SEASON_IDX = { P: 0, G: 1, O: 2, B: 3 }; // пик / хорошо / норм / не сезон
const baliPat = (DIRECTIONS.find((d) => d.slug === 'bali')?.r || []).map((c) => SEASON_IDX[c] ?? 3);

// Свежие посты
const allPosts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const posts = allPosts.slice(0, 3);
const readingTime = (body) => Math.max(1, Math.ceil(body.trim().split(/\s+/).length / 200));

const brandYear = new Date().getFullYear();
const desc = `Куда поехать из России в ${brandYear}: визы, сезоны и реальные цены с перелётом по 70+ направлениям — в одной таблице. Автор был лично на 7 континентах.`;
const ldJson = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebPage', '@id': 'https://traveltribe.ru/#webpage', url: 'https://traveltribe.ru/', name: `TravelTribe — куда поехать из России в ${brandYear}`, description: desc, isPartOf: { '@id': 'https://traveltribe.ru/#website' }, about: { '@id': 'https://traveltribe.ru/#org' }, inLanguage: 'ru-RU' },
    { '@type': 'ItemList', name: `Куда поехать из России в ${brandYear} — направления`, itemListElement: rows.map((r, i) => ({ '@type': 'ListItem', position: i + 1, name: r.nom, url: `https://traveltribe.ru/${r.slug}/` })) },
  ],
};
---
<Layout title={`Куда поехать из России в ${brandYear}: визы, сезоны, цены · TravelTribe`} description={desc} canonical="https://traveltribe.ru/" ldJson={ldJson}>
<div class="sw">

  <main id="main">
    <!-- Манифест -->
    <section class="manifest"><div class="wrap grid">
      <p class="meta"><b>Был лично на 7 континентах</b><br>60+ стран · цены с перелётом, не пересказ · обновлено {DATA_UPDATED_RU}</p>
      <h1 class="h1">Вся польза<br>о поездках —<br><span class="rd">на виду.</span></h1>
      <p class="sub">Визы, сезоны и реальные цены с перелётом по 70+ направлениям — в одной таблице. Куда, когда и за сколько видно сразу. Ничего копать не нужно.</p>
      <ul class="vlist">
        <li class="vi"><a href="/visa/"><span class="vi-l">Визы РФ</span></a></li>
        <li class="vi"><a href="/seasons/"><span class="vi-l">Когда ехать</span></a></li>
        <li class="vi"><a href="/calculator/"><span class="vi-l">Цена с перелётом</span></a></li>
        <li class="vi"><a href="/trips/"><span class="vi-l">Поездки</span></a></li>
        <li class="vi"><a href="/packing/"><span class="vi-l">Чек-листы</span></a></li>
        <li class="vi"><a href="/countries/"><span class="vi-l">70+ направлений</span></a></li>
      </ul>
    </div></section>

    <!-- Фильтры + дашборд -->
    <section><div class="wrap grid">
      <div class="shead"><div><h2>Куда поехать из России</h2></div><a href="/countries/">Смотреть все направления</a></div>
      <div class="filters" role="search">
        <div class="fg"><span class="fl">Когда</span><select class="t" id="fMonth" aria-label="Месяц поездки">
          <option value="0">любой</option>
          {MONTHS_PREP.slice(1).map((_, i) => (
            <option value={i + 1} selected={i + 1 === month}>{['январь','февраль','март','апрель','май','июнь','июль','август','сентябрь','октябрь','ноябрь','декабрь'][i]}</option>
          ))}
        </select></div>
        <div class="fg"><span class="fl">Поездка ₽</span><div class="fopts" data-g="b" role="group" aria-label="Бюджет поездки"><button class="t" data-v="low" type="button" aria-pressed="false">до 100к</button><button class="t" data-v="mid" type="button" aria-pressed="false">100–200к</button><button class="t" data-v="high" type="button" aria-pressed="false">200к+</button></div></div>
        <div class="fg"><span class="fl">Настроение</span><div class="fopts" data-g="vibe" role="group" aria-label="Настроение поездки"><button class="t" data-v="beach" type="button" aria-pressed="false">пляж</button><button class="t" data-v="mountains" type="button" aria-pressed="false">горы</button><button class="t" data-v="city" type="button" aria-pressed="false">город</button><button class="t" data-v="nature" type="button" aria-pressed="false">природа</button></div></div>
        <div class="fright">
          <div class="fg fg-sort"><span class="fl">Сортировка</span><div class="fopts" id="sortOpts" role="group" aria-label="Сортировка"><button class="t on" data-s="rel" type="button" aria-pressed="true">рекомендую</button><button class="t" data-s="asc" type="button" aria-pressed="false">дешевле</button><button class="t" data-s="desc" type="button" aria-pressed="false">дороже</button></div></div>
          <div class="fcount"><b id="fCountN">{nowRows.length}</b><span id="fCountW">{nowWord}</span></div>
        </div>
      </div>

      <p class="seasonlead" id="seasonlead">Сейчас, <b>в {monthWord}</b>, в сезоне: {nowNames.join(', ') || '—'}.</p>

      <div class="dashwrap"><table class="dash" id="dash">
        <thead><tr><th>Направление</th><th>Поездка с перелётом</th><th>Виза</th><th>Лучший сезон</th><th class="r" aria-label="Подробнее"></th></tr></thead>
        <tbody>
          {rows.map((r) => (
            <tr data-r={r.r.join('')} data-b={tier(r.budget)} data-v={r.visa} data-vibe={r.vibe.join(',')} data-budget={r.budget} data-name={r.nom.toLowerCase()}>
              <td class="cdest"><span class="dest"><span class="th"><Image src={r.cover} alt={r.nom} width={420} height={300} formats={['webp']} loading="lazy" /></span><span><a class="nm" href={`/${r.slug}/`}>{r.nom}</a><span class="vibe">{r.vibeRu}</span><span class="sq" hidden></span></span></span></td>
              <td data-l="Поездка"><span class="price">≈ {fmt(r.budget)}&nbsp;₽ <small>за неделю</small></span></td>
              <td data-l="Виза"><span class={`visa ${VISA_CLASS[r.visa]}`}>{VISA_LABEL[r.visa]}</span></td>
              <td data-l="Сезон" class="season">{r.season}</td>
              <td class="flight r"><a class="fly" href={`/${r.slug}/`}>Подробнее</a></td>
            </tr>
          ))}
          <tr id="moreRow" hidden><td colspan="5" class="more-cell"><a href="/countries/">Ещё <b id="moreN"></b> в сезоне — показать все</a></td></tr>
        </tbody>
      </table></div>
      <p class="nomatch" id="noMatch">Под эти фильтры ничего не нашлось — попробуйте ослабить один: другой месяц, бюджет повыше или другое настроение.</p>
      <p class="dfoot">Цена — ориентир всей поездки в комфорте на одного: перелёт из Москвы + жильё, еда и транспорт за 7 ночей (медиана Aviasales/Островок и траты из источников 2026, курс ≈90 ₽/$). Зависит от дат и сезона — <a href="/calculator/">посчитайте точно в калькуляторе</a></p>

      <!-- Авторские туры (YouTravel) — альтернатива DIY -->
      <div class="tourcta">
        <span class="tourcta-t"><b>Не хочешь планировать сам?</b> Авторский тур с экспертом — маршрут, логистика и малая группа уже собраны.</span>
        <a class="tourcta-a" href={TP_LINKS.youtravel} rel="sponsored noopener" target="_blank">Смотреть авторские туры</a>
        
      </div>

      <!-- Монетизация -->
      <div class="gear">
        <div class="gear-h"><h2>Собраться в дорогу</h2></div>
        <div class="gear-grid">
          <div class="gi"><div class="gl">Билеты</div><div class="gt">Авиабилеты</div><div class="gd">Сравнить цены и поймать дешёвый</div><a class="cta" href={TP_LINKS.aviasales} rel="sponsored noopener" target="_blank">Найти билет</a></div>
          <div class="gi"><div class="gl">Жильё</div><div class="gt">Отели и апарты</div><div class="gd">Оплата картой РФ, бесплатная отмена</div><a class="cta" href={TP_LINKS.ostrovok} rel="sponsored noopener" target="_blank">Подобрать жильё</a></div>
          <div class="gi"><div class="gl">Страховка</div><div class="gt">Мед. страховка</div><div class="gd">Под визу и погранусловия</div><a class="cta" href={TP_LINKS.cherehapa} rel="sponsored noopener" target="_blank">Оформить страховку</a></div>
          <div class="gi"><div class="gl">Авто</div><div class="gt">Прокат авто</div><div class="gd">Местные и международные прокатчики</div><a class="cta" href={TP_LINKS.economybookings} rel="sponsored noopener" target="_blank">Сравнить прокат</a></div>
          <div class="gi"><div class="gl">Связь</div><div class="gt">eSIM в роуминг</div><div class="gd">Интернет с прилёта, от $5 за неделю</div><a class="cta" href={TP_LINKS.airalo} rel="sponsored noopener" target="_blank">Подключить eSIM</a></div>
          <div class="gi"><div class="gl">Карты</div><div class="gt">Какие карты работают</div><div class="gd">МИР, UnionPay и иностранные — по странам</div><a class="cta" href="/cards/">Проверить карту</a></div>
        </div>
      </div>

      <div class="visaband"><span class="vt"><b>Виза для россиян 2026</b> — по каждой из 70+ стран: безвиз, e-Visa или консульство. В таблице выше виза видна в каждой строке.</span><a href="/visa/">Что изменилось по визам</a></div>
    </div></section>

    <!-- Инструменты -->
    <section class="sec"><div class="wrap grid">
      <div class="shead"><div><h2>Инструменты — не на слово</h2></div><a href="/seasons/">Таблица сезонов целиком</a></div>
      <div class="tools">
        <div class="tcard"><div class="tt">Когда ехать в каждую страну</div><div class="ts">Пример строки «Бали» — по месяцам:</div>
          <div class="heat" id="heat" data-pat={JSON.stringify(baliPat)}></div>
          <div class="heatlbl"><span>Я</span><span>Ф</span><span>М</span><span>А</span><span>М</span><span>И</span><span>И</span><span>А</span><span>С</span><span>О</span><span>Н</span><span>Д</span></div>
          <div class="lg"><span><i style="background:var(--gold)"></i>пик</span><span><i style="background:var(--ink)"></i>хорошо</span><span><i style="background:#9b9789"></i>норм</span><span><i style="background:var(--hair)"></i>не сезон</span></div>
          <div class="tl"><a href="/seasons/">Сезоны по месяцам</a><a href="/visa/">Визы для россиян</a></div>
        </div>
        <div class="tcard bud"><div class="tt">Калькулятор бюджета</div><div class="ts">Бали, комфорт на неделю с перелётом:</div>
          <div class="br"><span>Перелёт из Москвы</span><b>≈ {fmt(baliFlight)}&nbsp;₽</b></div>
          <div class="br"><span>Неделя на месте (комфорт)</span><b>≈ {fmt(baliStay)}&nbsp;₽</b></div>
          <div class="br"><span>Вся поездка</span><b>≈ {fmt(baliTrip)}&nbsp;₽</b></div>
          <div class="tl"><a href="/calculator/">Посчитать свою поездку</a></div>
        </div>
      </div>
    </div></section>

    <!-- Свежие истории -->
    <section class="sec"><div class="wrap grid">
      <div class="shead"><div><h2>Свежие истории</h2></div><a href="/blog/">Весь блог</a></div>
      <div class="posts">
        {posts.map((p, i) => (
          <a class="post" href={`/blog/${p.slug}/`}>
            <div class="ph"><Image src={p.data.coverImage} alt={p.data.title} width={760} height={507} formats={['webp']} /></div>
            <div class="tg">{(p.data.tags || []).slice(0, 2).join(' · ')}</div>
            <h3>{p.data.title}</h3>
            <div class="mt">{readingTime(p.body)} мин{p.data.sourceType === 'personal' && <span class="pers"> · был лично</span>}</div>
          </a>
        ))}
      </div>
      <p class="topics">Темы: <a href="/visa/">Визы</a> · <a href="/blog/pay-abroad-2026/">Деньги за границей</a> · <a href="/blog/esim-zagranicey-2026/">eSIM и связь</a> · <a href="/trips/">Поездки</a></p>
    </div></section>

    <!-- Сообщество + автор -->
    <section><div class="wrap grid">
      <div class="comm">
        <div class="tg2"><div class="k">Telegram</div><h3>Свежие истории и апдейты виз — раньше, чем на сайте</h3><a href="https://t.me/traveltriberu" rel="noopener" target="_blank">Подписаться на @traveltriberu</a></div>
        <div class="au"><div class="au-ph"><Image src={authorPhoto} alt="Никита Зайцев" width={156} height={156} formats={['webp']} /></div><div><div class="nm">Никита Зайцев</div><p>Был на всех 7 континентах, 60+ стран. Пишу только то, где был сам.</p><a class="method" href="/about/">Как я считаю бюджет и проверяю визы</a></div></div>
      </div>
    </div></section>
  </main>

  <footer class="sw-foot"><div class="wrap ft">
    <nav class="fnav" aria-label="Подвал"><a href="/countries/">Направления</a><a href="/visa/">Визы</a><a href="/seasons/">Сезоны</a><a href="/trips/">Поездки</a><a href="/calculator/">Калькулятор</a><a href="/packing/">Чек-листы</a><a href="/blog/">Блог</a><a href="/about/">Об авторе</a></nav>
    <div class="fbot"><div>© {brandYear} TravelTribe — Никита Зайцев</div><div>Telegram <a href="https://t.me/traveltriberu" rel="noopener" target="_blank">@traveltriberu</a> · Aviasales · Ostrovok</div></div>
  </div></footer>
</div>
</Layout>

<style is:global>
  /* Swiss-главная: фон только этой страницы (is:global грузится лишь на этом маршруте) */
  body { background: #f4f2eb; }
</style>

<style>
.sw{--paper:#f4f2eb;--ink:#1b1914;--mid:#6b685e;--line:#23211a;--hair:#cdc9bd;--gold:#8e6618;
  --ff:'Golos Text Variable','Golos Text',Helvetica,Arial,sans-serif;--edge:clamp(1.1rem,3vw,2.6rem);
  background:var(--paper);color:var(--ink);font-family:var(--ff);font-weight:400;line-height:1.4;
  font-variant-numeric:tabular-nums lining-nums;-webkit-font-smoothing:antialiased}
:where(.sw) :where(h1,h2,h3,h4,p,ul,li){margin:0}
.sw :where(h1,h2,h3,h4,button,select,input){font-family:var(--ff);color:var(--ink)}
.sw img{display:block;width:100%;height:100%;object-fit:cover;filter:grayscale(.06) contrast(1.02)}
.sw a{color:inherit;text-decoration:none}
.sw :focus-visible{outline:2px solid var(--gold);outline-offset:3px}
.wrap{max-width:1280px;margin-inline:auto;padding-inline:var(--edge)}
.grid{display:grid;grid-template-columns:repeat(12,minmax(0,1fr));gap:0 clamp(.8rem,2vw,1.6rem)}

/* Верхнее меню вынесено в общий компонент SwissHeader.astro (через Layout). */

.manifest{padding:clamp(2rem,5vw,4.5rem) 0 clamp(1.2rem,2.5vw,2rem)}
.meta{grid-column:8/13;grid-row:1;text-align:right;align-self:start;font-size:.8rem;color:var(--mid);line-height:1.5}
.meta b{color:var(--ink);font-weight:500}
.h1{grid-column:1/13;grid-row:2;font-weight:700;font-size:clamp(2.4rem,7vw,6.4rem);line-height:1.02;letter-spacing:-.035em;margin-top:clamp(1.2rem,2.5vw,2rem);padding-bottom:.06em}
.h1 .rd{color:var(--gold)}
.sub{grid-column:1/8;grid-row:3;font-size:clamp(1rem,1.3vw,1.18rem);color:var(--ink);margin-top:clamp(1.5rem,2vw,1.9rem);max-width:46ch}
.vlist{grid-column:1/13;grid-row:4;margin-top:2rem;display:grid;grid-template-columns:repeat(6,1fr);border-top:1px solid var(--line);border-bottom:1px solid var(--line);list-style:none}
.vi{border-right:1px solid var(--hair)}
.vi-l{display:block;font-size:.92rem;font-weight:600;line-height:1.25}
.vi:first-child{padding-left:0}.vi:last-child{border-right:none}
.vi a{display:block;color:inherit;min-height:48px;padding:.7rem 1rem}
.vi a:hover,.vi a:focus-visible{background:rgba(142,102,24,.05)}
.vi a:hover .vi-l,.vi a:focus-visible .vi-l{color:var(--gold)}
