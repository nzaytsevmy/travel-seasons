.ft{display:flex;justify-content:space-between;flex-wrap:wrap;gap:1rem;padding-block:1.6rem;font-size:.74rem;color:var(--mid);font-weight:500}
</style>

<script>
  const dash = document.getElementById('dash');
  if (dash) {
    const rows = [...dash.querySelectorAll('tbody tr')];
    const state = { m: new Date().getMonth() + 1, b: null, v: null, vibe: null };
    const PREP = ['', 'январе','феврале','марте','апреле','мае','июне','июле','августе','сентябре','октябре','ноябре','декабре'];
    const pl = (n) => (n % 10 === 1 && n % 100 !== 11 ? 'направление' : (n % 10 >= 2 && n % 10 <= 4 && (n % 100 < 10 || n % 100 >= 20) ? 'направления' : 'направлений'));
    function apply() {
      let n = 0;
      rows.forEach((c) => {
        const m = c.dataset.m.split(','), vibe = c.dataset.vibe.split(',');
        let ok = true;
        if (state.m && !m.includes(String(state.m))) ok = false;
        if (state.b && c.dataset.b !== state.b) ok = false;
        if (state.v && c.dataset.v !== state.v) ok = false;
        if (state.vibe && !vibe.includes(state.vibe)) ok = false;
        c.hidden = !ok; if (ok) n++;
      });
      document.getElementById('fCountN').textContent = n;
      document.getElementById('fCountW').textContent = pl(n);
      document.getElementById('noMatch').style.display = n ? 'none' : 'block';
      const names = rows.filter((r) => !r.hidden).map((r) => r.querySelector('.nm').textContent);
      const sl = document.getElementById('seasonlead');
      if (sl) sl.innerHTML = n
        ? `Сейчас, <b>${state.m ? 'в ' + PREP[state.m] : 'в любой месяц'}</b>, подходит: ${names.slice(0, 6).join(', ')}${names.length > 6 ? ' и ещё ' + (names.length - 6) : ''}.`
        : 'Под эти фильтры пока ничего — попробуйте другой месяц.';
    }
    document.getElementById('fMonth').addEventListener('change', (e) => { state.m = +e.target.value; apply(); });
    document.querySelectorAll('.fopts[data-g]').forEach((g) => g.addEventListener('click', (e) => {
      const b = e.target.closest('.t'); if (!b) return;
      const grp = g.dataset.g, was = b.classList.contains('on');
      g.querySelectorAll('.t').forEach((x) => x.classList.remove('on'));
      if (!was) { b.classList.add('on'); state[grp] = b.dataset.v; } else state[grp] = null;
      apply();
    }));
    apply();
    // мини-хитмэп Бали (пример): off,off,ok,good,peak×5,good,ok,off
    const pat = [3,3,2,1,0,0,0,0,0,1,2,3], col = ['var(--gold)','var(--ink)','#9b9789','var(--hair)'];
    const h = document.getElementById('heat');
    if (h) pat.forEach((p) => { const d = document.createElement('div'); d.className = 'mh'; d.style.cssText = 'height:1.6rem;background:' + col[p]; h.appendChild(d); });
  }
</script>
