---
import { getCollection } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import authorPhoto from '../assets/author/nikita.jpg';
import { DIRECTIONS, MONTHS } from '../data/directions.js';

// Search autocomplete data
const searchOptions = DIRECTIONS.map(d => ({
  label: d.cases.nom,
  slug: d.slug,
  region: d.region,
  sub: d.sub,
}));
const currentMonthSlug = MONTHS[new Date().getMonth()].slug;

// ── Schema ───────────────────────────────────────────
const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://traveltribe.ru/#website",
      "name": "TravelTribe",
      "url": "https://traveltribe.ru/",
      "description": "Авторский тревел-блог из России: личные отчёты, визы, сезоны, бюджет 39 направлений мира",
      "inLanguage": "ru-RU",
      "publisher": { "@id": "https://traveltribe.ru/#org" },
      "potentialAction": {
        "@type": "SearchAction",
        "target": { "@type": "EntryPoint", "urlTemplate": "https://traveltribe.ru/?s={search_term_string}" },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "@id": "https://traveltribe.ru/#org",
      "name": "TravelTribe",
      "url": "https://traveltribe.ru/",
      "logo": "https://traveltribe.ru/brand-mark.svg",
      "founder": { "@type": "Person", "name": "Никита Зайцев", "url": "https://t.me/traveltriberu" },
      "sameAs": ["https://t.me/traveltriberu", "https://github.com/nzaytsevmy/travel-seasons"]
    }
  ]
};

// ── Posts ─────────────────────────────────────────
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = allPosts[0];
const restPosts = allPosts.slice(1, 7);

function readingTime(body: string) {
  return Math.max(1, Math.ceil(body.trim().split(/\s+/).length / 200));
}

// ── Bento categories — featured destinations с cover photos из постов
import antarcticaCover from '../assets/blog/antarctica-cruise.jpg';
import japanCover      from '../assets/blog/japan-author-fushimi.jpg';
import baliCover       from '../assets/blog/bali-guide.jpg';
import galapagosCover  from '../assets/blog/galapagos.jpg';
import auroraCover     from '../assets/blog/aurora-nz.jpg';
import schengenCover   from '../assets/blog/schengen-visa.jpg';

const CATEGORIES = [
  // 2 large hero (top row), 4 medium (bottom)
  { label: 'Антарктида',   sub: 'Круиз 2026',          href: '/antarctica/',                  cover: antarcticaCover, size: 'lg', objPos: 'center 65%' },
  { label: 'Япония',       sub: 'Гайд + виза',         href: '/japan/',                       cover: japanCover,      size: 'lg', objPos: 'center 23%' },
  { label: 'Бали',         sub: '6 районов · цены',    href: '/blog/bali-guide-2026/',        cover: baliCover,       size: 'md' },
  { label: 'Галапагосы',   sub: 'Олуши + пингвины',    href: '/blog/galapagos-2026/',         cover: galapagosCover,  size: 'md' },
  { label: 'Новая Зеландия', sub: 'Южное сияние',      href: '/blog/aurora-new-zealand-2026/', cover: auroraCover,    size: 'md' },
  { label: 'Шенген',       sub: 'Виза 2026 · EES',     href: '/blog/schengen-visa-2026/',     cover: schengenCover,   size: 'md' },
];

const MONTHS_RU = ['январе','феврале','марте','апреле','мае','июне','июле','августе','сентябре','октябре','ноябре','декабре'];
const currentMonthRu = MONTHS_RU[new Date().getMonth()];

// LCP candidate — featured cover. Preload через Layout prop.
const featuredImageUrl = featured ? (await getImage({
  src: featured.data.coverImage,
  width: 1024,
  format: 'webp',
  quality: 72,
})).src : undefined;
---
<Layout
  title="TravelTribe — авторский тревел-блог из России"
  description="Личные отчёты Никиты Зайцева о путешествиях. Визы, сезоны, реальные бюджеты для 39 направлений мира — Антарктида, Япония, Бали, Африка, Латам."
  canonical="https://traveltribe.ru/"
  ogTitle="TravelTribe — авторский тревел-блог из России"
  ogDescription="60+ стран, 7 континентов. Личные отчёты, реальные цены 2026, без воды и рекламы."
  ldJson={ldJson}
  preloadImage={featuredImageUrl}
>
  <Nav active="home" />

  <main id="main">
    {/* ─── HERO — split: brand intro слева, featured story справа ─── */}
    {featured && (
      <section class="hero-split">
        <div class="hero-intro">
          <div class="hero-intro-eyebrow">// Travel-блог · Россия</div>
          <h1 class="hero-intro-title">
            Реальные путешествия. <em>Без воды.</em>
          </h1>
          <p class="hero-intro-desc">
            Личные отчёты, актуальные визы, реальные цены 2026 для 39 направлений мира. То что работает прямо сейчас — без рекламы и партнёрских туров.
          </p>

          <form class="hero-search" id="heroSearch" autocomplete="off" data-month={currentMonthSlug}>
            <label for="hero-search-input" class="hero-search-label">Куда хочешь поехать?</label>
            <div class="hero-search-row">
              <svg class="hero-search-icon" viewBox="0 0 16 16" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <circle cx="7" cy="7" r="5"></circle><line x1="11" y1="11" x2="14.5" y2="14.5"></line>
              </svg>
              <input
                id="hero-search-input"
                name="q"
                type="search"
                placeholder="Япония, Бали, Грузия, Антарктида…"
                list="hero-search-list"
                class="hero-search-input"
              />
              <button type="submit" class="hero-search-btn">
                <span>Найти</span>
                <span aria-hidden="true">→</span>
              </button>
            </div>
            <datalist id="hero-search-list">
              {searchOptions.map(o => (
                <option value={o.label} data-slug={o.slug}>{o.region} — {o.sub}</option>
              ))}
            </datalist>
          </form>
          <div class="hero-intro-stats">
            <div><strong>60+</strong><span>стран</span></div>
            <div><strong>7</strong><span>континентов</span></div>
            <div><strong>{allPosts.length}</strong><span>статей</span></div>
            <div><strong>39</strong><span>направлений</span></div>
          </div>
          <div class="hero-intro-cta">
            <a href="/blog/" class="hero-btn-primary">Читать блог</a>
            <a href="/seasons/" class="hero-btn-ghost">Куда ехать сейчас</a>
          </div>
        </div>

        <a class="hero-feature" href={`/blog/${featured.slug}/`}>
          <div class="hero-feature-image">
            <Image
              src={featured.data.coverImage}
              alt={featured.data.title}
              widths={[640, 1024, 1400]}
              sizes="(max-width: 960px) 100vw, 50vw"
              formats={['avif', 'webp']}
              fallbackFormat="jpg"
              quality={72}
              loading="eager"
              fetchpriority="high"
              style={`object-position: ${featured.data.coverPosition || 'center'};`}
            />
            <div class="hero-feature-overlay"></div>
          </div>
          <div class="hero-feature-content">
            <div class="hero-feature-meta">
              <span class="hero-feature-tag">Свежее · {featured.data.tags?.[0] || 'История'}</span>
              {featured.data.sourceType === 'personal' && featured.data.tripPlace && (
                <span class="hero-feature-trip">✓ Был лично</span>
              )}
            </div>
            <h2 class="hero-feature-title">{featured.data.title}</h2>
            <span class="hero-feature-cta">Читать историю →</span>
          </div>
        </a>
      </section>
    )}

    {/* ─── Categories Bento (Apple/Linear-style asymmetric grid с photo) ─── */}
    <section class="cat-section">
      <div class="cat-container">
        <div class="section-eyebrow">// Направления</div>
        <h2 class="section-title">Куда поехать</h2>
        <div class="bento-grid">
          {CATEGORIES.map((c, i) => (
            <a href={c.href} class={`bento-card bento-card--${c.size}`}>
              <Image
                src={c.cover}
                alt={c.label}
                widths={[400, 800, 1200]}
                sizes="(max-width: 700px) 100vw, (max-width: 1100px) 50vw, 33vw"
                formats={['avif', 'webp']}
                quality={68}
                loading={i < 2 ? 'eager' : 'lazy'}
                style={`object-position: ${c.objPos || 'center'};`}
              />
              <div class="bento-overlay"></div>
              <div class="bento-content">
                <div class="bento-sub">{c.sub}</div>
                <div class="bento-label">{c.label}</div>
              </div>
              <span class="bento-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* ─── Latest posts grid ─── */}
    {restPosts.length > 0 && (
      <section class="latest-section">
        <div class="latest-container">
          <header class="latest-header">
            <div class="section-eyebrow">// Последние истории</div>
            <h2 class="section-title">Свежие посты</h2>
            <a href="/blog/" class="latest-all">Все статьи →</a>
          </header>
          <div class="latest-grid">
            {restPosts.map((post) => (
              <a href={`/blog/${post.slug}/`} class="latest-card">
                <div class="latest-cover">
                  <Image
                    src={post.data.coverImage}
                    alt={post.data.title}
                    widths={[400, 720]}
                    sizes="(max-width: 700px) 100vw, 33vw"
                    formats={['avif', 'webp']}
                    quality={68}
                    loading="lazy"
                    style={`object-position: ${post.data.coverPositionCard || post.data.coverPosition || 'center'};`}
                  />
                </div>
                <div class="latest-body">
                  <div class="latest-tags">
                    {post.data.tags?.slice(0, 2).map((t) => (
                      <span class="latest-tag">{t}</span>
                    ))}
                  </div>
                  <h3 class="latest-title">{post.data.title}</h3>
                  <p class="latest-desc">{post.data.description}</p>
                  <div class="latest-meta">
                    <span>{readingTime(post.body)} мин</span>
                    {post.data.sourceType === 'personal' && <span class="latest-personal">· Был лично</span>}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* ─── Tools strip — calc + seasons + visa-map ─── */}
    <section class="tools-section">
      <div class="tools-container">
        <div class="section-eyebrow">// Инструменты</div>
        <div class="tools-grid">
          <a href="/seasons/" class="tool-card">
            <span class="tool-icon">🗓</span>
            <strong>Таблица сезонов</strong>
            <span>39 направлений × 12 месяцев. Когда лучше ехать.</span>
          </a>
          <a href="/calculator/" class="tool-card">
            <span class="tool-icon">💸</span>
            <strong>Калькулятор бюджета</strong>
            <span>Перелёт + проживание + еда. Живой курс ЦБ.</span>
          </a>
          <a href="/trips/" class="tool-card">
            <span class="tool-icon">🌍</span>
            <strong>Календарь поездок</strong>
            <span>Что работает в каждом месяце 2026.</span>
          </a>
          <a href="/blog/" class="tool-card">
            <span class="tool-icon">📓</span>
            <strong>Блог</strong>
            <span>Личные отчёты автора. {allPosts.length} статей.</span>
          </a>
        </div>
      </div>
    </section>

    {/* ─── Newsletter signup ─── */}
    <section class="news-section">
      <div class="news-container">
        <div class="news-text">
          <div class="section-eyebrow">// Telegram-канал</div>
          <h2>@traveltriberu — личные истории и оперативные обновления</h2>
          <p>Никита пишет про текущие поездки, апдейты по визам и неочевидные открытия. Без воды и рекламы. Раз в 2-3 дня.</p>
        </div>
        <a class="news-cta" href="https://t.me/traveltriberu" target="_blank" rel="noopener">
          <span>Подписаться в Telegram</span>
          <span class="news-arrow">→</span>
        </a>
      </div>
    </section>

    {/* ─── Author strip ─── */}
    <section class="author-section">
      <a href="/about/" class="author-strip">
        <Image
          src={authorPhoto}
          alt="Никита Зайцев — автор TravelTribe"
          width={88}
          height={88}
          format="webp"
          quality={82}
          loading="lazy"
          class="author-photo"
        />
        <div class="author-text">
          <strong>Никита Зайцев</strong>
          <span>7 континентов · 60+ стран · 13 лет в продуктах · авторский блог без рекламы</span>
        </div>
        <span class="author-arrow">→</span>
      </a>
    </section>
  </main>

  <Footer />
</Layout>

<script is:inline define:vars={{ searchOptions, currentMonthSlug }}>
  // Hero search: подбираем direction по тексту, редиректим на /trips/<month>/<slug>/
  const form = document.getElementById('heroSearch');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector('input[name="q"]');
      const q = (input.value || '').trim().toLowerCase();
      if (!q) return;

      // Try exact match first, then fuzzy match (substring on label/region/sub)
      const exact = searchOptions.find(o => o.label.toLowerCase() === q);
      const partial = exact || searchOptions.find(o =>
        o.label.toLowerCase().includes(q) ||
        o.region.toLowerCase().includes(q) ||
        o.sub.toLowerCase().includes(q)
      );

      if (partial) {
        window.location.href = `/trips/${currentMonthSlug}/${partial.slug}/`;
      } else {
        // Fallback — search overlay (Pagefind) with prefilled query
        window.location.href = `/seasons/?q=${encodeURIComponent(q)}`;
      }
    });
  }
</script>

<style>
/* ─── HERO split: brand intro + featured story (Atlas Obscura / Outside pattern) ─── */
.hero-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  min-height: clamp(440px, 70vh, 680px);
  border-bottom: 1px solid var(--line);
}
@media (max-width: 960px) {
  .hero-split { grid-template-columns: 1fr; }
}

.hero-intro {
  display: flex; flex-direction: column; justify-content: center;
  padding: clamp(2rem, 6vw, 5rem) clamp(1.5rem, 5vw, 4rem);
  background: var(--bg);
}
.hero-intro-eyebrow {
  font-size: var(--text-xs); letter-spacing: var(--tracking-widest);
  text-transform: uppercase; color: var(--gold-600);
  margin-bottom: var(--space-4);
}
.hero-intro-title {
  font-family: var(--ff-display);
  font-size: var(--text-6xl);
  font-weight: 700;
  line-height: var(--leading-tight);
  letter-spacing: var(--tracking-tight);
  color: var(--text);
  margin: 0 0 var(--space-5);
  text-wrap: balance;
}
.hero-intro-title em { font-style: italic; color: var(--gold-600); font-weight: 600; }
.hero-intro-desc {
  font-size: var(--text-lg);
  line-height: var(--leading-relaxed);
  color: var(--text-dim);
  margin: 0 0 var(--space-6);
  max-width: 480px;
}
.hero-intro-stats {
  display: grid;
  grid-template-columns: repeat(4, auto);
  gap: var(--space-6);
  margin-bottom: var(--space-8);
  padding: var(--space-4) 0;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}
.hero-intro-stats > div { display: flex; flex-direction: column; gap: 2px; }
.hero-intro-stats strong {
  font-family: var(--ff-display);
  font-size: var(--text-3xl);
  font-weight: 700;
  color: var(--gold-600);
  font-variant-numeric: tabular-nums;
  letter-spacing: var(--tracking-tight);
}
.hero-intro-stats span {
  font-size: var(--text-xs);
  letter-spacing: var(--tracking-wide);
  color: var(--text-faint);
  text-transform: uppercase;
}
/* ─── Hero search bar (Skyscanner / Booking-style) ─── */
.hero-search {
  margin: var(--space-6) 0 var(--space-7);
  display: flex; flex-direction: column; gap: var(--space-2);
}
.hero-search-label {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--text-dim);
}
.hero-search-row {
  display: flex; align-items: center;
  background: var(--bg2);
  border: 1.5px solid var(--line);
  border-radius: var(--radius-pill);
  padding: 4px 4px 4px 16px;
  transition: border-color 0.15s, box-shadow 0.15s;
  max-width: 480px;
}
.hero-search-row:focus-within {
  border-color: var(--gold-600);
  box-shadow: 0 0 0 3px rgba(201,151,58,0.15);
}
.hero-search-icon { color: var(--text-faint); flex: 0 0 auto; }
.hero-search-input {
  flex: 1; min-width: 0;
  padding: 0.85rem 0.5rem;
  border: none; background: transparent; outline: none;
  font-family: var(--ff-body);
  font-size: var(--text-base);
  color: var(--text);
  font-weight: 500;
}
.hero-search-input::placeholder { color: var(--text-faint); font-weight: 400; }
.hero-search-input::-webkit-search-cancel-button { -webkit-appearance: none; }

.hero-search-btn {
  display: inline-flex; align-items: center; gap: 0.4rem;
  padding: 0.7rem 1.3rem;
  background: var(--gold-600);
  color: #fff;
  border: none;
  border-radius: var(--radius-pill);
  font-family: var(--ff-body);
  font-size: var(--text-sm);
  font-weight: 600;
  cursor: pointer;
  transition: background 0.15s, transform 0.1s;
}
.hero-search-btn:hover { background: var(--gold-500); }
.hero-search-btn:active { transform: scale(0.97); }
.hero-search-btn:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }

.hero-intro-cta { display: flex; gap: var(--space-3); flex-wrap: wrap; }
.hero-btn-primary, .hero-btn-ghost {
  display: inline-flex; align-items: center;
  padding: var(--space-3) var(--space-5);
  border-radius: var(--radius-pill);
  font-weight: 600; font-size: var(--text-base);
  text-decoration: none;
  transition: background var(--duration-fast), border-color var(--duration-fast), transform var(--duration-fast), box-shadow var(--duration-fast);
}
.hero-btn-primary {
  background: var(--gold-600);
  color: #fff;
  box-shadow: var(--shadow-md);
}
.hero-btn-primary:hover { background: var(--gold-500); transform: translateY(-1px); box-shadow: var(--shadow-lg); }
.hero-btn-ghost {
  background: transparent;
  color: var(--text);
  border: 1.5px solid var(--line);
}
.hero-btn-ghost:hover { border-color: var(--gold-600); color: var(--gold-600); }

/* Featured story — image + overlay + title */
.hero-feature {
  position: relative;
  display: block; overflow: hidden;
  isolation: isolate;
  text-decoration: none; color: #fff;
  min-height: 380px;
}
.hero-feature-image { position: absolute; inset: 0; z-index: -1; }
.hero-feature-image picture, .hero-feature-image img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.6s var(--ease-out);
}
.hero-feature:hover .hero-feature-image img { transform: scale(1.04); }
.hero-feature-overlay {
  position: absolute; inset: 0; z-index: 1;
  background:
    linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.1) 100%);
}
.hero-feature-content {
  position: relative; z-index: 2;
  display: flex; flex-direction: column; gap: var(--space-3);
  height: 100%; justify-content: flex-end;
  padding: var(--space-8) clamp(1.5rem, 4vw, 3rem);
}
.hero-feature-meta {
  display: flex; flex-wrap: wrap; align-items: center; gap: 0.7rem;
}
.hero-feature-tag {
  font-size: var(--text-xs); letter-spacing: var(--tracking-widest);
  text-transform: uppercase; color: var(--gold-300, #e8c062);
}
.hero-feature-trip {
  font-size: var(--text-xs); color: rgba(255,255,255,0.85);
  border: 1px solid rgba(232,192,98,0.5);
  background: rgba(232,192,98,0.15);
  padding: 0.2rem 0.6rem; border-radius: var(--radius-pill);
}
.hero-feature-title {
  font-family: var(--ff-display);
  font-size: clamp(1.7rem, 3.5vw, 2.4rem);
  font-weight: 600;
  line-height: var(--leading-snug);
  letter-spacing: var(--tracking-tight);
  color: #fff;
  margin: 0;
  text-wrap: balance;
  text-shadow: 0 2px 14px rgba(0,0,0,0.4);
}
.hero-feature-cta {
  font-size: var(--text-sm); color: var(--gold-300);
  letter-spacing: var(--tracking-wide); font-weight: 500;
  transition: transform var(--duration-base) var(--ease-out);
  display: inline-block;
}
.hero-feature:hover .hero-feature-cta { transform: translateX(4px); }

@media (max-width: 600px) {
  .hero-intro-stats { grid-template-columns: repeat(2, 1fr); gap: var(--space-4); }
  .hero-intro-title { font-size: var(--text-5xl); }
  .hero-feature { min-height: 300px; }
}

/* ─── SECTION primitives ─── */
.section-eyebrow {
  font-size: var(--text-xs); letter-spacing: var(--tracking-widest);
  text-transform: uppercase; color: var(--gold-600);
  margin-bottom: var(--space-3);
}
.section-title {
  font-family: var(--ff-display);
  font-size: var(--text-4xl);
  font-weight: 600; line-height: var(--leading-tight);
  letter-spacing: var(--tracking-tight);
  margin: 0;
}

/* ─── BENTO categories — Apple/Linear asymmetric grid с photo backgrounds ─── */
.cat-section { padding: var(--space-12) 0 var(--space-12); }
