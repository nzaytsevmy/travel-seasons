<script>
  const dash = document.getElementById('dash');
  if (dash) {
    const tbody = dash.querySelector('tbody');
    const moreRow = document.getElementById('moreRow'), moreN = document.getElementById('moreN');
    const allRows = [...tbody.querySelectorAll('tr:not(#moreRow)')];
    const CAP = 5;
    const state = { m: new Date().getMonth() + 1, b: null, vibe: null, sort: 'rel' };
    const PREP = ['', 'январе','феврале','марте','апреле','мае','июне','июле','августе','сентябре','октябре','ноябре','декабре'];
    const pl = (n) => (n % 10 === 1 && n % 100 !== 11 ? 'направление' : (n % 10 >= 2 && n % 10 <= 4 && (n % 100 < 10 || n % 100 >= 20) ? 'направления' : 'направлений'));
    const qcode = (tr) => (state.m ? (tr.dataset.r[state.m - 1] || '') : ''); // код сезона выбранного месяца
    const rank = (tr) => { const c = qcode(tr); return c === 'P' ? 0 : (c === 'G' ? 1 : 2); };
    const ordered = () => {
      if (state.sort === 'asc') return [...allRows].sort((a, b) => +a.dataset.budget - +b.dataset.budget);
      if (state.sort === 'desc') return [...allRows].sort((a, b) => +b.dataset.budget - +a.dataset.budget);
      if (state.m) { const idx = new Map(allRows.map((r, i) => [r, i])); return [...allRows].sort((a, b) => rank(a) - rank(b) || idx.get(a) - idx.get(b)); } // рекомендую: пик раньше хорошего
      return allRows; // без месяца — порядок подборки
    };
    function apply() {
      const list = ordered();
      list.forEach((r) => tbody.insertBefore(r, moreRow)); // переставить под текущую сортировку
      let n = 0, shown = 0; const names = [];
      list.forEach((c) => {
        const code = qcode(c);
        const vibe = c.dataset.vibe ? c.dataset.vibe.split(',') : [];
        let ok = true;
        if (state.m && code !== 'P' && code !== 'G') ok = false; // в сезоне = пик ИЛИ хороший (не только пик)
        if (state.b && c.dataset.b !== state.b) ok = false;
        if (state.vibe && !vibe.includes(state.vibe)) ok = false; // вайб должен реально совпадать (без тегов — не под конкретный)
        const sq = c.querySelector('.sq'); // бейдж качества сезона выбранного месяца
        if (sq) {
          if (state.m && (code === 'P' || code === 'G')) { sq.hidden = false; sq.textContent = code === 'P' ? 'пик сезона' : 'хороший сезон'; sq.className = 'sq ' + (code === 'P' ? 'peak' : 'good'); }
          else sq.hidden = true;
        }
        if (ok) {
          n++;
          if (shown < CAP) { c.hidden = false; shown++; if (names.length < 6) names.push(c.querySelector('.nm').textContent); }
          else c.hidden = true;
        } else c.hidden = true;
      });
      document.getElementById('fCountN').textContent = n;
      document.getElementById('fCountW').textContent = pl(n);
      document.getElementById('noMatch').style.display = n ? 'none' : 'block';
      if (moreRow) { if (n > CAP) { moreN.textContent = n - CAP; moreRow.hidden = false; } else moreRow.hidden = true; }
      const sl = document.getElementById('seasonlead');
      if (sl) sl.innerHTML = n
        ? `Сейчас, <b>${state.m ? 'в ' + PREP[state.m] : 'в любой месяц'}</b>, в сезоне ${n}: ${names.join(', ')}${n > names.length ? ' и др' : ''}.`
        : 'Под эти фильтры ничего не нашлось — ослабьте один: месяц, бюджет или настроение.';
    }
    const fMonth = document.getElementById('fMonth');
    if (fMonth) fMonth.value = String(state.m); // месяц по дате пользователя, а не по дате сборки
    fMonth.addEventListener('change', (e) => { state.m = +e.target.value; apply(); });
    document.querySelectorAll('.fopts[data-g]').forEach((g) => g.addEventListener('click', (e) => {
      const b = e.target.closest('.t'); if (!b) return;
      const grp = g.dataset.g, was = b.classList.contains('on');
      g.querySelectorAll('.t').forEach((x) => { x.classList.remove('on'); x.setAttribute('aria-pressed', 'false'); });
      if (!was) { b.classList.add('on'); b.setAttribute('aria-pressed', 'true'); state[grp] = b.dataset.v; } else state[grp] = null;
      apply();
    }));
    const sortOpts = document.getElementById('sortOpts');
    if (sortOpts) sortOpts.addEventListener('click', (e) => {
      const b = e.target.closest('.t'); if (!b) return;
      sortOpts.querySelectorAll('.t').forEach((x) => { x.classList.remove('on'); x.setAttribute('aria-pressed', 'false'); });
      b.classList.add('on'); b.setAttribute('aria-pressed', 'true'); state.sort = b.dataset.s; apply();
    });
    apply();
    // мини-хитмэп Бали — из реальных данных DIRECTIONS (data-pat), не хардкод
    const col = ['var(--gold)','var(--ink)','#9b9789','var(--hair)'];
    const h = document.getElementById('heat');
    if (h) JSON.parse(h.dataset.pat || '[]').forEach((p) => { const d = document.createElement('div'); d.className = 'mh'; d.style.cssText = 'height:1.6rem;background:' + col[p]; h.appendChild(d); });
  }
</script>
