---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { data as regions } from '../data/regions.js';
import { PRICES } from '../data/prices.js';
import fs from 'node:fs';
import path from 'node:path';

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://traveltribe.ru/#website",
      "name": "TravelTribe",
      "url": "https://traveltribe.ru/",
      "description": "Бесплатный open source сервис для путешественников: сезоны, виза, бюджет для 39 направлений мира",
      "inLanguage": "ru-RU",
      "publisher": { "@id": "https://traveltribe.ru/#org" }
    },
    {
      "@type": "Organization",
      "@id": "https://traveltribe.ru/#org",
      "name": "TravelTribe",
      "url": "https://traveltribe.ru/",
      "logo": "https://traveltribe.ru/og-image.png",
      "founder": { "@type": "Person", "name": "Никита Зайцев", "url": "https://t.me/traveltriberu" },
      "sameAs": [
        "https://t.me/traveltriberu",
        "https://github.com/nzaytsevmy/travel-seasons"
      ]
    }
  ]
};

const MONTHS = [
  { slug: 'january',   name: 'январе',   nameNom: 'Январь'   },
  { slug: 'february',  name: 'феврале',  nameNom: 'Февраль'  },
  { slug: 'march',     name: 'марте',    nameNom: 'Март'     },
  { slug: 'april',     name: 'апреле',   nameNom: 'Апрель'   },
  { slug: 'may',       name: 'мае',      nameNom: 'Май'      },
  { slug: 'june',      name: 'июне',     nameNom: 'Июнь'     },
  { slug: 'july',      name: 'июле',     nameNom: 'Июль'     },
  { slug: 'august',    name: 'августе',  nameNom: 'Август'   },
  { slug: 'september', name: 'сентябре', nameNom: 'Сентябрь' },
  { slug: 'october',   name: 'октябре',  nameNom: 'Октябрь'  },
  { slug: 'november',  name: 'ноябре',   nameNom: 'Ноябрь'   },
  { slug: 'december',  name: 'декабре',  nameNom: 'Декабрь'  },
];
const monthIdx = new Date().getMonth();
const currentMonth = MONTHS[monthIdx];

const VISA_LABEL = { free: 'Без визы', evisa: 'eVisa', required: 'Виза' };
const VISA_CLASS = { free: 'tag-free', evisa: 'tag-evisa', required: 'tag-visa' };
const BUDGET_LABEL = { low: '$', mid: '$$', high: '$$$' };

// Build directions list with their group label
const directions: any[] = [];
let groupLabel = '';
for (const r of regions) {
  if ((r as any).group) {
    groupLabel = (r as any).group.replace(/^[^\s]+\s/, '');
  } else {
    directions.push({ ...r, group: groupLabel });
  }
}

// Match regions to PRICES by name fragment to get IATA + flight
let livePrices: Record<string, number> = {};
try {
  const pjson = JSON.parse(fs.readFileSync(path.resolve('./public/prices.json'), 'utf8'));
  livePrices = pjson.prices || {};
} catch (e) { /* fallback to estimates */ }

function findPrice(d: any) {
  const norm = (s: string) => s.toLowerCase().replace(/[^a-zа-я0-9]/gi, '');
  const dn = norm(d.region) + norm(d.sub);
  return PRICES.find((p: any) => {
    const pn = norm(p.name);
    return dn.includes(norm(p.name.split(' ')[0])) || pn.includes(norm(d.region));
  });
}

// Top 6 peak destinations for current month, sorted by cheapest flight
const peakNow = directions
  .filter(d => d.r[monthIdx] === 'P')
  .map(d => {
    const price = findPrice(d);
    const liveFlight = price?.iata && livePrices[price.iata];
    return {
      ...d,
      flight: (liveFlight || price?.flight?.[0]) as number | undefined,
    };
  })
  .sort((a, b) => (a.flight || 9999) - (b.flight || 9999))
  .slice(0, 6);
---
<Layout
  title="TravelTribe — сезоны, бюджет, виза для россиян"
  description="Бесплатный open source сервис для путешественников из России: таблица сезонов, виза, бюджет и калькулятор перелёта для 39 направлений мира."
  canonical="https://traveltribe.ru/"
  ogTitle="TravelTribe — Куда ехать и когда"
  ogDescription="Бесплатный open source сервис: таблица сезонов, виза и бюджет для 39 направлений. Калькулятор перелёта из Москвы."
  ldJson={ldJson}
>
  <Nav active="home" />

  <main id="main">
    <div class="hero">
      <div class="hero-bg"></div>
      <div class="hero-content">
        <div class="hero-tag">// Open Source · Бесплатно навсегда</div>
        <h1>Куда поехать: <em>сезоны,<br>визы и бюджет</em></h1>
        <p class="hero-sub">Интерактивный инструмент для путешественников из России — виза, сезоны, бюджет и живые цены для 39 направлений мира.</p>
        <div class="hero-actions">
          <a class="btn-primary" href="/seasons/">Открыть таблицу сезонов</a>
          <a class="btn-ghost" href="/calculator/">Калькулятор бюджета</a>
        </div>
        <div class="hero-stats">
          <div><div class="stat-val">39</div><div class="stat-label">Регионов мира</div></div>
          <div><div class="stat-val">12</div><div class="stat-label">Месяцев</div></div>
          <div><div class="stat-val">0 ₽</div><div class="stat-label">Стоимость</div></div>
          <div><div class="stat-val">2026</div><div class="stat-label">Актуально</div></div>
        </div>
      </div>
    </div>

    <div class="pills-row">
      <span class="pill pill-os">⊹ Open Source</span>
      <span class="pill pill-free">✓ Бесплатно навсегда</span>
      <span class="pill pill-uni">◈ Без воды и рекламы</span>
    </div>

    <hr class="divider" />

    <div class="section">
      <div class="section-label">// Календарь · {currentMonth.nameNom} 2026</div>
      <h2 class="section-title">Куда поехать <em>в {currentMonth.name}</em></h2>
      <p class="section-sub">Топ-{peakNow.length} направлений с пиком сезона прямо сейчас. Реальные цены на перелёт из Москвы, виза для россиян, бюджет на день.</p>

      <div class="trending-grid">
        {peakNow.map((d) => (
          <a href="/seasons/" class="trending-card">
            <div class="tc-head">
              <div class="tc-region">{d.group}</div>
              <div class="tc-peak">🔥 Пик</div>
            </div>
            <h3 class="tc-title">{d.region}</h3>
            <p class="tc-sub">{d.sub}</p>
            <div class="tc-tags">
              <span class={`tag ${VISA_CLASS[d.visa]}`}>{VISA_LABEL[d.visa]}</span>
              <span class="tc-budget">{BUDGET_LABEL[d.budget]}</span>
            </div>
            <div class="tc-bar" aria-hidden="true">
              {d.r.map((s: string, i: number) => (
                <div class={`tc-mo s-${s} ${i === monthIdx ? 'is-current' : ''}`} aria-hidden="true"></div>
              ))}
            </div>
            <div class="tc-footer">
              <span class="tc-price">{d.flight ? `от $${d.flight}` : 'цены уточняй'}</span>
              <span class="tc-arrow">→</span>
            </div>
          </a>
        ))}
      </div>

      <div class="month-pills-wrap">
        <div class="month-pills-label">Или выбери другой месяц:</div>
        <div class="calendar-promo-grid">
          {MONTHS.map((m) => (
            <a href={`/trips/${m.slug}/`} class={`cm-pill ${m.slug === currentMonth.slug ? 'is-current' : ''}`}>{m.nameNom.slice(0,3)}</a>
          ))}
        </div>
      </div>
    </div>

    <hr class="divider" />

    <div class="section">
      <div class="section-label">// Инструменты</div>
      <h2 class="section-title">Всё для <em>планирования</em></h2>
      <p class="section-sub">Только то, чего нет на других сайтах.</p>
      <div class="features">
        <div class="feature">
          <div class="feature-icon">🗓</div>
          <div class="feature-title">Таблица сезонов</div>
          <div class="feature-desc">39 регионов × 12 месяцев. Фильтр по месяцу, виза и бюджет для каждого направления.</div>
        </div>
        <div class="feature">
          <div class="feature-icon">💰</div>
          <div class="feature-title">Калькулятор бюджета</div>
          <div class="feature-desc">Живые цены Aviasales + курс ЦБ РФ. Перелёт, отель, еда — выбираешь что считать.</div>
        </div>
        <div class="feature">
          <div class="feature-icon">🛂</div>
          <div class="feature-title">Визовый статус</div>
          <div class="feature-desc">Без визы, eVisa или виза — актуально для россиян на 2026 год.</div>
        </div>
        <div class="feature">
          <div class="feature-icon">📱</div>
          <div class="feature-title">Telegram-канал</div>
          <div class="feature-desc">Личный опыт, маршруты и лайфхаки — @traveltriberu.</div>
        </div>
      </div>
    </div>

    <hr class="divider" />

    <div class="section">
      <div class="contribute">
        <div class="contribute-text">
          <h3>Добавь своё <em>направление</em></h3>
          <p>Знаешь регион которого здесь нет? Проект открытый — добавь данные, исправь ошибку или предложи фичу. Любой вклад приветствуется.</p>
        </div>
        <a class="contribute-btn" href="https://github.com/nzaytsevmy/traveltribe-feedback" target="_blank" rel="noopener">→ Contribute on GitHub</a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>


<style>
/* ─── HERO ─── */
.hero {
  min-height: calc(100vh - 64px); display: grid; place-items: center;
  position: relative; overflow: hidden; padding: 4rem 2rem;
}
.hero-bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 65% 35%, var(--hero-glow-1) 0%, transparent 60%),
    radial-gradient(ellipse 50% 70% at 20% 75%, var(--hero-glow-2) 0%, transparent 50%);
}
/* Force browsers to repaint radial gradient on theme switch */
html.light-theme .hero-bg {
  background:
    radial-gradient(ellipse 70% 60% at 65% 35%, var(--hero-glow-1) 0%, transparent 60%),
    radial-gradient(ellipse 50% 70% at 20% 75%, var(--hero-glow-2) 0%, transparent 50%);
}
.hero-content { position: relative; text-align: center; max-width: 820px; z-index: 1; }
.hero-tag {
  display: inline-flex; align-items: center; gap: 0.5rem;
  font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--gold); border: 1px solid rgba(201,151,58,0.3);
  background: rgba(201,151,58,0.08); padding: 0.3rem 0.85rem; border-radius: 20px;
  margin-bottom: 1.8rem;
}
.hero h1 {
  font-family: var(--ff-display); font-size: clamp(3rem, 7vw, 6.5rem);
  font-weight: 300; line-height: 1.0; letter-spacing: -0.01em; margin-bottom: 1.4rem;
}
.hero h1 em { color: var(--gold); font-style: italic; }
.hero-sub { color: var(--text-dim); font-size: clamp(0.9rem, 1.5vw, 1.05rem); line-height: 1.7; max-width: 500px; margin: 0 auto 2.2rem; }
.hero-actions { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; margin-bottom: 3.5rem; }
.btn-primary {
  background: var(--gold); color: #0c0a08; font-weight: 500;
  padding: 13px 28px; border-radius: 3px; font-size: 0.85rem;
  letter-spacing: 0.06em; text-transform: uppercase; border: none; cursor: pointer;
  font-family: var(--ff-body); transition: box-shadow 0.25s;
}
.btn-primary:hover { box-shadow: 0 0 28px var(--gold-glow), 0 0 60px var(--gold-glow); }
.btn-ghost {
  background: transparent; color: var(--gold); font-weight: 400;
  padding: 13px 28px; border-radius: 3px; font-size: 0.85rem;
  border: 1px solid rgba(201,151,58,0.35); letter-spacing: 0.06em; text-transform: uppercase;
  cursor: pointer; font-family: var(--ff-body);
}
.btn-ghost:hover { background: var(--gold-glow); box-shadow: 0 0 18px var(--gold-glow); }
.hero-stats {
  display: flex; gap: 2.5rem; justify-content: center; flex-wrap: wrap;
  padding-top: 2rem; border-top: 1px solid var(--line);
}
.stat-val { font-family: var(--ff-display); font-size: 2.4rem; color: var(--gold); font-weight: 300; line-height: 1; }
.stat-label { font-size: 0.62rem; color: var(--text-faint); letter-spacing: 0.1em; text-transform: uppercase; margin-top: 0.3rem; }

/* ─── PILLS ─── */
.pills-row {
  max-width: 1200px; margin: 0 auto; padding: 0 2rem 3rem;
  display: flex; flex-wrap: wrap; gap: 0.6rem; align-items: center; position: relative; z-index: 1;
}
.pill { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.68rem; letter-spacing: 0.06em; padding: 0.28rem 0.7rem; border-radius: 20px; border: 1px solid; }
.pill-os   { color: var(--gold);  border-color: rgba(201,151,58,0.3); background: rgba(201,151,58,0.07); }
.pill-free { color: var(--peak-text); border-color: rgba(34,197,94,0.3);  background: rgba(34,197,94,0.07);  }
.pill-uni  { color: var(--good-text); border-color: rgba(74,158,255,0.3); background: rgba(74,158,255,0.07); }

/* ─── SECTION ─── */
.section { max-width: 1200px; margin: 0 auto; padding: 3rem 2rem 5rem; position: relative; z-index: 1; }
.section-label { font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.6rem; }
.section-title { font-family: var(--ff-display); font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 300; letter-spacing: -0.01em; margin-bottom: 0.4rem; line-height: 1.15; }
.section-title em { color: var(--gold); font-style: italic; }
.section-sub { color: var(--text-dim); font-size: 0.88rem; line-height: 1.7; max-width: 440px; margin-bottom: 2rem; }

/* ─── TRENDING GRID (peak now) ─── */
.trending-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1px; background: var(--line);
  border: 1px solid var(--line); border-radius: 4px;
  overflow: hidden; margin-top: 1.5rem;
}
.trending-card {
  background: var(--bg); padding: 1.4rem 1.3rem 1.1rem;
  display: flex; flex-direction: column; gap: 0.5rem;
  position: relative; overflow: hidden;
  transition: background 0.25s ease;
}
.trending-card:hover { background: var(--bg3); }
.trending-card::before {
  content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold-dim), transparent);
  opacity: 0; transition: opacity 0.3s ease;
}
.trending-card:hover::before { opacity: 1; }

.tc-head { display: flex; justify-content: space-between; align-items: center; }
.tc-region {
  font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--text-faint);
}
.tc-peak {
  font-size: 0.62rem; letter-spacing: 0.06em; text-transform: uppercase;
  color: var(--peak-text); font-weight: 500;
}
.tc-title {
  font-family: var(--ff-display); font-size: 1.6rem; font-weight: 400;
  line-height: 1.15; margin: 0.2rem 0 0;
}
.tc-sub {
  color: var(--text-faint); font-size: 0.74rem;
  letter-spacing: 0.02em; margin: 0 0 0.5rem;
}
.tc-tags { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.3rem; }
.tc-budget {
  font-size: 0.7rem; color: var(--gold); font-weight: 500;
  padding: 0.18rem 0.4rem; border: 1px solid rgba(201,151,58,0.25);
  border-radius: 2px; background: rgba(201,151,58,0.06);
}

.tc-bar { display: flex; gap: 2px; margin: 0.3rem 0 0.4rem; }
.tc-mo {
  flex: 1; height: 6px; border-radius: 2px;
  position: relative;
}
.tc-mo.is-current {
  outline: 2px solid var(--gold); outline-offset: 1px; border-radius: 2px;
}

.tc-footer {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: auto; padding-top: 0.6rem; border-top: 1px solid var(--line);
}
.tc-price { font-size: 0.78rem; color: var(--text); font-weight: 500; }
.tc-arrow { color: var(--text-faint); transition: transform 0.15s ease, color 0.25s ease; }
.trending-card:hover .tc-arrow { transform: translateX(3px); color: var(--gold); }

/* Reuse season bar colors from Card.astro */
.tc-mo.s-P { background: #22c55e; }
.tc-mo.s-G { background: #4a9eff; }
.tc-mo.s-O { background: #f59e0b; }
.tc-mo.s-B { background: #ef4444; }
.tc-mo.s-X { background: rgba(201,151,58,0.15); }

@media (max-width: 900px) {
  .trending-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 540px) {
  .trending-grid { grid-template-columns: 1fr; }
}

/* ─── MONTH PILLS (compact selector under trending) ─── */
.month-pills-wrap { margin-top: 2.5rem; }
.month-pills-label {
  font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--text-faint); margin-bottom: 0.7rem;
}
.calendar-promo-grid {
  display: grid; grid-template-columns: repeat(12, 1fr); gap: 0.4rem;
}
.cm-pill {
  display: flex; align-items: center; justify-content: center;
  background: var(--bg2); border: 1px solid var(--line); border-radius: 3px;
  padding: 0.7rem 0.4rem; font-size: 0.78rem; color: var(--text-dim);
  letter-spacing: 0.04em; font-weight: 500;
  transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
}
.cm-pill:hover { border-color: var(--gold-dim); color: var(--gold); background: var(--bg3); }
.cm-pill.is-current {
  border-color: var(--gold); color: var(--gold);
  background: rgba(201,151,58,0.08);
}

@media (max-width: 720px) {
  .calendar-promo-grid { grid-template-columns: repeat(6, 1fr); }
}

.features { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1px; background: var(--line); }
.feature { background: var(--bg); padding: 1.6rem; position: relative; overflow: hidden; }
.feature::before {
  content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold-dim), transparent);
  opacity: 0; transition: opacity 0.3s;
}
.feature:hover { background: var(--bg3); }
.feature:hover::before { opacity: 1; }
.feature-icon { font-size: 1.5rem; margin-bottom: 0.8rem; }
.feature-title { font-family: var(--ff-display); font-size: 1.15rem; font-weight: 400; margin-bottom: 0.35rem; }
.feature-desc { color: var(--text-dim); font-size: 0.78rem; line-height: 1.6; }

/* ─── CONTRIBUTE ─── */
.contribute {
  background: var(--bg2); border: 1px solid var(--line); border-radius: 3px;
  padding: 2rem 2.5rem; display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 1.5rem; position: relative; overflow: hidden;
}
.contribute::before {
  content: ""; position: absolute; top: -1px; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold-dim), transparent);
}
.contribute-text h3 { font-family: var(--ff-display); font-size: 1.8rem; font-weight: 300; margin-bottom: 0.4rem; line-height: 1.2; }
.contribute-text h3 em { color: var(--gold); font-style: italic; }
.contribute-text p { color: var(--text-dim); font-size: 0.83rem; line-height: 1.6; max-width: 480px; }
.contribute-btn {
  font-size: 0.78rem; font-weight: 400; letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--gold); border: 1px solid rgba(201,151,58,0.35);
  background: rgba(201,151,58,0.08); padding: 10px 20px; border-radius: 3px; white-space: nowrap;
}
.contribute-btn:hover { background: var(--gold-glow); box-shadow: 0 0 18px var(--gold-glow); }

.divider { border: none; border-top: 1px solid var(--line); margin: 0 2rem; }
</style>
