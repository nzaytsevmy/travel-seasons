---
import { getCollection } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import authorPhoto from '../assets/author/nikita.jpg';
import { DIRECTIONS, MONTHS } from '../data/directions.js';
import { Icon } from 'astro-icon/components';

// Search autocomplete data
const searchOptions = DIRECTIONS.map(d => ({
  label: d.cases.nom,
  slug: d.slug,
  region: d.region,
  sub: d.sub,
}));

// Сгруппировано по первой букве — для алфавитного listbox под input
const sortedSearchOptions = [...searchOptions].sort((a, b) => a.label.localeCompare(b.label, 'ru'));
const grouped = sortedSearchOptions.reduce<Record<string, typeof sortedSearchOptions>>((acc, o) => {
  const letter = o.label.charAt(0).toUpperCase();
  (acc[letter] ||= []).push(o);
  return acc;
}, {});
const letters = Object.keys(grouped).sort((a, b) => a.localeCompare(b, 'ru'));

const currentMonthSlug = MONTHS[new Date().getMonth()].slug;

// ── Schema ───────────────────────────────────────────
const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://traveltribe.ru/#website",
      "name": "TravelTribe",
      "url": "https://traveltribe.ru/",
      "description": "Авторский тревел-блог из России: личные отчёты, визы, сезоны, бюджет 39 направлений мира",
      "inLanguage": "ru-RU",
      "publisher": { "@id": "https://traveltribe.ru/#org" },
      "potentialAction": {
        "@type": "SearchAction",
        "target": { "@type": "EntryPoint", "urlTemplate": "https://traveltribe.ru/?s={search_term_string}" },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "@id": "https://traveltribe.ru/#org",
      "name": "TravelTribe",
      "url": "https://traveltribe.ru/",
      "logo": "https://traveltribe.ru/brand-mark.svg",
      "founder": { "@type": "Person", "name": "Никита Зайцев", "url": "https://t.me/traveltriberu" },
      "sameAs": ["https://t.me/traveltriberu", "https://github.com/nzaytsevmy/travel-seasons"]
    }
  ]
};

// ── Posts ─────────────────────────────────────────
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = allPosts[0];
const restPosts = allPosts.slice(1, 7);

function readingTime(body: string) {
  return Math.max(1, Math.ceil(body.trim().split(/\s+/).length / 200));
}

// ── Bento categories — все ведут на /<slug>/ кратко-хабы (унифицировано)
import antarcticaCover from '../assets/destinations/antarctica.jpg';
import japanCover      from '../assets/destinations/japan.jpg';
import baliCover       from '../assets/destinations/bali.jpg';
import ecuadorCover    from '../assets/destinations/ecuador.jpg';
import nzCover         from '../assets/destinations/new-zealand.jpg';
import georgiaCover    from '../assets/destinations/georgia.jpg';

const CATEGORIES = [
  { label: 'Антарктида',     sub: 'Круиз · 750k–4.5M ₽',   href: '/antarctica/',  cover: antarcticaCover, size: 'lg' },
  { label: 'Япония',         sub: 'Виза · сезоны · бюджет', href: '/japan/',       cover: japanCover,      size: 'lg' },
  { label: 'Бали',           sub: '6 районов',              href: '/bali/',        cover: baliCover,       size: 'md' },
  { label: 'Эквадор',        sub: 'Галапагосы',             href: '/ecuador/',     cover: ecuadorCover,    size: 'md' },
  { label: 'Новая Зеландия', sub: 'Южное сияние',           href: '/new-zealand/', cover: nzCover,         size: 'md' },
  { label: 'Грузия',         sub: 'Безвиз · от $50/день',   href: '/georgia/',     cover: georgiaCover,    size: 'md' },
];

const MONTHS_RU = ['январе','феврале','марте','апреле','мае','июне','июле','августе','сентябре','октябре','ноябре','декабре'];
const currentMonthRu = MONTHS_RU[new Date().getMonth()];

// LCP candidate — featured cover. Preload через Layout prop.
const featuredImageUrl = featured ? (await getImage({
  src: featured.data.coverImage,
  width: 1024,
  format: 'webp',
  quality: 72,
})).src : undefined;
---
<Layout
  title="TravelTribe — авторский тревел-блог из России"
  description="Личные отчёты Никиты Зайцева о путешествиях. Визы, сезоны, реальные бюджеты для 39 направлений мира — Антарктида, Япония, Бали, Африка, Латам."
  canonical="https://traveltribe.ru/"
  ogTitle="TravelTribe — авторский тревел-блог из России"
  ogDescription="60+ стран, 7 континентов. Личные отчёты, реальные цены 2026, без воды и рекламы."
  ldJson={ldJson}
  preloadImage={featuredImageUrl}
>
  <Nav active="home" />

  <main id="main">
    {/* ─── HERO — split: brand intro слева, featured story справа ─── */}
    {featured && (
      <section class="hero-split">
        <div class="hero-intro">
          <div class="hero-intro-eyebrow">// Travel-блог · Россия</div>
          <h1 class="hero-intro-title">
            Реальные путешествия. <em>Без воды.</em>
          </h1>
          <p class="hero-intro-desc">
            Личные отчёты, актуальные визы, реальные цены 2026 для 52 направлений мира. То что работает прямо сейчас — без рекламы и партнёрских туров.
          </p>

          <form class="hero-search" id="heroSearch" autocomplete="off" data-month={currentMonthSlug} role="search">
            <label for="hero-search-input" class="hero-search-label">Куда хочешь поехать?</label>
            <div class="hero-search-row">
              <svg class="hero-search-icon" viewBox="0 0 16 16" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <circle cx="7" cy="7" r="5"></circle><line x1="11" y1="11" x2="14.5" y2="14.5"></line>
              </svg>
              <input
                id="hero-search-input"
                name="q"
                type="search"
                placeholder="Япония, Бали, Грузия, Антарктида…"
                class="hero-search-input"
                role="combobox"
                aria-expanded="false"
                aria-controls="hero-search-list"
                aria-autocomplete="list"
              />
              <button type="submit" class="hero-search-btn">
                <span>Найти</span>
                <span aria-hidden="true">→</span>
              </button>
            </div>
            <div id="hero-search-list" class="hero-list" role="listbox" aria-label="Все направления по алфавиту">
              {letters.map(letter => (
                <div class="hero-list-group" data-letter={letter}>
                  <div class="hero-list-letter" aria-hidden="true">{letter}</div>
                  <ul class="hero-list-items">
                    {grouped[letter].map(o => (
                      <li>
                        <a
                          href={`/${o.slug}/`}
                          class="hero-list-item"
                          role="option"
                          data-label={o.label.toLowerCase()}
                          data-region={o.region.toLowerCase()}
                        >
                          <span class="hero-list-name">{o.label}</span>
                          <span class="hero-list-region">{o.region}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
              <p class="hero-list-empty" hidden>Ничего не нашлось — попробуй другую страну или регион</p>
            </div>
          </form>
          <div class="hero-intro-stats">
            <div><strong>52</strong><span>направления</span></div>
            <div><strong>7</strong><span>континентов</span></div>
            <div><strong>{allPosts.length}</strong><span>лонгрида</span></div>
            <div><strong>800+</strong><span>страниц</span></div>
          </div>
          <div class="hero-intro-cta">
            <a href="/blog/" class="hero-btn-primary">Читать блог</a>
            <a href="/seasons/" class="hero-btn-ghost">Куда ехать сейчас</a>
          </div>
        </div>

        <a class="hero-feature" href={`/blog/${featured.slug}/`}>
          <div class="hero-feature-image">
            <Image
              src={featured.data.coverImage}
              alt={featured.data.title}
              widths={[640, 1024, 1400]}
              sizes="(max-width: 960px) 100vw, 50vw"
              formats={['avif', 'webp']}
              fallbackFormat="jpg"
              quality={72}
              loading="eager"
              fetchpriority="high"
              style={`object-position: ${featured.data.coverPosition || 'center'};`}
            />
            <div class="hero-feature-overlay"></div>
          </div>
          <div class="hero-feature-content">
            <div class="hero-feature-meta">
              <span class="hero-feature-tag">Свежее · {featured.data.tags?.[0] || 'История'}</span>
              {featured.data.sourceType === 'personal' && featured.data.tripPlace && (
                <span class="hero-feature-trip">✓ Был лично</span>
              )}
            </div>
            <h2 class="hero-feature-title">{featured.data.title}</h2>
            <span class="hero-feature-cta">Читать историю →</span>
          </div>
        </a>
      </section>
    )}

    {/* ─── Categories Bento (Apple/Linear-style asymmetric grid с photo) ─── */}
    <section class="cat-section">
      <div class="cat-container">
        <div class="section-eyebrow">// Направления</div>
        <h2 class="section-title">Куда поехать</h2>
        <div class="bento-grid">
          {CATEGORIES.map((c, i) => (
            <a href={c.href} class={`bento-card bento-card--${c.size}`}>
              <Image
                src={c.cover}
                alt={c.label}
                widths={[400, 800, 1200]}
                sizes="(max-width: 700px) 100vw, (max-width: 1100px) 50vw, 33vw"
                formats={['avif', 'webp']}
                quality={68}
                loading={i < 2 ? 'eager' : 'lazy'}
                style={`object-position: ${c.objPos || 'center'};`}
              />
              <div class="bento-overlay"></div>
              <div class="bento-content">
                <div class="bento-sub">{c.sub}</div>
                <div class="bento-label">{c.label}</div>
              </div>
              <span class="bento-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* ─── Latest posts grid ─── */}
    {restPosts.length > 0 && (
      <section class="latest-section">
        <div class="latest-container">
          <header class="latest-header">
            <div class="section-eyebrow">// Последние истории</div>
            <h2 class="section-title">Свежие посты</h2>
            <a href="/blog/" class="latest-all">Все статьи →</a>
          </header>
          <div class="latest-grid">
            {restPosts.map((post) => (
              <a href={`/blog/${post.slug}/`} class="latest-card">
                <div class="latest-cover">
                  <Image
                    src={post.data.coverImage}
                    alt={post.data.title}
                    widths={[400, 720]}
                    sizes="(max-width: 700px) 100vw, 33vw"
                    formats={['avif', 'webp']}
                    quality={68}
                    loading="lazy"
                    style={`object-position: ${post.data.coverPositionCard || post.data.coverPosition || 'center'};`}
                  />
                </div>
                <div class="latest-body">
                  <div class="latest-tags">
                    {post.data.tags?.slice(0, 2).map((t) => (
                      <span class="latest-tag">{t}</span>
                    ))}
                  </div>
                  <h3 class="latest-title">{post.data.title}</h3>
                  <p class="latest-desc">{post.data.description}</p>
                  <div class="latest-meta">
                    <span>{readingTime(post.body)} мин</span>
                    {post.data.sourceType === 'personal' && <span class="latest-personal">· Был лично</span>}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* ─── Tools strip — calc + seasons + visa-map ─── */}
    <section class="tools-section">
      <div class="tools-container">
        <div class="section-eyebrow">// Инструменты</div>
        <div class="tools-grid">
          <a href="/seasons/" class="tool-card">
            <Icon name="lucide:calendar-days" class="tool-icon" />
            <strong>Таблица сезонов</strong>
            <span>52 направления × 12 месяцев. Когда лучше ехать.</span>
          </a>
          <a href="/calculator/" class="tool-card">
            <Icon name="lucide:wallet" class="tool-icon" />
            <strong>Калькулятор бюджета</strong>
            <span>Перелёт + проживание + еда. Живой курс ЦБ.</span>
          </a>
          <a href="/trips/" class="tool-card">
            <Icon name="lucide:globe-2" class="tool-icon" />
            <strong>Календарь поездок</strong>
            <span>Что работает в каждом месяце 2026.</span>
          </a>
          <a href="/blog/" class="tool-card">
            <Icon name="lucide:book-open" class="tool-icon" />
            <strong>Блог</strong>
            <span>Личные отчёты автора. {allPosts.length} статей.</span>
          </a>
        </div>
      </div>
    </section>

    {/* ─── Newsletter — Telegram-канал (Email убран — в РФ Telegram > Email) ─── */}
    <section class="news-section">
      <div class="news-container">
        <div class="news-head">
          <div class="section-eyebrow">// Telegram-канал</div>
          <h2>Свежие истории и апдейты виз</h2>
          <p>Личные истории из текущих поездок, оперативные апдейты виз и неочевидные открытия. Без воды и рекламы. Раз в 2-3 дня.</p>
        </div>

        <a class="news-tg-big" href="https://t.me/traveltriberu" target="_blank" rel="noopener">
          <span class="news-tg-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.446 1.394c-.14.18-.357.295-.6.295l.213-3.053 5.56-5.022c.24-.213-.054-.334-.373-.121l-6.869 4.326-2.96-.924c-.64-.203-.658-.643.135-.953l11.566-4.458c.538-.196 1.006.128.832.937z"/></svg>
          </span>
          <span class="news-tg-text">
            <strong>@traveltriberu</strong>
            <span>Подписаться в Telegram</span>
          </span>
          <span class="news-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    {/* ─── Author strip ─── */}
    <section class="author-section">
      <a href="/about/" class="author-strip">
        <Image
          src={authorPhoto}
          alt="Никита Зайцев — автор TravelTribe"
          width={88}
          height={88}
          format="webp"
          quality={82}
          loading="lazy"
          class="author-photo"
        />
        <div class="author-text">
          <strong>Никита Зайцев</strong>
          <span>7 континентов · 60+ стран · 13 лет в продуктах · авторский блог без рекламы</span>
        </div>
        <span class="author-arrow">→</span>
      </a>
    </section>
  </main>

  <Footer />
</Layout>

<script is:inline define:vars={{ searchOptions, currentMonthSlug }}>
  // Hero search: combobox с алфавитным listbox + live-фильтр + submit-фолбек
  const heroForm = document.getElementById('heroSearch');
  if (heroForm) {
    const input = heroForm.querySelector('input[name="q"]');
    const list  = document.getElementById('hero-search-list');
    const items = list ? Array.from(list.querySelectorAll('.hero-list-item')) : [];
    const groups = list ? Array.from(list.querySelectorAll('.hero-list-group')) : [];
    const empty = list ? list.querySelector('.hero-list-empty') : null;

    function open() {
      if (!list) return;
      list.classList.add('is-open');
      input.setAttribute('aria-expanded', 'true');
    }
    function close() {
      if (!list) return;
      list.classList.remove('is-open');
      input.setAttribute('aria-expanded', 'false');
    }
    function filter(q) {
      const query = (q || '').trim().toLowerCase();
      let visible = 0;
      items.forEach(a => {
        const label = a.dataset.label || '';
        const region = a.dataset.region || '';
        const match = !query || label.includes(query) || region.includes(query);
        a.parentElement.hidden = !match;
        if (match) visible++;
      });
      // Hide letter group if no items visible
      groups.forEach(g => {
        const has = Array.from(g.querySelectorAll('li')).some(li => !li.hidden);
        g.hidden = !has;
      });
      if (empty) empty.hidden = visible !== 0;
    }

    input.addEventListener('focus', open);
    input.addEventListener('input', () => { open(); filter(input.value); });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { close(); input.blur(); }
    });
    document.addEventListener('click', (e) => {
      if (!heroForm.contains(e.target)) close();
    });

    heroForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = (input.value || '').trim().toLowerCase();
      if (!q) return;

      const exact = searchOptions.find(o => o.label.toLowerCase() === q);
      const partial = exact || searchOptions.find(o =>
        o.label.toLowerCase().includes(q) ||
        o.region.toLowerCase().includes(q) ||
        o.sub.toLowerCase().includes(q)
      );

      if (partial) {
        window.location.href = `/${partial.slug}/`;
      } else {
        window.location.href = `/seasons/?q=${encodeURIComponent(q)}`;
      }
    });
  }
</script>

<style>
/* ─── HERO split: brand intro + featured story (Atlas Obscura / Outside pattern) ─── */
.hero-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  min-height: clamp(440px, 70vh, 680px);
  border-bottom: 1px solid var(--line);
}
@media (max-width: 960px) {
  .hero-split { grid-template-columns: 1fr; }
}

.hero-intro {
  display: flex; flex-direction: column; justify-content: center;
  padding: clamp(2rem, 6vw, 5rem) clamp(1.5rem, 5vw, 4rem);
  background: var(--bg);
}
.hero-intro-eyebrow {
  font-size: var(--text-xs); letter-spacing: var(--tracking-widest);
  text-transform: uppercase; color: var(--gold-600);
  margin-bottom: var(--space-4);
}
.hero-intro-title {
  font-family: var(--ff-display);
  font-size: var(--text-6xl);
  font-weight: 700;
  line-height: var(--leading-tight);
  letter-spacing: var(--tracking-tight);
  color: var(--text);
  margin: 0 0 var(--space-5);
  text-wrap: balance;
}
.hero-intro-title em { font-style: italic; color: var(--gold-600); font-weight: 600; }
.hero-intro-desc {
  font-size: var(--text-lg);
  line-height: var(--leading-relaxed);
  color: var(--text-dim);
  margin: 0 0 var(--space-6);
  max-width: 480px;
}
.hero-intro-stats {
  display: grid;
  grid-template-columns: repeat(4, auto);
  gap: var(--space-6);
  margin-bottom: var(--space-8);
  padding: var(--space-4) 0;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}
.hero-intro-stats > div { display: flex; flex-direction: column; gap: 2px; }
.hero-intro-stats strong {
  font-family: var(--ff-display);
  font-size: var(--text-3xl);
  font-weight: 700;
  color: var(--gold-600);
  font-variant-numeric: tabular-nums;
  letter-spacing: var(--tracking-tight);
}
.hero-intro-stats span {
  font-size: var(--text-xs);
  letter-spacing: var(--tracking-wide);
  color: var(--text-faint);
  text-transform: uppercase;
}
/* ─── Hero search bar (Skyscanner / Booking-style) ─── */
.hero-search {
  position: relative;
  margin: var(--space-6) 0 var(--space-7);
  display: flex; flex-direction: column; gap: var(--space-2);
  max-width: 480px;
}

/* ── Алфавитный listbox под input ── */
.hero-list {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  right: 0;
  max-height: 360px;
  overflow-y: auto;
  background: var(--bg2);
  border: 1px solid var(--line);
  border-radius: var(--radius-md, 10px);
  box-shadow: 0 18px 48px -12px rgba(0,0,0,0.18);
  padding: 0.5rem 0;
  z-index: 50;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-4px);
  transition: opacity 0.15s, transform 0.15s, visibility 0s linear 0.15s;
  scrollbar-width: thin;
  scrollbar-color: var(--gold-dim) var(--bg2);
}
.hero-list.is-open {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
  transition-delay: 0s;
}
.hero-list-group { padding: 0; }
.hero-list-letter {
  position: sticky;
  top: 0;
  background: var(--bg2);
  padding: 0.4rem 1rem 0.3rem;
  font-family: var(--ff-display);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--gold-600);
  border-bottom: 1px solid var(--line);
  z-index: 1;
}
.hero-list-items {
  list-style: none;
  margin: 0;
  padding: 0.25rem 0;
}
.hero-list-items li { margin: 0; padding: 0; }
.hero-list-item {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 0.75rem;
  padding: 0.55rem 1rem;
  text-decoration: none;
  color: var(--text);
  transition: background 0.12s;
}
.hero-list-item:hover { background: rgba(201,151,58,0.08); }
.hero-list-item:hover .hero-list-name { color: var(--gold); }
.hero-list-name { font-size: 0.92rem; font-weight: 500; }
.hero-list-region {
  font-size: 0.74rem;
  color: var(--text-faint);
  letter-spacing: 0.02em;
}
.hero-list-empty {
  margin: 0;
  padding: 1rem 1.2rem;
  font-size: 0.85rem;
  color: var(--text-faint);
  text-align: center;
}
.hero-search-label {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--text-dim);
}
.hero-search-row {
  display: flex; align-items: center;
  background: var(--bg2);
