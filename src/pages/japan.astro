---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
import EssentialsCard from '../components/EssentialsCard.astro';
import MonthlyEvents from '../components/MonthlyEvents.astro';
import CountryMap from '../components/CountryMap.astro';
import { DATA_UPDATED, DATA_UPDATED_RU } from '../data/meta.js';
import { buildEssentialsFaq } from '../data/essentials-faq.js';
import { TP_LINKS, aviasalesRoute } from '../data/affiliate.js';

const url = 'https://traveltribe.ru/japan/';

const faqs = [
  {
    q: 'Когда лучше ехать в Японию в 2026?',
    a: 'Оптимальные сезоны — октябрь–ноябрь (момидзи, красные клёны, +18°C, сухо) и конец марта — начало апреля (сакура, +15°C, но толпы и пик цен). Избегать: Золотая неделя 29 апреля — 6 мая (цены ×2.5–3, толпы), Обон (середина августа), сезон дождей цую (середина июня — середина июля), лета (+38°C, влажность 100%).'
  },
  {
    q: 'Сколько стоит виза в Японию для россиян в 2026?',
    a: 'Сама виза бесплатна (консульский сбор 0 ₽). Платится только сервисный сбор JVAC: 970 ₽ в Москве и СПб, до 2500 ₽ в региональных VFS. С февраля 2026 документы принимают только через JVAC под управлением VFS Global, посольство напрямую не работает с туристами. Срок 4–7 рабочих дней, отказы <5%, отели можно не выкупать заранее (новое правило с ноября 2024).'
  },
  {
    q: 'Какой бюджет на поездку в Японию в 2026?',
    a: 'Реальные диапазоны на день на одного: эконом — $50–80 (хостелы, чифаньки, общественный транспорт), комфорт — $150–250 (3* отели, нормальные рестораны, такси периодически), премиум — $300+ (4–5*, кайсэки, частный транспорт). Перелёт Москва → Токио с пересадкой $500–900 в обычные даты, $1100–1500 на Golden Week. Иена в 2026 слабая, что делает Японию доступнее обычного. Минимум 10 дней на Golden Route Токио — Хаконе — Киото — Осака.'
  },
  {
    q: 'Когда Золотая неделя в Японии в 2026?',
    a: 'С 29 апреля (среда) по 6 мая (среда) 2026 — 8 дней подряд. Это «Super Golden Week», случается раз в 5–7 лет благодаря удачному выпадению дней недели. Праздничные даты: 29 апреля (Showa Day), 3 мая (Constitution Memorial Day), 4 мая (Greenery Day), 5 мая (Children\'s Day), 6 мая (substitute holiday). 30 апреля и 1–2 мая — bridge-выходные. Цены ×2.5–3, толпы максимальные за год.'
  },
  {
    q: 'Нужен ли JR Pass в 2026?',
    a: 'Скорее нет. С октября 2023 цена JR Pass выросла на 70% (с 29 650 до 50 000 ¥ за 7 дней). Старая логика «всем брать» больше не работает. Считайте по конкретному маршруту: один билет Токио → Киото → Токио ~30 000 ¥, плюс местные поезда — JR Pass окупится только если планируете 4+ дальних переезда. Для стандартного маршрута Токио + Киото + Осака — выгоднее покупать билеты по отдельности через SmartEX или Klook.'
  },
  {
    q: 'Есть ли прямые рейсы Россия — Япония в 2026?',
    a: 'Нет. Прямых рейсов между Россией и Японией нет с марта 2022 и в обозримом будущем не будет. Все варианты — с пересадкой через Стамбул (Turkish), Дубай (Emirates), Доху (Qatar), Пекин/Шанхай (Air China, China Eastern), Сеул (Korean Air, Asiana). Время в пути 14–22 часа, цена $500–900 в обычные даты.'
  },
  {
    q: 'Что нельзя ввозить в Японию из России?',
    a: 'Главное — Корвалол, Валокордин (содержат фенобарбитал — это в Японии наркотик, депортация и запрет на въезд). Псевдоэфедрин (Sudafed, Actifed). Аддерол и амфетамин-содержащие. Из еды — мясо, сало, колбасу, мёд, цитрусовые. Свежие фрукты и овощи. Ограничения на алкоголь (3 бутылки) и сигареты (200 шт). Заполняйте таможенную декларацию честно — штрафы крупные.'
  },
  ...buildEssentialsFaq('japan', 'в Японии').filter(
    (item) => !/что\s+нельзя\s+ввозить/i.test(item.q)
  )
];

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#collection`,
      "url": url,
      "name": "Япония 2026: гайды, виза, сезоны для россиян",
      "description": "Полный обзор поездок в Японию из России в 2026: бесплатная виза, бюджет $50–300/день, лучшие сезоны (момидзи и сакура), Золотая неделя, главные гайды.",
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "about": { "@type": "Country", "name": "Япония" },
      "datePublished": "2026-04-30",
      "dateModified": DATA_UPDATED,
      "author": { "@id": "https://traveltribe.ru/about/#person" },
      "publisher": { "@id": "https://traveltribe.ru/#org" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", ".jp-tldr"] },
      "mainEntity": {
        "@type": "ItemList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "url": "https://traveltribe.ru/blog/japan-guide-2026/", "name": "Япония 2026: гайд без воды для россиян" },
          { "@type": "ListItem", "position": 2, "url": "https://traveltribe.ru/blog/japan-visa-2026/", "name": "Виза в Японию для россиян 2026: пошаговый гайд" },
          { "@type": "ListItem", "position": 3, "url": "https://traveltribe.ru/blog/japan-golden-week-2026/", "name": "Золотая неделя в Японии 2026: даты, цены, стратегия" }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "@id": `${url}#faq`,
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Япония", "item": url }
      ]
    }
  ]
};
---
<Layout
  title="Япония 2026: гайд, виза, сезоны, бюджет для россиян — TravelTribe"
  description="Поездка в Японию из России в 2026: виза бесплатна (сервис JVAC 970 ₽), бюджет от $50/день, лучшие сезоны октябрь–ноябрь (момидзи) и конец марта (сакура). Главные гайды от автора."
  canonical={url}
  ogTitle="Япония 2026 — виза, сезоны, бюджет"
  ogDescription="Виза бесплатна, бюджет от $50/день, момидзи в ноябре. Гайды, маршруты и FAQ."
  ogType="website"
  ogImage="https://traveltribe.ru/og/hub-japan.png"
  ldJson={ldJson}
>
  <Breadcrumbs crumbs={[{ label: 'Япония' }]} />

  <main id="main" class="jp">
    {/* MANIFEST */}
    <section class="jp-manifest">
      <div class="jp-idx">01 / Страна<b>Япония 2026</b></div>
      <div class="jp-meta">Был в ноябре 2023<br /><b>Обновлено V.2026</b></div>
      <h1 class="jp-h1">Япония <span class="rd">2026</span></h1>
      <p class="jp-sub">Виза, сезоны, бюджет, маршруты — всё что нужно для первой поездки из России. Без воды, с реальными цифрами из чеков.</p>

      <div class="jp-vlist">
        <div class="jp-vi"><span><b>01</b> Виза</span><div>Бесплатно</div></div>
        <div class="jp-vi"><span><b>02</b> Сбор JVAC</span><div>970 ₽</div></div>
        <div class="jp-vi"><span><b>03</b> Бюджет</span><div>$50–300 / день</div></div>
        <div class="jp-vi"><span><b>04</b> Когда лучше</span><div>Октябрь–ноябрь</div></div>
        <div class="jp-vi"><span><b>05</b> Мин. маршрут</span><div>10 дней</div></div>
        <div class="jp-vi"><span><b>06</b> JR Pass</span><div>Не нужен</div></div>
      </div>
    </section>

    {/* TLDR + BYLINE */}
    <section class="jp-section">
      <div class="jp-shead"><span class="jp-n">02</span><h2>Если коротко</h2></div>
      <p class="jp-tldr">Виза <b>бесплатна</b>, сервисный сбор JVAC <b>970 ₽</b>, отказов &lt;5%. Лучший сезон — <b>октябрь–ноябрь</b> (момидзи). Избегать: <b>Золотая неделя 29 апр — 6 мая 2026</b>, Обон (середина августа), цую (июнь–июль). Бюджет: <b>$50/день</b> эконом, <b>$150–250</b> комфорт, <b>$300+</b> премиум. JR Pass с 2023 чаще не нужен. Минимум 10 дней на Golden Route Токио — Хаконе — Киото — Осака.</p>
      <p class="jp-byline">
        <a href="/about/" class="byline-author">Никита Зайцев</a> ·
        <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> ·
        <span class="byline-fresh">был в Японии в ноябре 2023 · данные актуальны на {DATA_UPDATED_RU}</span>
      </p>
    </section>

    {/* СЕЗОНЫ */}
    <section class="jp-section">
      <div class="jp-shead"><span class="jp-n">03</span><h2>Сезоны — когда лететь</h2></div>
      <ul class="jp-list">
        <li><b>Октябрь–ноябрь</b> — момидзи (красные клёны), сухо, +18°C, идеальная погода. Мой выбор для первой поездки. Пик в Киото — середина–конец ноября.</li>
        <li><b>Конец марта — начало апреля</b> — сакура. Пик туризма, отели бронируются за полгода, цены максимальные. Цветение 1–2 недели, зависит от широты.</li>
        <li><b>29 апреля — 6 мая 2026 (Golden Week)</b> — избегать. Толпы, цены ×2.5–3, синкансены забиты.</li>
        <li><b>Середина июня — середина июля (цую)</b> — сезон дождей, влажно.</li>
        <li><b>Июль–август</b> — жара до +38°C, влажность 100%. Ехать только за восхождением на Фудзи (1 июля — 10 сентября) или летними фестивалями.</li>
        <li><b>Середина августа (Обон)</b> — второй национальный отпуск, толпы и цены.</li>
      </ul>
      <p class="jp-note"><a href="/seasons/">Таблица сезонов</a> — Япония и 38 других направлений с оптимальными окнами.</p>
    </section>

    <MonthlyEvents slug="japan" countryNom="Япония" countryNameVp="в Японии" idx="04" />

    {/* ВИЗА */}
    <section class="jp-section">
      <div class="jp-shead"><span class="jp-n">05</span><h2>Виза для россиян в 2026</h2></div>
      <ul class="jp-list">
        <li><b>Стоимость:</b> виза бесплатна, сервисный сбор JVAC <b>970 ₽</b> (Москва, СПб), до 2500 ₽ в регионах</li>
        <li><b>Где подавать:</b> JVAC под управлением VFS Global с 12 февраля 2026 (посольство больше не принимает напрямую)</li>
        <li><b>Срок:</b> 4–7 рабочих дней, не ранее чем за 3 месяца до вылета</li>
        <li><b>Документы:</b> загранпаспорт, фото <b>4.5 × 4.5 см</b> (не Шенген!), банковская выписка $100/день минимум $2000, авиабилеты, бронь отеля (с ноября 2024 — можно не выкупать)</li>
        <li><b>Отказы:</b> &lt;5%, главная причина — неправильный формат фото или незаполненные поля анкеты</li>
      </ul>
      <p class="jp-note"><a href="/blog/japan-visa-2026/">Полный пошаговый гайд по визе →</a></p>
      <p class="jp-cta">
        <a class="jp-aff" href={TP_LINKS.cherehapa} rel="sponsored noopener" target="_blank">Оформить страховку для визы в Японию →</a>
        
        <span class="jp-trust">от 110 ₽/день · подходит под требования JVAC · оплата картами РФ</span>
      </p>
    </section>

    {/* БЮДЖЕТ — три уровня Swiss */}
    <section class="jp-section">
      <div class="jp-shead"><span class="jp-n">06</span><h2>Бюджет — реальные цифры 2026</h2></div>
      <div class="jp-tiers">
        <article class="jp-tier">
          <div class="jp-tier-top"><span class="jp-tier-idx">01</span><div class="jp-tier-l">Эконом</div></div>
          <div class="jp-tier-p">$50–80<small> / день</small></div>
          <div class="jp-tier-n">минимум на двоих</div>
          <ul>
            <li>Хостел или капсульный отель</li>
            <li>Чифаньки и конбини</li>
            <li>IC-карта на метро</li>
            <li>Базовая еда без рамена в очереди</li>
          </ul>
        </article>
        <article class="jp-tier jp-tier--mid">
          <div class="jp-tier-top"><span class="jp-tier-idx">02</span><div class="jp-tier-l">Комфорт <span class="jp-tier-badge">большинство туристов</span></div></div>
          <div class="jp-tier-p">$150–250<small> / день</small></div>
          <div class="jp-tier-n">первый раз — оптимально</div>
          <ul>
            <li>3★ отель или бизнес-отель</li>
            <li>Нормальные рестораны</li>
            <li>Такси по необходимости</li>
            <li>Хотя бы одна ночь в рёкан</li>
          </ul>
        </article>
        <article class="jp-tier">
          <div class="jp-tier-top"><span class="jp-tier-idx">03</span><div class="jp-tier-l">Премиум</div></div>
          <div class="jp-tier-p">$300+<small> / день</small></div>
          <div class="jp-tier-n">без компромиссов</div>
          <ul>
            <li>4–5★ или премиум рёкан</li>
            <li>Кайсэки в Мишлен-ресторанах</li>
            <li>Онсэн в горах + спа</li>
            <li>Частный транспорт / гид</li>
          </ul>
        </article>
      </div>
      <p class="jp-after">Перелёт Москва ↔ Токио с пересадкой: <b>$500–900</b> в обычные даты, <b>$1100–1500</b> на Golden Week. Иена в 2026 слабая (~7 ¥/₽), что делает Японию доступнее обычного. <a href="/calculator/">Калькулятор бюджета</a> — точная сумма под твои даты.</p>
      <p class="jp-cta">
        <a class="jp-aff" href={aviasalesRoute('MOW','HND')} rel="sponsored noopener" target="_blank">Найти билет Москва — Токио от $500 →</a>
        
        <span class="jp-trust">все авиакомпании в одной выдаче · оплата картами РФ</span>
      </p>
    </section>

    <CountryMap slug="japan" countryNom="Япония" idx="07" />

    <EssentialsCard slug="japan" countryName="Япония" idx="08" />

    {/* ГЛАВНЫЕ ГАЙДЫ */}
    <section class="jp-section">
      <div class="jp-shead"><span class="jp-n">09</span><h2>Главные гайды</h2></div>
      <div class="jp-posts">
        <a href="/blog/japan-guide-2026/" class="jp-post">
          <div class="jp-pn">01</div>
          <div class="jp-pt">Главный гайд · ноябрь 2023</div>
          <h3>Япония 2026: гайд без воды для россиян</h3>
          <p>Бюджет, аэропорты Токио, доставка багажа, IC-карты, Tax Free, что нельзя ввозить (Корвалол депортируют).</p>
          <span class="jp-pa">Читать →</span>
        </a>
        <a href="/blog/japan-visa-2026/" class="jp-post">
          <div class="jp-pn">02</div>
          <div class="jp-pt">Виза · обновлено</div>
          <h3>Виза в Японию для россиян 2026</h3>
          <p>Пошагово через JVAC: документы, фото 4.5×4.5 (не Шенген), банковская выписка, неоплаченные брони — что изменилось в 2024–2026.</p>
          <span class="jp-pa">Читать →</span>
        </a>
        <a href="/blog/japan-golden-week-2026/" class="jp-post">
          <div class="jp-pn">03</div>
          <div class="jp-pt">Golden Week 2026</div>
          <h3>Золотая неделя в Японии 2026</h3>
          <p>29 апреля — 6 мая, 8 дней подряд. Цены ×3, что закрыто, что работает, альтернативные даты, стратегия если уже купили билеты.</p>
          <span class="jp-pa">Читать →</span>
        </a>
        <a href="/blog/pay-abroad-2026/" class="jp-post">
          <div class="jp-pn">04</div>
          <div class="jp-pt">Деньги за границей</div>
          <h3>Как платить в Японии россиянину 2026</h3>
          <p>Visa/MC российских банков не работают. JCB и UnionPay Газпромбанка местами. Виртуальная карта USD/EUR за 2 минуты. Сравнение всех способов с цифрами.</p>
          <span class="jp-pa">Читать →</span>
        </a>
      </div>
      <p class="jp-cta">
        <a class="jp-aff" href={TP_LINKS.ostrovok} rel="sponsored noopener" target="_blank">Подобрать отель в Токио или Киото →</a>
        
        <span class="jp-trust">цены в ₽ · оплата картами РФ · бесплатная отмена</span>
      </p>
    </section>

    {/* FAQ */}
    <section class="jp-section">
      <div class="jp-shead"><span class="jp-n">10</span><h2>FAQ</h2></div>
      <div class="jp-faq">
        {faqs.map(f => (
          <details class="jp-faq-i">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    {/* RELATED */}
    <section class="jp-section">
      <div class="jp-shead"><span class="jp-n">11</span><h2>Что почитать дальше</h2></div>
      <ul class="jp-related">
        <li><a href="/seasons/">Таблица сезонов</a> — 70+ направлений мира, фильтр по месяцу и визе</li>
        <li><a href="/calculator/">Калькулятор бюджета путешествия</a> — перелёт + проживание + питание</li>
        <li><a href="/blog/aurora-new-zealand-2026/">Южное сияние в Новой Зеландии</a> — частый компаньон Японии через Сингапур</li>
        <li><a href="/blog/">Все статьи блога</a> — личные отчёты по странам</li>
      </ul>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.jp {
  /* Swiss page-level tokens (override under-component) */
  --line-strong: #1b1914;
  --line-hair: var(--line); /* в global.css --line == hair-уровень */
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 clamp(1.1rem, 3vw, 2.6rem) clamp(2rem, 4vw, 4rem);
  font-family: var(--ff-display);
  font-variant-numeric: tabular-nums lining-nums;
  color: var(--text);
}

/* ===== MANIFEST ===== */
.jp-manifest {
  display: grid;
  grid-template-columns: repeat(12, minmax(0, 1fr));
  gap: 0 clamp(.8rem, 2vw, 1.6rem);
  padding: clamp(2rem, 5vw, 4.5rem) 0 clamp(1.2rem, 2.5vw, 2rem);
}
.jp-idx {
  grid-column: 1 / 5; grid-row: 1;
  font-size: .74rem; font-weight: 700;
  letter-spacing: .04em; text-transform: uppercase;
  color: var(--gold);
}
.jp-idx b {
  display: block; color: var(--text); font-size: .74rem;
  font-weight: 600; margin-top: .2rem;
}
.jp-meta {
  grid-column: 8 / 13; grid-row: 1;
  text-align: right; align-self: start;
  font-size: .8rem; color: var(--text-dim);
  line-height: 1.5;
}
.jp-meta b { color: var(--text); font-weight: 600; }
.jp-h1 {
  grid-column: 1 / 13; grid-row: 2;
