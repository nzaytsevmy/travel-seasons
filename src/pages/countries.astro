<script>
  function initAtlasReveal() {
    const targets = document.querySelectorAll('[data-reveal]');
    if (!targets.length || !('IntersectionObserver' in window)) {
      targets.forEach((el) => (el as HTMLElement).classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      },
      { rootMargin: '-10% 0px -5% 0px', threshold: 0.1 }
    );
    targets.forEach((t) => io.observe(t));
  }

  function initAtlasFilter() {
    const stats = document.querySelectorAll('.atlas-stat');
    const heroCards = document.querySelectorAll('.atlas-hero-card');
    const rows = document.querySelectorAll('.atlas-row');
    const chapters = document.querySelectorAll('.atlas-chapter');
    const search = document.getElementById('countriesSearch') as HTMLInputElement | null;
    const clearBtn = document.getElementById('countriesSearchClear');
    const emptyState = document.getElementById('countriesEmpty');
    if (!stats.length || !search) return;

    let currentFilter: string = 'all';
    let currentQuery: string = '';

    function matches(el: HTMLElement) {
      const visa = el.dataset.visa || '';
      const name = el.dataset.name || '';
      const matchVisa = currentFilter === 'all' || visa === currentFilter;
      const matchSearch = !currentQuery || name.includes(currentQuery);
      return matchVisa && matchSearch;
    }

    function apply() {
      let visibleTotal = 0;
      heroCards.forEach((c) => {
        const show = matches(c as HTMLElement);
        (c as HTMLElement).hidden = !show;
        if (show) visibleTotal++;
      });
      rows.forEach((r) => {
        const show = matches(r as HTMLElement);
        (r as HTMLElement).hidden = !show;
        if (show) visibleTotal++;
      });
      chapters.forEach((ch) => {
        const heroes = Array.from(ch.querySelectorAll('.atlas-hero-card')).some((c) => !(c as HTMLElement).hidden);
        const list = Array.from(ch.querySelectorAll('.atlas-row')).some((r) => !(r as HTMLElement).hidden);
        (ch as HTMLElement).hidden = !heroes && !list;
      });
      if (emptyState) (emptyState as HTMLElement).hidden = visibleTotal > 0;
    }

    stats.forEach((btn) => {
      btn.addEventListener('click', () => {
        currentFilter = (btn as HTMLElement).dataset.filter || 'all';
        stats.forEach((b) => b.classList.toggle('atlas-stat--active', b === btn));
        apply();
      });
    });

    search.addEventListener('input', () => {
      currentQuery = search.value.trim().toLowerCase();
      if (clearBtn) (clearBtn as HTMLElement).hidden = currentQuery.length === 0;
      apply();
    });

    if (clearBtn) clearBtn.addEventListener('click', () => {
      search.value = '';
      currentQuery = '';
      (clearBtn as HTMLElement).hidden = true;
      apply();
      search.focus();
    });
  }

  initAtlasReveal();
  initAtlasFilter();
  document.addEventListener('astro:page-load', () => {
    initAtlasReveal();
    initAtlasFilter();
  });
</script>
