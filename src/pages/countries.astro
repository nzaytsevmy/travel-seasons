---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import { DIRECTIONS } from '../data/directions.js';
import { COORDS, SLUG_TO_ISO } from '../data/destination-coords.js';

const destPhotos = import.meta.glob('../assets/destinations/*.jpg', { eager: true, import: 'default' });

// Sort by group, потом alphabet
const grouped = {};
for (const d of DIRECTIONS) {
  if (!grouped[d.group]) grouped[d.group] = [];
  grouped[d.group].push(d);
}
const groupOrder = Object.keys(grouped).sort();

const VISA_LABEL = { free: 'Без визы', evisa: 'eVisa', required: 'Виза' };
const BUDGET_LABEL = { low: '$', mid: '$$', high: '$$$' };

// Иконка-эмблема для региона (decoration в group-заголовке)
const GROUP_ICON = {
  'Африка и Ближний Восток': '🌍',
  'Европа': '🇪🇺',
  'Латам и Карибы': '🌴',
  'Океания': '🌊',
  'Полярные регионы': '❄️',
  'Северная Америка': '🗽',
  'Россия и СНГ': '🇷🇺',
  'Юго-Восточная Азия': '🌏',
  'Южная Азия': '🛕',
  'Восточная Азия': '🏯',
};

// Статистика для hero
const stats = {
  total: DIRECTIONS.length,
  free: DIRECTIONS.filter(d => d.visa === 'free').length,
  evisa: DIRECTIONS.filter(d => d.visa === 'evisa').length,
  required: DIRECTIONS.filter(d => d.visa === 'required').length,
};

// Топ-направления Bento — крупные 2×1 tile в своих регионах
const FEATURED_SLUGS = new Set([
  'japan', 'turkey', 'bali', 'antarctica',
  'georgia', 'thailand', 'peru', 'uae',
  'kenya', 'australia-east'
]);

// Данные для Map view — choropleth: ISO_A3 → direction info
const isoToDir = {};
DIRECTIONS.forEach((d) => {
  const iso = SLUG_TO_ISO[d.slug];
  if (iso && !isoToDir[iso]) {
    isoToDir[iso] = {
      slug: d.slug,
      name: d.cases.nom,
      visa: d.visa,
      budget: d.budget,
      emoji: d.visual?.emoji || '📍',
    };
  }
});

const url = 'https://traveltribe.ru/countries/';
const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#page`,
      "url": url,
      "name": "Все страны на TravelTribe — 39 направлений 2026",
      "description": "Полный список 39 направлений: виза, лучшие сезоны, бюджет на день. Кратко всё что нужно знать перед поездкой.",
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": DIRECTIONS.length,
        "itemListElement": DIRECTIONS.map((d, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "url": `https://traveltribe.ru/${d.slug}/`,
          "name": d.cases.nom,
        }))
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Страны", "item": url },
      ]
    }
  ]
};
---
<Layout
  title="Кратко о странах — все направления TravelTribe 2026"
  description="Полный список стран: виза, лучшие сезоны, бюджет на день, главные гайды. Кратко всё что важно перед поездкой."
  canonical={url}
  ogTitle="Кратко о странах — TravelTribe"
  ogDescription="Виза, сезоны, бюджет для каждой страны — кратко"
  ldJson={ldJson}
>
  <Nav active="countries" />
  <Breadcrumbs crumbs={[{ label: 'Кратко о странах' }]} />

  <main id="main" class="countries-wrap">
    <header class="countries-header">
      <div class="section-eyebrow">// Все направления</div>
      <h1>Кратко о <em>странах</em></h1>
      <p class="countries-sub">Виза, сезоны, бюджет на день и главные гайды. Если нужно быстро решить «куда» — выбирай регион ниже.</p>
      <div class="countries-stats" role="tablist" aria-label="Фильтр по визе">
        <button type="button" class="cstat cstat--active" data-filter="all" role="tab"><strong>{stats.total}</strong><span>направлений</span></button>
        <button type="button" class="cstat" data-filter="free" role="tab"><strong>{stats.free}</strong><span>без визы</span></button>
        <button type="button" class="cstat" data-filter="evisa" role="tab"><strong>{stats.evisa}</strong><span>eVisa</span></button>
        <button type="button" class="cstat" data-filter="required" role="tab"><strong>{stats.required}</strong><span>с визой</span></button>
      </div>
      <div class="countries-tools">
        <div class="countries-search">
          <svg class="cs-icon" viewBox="0 0 20 20" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="9" r="6"></circle><line x1="14" y1="14" x2="18" y2="18"></line></svg>
          <input type="search" id="countriesSearch" placeholder="Найти страну…" autocomplete="off" aria-label="Поиск страны" />
          <button type="button" class="cs-clear" id="countriesSearchClear" aria-label="Очистить" hidden>×</button>
        </div>
        <div class="view-toggle" role="tablist" aria-label="Вид">
          <button type="button" class="vt-btn vt-btn--active" data-view="list" role="tab">📋 Список</button>
          <button type="button" class="vt-btn" data-view="map" role="tab">🗺 Карта</button>
        </div>
      </div>
      <p class="countries-empty" id="countriesEmpty" hidden>Ничего не найдено. Попробуй другой запрос или сбрось фильтр.</p>
    </header>

    {/* Map контейнер — изначально hidden, лениво грузим Leaflet при клике */}
    <section id="countriesMapWrap" class="map-wrap" hidden aria-label="Карта направлений">
      <div id="countriesMap"></div>
      <div class="map-legend">
        <span class="ml-item"><span class="ml-dot ml-dot--free"></span>Без визы</span>
        <span class="ml-item"><span class="ml-dot ml-dot--evisa"></span>eVisa</span>
        <span class="ml-item"><span class="ml-dot ml-dot--required"></span>Виза</span>
      </div>
    </section>

    <script type="application/json" id="mapIsoData" set:html={JSON.stringify(isoToDir)}></script>

    <div id="countriesListWrap">

    {groupOrder.map((group) => (
      <section class="countries-group" data-group={group}>
        <h2 class="countries-group-title">
          <span class="cgt-icon" aria-hidden="true">{GROUP_ICON[group] || '📍'}</span>
          <span class="cgt-name">{group}</span>
          <span class="cgt-count">{grouped[group].length}</span>
        </h2>
        <div class="countries-grid">
          {grouped[group].map((d) => {
            const photo = destPhotos[`../assets/destinations/${d.slug}.jpg`];
            const featured = FEATURED_SLUGS.has(d.slug);
            return (
              <a href={`/${d.slug}/`} class={`country-card ${featured ? 'country-card--featured' : ''}`} data-visa={d.visa} data-name={d.cases.nom.toLowerCase()}>
                <div class="cc-media">
                  {photo ? (
                    <Image
                      src={photo}
                      alt={d.cases.nom}
                      widths={[300, 600]}
                      sizes="(max-width: 700px) 50vw, 25vw"
                      formats={['avif', 'webp']}
                      quality={68}
                      loading="lazy"
                    />
                  ) : (
                    <div class="cc-fallback" style={`background: linear-gradient(135deg, ${d.visual.g1}, ${d.visual.g2})`}>
                      <span class="cc-fallback-emoji" aria-hidden="true">{d.visual.emoji}</span>
                      <span class="cc-fallback-pattern" aria-hidden="true"></span>
                    </div>
                  )}
                  <div class="cc-overlay"></div>
                </div>
                <div class="cc-body">
                  <div class="cc-name">{d.cases.nom}</div>
                  <div class="cc-meta">
                    <span class={`cc-tag cc-tag--${d.visa}`}>{VISA_LABEL[d.visa]}</span>
                    <span class="cc-budget">{BUDGET_LABEL[d.budget]}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    </div>

    <p class="countries-updated">Актуально на: 13 мая 2026 · {DIRECTIONS.length} направлений · обновляется каждые 4–6 недель</p>
  </main>

  <Footer />
</Layout>

<script>
  function initCountriesFilter() {
    const stats = document.querySelectorAll('.cstat');
    const cards = document.querySelectorAll('.country-card');
    const groups = document.querySelectorAll('.countries-group');
    const search = document.getElementById('countriesSearch') as HTMLInputElement | null;
    const clearBtn = document.getElementById('countriesSearchClear');
    const emptyState = document.getElementById('countriesEmpty');

    if (!stats.length || !cards.length || !search) return;

    let currentFilter: string = 'all';
    let currentQuery: string = '';

    function applyFilters() {
      let visibleTotal = 0;
      cards.forEach((card) => {
        const visa = (card as HTMLElement).dataset.visa || '';
        const name = (card as HTMLElement).dataset.name || '';
        const matchVisa = currentFilter === 'all' || visa === currentFilter;
        const matchSearch = !currentQuery || name.includes(currentQuery);
        const visible = matchVisa && matchSearch;
        (card as HTMLElement).hidden = !visible;
        if (visible) visibleTotal++;
      });
      // Скрыть пустые группы
      groups.forEach((g) => {
        const anyVisible = Array.from(g.querySelectorAll('.country-card')).some((c) => !(c as HTMLElement).hidden);
        (g as HTMLElement).hidden = !anyVisible;
      });
      if (emptyState) (emptyState as HTMLElement).hidden = visibleTotal > 0;
    }

    stats.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = (btn as HTMLElement).dataset.filter || 'all';
        currentFilter = filter;
        stats.forEach((b) => b.classList.toggle('cstat--active', b === btn));
        applyFilters();
      });
    });

    search.addEventListener('input', () => {
      currentQuery = search.value.trim().toLowerCase();
      if (clearBtn) (clearBtn as HTMLElement).hidden = currentQuery.length === 0;
      applyFilters();
    });

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        search.value = '';
        currentQuery = '';
        (clearBtn as HTMLElement).hidden = true;
        applyFilters();
        search.focus();
      });
    }
  }

  initCountriesFilter();
  document.addEventListener('astro:page-load', initCountriesFilter);

  /* ─── Map view: Leaflet lazy-load по клику на toggle ─── */
  function loadLeaflet(): Promise<typeof window.L> {
    if ((window as any).L) return Promise.resolve((window as any).L);
    return new Promise((resolve) => {
      const css = document.createElement('link');
      css.rel = 'stylesheet';
      css.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
      document.head.appendChild(css);
      const js = document.createElement('script');
      js.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      js.onload = () => resolve((window as any).L);
      document.head.appendChild(js);
    });
  }

  let mapInstance: any = null;

  const VISA_FILLS: Record<string, string> = {
    free: '#22c55e',
    evisa: '#4a9eff',
    required: '#c9973a',
  };
  const VISA_LABELS: Record<string, string> = {
    free: 'Без визы',
    evisa: 'eVisa',
    required: 'Виза',
  };

  async function initMap() {
    if (mapInstance) return;
    const L = await loadLeaflet();
    const container = document.getElementById('countriesMap');
    if (!container) return;
    const isoRaw = document.getElementById('mapIsoData')?.textContent || '{}';
    const isoToDir = JSON.parse(isoRaw);

    mapInstance = L.map(container, {
      center: [20, 10],
      zoom: 2,
      worldCopyJump: true,
      scrollWheelZoom: true,
      minZoom: 2,
      maxZoom: 6,
      preferCanvas: false,
    });
    L.tileLayer('https://cartodb-basemaps-{s}.global.ssl.fastly.net/dark_all/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap, &copy; CARTO',
      subdomains: 'abcd',
      maxZoom: 6,
    }).addTo(mapInstance);

    // Загружаем GeoJSON всех стран мира
    const geoResp = await fetch('/data/world-countries.geojson');
    const geoData = await geoResp.json();

    const baseStyle = (feature: any) => {
      const iso = feature.properties.iso_a3;
      const d = isoToDir[iso];
      if (d) {
        return {
          fillColor: VISA_FILLS[d.visa] || '#888',
          fillOpacity: 0.55,
          weight: 0.8,
          color: '#0c0a08',
          opacity: 0.6,
        };
      }
      return {
        fillColor: '#2a2622',
        fillOpacity: 0.25,
        weight: 0.4,
        color: '#0c0a08',
        opacity: 0.4,
      };
    };

    const geoLayer = L.geoJSON(geoData, {
      style: baseStyle,
      onEachFeature: (feature: any, layer: any) => {
        const iso = feature.properties.iso_a3;
        const d = isoToDir[iso];
        if (d) {
          const budgetLabel = d.budget === 'low' ? '$' : d.budget === 'mid' ? '$$' : '$$$';
          layer.bindPopup(`
            <div class="map-pop-title">${d.emoji} ${d.name}</div>
            <div class="map-pop-meta">${VISA_LABELS[d.visa]} · ${budgetLabel}</div>
            <a class="map-pop-link" href="/${d.slug}/">Подробнее →</a>
          `);
          layer.bindTooltip(`<strong>${d.name}</strong><br><span style="font-size:11px;opacity:0.8">${VISA_LABELS[d.visa]} · ${budgetLabel}</span>`, {
            sticky: true,
            direction: 'auto',
            className: 'map-country-tooltip',
          });
          layer.on('mouseover', (e: any) => {
            e.target.setStyle({ fillOpacity: 0.85, weight: 1.5, color: '#fff', opacity: 1 });
            e.target.bringToFront();
          });
          layer.on('mouseout', (e: any) => {
            geoLayer.resetStyle(e.target);
          });
          layer.on('click', (e: any) => {
            mapInstance.flyTo(e.latlng, Math.max(mapInstance.getZoom(), 4), { duration: 0.5 });
          });
        } else {
          layer.bindTooltip(feature.properties.name, { sticky: true, className: 'map-country-tooltip map-country-tooltip--dim' });
        }
      },
    }).addTo(mapInstance);
  }

  function initViewToggle() {
    const buttons = document.querySelectorAll('.vt-btn');
    const listWrap = document.getElementById('countriesListWrap');
    const mapWrap = document.getElementById('countriesMapWrap');
    if (!buttons.length || !listWrap || !mapWrap) return;
    buttons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const view = (btn as HTMLElement).dataset.view;
        buttons.forEach((b) => b.classList.toggle('vt-btn--active', b === btn));
        if (view === 'map') {
          (listWrap as HTMLElement).hidden = true;
          (mapWrap as HTMLElement).hidden = false;
          await initMap();
          if (mapInstance) setTimeout(() => mapInstance.invalidateSize(), 100);
        } else {
          (mapWrap as HTMLElement).hidden = true;
          (listWrap as HTMLElement).hidden = false;
        }
      });
    });
  }

  initViewToggle();
  document.addEventListener('astro:page-load', initViewToggle);
</script>

<style>
.countries-wrap { max-width: var(--container-wide, 1200px); margin: 0 auto; padding: 0 var(--container-edge, 2rem) var(--space-16, 4rem); }

.countries-header { text-align: center; margin: var(--space-10) 0 var(--space-12); }
.section-eyebrow { font-size: var(--text-xs); letter-spacing: var(--tracking-widest); text-transform: uppercase; color: var(--gold-600); margin-bottom: var(--space-3); }
.countries-header h1 {
  font-family: var(--ff-display);
  font-size: var(--text-6xl);
  font-weight: 700;
  line-height: var(--leading-tight);
  letter-spacing: var(--tracking-tight);
  margin: 0 auto;
  max-width: 720px;
  text-wrap: balance;
}
.countries-header h1 em { color: var(--gold); font-style: italic; font-weight: 600; }
.countries-sub {
  margin: var(--space-3) auto 0;
  max-width: 560px;
  color: var(--text-dim);
  font-size: var(--text-lg);
  line-height: var(--leading-relaxed);
}
/* ─── Hero статистика как фильтр-чипы ─── */
.countries-stats {
  display: flex; justify-content: center; flex-wrap: wrap; gap: var(--space-3);
  margin: var(--space-7) auto 0;
  padding: var(--space-5) 0;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  max-width: 760px;
}
.cstat {
  display: flex; flex-direction: column; gap: 4px; align-items: center;
  padding: 0.85rem 1.4rem;
  background: transparent;
  border: 1px solid transparent;
  border-radius: var(--radius-3, 10px);
  cursor: pointer;
  transition: background var(--duration-fast), border-color var(--duration-fast), transform var(--duration-fast);
  font-family: inherit; color: inherit;
  min-width: 110px;
}
.cstat:hover { background: var(--bg2); border-color: var(--line); transform: translateY(-1px); }
.cstat--active {
  background: rgba(201,151,58,0.1);
  border-color: rgba(201,151,58,0.4);
}
.cstat--active strong { color: var(--gold); }
.cstat strong {
  font-family: var(--ff-display);
  font-size: var(--text-4xl);
  font-weight: 700;
  color: var(--gold);
  line-height: 1;
  font-variant-numeric: tabular-nums;
}
.cstat span {
  font-size: var(--text-xs); color: var(--text-faint);
  letter-spacing: var(--tracking-wide); text-transform: uppercase;
}

/* ─── Поиск ─── */
.countries-search {
  position: relative;
  max-width: 460px;
  margin: var(--space-5) auto 0;
}
.cs-icon {
  position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
  color: var(--text-faint);
  pointer-events: none;
}
.countries-search input {
  width: 100%;
  padding: 0.85rem 2.5rem 0.85rem 2.6rem;
  background: var(--bg2);
  border: 1px solid var(--line);
  border-radius: var(--radius-3, 10px);
  color: var(--text);
  font-size: var(--text-base);
  font-family: inherit;
  transition: border-color var(--duration-fast), background var(--duration-fast);
}
.countries-search input:focus {
  outline: none;
  border-color: rgba(201,151,58,0.5);
  background: var(--bg2);
}
.countries-search input::placeholder { color: var(--text-faint); }
.cs-clear {
  position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
  width: 28px; height: 28px;
  border: none; background: transparent;
  color: var(--text-faint);
  font-size: 1.5rem;
  cursor: pointer;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  line-height: 1;
}
.cs-clear:hover { background: var(--bg3); color: var(--text); }

.countries-empty {
  text-align: center;
  color: var(--text-dim);
  font-size: var(--text-base);
  margin: var(--space-8) auto;
  padding: var(--space-6);
  border: 1px dashed var(--line);
  border-radius: var(--radius-3, 10px);
  max-width: 460px;
}

/* ─── Tools row: search + view toggle ─── */
.countries-tools {
  display: flex; gap: var(--space-3);
  max-width: 760px;
  margin: var(--space-5) auto 0;
  align-items: center;
  flex-wrap: wrap;
}
.countries-tools .countries-search { flex: 1; margin: 0; min-width: 240px; }
.view-toggle {
  display: inline-flex;
  background: var(--bg2);
  border: 1px solid var(--line);
  border-radius: var(--radius-3, 10px);
  padding: 4px;
  gap: 2px;
}
.vt-btn {
  padding: 0.55rem 1.1rem;
  background: transparent;
  border: none;
  border-radius: 7px;
  color: var(--text-dim);
  font-size: var(--text-sm);
  font-weight: 500;
  cursor: pointer;
  font-family: inherit;
  transition: background var(--duration-fast), color var(--duration-fast);
  white-space: nowrap;
}
.vt-btn:hover { color: var(--text); }
.vt-btn--active {
  background: var(--gold);
  color: #fff;
}

/* ─── Map view ─── */
.map-wrap {
  position: relative;
  margin: var(--space-6) 0 var(--space-8);
  border-radius: var(--radius-4, 12px);
  overflow: hidden;
  border: 1px solid var(--line);
}
#countriesMap {
  width: 100%;
  height: 600px;
  background: var(--bg3);
}
.map-legend {
  position: absolute;
  bottom: 16px;
  left: 16px;
  display: flex; gap: var(--space-4);
  padding: 0.6rem 1rem;
  background: rgba(12,10,8,0.85);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: var(--radius-3, 10px);
  font-size: var(--text-sm);
  color: #f8f5ef;
  z-index: 500;
  flex-wrap: wrap;
}
.ml-item { display: inline-flex; align-items: center; gap: 0.5rem; }
.ml-dot {
  width: 12px; height: 12px;
  border-radius: 50%;
  border: 2px solid #fff;
  box-shadow: 0 0 0 1px rgba(0,0,0,0.4);
}
.ml-dot--free { background: #22c55e; }
.ml-dot--evisa { background: #4a9eff; }
.ml-dot--required { background: #c9973a; }

/* Кастомизация Leaflet popup под наш стиль */
:global(.leaflet-popup-content-wrapper) {
  background: var(--bg2);
  color: var(--text);
  border-radius: 8px;
  border: 1px solid var(--line);
}
:global(.leaflet-popup-tip) { background: var(--bg2); }
:global(.leaflet-popup-content) {
  margin: 12px 14px;
  font-size: 14px;
  line-height: 1.5;
}
:global(.leaflet-popup-content .map-pop-title) {
  font-family: var(--ff-display);
  font-size: 1.1rem;
  font-weight: 600;
  margin-bottom: 4px;
  color: var(--text);
}
:global(.leaflet-popup-content .map-pop-meta) {
  font-size: 0.78rem;
  color: var(--text-faint);
