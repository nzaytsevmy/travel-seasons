---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import { DIRECTIONS } from '../data/directions.js';

const destPhotos = import.meta.glob('../assets/destinations/*.jpg', { eager: true, import: 'default' });

// Sort by group, потом alphabet
const grouped = {};
for (const d of DIRECTIONS) {
  if (!grouped[d.group]) grouped[d.group] = [];
  grouped[d.group].push(d);
}
const groupOrder = Object.keys(grouped).sort();

const VISA_LABEL = { free: 'Без визы', evisa: 'eVisa', required: 'Виза' };
const BUDGET_LABEL = { low: '$', mid: '$$', high: '$$$' };

// Иконка-эмблема для региона (decoration в group-заголовке)
const GROUP_ICON = {
  'Африка и Ближний Восток': '🌍',
  'Европа': '🇪🇺',
  'Латам и Карибы': '🌴',
  'Океания': '🌊',
  'Полярные регионы': '❄️',
  'Северная Америка': '🗽',
  'Россия и СНГ': '🇷🇺',
  'Юго-Восточная Азия': '🌏',
  'Южная Азия': '🛕',
  'Восточная Азия': '🏯',
};

// Статистика для hero
const stats = {
  total: DIRECTIONS.length,
  free: DIRECTIONS.filter(d => d.visa === 'free').length,
  evisa: DIRECTIONS.filter(d => d.visa === 'evisa').length,
  required: DIRECTIONS.filter(d => d.visa === 'required').length,
};

// Топ-направления Bento — крупные 2×1 tile в своих регионах
const FEATURED_SLUGS = new Set([
  'japan', 'turkey', 'bali', 'antarctica',
  'georgia', 'thailand', 'peru', 'uae',
  'kenya', 'australia-east'
]);

const url = 'https://traveltribe.ru/countries/';
const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#page`,
      "url": url,
      "name": "Все страны на TravelTribe — 70 направлений 2026",
      "description": "Полный список 70 направлений: виза, лучшие сезоны, бюджет на день. Кратко всё что нужно знать перед поездкой.",
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": DIRECTIONS.length,
        "itemListElement": DIRECTIONS.map((d, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "url": `https://traveltribe.ru/${d.slug}/`,
          "name": d.cases.nom,
        }))
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Страны", "item": url },
      ]
    }
  ]
};
---
<Layout
  title="Кратко о странах — все направления TravelTribe 2026"
  description="Полный список стран: виза, лучшие сезоны, бюджет на день, главные гайды. Кратко всё что важно перед поездкой."
  canonical={url}
  ogTitle="Кратко о странах — TravelTribe"
  ogDescription="Виза, сезоны, бюджет для каждой страны — кратко"
  ldJson={ldJson}
>
  <Nav active="countries" />
  <Breadcrumbs crumbs={[{ label: 'Кратко о странах' }]} />

  <main id="main" class="countries-wrap">
    <header class="countries-header">
      <div class="section-eyebrow">// Все направления</div>
      <h1>Кратко о <em>странах</em></h1>
      <p class="countries-sub">Виза, сезоны, бюджет на день и главные гайды. Если нужно быстро решить «куда» — выбирай регион ниже.</p>
      <div class="countries-stats" role="tablist" aria-label="Фильтр по визе">
        <button type="button" class="cstat cstat--active" data-filter="all" role="tab"><strong>{stats.total}</strong><span>направлений</span></button>
        <button type="button" class="cstat" data-filter="free" role="tab"><strong>{stats.free}</strong><span>без визы</span></button>
        <button type="button" class="cstat" data-filter="evisa" role="tab"><strong>{stats.evisa}</strong><span>eVisa</span></button>
        <button type="button" class="cstat" data-filter="required" role="tab"><strong>{stats.required}</strong><span>с визой</span></button>
      </div>
      <div class="countries-search">
        <svg class="cs-icon" viewBox="0 0 20 20" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="9" r="6"></circle><line x1="14" y1="14" x2="18" y2="18"></line></svg>
        <input type="search" id="countriesSearch" placeholder="Найти страну…" autocomplete="off" aria-label="Поиск страны" />
        <button type="button" class="cs-clear" id="countriesSearchClear" aria-label="Очистить" hidden>×</button>
      </div>
      <p class="countries-empty" id="countriesEmpty" hidden>Ничего не найдено. Попробуй другой запрос или сбрось фильтр.</p>
    </header>

    {groupOrder.map((group) => (
      <section class="countries-group" data-group={group}>
        <h2 class="countries-group-title">
          <span class="cgt-icon" aria-hidden="true">{GROUP_ICON[group] || '📍'}</span>
          <span class="cgt-name">{group}</span>
          <span class="cgt-count">{grouped[group].length}</span>
        </h2>
        <div class="countries-grid">
          {grouped[group].map((d) => {
            const photo = destPhotos[`../assets/destinations/${d.slug}.jpg`];
            const featured = FEATURED_SLUGS.has(d.slug);
            return (
              <a href={`/${d.slug}/`} class={`country-card ${featured ? 'country-card--featured' : ''}`} data-visa={d.visa} data-name={d.cases.nom.toLowerCase()}>
                <div class="cc-media">
                  {photo ? (
                    <Image
                      src={photo}
                      alt={d.cases.nom}
                      widths={[300, 600]}
                      sizes="(max-width: 700px) 50vw, 25vw"
                      formats={['avif', 'webp']}
                      quality={68}
                      loading="lazy"
                    />
                  ) : (
                    <div class="cc-fallback" style={`background: linear-gradient(135deg, ${d.visual.g1}, ${d.visual.g2})`}>
                      <span class="cc-fallback-emoji" aria-hidden="true">{d.visual.emoji}</span>
                      <span class="cc-fallback-pattern" aria-hidden="true"></span>
                    </div>
                  )}
                  <div class="cc-overlay"></div>
                </div>
                <div class="cc-body">
                  <div class="cc-name">{d.cases.nom}</div>
                  <div class="cc-meta">
                    <span class={`cc-tag cc-tag--${d.visa}`}>{VISA_LABEL[d.visa]}</span>
                    <span class="cc-budget">{BUDGET_LABEL[d.budget]}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    <p class="countries-updated">Актуально на: 13 мая 2026 · {DIRECTIONS.length} направлений · обновляется каждые 4–6 недель</p>
  </main>

  <Footer />
</Layout>

<script>
  function initCountriesFilter() {
    const stats = document.querySelectorAll('.cstat');
    const cards = document.querySelectorAll('.country-card');
    const groups = document.querySelectorAll('.countries-group');
    const search = document.getElementById('countriesSearch') as HTMLInputElement | null;
    const clearBtn = document.getElementById('countriesSearchClear');
    const emptyState = document.getElementById('countriesEmpty');

    if (!stats.length || !cards.length || !search) return;

    let currentFilter: string = 'all';
    let currentQuery: string = '';

    function applyFilters() {
      let visibleTotal = 0;
      cards.forEach((card) => {
        const visa = (card as HTMLElement).dataset.visa || '';
        const name = (card as HTMLElement).dataset.name || '';
        const matchVisa = currentFilter === 'all' || visa === currentFilter;
        const matchSearch = !currentQuery || name.includes(currentQuery);
        const visible = matchVisa && matchSearch;
        (card as HTMLElement).hidden = !visible;
        if (visible) visibleTotal++;
      });
      // Скрыть пустые группы
      groups.forEach((g) => {
        const anyVisible = Array.from(g.querySelectorAll('.country-card')).some((c) => !(c as HTMLElement).hidden);
        (g as HTMLElement).hidden = !anyVisible;
      });
      if (emptyState) (emptyState as HTMLElement).hidden = visibleTotal > 0;
    }

    stats.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = (btn as HTMLElement).dataset.filter || 'all';
        currentFilter = filter;
        stats.forEach((b) => b.classList.toggle('cstat--active', b === btn));
        applyFilters();
      });
    });

    search.addEventListener('input', () => {
      currentQuery = search.value.trim().toLowerCase();
      if (clearBtn) (clearBtn as HTMLElement).hidden = currentQuery.length === 0;
      applyFilters();
    });

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        search.value = '';
        currentQuery = '';
        (clearBtn as HTMLElement).hidden = true;
        applyFilters();
        search.focus();
      });
    }
  }

  initCountriesFilter();
  document.addEventListener('astro:page-load', initCountriesFilter);
</script>

<style>
.countries-wrap { max-width: var(--container-wide, 1200px); margin: 0 auto; padding: 0 var(--container-edge, 2rem) var(--space-16, 4rem); }

.countries-header { text-align: center; margin: var(--space-10) 0 var(--space-12); }
.section-eyebrow { font-size: var(--text-xs); letter-spacing: var(--tracking-widest); text-transform: uppercase; color: var(--gold-600); margin-bottom: var(--space-3); }
.countries-header h1 {
  font-family: var(--ff-display);
  font-size: var(--text-6xl);
  font-weight: 700;
  line-height: var(--leading-tight);
  letter-spacing: var(--tracking-tight);
  margin: 0 auto;
  max-width: 720px;
  text-wrap: balance;
}
.countries-header h1 em { color: var(--gold); font-style: italic; font-weight: 600; }
.countries-sub {
  margin: var(--space-3) auto 0;
  max-width: 560px;
  color: var(--text-dim);
  font-size: var(--text-lg);
  line-height: var(--leading-relaxed);
}
/* ─── Hero статистика как фильтр-чипы ─── */
.countries-stats {
  display: flex; justify-content: center; flex-wrap: wrap; gap: var(--space-3);
  margin: var(--space-7) auto 0;
  padding: var(--space-5) 0;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  max-width: 760px;
}
.cstat {
  display: flex; flex-direction: column; gap: 4px; align-items: center;
  padding: 0.85rem 1.4rem;
  background: transparent;
  border: 1px solid transparent;
  border-radius: var(--radius-3, 10px);
  cursor: pointer;
  transition: background var(--duration-fast), border-color var(--duration-fast), transform var(--duration-fast);
  font-family: inherit; color: inherit;
  min-width: 110px;
}
.cstat:hover { background: var(--bg2); border-color: var(--line); transform: translateY(-1px); }
.cstat--active {
  background: rgba(201,151,58,0.1);
  border-color: rgba(201,151,58,0.4);
}
.cstat--active strong { color: var(--gold); }
.cstat strong {
  font-family: var(--ff-display);
  font-size: var(--text-4xl);
  font-weight: 700;
  color: var(--gold);
  line-height: 1;
  font-variant-numeric: tabular-nums;
}
.cstat span {
  font-size: var(--text-xs); color: var(--text-faint);
  letter-spacing: var(--tracking-wide); text-transform: uppercase;
}

/* ─── Поиск ─── */
.countries-search {
  position: relative;
  max-width: 460px;
  margin: var(--space-5) auto 0;
}
.cs-icon {
  position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
  color: var(--text-faint);
  pointer-events: none;
}
.countries-search input {
  width: 100%;
  padding: 0.85rem 2.5rem 0.85rem 2.6rem;
  background: var(--bg2);
  border: 1px solid var(--line);
  border-radius: var(--radius-3, 10px);
  color: var(--text);
  font-size: var(--text-base);
  font-family: inherit;
  transition: border-color var(--duration-fast), background var(--duration-fast);
}
.countries-search input:focus {
  outline: none;
  border-color: rgba(201,151,58,0.5);
  background: var(--bg2);
}
.countries-search input::placeholder { color: var(--text-faint); }
.cs-clear {
  position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
  width: 28px; height: 28px;
  border: none; background: transparent;
  color: var(--text-faint);
  font-size: 1.5rem;
  cursor: pointer;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  line-height: 1;
}
.cs-clear:hover { background: var(--bg3); color: var(--text); }

.countries-empty {
  text-align: center;
  color: var(--text-dim);
  font-size: var(--text-base);
  margin: var(--space-8) auto;
  padding: var(--space-6);
  border: 1px dashed var(--line);
  border-radius: var(--radius-3, 10px);
  max-width: 460px;
}


/* Группа скрыта если в ней нет видимых карточек */
.countries-group[hidden] { display: none; }

/* ─── Заголовок региона с emoji и счётчиком ─── */
.countries-group { margin-bottom: var(--space-14); }
.countries-group-title {
  display: flex; align-items: baseline; gap: var(--space-3);
  font-family: var(--ff-display);
  font-size: var(--text-3xl);
  font-weight: 700;
  margin: 0 0 var(--space-6);
  padding-bottom: var(--space-4);
  border-bottom: 1px solid var(--line);
  color: var(--text);
  letter-spacing: var(--tracking-tight);
}
.cgt-icon { font-size: 1.5rem; line-height: 1; flex: 0 0 auto; transform: translateY(2px); }
.cgt-name { flex: 1; }
.cgt-count {
  font-family: var(--ff-display);
  font-size: var(--text-base);
  font-weight: 500;
  color: var(--gold-600);
  background: rgba(201,151,58,0.1);
  padding: 0.25rem 0.65rem;
  border-radius: 999px;
  letter-spacing: 0;
  flex: 0 0 auto;
}

/* ─── Сетка Bento — featured-карточки 2×1, остальные 1×1 ─── */
.countries-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: var(--space-5);
}

.country-card {
  display: flex; flex-direction: column;
  background: var(--bg2);
  border: 1px solid var(--line);
  border-radius: var(--radius-4, 10px);
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  transition: transform var(--duration-base), box-shadow var(--duration-base), border-color var(--duration-base);
}
/* Скрытые при фильтрации/поиске */
.country-card[hidden] { display: none; }

/* Bento featured — занимает 2 колонки на широких экранах */
@media (min-width: 760px) {
  .country-card--featured {
    grid-column: span 2;
  }
  .country-card--featured .cc-media {
    aspect-ratio: 16 / 9;
  }
  .country-card--featured .cc-name {
    font-size: var(--text-2xl);
    letter-spacing: -0.015em;
  }
  .country-card--featured .cc-fallback-emoji { font-size: 6rem; }
}
.country-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 40px -20px rgba(0,0,0,0.45), 0 0 0 1px rgba(201,151,58,0.35);
  border-color: rgba(201,151,58,0.5);
}
.cc-media {
  position: relative; aspect-ratio: 4 / 3;
  background: var(--bg3);
  overflow: hidden;
}
.cc-media img, .cc-media picture {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.5s var(--ease-out);
}
.country-card:hover .cc-media img { transform: scale(1.06); }

/* ─── Fallback для стран без фото — большой emoji + градиент + pattern ─── */
.cc-fallback {
  position: relative;
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.cc-fallback-emoji {
  position: relative; z-index: 2;
  font-size: 4.5rem;
  filter: drop-shadow(0 6px 16px rgba(0,0,0,0.3));
  transition: transform 0.5s var(--ease-out);
}
.country-card:hover .cc-fallback-emoji { transform: scale(1.1) rotate(-3deg); }
.cc-fallback-pattern {
  position: absolute; inset: 0;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,0.12) 0%, transparent 25%),
    radial-gradient(circle at 80% 80%, rgba(255,255,255,0.08) 0%, transparent 30%);
  z-index: 1;
}
.cc-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.35) 0%, transparent 55%);
  z-index: 3;
  pointer-events: none;
}
.cc-body {
  padding: var(--space-4) var(--space-4) var(--space-4);
  display: flex; flex-direction: column; gap: var(--space-2);
  flex: 1;
}
.cc-name {
  font-family: var(--ff-display);
  font-size: var(--text-xl);
  font-weight: 600;
  line-height: var(--leading-snug);
  color: var(--text);
  text-wrap: balance;
  letter-spacing: -0.005em;
}
.country-card:hover .cc-name { color: var(--gold); transition: color var(--duration-fast); }
.cc-meta {
  display: flex; align-items: center; gap: var(--space-2);
  margin-top: auto;
  padding-top: var(--space-3);
}
.cc-tag {
  font-size: var(--text-xs);
  letter-spacing: 0.04em;
  padding: 0.3rem 0.65rem;
  border-radius: var(--radius-1);
  font-weight: 600;
}
.cc-tag--free { background: rgba(34, 197, 94, 0.15); color: var(--peak-text); }
.cc-tag--evisa { background: rgba(74, 158, 255, 0.15); color: var(--good-text); }
.cc-tag--required { background: rgba(201, 151, 58, 0.15); color: var(--gold-700, var(--gold)); }
.cc-budget {
  font-size: var(--text-sm);
  color: var(--gold-600);
  font-weight: 600;
  letter-spacing: 0.05em;
}

.countries-updated {
  margin-top: var(--space-10);
  font-size: var(--text-xs);
  color: var(--text-faint);
  text-align: center;
  letter-spacing: var(--tracking-wide);
  padding-top: var(--space-6);
  border-top: 1px solid var(--line);
}

@media (max-width: 600px) {
  .countries-grid { grid-template-columns: repeat(2, 1fr); }
  .countries-header h1 { font-size: var(--text-4xl); }
}
</style>
