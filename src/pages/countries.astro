---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import { DIRECTIONS } from '../data/directions.js';

const destPhotos = import.meta.glob('../assets/destinations/*.jpg', { eager: true, import: 'default' });

// Group по регионам с editorial-порядком — крупные первыми
const grouped = {};
for (const d of DIRECTIONS) {
  if (!grouped[d.group]) grouped[d.group] = [];
  grouped[d.group].push(d);
}

// Editorial order — сначала Азия, потом крупные регионы
const GROUP_ORDER = [
  '🌏 Азия',
  '🌍 Африка & Ближний Восток',
  '🌎 Латам и Карибы — расширение',
  '🌎 Америка',
  '🐧 Полярные регионы',
  '🏔️ Европа',
  '🌊 Австралия & Океания',
];
const groupOrder = GROUP_ORDER.filter(g => grouped[g]).concat(
  Object.keys(grouped).filter(g => !GROUP_ORDER.includes(g))
);

const VISA_LABEL = { free: 'Без визы', evisa: 'eVisa', required: 'Виза' };
const BUDGET_LABEL = { low: '$', mid: '$$', high: '$$$' };

// Roman numerals для chapters
const ROMAN = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X'];

// Hero featured — самые сильные карточки региона
const HERO_FEATURED = new Set([
  'japan', 'antarctica', 'turkey', 'bali', 'peru',
  'china', 'uae', 'australia-east', 'iceland', 'kenya'
]);

// Статистика
const stats = {
  total: DIRECTIONS.length,
  free: DIRECTIONS.filter(d => d.visa === 'free').length,
  evisa: DIRECTIONS.filter(d => d.visa === 'evisa').length,
  required: DIRECTIONS.filter(d => d.visa === 'required').length,
};

// Issue для журнальной обёртки
const issueNum = '01';
const issueDate = 'МАЙ 2026';

const url = 'https://traveltribe.ru/countries/';
const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#page`,
      "url": url,
      "name": "Atlas — все 70 направлений TravelTribe 2026",
      "description": "Полный атлас направлений: виза, лучшие сезоны, бюджет, главные гайды. Кратко всё что важно перед поездкой.",
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": DIRECTIONS.length,
        "itemListElement": DIRECTIONS.map((d, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "url": `https://traveltribe.ru/${d.slug}/`,
          "name": d.cases.nom,
        }))
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Atlas", "item": url },
      ]
    }
  ]
};
---
<Layout
  title="Atlas 2026 — 70 направлений для российского путешественника"
  description="Editorial-атлас всех направлений: виза, лучшие сезоны, бюджет на день, главные гайды. Кратко всё что важно перед поездкой."
  canonical={url}
  ogTitle="Atlas — Кратко о странах · TravelTribe"
  ogDescription="70 направлений с визой, сезонами, бюджетом и главными гайдами"
  ldJson={ldJson}
>
  <Nav active="countries" />
  <Breadcrumbs crumbs={[{ label: 'Atlas' }]} />

  <main id="main" class="atlas-wrap">

    {/* ─── Hero как разворот журнала ─── */}
    <header class="atlas-hero">
      <div class="atlas-issue">
        <span class="atlas-issue-meta">Выпуск № {issueNum}</span>
        <span class="atlas-issue-sep">·</span>
        <span class="atlas-issue-meta">{issueDate}</span>
        <span class="atlas-issue-sep">·</span>
        <span class="atlas-issue-meta">Travel Atlas</span>
      </div>

      <h1 class="atlas-title">
        <span class="atlas-title-line">Atlas</span>
        <span class="atlas-title-deco" aria-hidden="true">—</span>
        <span class="atlas-title-sub"><em>{stats.total}</em> направлений<br />для российского путешественника</span>
      </h1>

      <p class="atlas-lede">
        <span class="atlas-dropcap">К</span>раткие путеводители по всему миру в 2026 году. Каждая страна — виза, лучшие месяцы, реальный бюджет на день и связанные гайды. <em>Без воды, с конкретикой.</em>
      </p>

      <div class="atlas-rule" aria-hidden="true">
        <span class="atlas-rule-line"></span>
        <span class="atlas-rule-star">✦</span>
        <span class="atlas-rule-line"></span>
      </div>

      {/* Stats как кликабельные фильтры */}
      <div class="atlas-stats" role="tablist" aria-label="Фильтр по визе">
        <button type="button" class="atlas-stat atlas-stat--active" data-filter="all" role="tab">
          <span class="atlas-stat-num">{stats.total}</span>
          <span class="atlas-stat-label">Все<br />направления</span>
        </button>
        <button type="button" class="atlas-stat" data-filter="free" role="tab">
          <span class="atlas-stat-num">{stats.free}</span>
          <span class="atlas-stat-label">Без<br />визы</span>
        </button>
        <button type="button" class="atlas-stat" data-filter="evisa" role="tab">
          <span class="atlas-stat-num">{stats.evisa}</span>
          <span class="atlas-stat-label">e<wbr/>Visa<br />онлайн</span>
        </button>
        <button type="button" class="atlas-stat" data-filter="required" role="tab">
          <span class="atlas-stat-num">{stats.required}</span>
          <span class="atlas-stat-label">С<br />визой</span>
        </button>
      </div>

      <div class="atlas-search">
        <span class="atlas-search-prompt" aria-hidden="true">— Найти страну</span>
        <input type="search" id="countriesSearch" placeholder="Например: Япония, Турция…" autocomplete="off" aria-label="Поиск страны" />
        <button type="button" class="atlas-search-clear" id="countriesSearchClear" aria-label="Очистить" hidden>×</button>
      </div>

      <p class="atlas-empty" id="countriesEmpty" hidden>Ничего не нашлось. Попробуй другой запрос или сбрось фильтр.</p>
    </header>

    {/* ─── Регионы как главы ─── */}
    {groupOrder.map((group, gIdx) => {
      // Делим регион на featured + остальные
      const heroes = grouped[group].filter(d => HERO_FEATURED.has(d.slug)).slice(0, 2);
      const rest = grouped[group].filter(d => !heroes.includes(d));
      return (
        <section class="atlas-chapter" data-group={group}>
          <header class="atlas-chapter-head">
            <div class="atlas-chapter-num">
              <span class="atlas-chapter-roman" aria-hidden="true">{ROMAN[gIdx] || gIdx + 1}</span>
              <span class="atlas-chapter-meta">Глава</span>
            </div>
            <h2 class="atlas-chapter-title">{group.replace(/^[^\s]+\s/, '')}</h2>
            <div class="atlas-chapter-meta-right">
              <span class="atlas-chapter-count">{grouped[group].length}</span>
              <span class="atlas-chapter-meta">направлений</span>
            </div>
          </header>

          {/* Featured spread — 2 крупных карточки если есть */}
          {heroes.length > 0 && (
            <div class={`atlas-spread ${heroes.length === 1 ? 'atlas-spread--single' : ''}`}>
              {heroes.map((d) => {
                const photo = destPhotos[`../assets/destinations/${d.slug}.jpg`];
                return (
                  <a href={`/${d.slug}/`} class="atlas-hero-card" data-visa={d.visa} data-name={d.cases.nom.toLowerCase()}>
                    <div class="ahc-photo">
                      {photo ? (
                        <Image
                          src={photo}
                          alt={d.cases.nom}
                          widths={[600, 1200]}
                          sizes="(max-width: 720px) 100vw, 50vw"
                          formats={['avif', 'webp']}
                          quality={72}
                          loading="lazy"
                        />
                      ) : (
                        <div class="ahc-photo-fallback" style={`background: linear-gradient(135deg, ${d.visual.g1}, ${d.visual.g2})`}>
                          <span class="ahc-fallback-emoji" aria-hidden="true">{d.visual.emoji}</span>
                        </div>
                      )}
                      <div class="ahc-photo-tint" aria-hidden="true"></div>
                    </div>
                    <div class="ahc-text">
                      <div class="ahc-eyebrow">
                        <span>{VISA_LABEL[d.visa]}</span>
                        <span class="ahc-eyebrow-sep">·</span>
                        <span>{BUDGET_LABEL[d.budget]}</span>
                      </div>
                      <h3 class="ahc-title">{d.cases.nom}</h3>
                      <p class="ahc-sub">{d.sub}</p>
                      <span class="ahc-cta">Читать подробно <span class="ahc-cta-arrow">→</span></span>
                    </div>
                  </a>
                );
              })}
            </div>
          )}

          {/* Editorial list — остальные страны региона */}
          {rest.length > 0 && (
            <ul class="atlas-list">
              {rest.map((d, idx) => {
                const photo = destPhotos[`../assets/destinations/${d.slug}.jpg`];
                const num = String(idx + heroes.length + 1).padStart(2, '0');
                return (
                  <li class="atlas-row" data-visa={d.visa} data-name={d.cases.nom.toLowerCase()}>
                    <a href={`/${d.slug}/`} class="atlas-row-link">
                      <span class="ar-num">{num}</span>
                      <span class="ar-thumb">
                        {photo ? (
                          <Image
                            src={photo}
                            alt={d.cases.nom}
                            widths={[120, 240]}
                            sizes="120px"
                            formats={['avif', 'webp']}
                            quality={70}
                            loading="lazy"
                          />
                        ) : (
                          <span class="ar-thumb-emoji" style={`background: linear-gradient(135deg, ${d.visual.g1}, ${d.visual.g2})`} aria-hidden="true">{d.visual.emoji}</span>
                        )}
                      </span>
                      <span class="ar-name">{d.cases.nom}</span>
                      <span class="ar-meta">
                        <span class={`ar-visa ar-visa--${d.visa}`}>{VISA_LABEL[d.visa]}</span>
                        <span class="ar-budget">{BUDGET_LABEL[d.budget]}</span>
                      </span>
                      <span class="ar-arrow" aria-hidden="true">→</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          )}
        </section>
      );
    })}

    {/* ─── Colophon ─── */}
    <footer class="atlas-colophon">
      <div class="atlas-rule" aria-hidden="true">
        <span class="atlas-rule-line"></span>
        <span class="atlas-rule-star">✦</span>
        <span class="atlas-rule-line"></span>
      </div>
      <p class="atlas-colophon-text">
        <em>Атлас составлен Никитой Зайцевым. Был на 7 континентах, посетил 60+ стран лично. Каждая страница содержит личный опыт там, где удалось. Обновляется каждые 4–6 недель.</em>
      </p>
      <p class="atlas-colophon-date">Актуально на 13 мая 2026 · <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a></p>
    </footer>
  </main>

  <Footer />
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════════════
     ATLAS — Editorial Magazine редизайн /countries/
     Серифная типография Cormorant Garamond + sans-serif body
     Asymmetric grid с featured-spreads, generous spacing
     ═══════════════════════════════════════════════════════════════ */

  .atlas-wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 var(--container-edge, 2rem) 6rem;
  }

  /* ─── Issue eyebrow ─── */
  .atlas-issue {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    margin: 2.5rem 0 2rem;
    color: var(--text-faint);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .atlas-issue-sep { color: var(--gold-600); }

  /* ─── Hero title ─── */
  .atlas-hero { text-align: center; padding-bottom: 3rem; }
  .atlas-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 400;
    margin: 0 auto 1.5rem;
    line-height: 0.95;
    letter-spacing: -0.025em;
    color: var(--text);
  }
  .atlas-title-line {
    display: block;
    font-size: clamp(4rem, 12vw, 9rem);
    font-weight: 500;
    font-style: italic;
  }
  .atlas-title-deco {
    display: block;
    margin: 1rem auto 1.2rem;
    color: var(--gold);
    font-size: 2rem;
    letter-spacing: 0.1em;
  }
  .atlas-title-sub {
    display: block;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-style: normal;
    font-weight: 400;
    line-height: 1.4;
    color: var(--text-dim);
    letter-spacing: 0.005em;
  }
  .atlas-title-sub em {
    font-style: italic;
    color: var(--gold);
    font-weight: 600;
    font-size: 1.15em;
    font-variant-numeric: lining-nums;
  }

  /* ─── Lede с drop-cap ─── */
  .atlas-lede {
    max-width: 540px;
    margin: 0 auto 2.5rem;
    font-size: clamp(0.95rem, 1.3vw, 1.05rem);
    line-height: 1.75;
    color: var(--text-dim);
    text-align: center;
    font-weight: 400;
  }
  .atlas-lede em {
    color: var(--text);
    font-style: italic;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.15em;
  }
  .atlas-dropcap {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 3.2rem;
    line-height: 1;
    color: var(--gold);
    float: left;
    margin: 0.1rem 0.5rem 0 0;
    font-weight: 600;
    font-style: italic;
  }
  /* На мобиле drop-cap уменьшаем */
  @media (max-width: 600px) {
    .atlas-dropcap { font-size: 2.5rem; }
  }

  /* ─── Editorial rule (декоративный разделитель) ─── */
  .atlas-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.2rem;
    margin: 2.5rem auto;
    max-width: 600px;
  }
  .atlas-rule-line {
    flex: 1;
    height: 1px;
    background: var(--line);
  }
  .atlas-rule-star {
    color: var(--gold-600);
    font-size: 0.85rem;
    letter-spacing: 0.2em;
  }

  /* ─── Stats: классические циферки с серифом ─── */
  .atlas-stats {
    display: flex;
    justify-content: center;
    gap: 0;
    margin: 2.5rem auto 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    max-width: 800px;
  }
  .atlas-stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 1.4rem 0.5rem;
    background: transparent;
    border: none;
    border-right: 1px solid var(--line);
    cursor: pointer;
    transition: background 0.2s ease;
    font-family: inherit;
    color: inherit;
  }
  .atlas-stat:last-child { border-right: none; }
  .atlas-stat:hover { background: var(--bg2); }
  .atlas-stat--active {
    background: rgba(201,151,58,0.06);
  }
  .atlas-stat-num {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 500;
    font-style: italic;
    color: var(--gold);
    line-height: 1;
    font-variant-numeric: lining-nums;
  }
  .atlas-stat--active .atlas-stat-num {
    color: var(--gold);
  }
  .atlas-stat-label {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-faint);
    line-height: 1.3;
    text-align: center;
    font-weight: 500;
  }
  .atlas-stat--active .atlas-stat-label { color: var(--text-dim); }

  /* ─── Search bar в editorial-стиле ─── */
  .atlas-search {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    max-width: 540px;
    margin: 2.5rem auto 0;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--line);
    position: relative;
  }
  .atlas-search-prompt {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    color: var(--gold-600);
    font-size: 1.05rem;
    flex: 0 0 auto;
    white-space: nowrap;
  }
  .atlas-search input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text);
    font-size: 1rem;
    font-family: inherit;
    padding: 0.3rem 0;
    outline: none;
  }
  .atlas-search input::placeholder {
    color: var(--text-faint);
    font-style: italic;
  }
  .atlas-search-clear {
    flex: 0 0 auto;
    width: 28px; height: 28px;
    border: none;
    background: transparent;
    color: var(--text-faint);
    font-size: 1.5rem;
    cursor: pointer;
    line-height: 1;
    border-radius: 50%;
  }
  .atlas-search-clear:hover { color: var(--text); background: var(--bg2); }

  .atlas-empty {
    max-width: 540px;
    margin: 2rem auto;
    text-align: center;
    color: var(--text-dim);
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 1.15rem;
  }

  /* ═══════════════════════════════════════════════════
     CHAPTER (регион)
     ═══════════════════════════════════════════════════ */
  .atlas-chapter {
    padding: 4.5rem 0;
    border-top: 1px solid var(--line);
  }
  .atlas-chapter:first-of-type { margin-top: 3rem; }
  .atlas-chapter[hidden] { display: none; }

  .atlas-chapter-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: end;
    gap: 1.5rem;
    margin-bottom: 3rem;
    padding-bottom: 1.2rem;
    border-bottom: 1px solid var(--line);
  }
  .atlas-chapter-num {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .atlas-chapter-roman {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.5rem;
    line-height: 1;
    color: var(--gold);
    font-weight: 500;
    font-style: italic;
  }
  .atlas-chapter-meta {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-top: 0.4rem;
  }
  .atlas-chapter-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 500;
    line-height: 1.1;
    color: var(--text);
    margin: 0;
    letter-spacing: -0.01em;
  }
  .atlas-chapter-meta-right {
    text-align: right;
  }
  .atlas-chapter-count {
    display: block;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2rem;
    font-style: italic;
    color: var(--gold);
    line-height: 1;
    font-variant-numeric: lining-nums;
  }

  @media (max-width: 600px) {
    .atlas-chapter-head {
      grid-template-columns: auto auto;
      grid-template-rows: auto auto;
    }
    .atlas-chapter-meta-right { grid-column: 2; grid-row: 1; text-align: right; }
    .atlas-chapter-title { grid-column: 1 / -1; grid-row: 2; }
  }

  /* ═══════════════════════════════════════════════════
     FEATURED SPREAD (top-2 страны региона как магазинный разворот)
     ═══════════════════════════════════════════════════ */
  .atlas-spread {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .atlas-spread--single { grid-template-columns: 1fr; }
  @media (max-width: 780px) {
    .atlas-spread { grid-template-columns: 1fr; }
  }

  .atlas-hero-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--line);
    background: var(--bg2);
    overflow: hidden;
    transition: border-color 0.25s ease, transform 0.4s var(--ease-out);
  }
  .atlas-hero-card[hidden] { display: none; }
  .atlas-hero-card:hover { border-color: rgba(201,151,58,0.5); }
  .atlas-hero-card:hover .ahc-photo :global(img) { transform: scale(1.04); }
  .atlas-hero-card:hover .ahc-cta-arrow { transform: translateX(6px); }

  .ahc-photo {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg3);
  }
  .ahc-photo :global(img),
  .ahc-photo :global(picture) {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s var(--ease-out);
  }
  .ahc-photo-fallback {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
  }
  .ahc-fallback-emoji {
    font-size: 5rem;
    filter: drop-shadow(0 4px 14px rgba(0,0,0,0.25));
  }
  .ahc-photo-tint {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(12,10,8,0.35) 100%);
    pointer-events: none;
  }

  .ahc-text {
    padding: 1.8rem 1.6rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ahc-eyebrow {
