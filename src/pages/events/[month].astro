---
// /events/<month>/ — фестивали и праздники мира в конкретном месяце: срез
// country-holidays.js поперёк стран (обычно виден только на страновых хабах).
// Swiss-канон BRANDBOOK.md (hairlines, gold accent, без border-radius/shadow).
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { MONTHS, bySlug } from '../../data/directions.js';
import { getEventsByMonth } from '../../data/country-holidays.js';
import { EVENTS_MONTHLY_INTRO } from '../../data/events-monthly-intro.js';
import { DATA_UPDATED_RU } from '../../data/meta.js';

export async function getStaticPaths() {
  return MONTHS.map((m, i) => ({ params: { month: m.slug }, props: { m, monthIdx: i } }));
}

const { m, monthIdx } = Astro.props;
const monthCap = m.nom.charAt(0).toUpperCase() + m.nom.slice(1);
const monthNum = monthIdx + 1;

const events = getEventsByMonth(monthNum)
  .map((e) => ({ ...e, nom: bySlug(e.slug)?.cases?.nom || e.slug }))
  .sort((a, b) => a.nom.localeCompare(b.nom, 'ru'));

const TAG_LABEL = { closed: 'выходные/закрыто', fest: 'фестиваль', culture: 'сезонное' };
const closed = events.filter((e) => e.tag === 'closed');
const fest = events.filter((e) => e.tag === 'fest');
const culture = events.filter((e) => e.tag === 'culture');

const editorial = EVENTS_MONTHLY_INTRO[m.slug];

// Русское склонение: 1 страна / 2 страны / 5 стран (см. bezviz.astro).
const plural = (n, one, few, many) => {
  const m10 = n % 10, m100 = n % 100;
  if (m10 === 1 && m100 !== 11) return one;
  if (m10 >= 2 && m10 <= 4 && (m100 < 12 || m100 > 14)) return few;
  return many;
};
const closedCountryCount = new Set(closed.map((e) => e.slug)).size;
const closedWord = plural(closedCountryCount, 'стране', 'странах', 'странах');
const eventWord = plural(events.length, 'событие', 'события', 'событий');
const countryCount = new Set(events.map((e) => e.slug)).size;
const countryWord = plural(countryCount, 'страна', 'страны', 'стран');

const prevIdx = (monthIdx + 11) % 12;
const nextIdx = (monthIdx + 1) % 12;

const url = `https://traveltribe.ru/events/${m.slug}/`;
const title = `Фестивали и праздники мира в ${m.prep} 2026`;
const description = `Что закрыто, что стоит успеть и какие фестивали идут в ${m.prep}: ${events.length} ${eventWord} по ${countryCount} странам — с датами и практическими нюансами.`.slice(0, 155);

const FAQS = [
  {
    q: `Что закрыто в ${m.prep}?`,
    a: closed.length
      ? `В ${closedCountryCount} ${closedWord} в ${m.prep} государственные праздники или ограничения: ${closed.slice(0, 5).map((e) => `${e.nom} (${e.name})`).join(', ')}${closed.length > 5 ? ' и другие' : ''}.`
      : `В ${m.prep} по нашим данным нет закрытий, которые сильно повлияют на туриста.`,
  },
  {
    q: `Какие фестивали стоит успеть в ${m.prep}?`,
    a: fest.length
      ? fest.slice(0, 4).map((e) => `${e.name} (${e.nom})`).join(', ') + '.'
      : `Ярких фестивалей в ${m.prep} в нашей подборке нет — смотри соседние месяцы.`,
  },
  {
    q: editorial ? 'Стоит ли ехать именно в этот месяц?' : `Какой сезон в ${m.prep}?`,
    a: editorial?.verdict || `Смотри таблицу сезонов по конкретной стране — календарь событий не заменяет погодный разбор.`,
  },
];

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#page`,
      "name": title,
      "description": description,
      "url": url,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "datePublished": "2026-07-06",
      "dateModified": DATA_UPDATED_RU,
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", ".evt-tldr"] },
    },
    {
      "@type": "ItemList",
      "@id": `${url}#events`,
      "name": `События ${m.prep} по странам`,
      "itemListElement": events.map((e, i) => ({ "@type": "ListItem", "position": i + 1, "name": `${e.nom}: ${e.name}` })),
    },
    {
      "@type": "FAQPage",
      "@id": `${url}#faq`,
      "mainEntity": FAQS.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "События", "item": "https://traveltribe.ru/events/" },
        { "@type": "ListItem", "position": 3, "name": monthCap, "item": url },
      ],
    },
  ],
};
---
<Layout title={title} description={description} canonical={url} ldJson={ldJson}>
  <Breadcrumbs crumbs={[{ label: 'События', href: '/events/' }, { label: monthCap }]} />

  <main id="main" class="evt">
    <section class="evt-manifest">
      <div class="evt-idx">01 / События<b>{events.length} {eventWord} · {countryCount} {countryWord}</b></div>
      <div class="evt-meta">Календарь<br /><b>Обновлено {DATA_UPDATED_RU}</b></div>
      <h1 class="evt-h1">Праздники и фестивали <span class="rd">в {m.prep}</span></h1>
      {editorial && <p class="evt-tldr">{editorial.intro}</p>}
    </section>

    {closed.length > 0 && (
      <section class="evt-section">
        <div class="evt-shead"><h2>Закрыто или выходные</h2></div>
        <p class="evt-note">Государственные праздники: транспорт и часть бизнеса могут не работать, цены иногда растут.</p>
        <ul class="evt-list">
          {closed.map((e) => (
            <li>
              <span class="evt-tag evt-tag--closed">{TAG_LABEL.closed}</span>
              <a href={`/${e.slug}/`} class="evt-link"><b>{e.nom}</b></a>
              <span class="evt-name">{e.name}{e.dates ? ` — ${e.dates}` : ''}</span>
              {e.note && <span class="evt-desc">{e.note}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}

    {fest.length > 0 && (
      <section class="evt-section">
        <div class="evt-shead"><h2>Фестивали — стоит планировать поездку вокруг</h2></div>
        <ul class="evt-list">
          {fest.map((e) => (
            <li>
              <span class="evt-tag evt-tag--fest">{TAG_LABEL.fest}</span>
              <a href={`/${e.slug}/`} class="evt-link"><b>{e.nom}</b></a>
              <span class="evt-name">{e.name}{e.dates ? ` — ${e.dates}` : ''}</span>
              {e.note && <span class="evt-desc">{e.note}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}

    {culture.length > 0 && (
      <section class="evt-section">
        <div class="evt-shead"><h2>Сезонные явления</h2></div>
        <ul class="evt-list">
          {culture.map((e) => (
            <li>
              <span class="evt-tag evt-tag--culture">{TAG_LABEL.culture}</span>
              <a href={`/${e.slug}/`} class="evt-link"><b>{e.nom}</b></a>
              <span class="evt-name">{e.name}{e.dates ? ` — ${e.dates}` : ''}</span>
              {e.note && <span class="evt-desc">{e.note}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}

    {editorial && (
      <section class="evt-section">
        <div class="evt-shead"><h2>Вывод</h2></div>
        <p class="evt-verdict">{editorial.verdict}</p>
      </section>
    )}

    <section class="evt-section">
      <div class="evt-shead"><h2>FAQ</h2></div>
      <div class="evt-faq">
        {FAQS.map((f) => (
          <details class="evt-faq-i">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="evt-section">
      <div class="evt-shead"><h2>Другие месяцы</h2></div>
      <div class="evt-monthnav">
        <a class="evt-monthnav-side" href={`/events/${MONTHS[prevIdx].slug}/`}>← {MONTHS[prevIdx].nom}</a>
        <a href="/events/" class="evt-monthnav-mid">Все месяцы</a>
        <a class="evt-monthnav-side evt-monthnav-side--right" href={`/events/${MONTHS[nextIdx].slug}/`}>{MONTHS[nextIdx].nom} →</a>
      </div>
    </section>

    <section class="evt-section">
      <div class="evt-shead"><h2>Что почитать дальше</h2></div>
      <ul class="evt-related">
        <li><a href={`/trips/${m.slug}/`}><b>Куда ехать в {m.prep}</b></a><span>календарь направлений по сезону</span></li>
        <li><a href="/seasons/"><b>Таблица сезонов 70+ направлений</b></a><span>погода и цены по месяцам</span></li>
        <li><a href="/compare/"><b>Сравнить направления</b></a><span>компаратор</span></li>
      </ul>
    </section>

    <p class="evt-updated">Актуально на: {DATA_UPDATED_RU}</p>
  </main>

  <Footer />
</Layout>

<style>
.evt {
  max-width: 980px;
  margin: 0 auto;
  padding: 0 clamp(1.1rem, 3vw, 2.6rem) clamp(2rem, 4vw, 4rem);
  font-family: var(--ff-display);
  font-variant-numeric: tabular-nums lining-nums;
  color: var(--text);
}
.evt-manifest {
  display: grid;
  grid-template-columns: repeat(12, minmax(0, 1fr));
  gap: 0 clamp(.8rem, 2vw, 1.6rem);
  padding: clamp(1rem, 2vw, 1.8rem) 0 clamp(1.2rem, 2.5vw, 2rem);
}
.evt-idx { grid-column: 1 / 7; grid-row: 1; font-size: .74rem; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; color: var(--gold); }
.evt-idx b { display: block; color: var(--text); font-size: .74rem; font-weight: 600; margin-top: .2rem; }
.evt-meta { grid-column: 8 / 13; grid-row: 1; text-align: right; align-self: start; font-size: .8rem; color: var(--text-dim); line-height: 1.5; }
.evt-meta b { color: var(--text); font-weight: 600; }
.evt-h1 { grid-column: 1 / 13; grid-row: 2; font-weight: 800; font-size: clamp(2rem, 5.5vw, 4.4rem); line-height: 1.0; letter-spacing: -.03em; margin: clamp(1rem, 2vw, 1.6rem) 0 0; text-wrap: balance; }
.evt-h1 .rd { color: var(--gold); }
.evt-tldr { grid-column: 1 / 11; grid-row: 3; font-size: clamp(1rem, 1.3vw, 1.15rem); color: var(--text); line-height: 1.6; margin-top: 1.3rem; }

.evt-section { border-top: 2px solid #1b1914; padding: clamp(1.4rem, 3vw, 2.2rem) 0; scroll-margin-top: 80px; }
.evt-shead h2 { font-size: clamp(1.2rem, 2.4vw, 1.6rem); font-weight: 800; letter-spacing: -.015em; margin: 0 0 .5rem; }
.evt-note { font-size: .88rem; color: var(--text-dim); margin: 0 0 1rem; }
.evt-verdict { font-size: 1rem; line-height: 1.6; }

.evt-list { list-style: none; margin: 0; padding: 0; }
.evt-list li {
  border-top: 1px solid var(--line);
  padding: .8rem 0;
  display: grid;
  grid-template-columns: auto auto 1fr;
  gap: .3rem .7rem;
  align-items: baseline;
}
.evt-list li:first-child { border-top: none; }
.evt-tag {
  display: inline-block;
  padding: .15rem .5rem;
  font-size: .64rem;
  font-weight: 700;
  letter-spacing: .04em;
  text-transform: uppercase;
  border: 1px solid var(--line);
  align-self: start;
}
.evt-tag--closed { color: var(--bad-text); border-color: var(--bad-text); }
.evt-tag--fest { color: var(--gold); border-color: var(--gold); }
.evt-tag--culture { color: var(--good-text); border-color: var(--good-text); }
.evt-link { color: var(--text); text-decoration: none; white-space: nowrap; }
.evt-link b { color: var(--gold); text-decoration: underline; text-underline-offset: 3px; font-weight: 700; }
.evt-name { grid-column: 1 / -1; font-size: .92rem; color: var(--text); }
.evt-desc { grid-column: 1 / -1; font-size: .82rem; color: var(--text-faint); }

@media (max-width: 640px) {
  .evt-list li { grid-template-columns: auto 1fr; }
  .evt-link { white-space: normal; }
}

.evt-faq-i { border-top: 1px solid var(--line); padding: .9rem 0; }
.evt-faq-i summary { font-weight: 700; cursor: pointer; min-height: 44px; display: flex; align-items: center; }
.evt-faq-i p { margin: .6rem 0 0; color: var(--text-dim); line-height: 1.6; }

.evt-monthnav { display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
.evt-monthnav-side { color: var(--gold); font-weight: 700; text-decoration: underline; text-underline-offset: 3px; min-height: 44px; display: inline-flex; align-items: center; }
.evt-monthnav-mid { color: var(--text-dim); text-decoration: underline; text-underline-offset: 3px; min-height: 44px; display: inline-flex; align-items: center; }
.evt-monthnav-side--right { margin-left: auto; }

.evt-related { list-style: none; margin: 0; padding: 0; }
.evt-related li { border-top: 1px solid var(--line); padding: .8rem 0; display: flex; flex-direction: column; }
.evt-related a { color: var(--text); text-decoration: none; }
.evt-related a b { color: var(--gold); text-decoration: underline; text-underline-offset: 3px; }
.evt-related span { font-size: .82rem; color: var(--text-faint); margin-top: .15rem; }

.evt-updated { margin-top: 2rem; font-size: .72rem; color: var(--text-faint); }
</style>
