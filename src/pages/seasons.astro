---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import AviasalesWidget from '../components/post/AviasalesWidget.astro';
import { data } from '../data/regions.js';
import { regionMeta } from '../data/regions-meta.js';
import { regionsRich } from '../data/regions-rich.js';
import pricesData from '../data/prices-cache.json';
import { DATA_UPDATED_RU } from '../data/meta.js';

const VISA_LABEL = { free: 'Без визы', evisa: 'eVisa', required: 'Виза' };
const VISA_CLASS = { free: 'tag-free', evisa: 'tag-evisa', required: 'tag-visa' };
const BUDGET_LABEL = { low: '$ Дёшево', mid: '$$ Средне', high: '$$$ Дорого' };
const BUDGET_CLASS = { low: 'tag-low', mid: 'tag-mid', high: 'tag-high' };
const CLASSES = { P: 'peak', G: 'good', O: 'ok', B: 'bad', X: 'off' };
const LABELS  = { P: '●', G: '●', O: '●', B: '●', X: '·' };
const RANK    = { P: 4, G: 3, O: 2, B: 1, X: 0 };

const MONTH_NAMES = ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];
const MONTH_NAMES_LOCATIVE = ['январе','феврале','марте','апреле','мае','июне','июле','августе','сентябре','октябре','ноябре','декабре'];

// Текущий месяц (для подсветки и default-фокуса)
const now = new Date();
const currentMonth = now.getMonth();

// Хелпер: best/worst месяцы для строки
function findBestWorst(r) {
  let bestIdx = -1, worstIdx = -1, bestRank = -1, worstRank = 99;
  r.forEach((code, i) => {
    const v = RANK[code];
    if (v > bestRank) { bestRank = v; bestIdx = i; }
    if (v < worstRank) { worstRank = v; worstIdx = i; }
  });
  return { bestIdx, worstIdx };
}

// 12 месяцев вперёд для мапинга ячейка → YYYY-MM (для prices)
function priceMonthFor(monthIdx) {
  const target = (currentMonth + ((monthIdx - currentMonth + 12) % 12));
  const year = now.getFullYear() + (target < currentMonth ? 1 : 0);
  // target overflow → next year
  const realMonth = target % 12;
  const realYear = year + Math.floor(target / 12);
  return `${realYear}-${String(realMonth + 1).padStart(2, '0')}`;
}

// Простая версия: 0=янв, цена нужна на ближайший такой месяц
function nearestPriceKey(monthIdx) {
  const targetYear = monthIdx >= currentMonth ? now.getFullYear() : now.getFullYear() + 1;
  return `${targetYear}-${String(monthIdx + 1).padStart(2, '0')}`;
}

// Aviasales deep-link для месяца: формат MOW{DD}{MM}{IATA}1 (1 пассажир)
const AVIASALES_MARKER = '546042.Zz66f13c16ff6b488883a4127-546042';
function aviasalesUrl(iata, monthIdx) {
  if (!iata) return null;
  const yr = monthIdx >= currentMonth ? now.getFullYear() : now.getFullYear() + 1;
  const mm = String(monthIdx + 1).padStart(2, '0');
  // Середина месяца
  return `https://www.aviasales.ru/search/MOW15${mm}${iata}1?marker=${AVIASALES_MARKER}`;
}

// Подготовка данных для рендера: для каждого региона предвычисляем enriched-объект
const enrichedRows = data.map(row => {
  if (row.group) return row;
  const meta = regionMeta[row.sub] || { slug: '', iata: null, blogSlug: null };
  const rich = regionsRich[meta.slug] || { events: Array(12).fill(null), notes: Array(12).fill(null), negatives: Array(12).fill(null) };
  const { bestIdx, worstIdx } = findBestWorst(row.r);
  const prices = meta.iata && pricesData.prices && pricesData.prices[meta.iata] ? pricesData.prices[meta.iata] : {};
  return { ...row, meta, rich, bestIdx, worstIdx, prices };
});

// Все НЕ-group строки для TouristDestination Schema
const destinationRows = enrichedRows.filter(r => !r.group);

// JSON-LD: WebPage + ItemList + все TouristDestination + FAQPage + Breadcrumbs
const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://traveltribe.ru/seasons/#webpage",
      "url": "https://traveltribe.ru/seasons/",
      "name": "Сезоны для путешествий 2026 — куда и когда из России | TravelTribe",
      "description": "Интерактивная таблица: 70 направлений мира, лучшее время для поездки, виза, бюджет и реальные цены билетов из Москвы. Для путешественников из России.",
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "mainEntity": { "@id": "https://traveltribe.ru/seasons/#destinations" },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".seasons-tldr"]
      }
    },
    {
      "@type": "ItemList",
      "@id": "https://traveltribe.ru/seasons/#destinations",
      "name": "Лучшие направления для путешествий из России — сезонность 2026",
      "description": `${destinationRows.length} направлений мира с анализом сезонности, визовых требований и бюджета для путешественников из России`,
      "numberOfItems": destinationRows.length,
      "itemListElement": destinationRows.map((r, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "TouristDestination",
          "@id": `https://traveltribe.ru/seasons/#${r.meta.slug}`,
          "name": `${r.region} — ${r.sub}`,
          "description": `Лучшее время для поездки в ${r.region}: ${MONTH_NAMES[r.bestIdx]}. ${r.t[r.bestIdx]}`,
          "touristType": ["Russian travelers"],
          ...(r.meta.blogSlug ? { "url": `https://traveltribe.ru/blog/${r.meta.blogSlug}/` } : {})
        }
      }))
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Когда лучше ехать в путешествие из России в 2026 году?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Зависит от направления. Для пляжного отдыха зимой — Бали (апрель–октябрь), Таиланд (ноябрь–февраль), Доминикана (декабрь–апрель). Летом без визы — Грузия, Армения, Турция, Узбекистан, Казахстан. Осенью — Япония (момидзи в ноябре), Канада (foliage в Квебеке в октябре), Чили (март)."
          }
        },
        {
          "@type": "Question",
          "name": "Куда поехать без визы из России в 2026?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Без визы: Турция, Грузия, Армения, Узбекистан, Казахстан, Кыргызстан, ОАЭ, Таиланд, Вьетнам, Мальдивы, ЮАР, Марокко, Куба, Доминикана, Мексика, Чили. С eVisa онлайн: Индонезия (Бали), Шри-Ланка, Индия (Гоа), Кения, Египет, Корея."
          }
        },
        {
          "@type": "Question",
          "name": "Сколько стоит билет из Москвы в популярные страны?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "По данным Aviasales на актуальный месяц из таблицы: Стамбул от 21 000 ₽, Ташкент от 15 000 ₽, Алматы от 28 000 ₽, Бангкок от 43 000 ₽, Дубай от 30 000 ₽, Токио от 55 000 ₽, Гавана от 150 000 ₽. Цены обновляются ежедневно — кликните на ячейку нужного месяца, чтобы увидеть свежий минимум и перейти к билетам."
          }
        },
        {
          "@type": "Question",
          "name": "Как пользоваться таблицей сезонов?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Каждая ячейка — оценка месяца для конкретного региона: пик (зелёный), хорошо (синий), нормально (жёлтый), плохо (красный), закрыто (пунктир). Кликните на ячейку — откроется панель с описанием погоды, событиями, личными пометками и ценой билета. Используйте поиск и фильтр по месяцу, чтобы быстро найти направление."
          }
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Сезоны", "item": "https://traveltribe.ru/seasons/" }
      ]
    }
  ]
};

const pricesUpdatedAt = pricesData.updatedAt
  ? new Date(pricesData.updatedAt).toLocaleDateString('ru-RU')
  : null;
---
<Layout
  title="Сезоны для путешествий 2026 — куда и когда из России"
  description="Таблица сезонности: 70 направлений — когда лететь, виза, бюджет и реальные цены билетов из Москвы по месяцам. Кликни месяц для погоды и деталей."
  canonical="https://traveltribe.ru/seasons/"
  ogTitle="Сезоны для путешествий из России — 70 направлений и цены"
  ogDescription="Таблица сезонности: где сейчас комфортно, когда лететь дёшево, какие события в каком месяце. Реальные цены Aviasales."
  ldJson={ldJson}
  noTransitions
>

  <main id="main">
  <header>
    <h1>Сезоны для <em>путешествий</em></h1>
    <p class="subtitle">// {destinationRows.length} направлений · виза, бюджет и цены билетов · обновлено {pricesUpdatedAt ?? '—'}</p>
    <p class="seasons-byline">
      <a href="/about/" class="byline-author">Никита Зайцев</a> ·
      <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> ·
      <span class="byline-fresh">сезоны и визы актуальны на {DATA_UPDATED_RU}</span>
    </p>
  </header>

  <div class="seasons-tldr">
    <div class="tldr-box">
      <p><strong>Когда лучше ехать:</strong> зимой (декабрь–февраль) — Юго-Восточная Азия, Бали, Мальдивы, ОАЭ и Карибы; летом без визы — Грузия, Армения, Турция и Средняя Азия; осенью — Япония (момидзи в ноябре) и Патагония; весной — Узбекистан и цветение сакуры в Японии и Корее.</p>
      <p>Ниже — таблица по {destinationRows.length} направлениям: <strong>цвет ячейки</strong> показывает, насколько хорош месяц для поездки, <strong>★</strong> — лучший месяц по строке, <strong>цифра</strong> — цена билета из Москвы. Кликни на месяц — погода, события, личные пометки и ссылка на билет.</p>
    </div>
  </div>

  <div class="mission">
    <span class="mission-pill pill-os">⊹ Open Source</span>
    <span class="mission-pill pill-free">✓ Бесплатно навсегда</span>
    <span class="mission-pill pill-uni">◈ Без воды и рекламы</span>
    <span class="mission-sep">·</span>
    <span style="font-size:0.75rem;color:var(--text-dim)">Кликни на месяц — открой полную карточку</span>
  </div>

  <div class="controls">
    <input
      id="seasonsSearch"
      type="search"
      class="search-input"
      placeholder="Поиск страны или города…"
      aria-label="Поиск по таблице"
      autocomplete="off"
    />
    <span class="controls-label">Месяц →</span>
    <button class="month-btn" data-month="0" aria-pressed="false">Янв</button>
    <button class="month-btn" data-month="1" aria-pressed="false">Фев</button>
    <button class="month-btn" data-month="2" aria-pressed="false">Мар</button>
    <button class="month-btn" data-month="3" aria-pressed="false">Апр</button>
    <button class="month-btn" data-month="4" aria-pressed="false">Май</button>
    <button class="month-btn" data-month="5" aria-pressed="false">Июн</button>
    <button class="month-btn" data-month="6" aria-pressed="false">Июл</button>
    <button class="month-btn" data-month="7" aria-pressed="false">Авг</button>
    <button class="month-btn" data-month="8" aria-pressed="false">Сен</button>
    <button class="month-btn" data-month="9" aria-pressed="false">Окт</button>
    <button class="month-btn" data-month="10" aria-pressed="false">Ноя</button>
    <button class="month-btn" data-month="11" aria-pressed="false">Дек</button>
    <button class="reset-btn" id="resetBtn" aria-label="Сбросить фильтры">Сброс</button>
  </div>

  <div class="legend">
    <div class="legend-item"><div class="dot" style="background:var(--peak)"></div> Пик сезона</div>
    <div class="legend-item"><div class="dot" style="background:var(--good)"></div> Хорошо</div>
    <div class="legend-item"><div class="dot" style="background:var(--ok)"></div> Нормально</div>
    <div class="legend-item"><div class="dot" style="background:var(--bad)"></div> Плохо</div>
    <div class="legend-item"><div class="dot" style="background:var(--off)"></div> Закрыт</div>
    <div class="legend-item"><span class="best-mark">★</span> Лучший месяц</div>
    <div class="legend-item"><span class="worst-mark">✕</span> Худший месяц</div>
  </div>

  <div class="table-wrap" role="region" aria-label="Таблица сезонности по регионам">
    <table id="mainTable">
      <caption class="visually-hidden">Сезоны для путешествий — {destinationRows.length} направлений мира</caption>
      <thead>
        <tr>
          <th scope="col">Регион</th>
          {MONTH_NAMES.map((_, i) => (
            <th
              scope="col"
              class={`month-header${i === currentMonth ? ' is-current' : ''}`}
              data-month={i}
            >{['ЯНВ','ФЕВ','МАР','АПР','МАЙ','ИЮН','ИЮЛ','АВГ','СЕН','ОКТ','НОЯ','ДЕК'][i]}</th>
          ))}
        </tr>
      </thead>
      <tbody id="tbody">
        {enrichedRows.map(row => row.group ? (
          <tr class="group-header">
            <td colspan="13">{row.group}</td>
          </tr>
        ) : (
          <tr data-region={row.region.toLowerCase()} data-sub={row.sub.toLowerCase()} data-slug={row.meta.slug}>
            <td class="region-cell">
              {row.meta.slug ? (
                <a href={`/${row.meta.slug}/`} class="region-link">{row.region}</a>
              ) : (
                <span>{row.region}</span>
              )}
              <span class="region-sub">{row.sub}</span>
              <div class="tags">
                {row.region === 'Япония'
                  ? <a href="/blog/japan-visa-2026/" class={`tag ${VISA_CLASS[row.visa]}`}>{VISA_LABEL[row.visa]}</a>
                  : <span class={`tag ${VISA_CLASS[row.visa]}`}>{VISA_LABEL[row.visa]}</span>
                }
                <span class={`tag ${BUDGET_CLASS[row.budget]}`}>{BUDGET_LABEL[row.budget]}</span>
              </div>
            </td>
            {row.r.map((code, i) => {
              const isBest = i === row.bestIdx;
              const isWorst = i === row.worstIdx;
              const priceKey = nearestPriceKey(i);
              const price = row.prices[priceKey] ?? null;
              return (
                <td
                  class={`cell ${CLASSES[code]}${isBest ? ' is-best' : ''}${isWorst ? ' is-worst' : ''}${i === currentMonth ? ' is-current-month' : ''}`}
                  data-month={i}
                  data-region={row.region}
                  data-sub={row.sub}
                  data-slug={row.meta.slug}
                  data-text={row.t[i] ?? ''}
                  data-event={row.rich.events[i] ?? ''}
                  data-note={row.rich.notes[i] ?? ''}
                  data-negative={row.rich.negatives[i] ?? ''}
                  data-iata={row.meta.iata ?? ''}
                  data-blog={row.meta.blogSlug ?? ''}
                  data-price={price ?? ''}
                  data-visa={row.visa}
                  data-budget={row.budget}
                  tabindex="0"
                  role="button"
                  aria-label={`${row.region}, ${MONTH_NAMES[i]}: ${row.t[i]}`}
                >
                  <span class="badge">{LABELS[code]}</span>
                  <span class="cell-mo" aria-hidden="true">{['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек'][i]}</span>
                  {isBest && <span class="best-mark" aria-hidden="true">★</span>}
                  {isWorst && <span class="worst-mark" aria-hidden="true">✕</span>}
                  {price && <span class="price-mini" aria-hidden="true">{Math.round(price / 1000)}к</span>}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
    <p class="empty-state" id="emptyState" hidden>Ничего не найдено. Попробуй другой запрос или сбрось фильтры.</p>
  </div>

  <p class="climate-disclaimer">
    Данные по погоде — обобщение наблюдений 2020–2025. Классические сезоны дождей и муссонов <strong>сдвинулись на 2–3 недели</strong> относительно «учебников» 2010-х. Цены — реальные минимумы на one-way рейсы из Москвы по данным Aviasales, обновляются ежедневно.
  </p>

  <footer class="table-footer">
    * Пик = идеальные условия · Хорошо = отлично, меньше толп · Нормально = можно, есть нюансы · Плохо = дожди/жара/холод критичны · Закрыт = инфраструктура не работает<br />
    * Виза и бюджет — для россиян на 2026 год. eVisa = онлайн без посещения консульства<br />
    * Бюджет: $ до ~$1500/нед · $$ $1500–3000/нед · $$$ от $3000/нед (перелёт + проживание + еда)<br />
    * ★ — лучший месяц по строке · ✕ — худший · цены в углу = тысяч рублей за one-way из MOW
  </footer>

  <section class="faq" aria-label="Методология">
    <h2>Как читать таблицу</h2>
    <dl>
      <div>
        <dt><span class="dot dot-peak">●</span> Пик сезона</dt>
        <dd>Идеальные погодные условия, лучшее время для поездки. Высокий туристический сезон — бронируйте заранее.</dd>
      </div>
      <div>
        <dt><span class="dot dot-good">●</span> Хорошо</dt>
        <dd>Отличные условия с меньшим потоком туристов. Часто выгоднее по ценам при сопоставимом комфорте.</dd>
      </div>
      <div>
        <dt><span class="dot dot-ok">●</span> Нормально</dt>
        <dd>Поехать можно, но есть нюансы: дожди, жара или влажность. Уточняйте детали по конкретному региону.</dd>
      </div>
      <div>
        <dt><span class="dot dot-bad">●</span> Плохо</dt>
        <dd>Критичные условия: сезон дождей, экстремальная жара или холод. Не рекомендуется без веской причины.</dd>
      </div>
    </dl>
    <h2 style="margin-top:2rem">Когда лучше ехать в путешествие из России в 2026?</h2>
    <p>Зависит от направления и того, что ты ищешь. Для <strong>пляжного отдыха зимой</strong> (декабрь–февраль) лучшие варианты — Таиланд, Бали (апрель–октябрь сухой сезон), Доминикана, Мальдивы, ОАЭ, Куба. <strong>Летом без визы</strong> — Грузия, Армения, Турция, Узбекистан, Казахстан, Кыргызстан. <strong>Осенью</strong> — Япония (момидзи в ноябре), Канада (foliage в Квебеке в октябре), Чили (март–апрель в Патагонии). <strong>Весной</strong> — Узбекистан в апреле, цветение сакуры в Японии и Корее.</p>

    <h2 style="margin-top:1.5rem">Куда поехать без визы или с eVisa?</h2>
    <p><strong>Без визы для россиян:</strong> <a href="/turkey/">Турция</a>, <a href="/georgia/">Грузия</a>, <a href="/armenia/">Армения</a>, <a href="/uzbekistan/">Узбекистан</a>, <a href="/kazakhstan/">Казахстан</a>, <a href="/kyrgyzstan/">Кыргызстан</a>, <a href="/uae/">ОАЭ</a>, <a href="/thailand/">Таиланд</a>, <a href="/vietnam/">Вьетнам</a>, <a href="/maldives/">Мальдивы</a>, <a href="/south-africa/">ЮАР</a>, <a href="/morocco/">Марокко</a>, <a href="/cuba/">Куба</a>, <a href="/dominican-republic/">Доминикана</a>, <a href="/mexico/">Мексика</a>, <a href="/chile-patagonia/">Чили</a>, <a href="/switzerland/">Швейцария</a> по Шенгену.<br /><strong>С eVisa онлайн:</strong> <a href="/bali/">Индонезия (Бали)</a>, <a href="/sri-lanka/">Шри-Ланка</a>, <a href="/india-goa/">Индия (Гоа)</a>, <a href="/kenya/">Кения</a>, <a href="/egypt/">Египет</a>, <a href="/south-korea/">Южная Корея</a>, <a href="/tajikistan/">Таджикистан</a>.<br /><strong>Стандартная виза:</strong> <a href="/japan/">Япония</a>, страны Шенгена, <a href="/canada-east/">Канада</a>, <a href="/australia-north/">Австралия</a>.</p>
    <p class="faq-hubs"><a href="/visa/"><strong>Все визовые требования по странам →</strong></a> · <a href="/countries/"><strong>Каталог всех 70 направлений →</strong></a></p>

    <p class="faq-note">Виза и бюджет актуальны для граждан России на 2026 год. Всегда уточняйте визовые требования на сайте консульства перед покупкой билетов.</p>

    <h2 style="margin-top:1.5rem">Что взять в поездку</h2>
    <p>Чек-листы по 70 странам и 12 месяцам — одежда под погоду, документы, аптечка, техника, переходник. <a href="/packing/"><strong>Открыть чек-листы поездок →</strong></a></p>
  </section>

  <AviasalesWidget title="Найти билеты — куда планируешь поехать?" subid="seasons" />

  <div class="footer-contribute">
    <p>
      <strong>Open Source проект о путешествиях.</strong> Знаешь направление которого здесь нет?<br />
      Добавь регион, фичу или исправь данные — любой вклад приветствуется.
    </p>
    <a class="contribute-btn" href="https://github.com/nzaytsevmy/traveltribe-feedback" target="_blank" rel="noopener">→ Contribute on GitHub</a>
  </div>
  </main>

  <!-- Side-panel (desktop) / Bottom-sheet (mobile) — открывается по клику на ячейку -->
  <div id="panelOverlay" class="panel-overlay" aria-hidden="true"></div>
  <aside id="cellPanel" class="cell-panel" role="dialog" aria-modal="false" aria-labelledby="panelTitle" aria-hidden="true">
    <header class="panel-header">
      <div>
        <h2 id="panelTitle"></h2>
        <p id="panelMeta"></p>
      </div>
      <button id="panelClose" class="panel-close" aria-label="Закрыть">×</button>
    </header>
    <div class="panel-body">
      <div id="panelStatus" class="panel-status"></div>
      <p id="panelText" class="panel-text"></p>
      <div id="panelEvent" class="panel-block panel-event" hidden>
        <span class="panel-block-label">Событие месяца</span>
        <p id="panelEventText"></p>
      </div>
      <div id="panelNote" class="panel-block panel-note" hidden>
        <span class="panel-block-label">Личная пометка Никиты</span>
        <p id="panelNoteText"></p>
      </div>
      <div id="panelNegative" class="panel-block panel-negative" hidden>
        <span class="panel-block-label">Что важно знать</span>
        <p id="panelNegativeText"></p>
      </div>
      <div class="panel-spacer"></div>
      <div id="panelPrice" class="panel-block panel-price" hidden>
        <span class="panel-block-label">Билет из Москвы</span>
        <p id="panelPriceText"></p>
      </div>
    </div>
    <footer class="panel-footer">
      <a id="panelAviasales" class="panel-cta panel-cta-primary" href="#" target="_blank" rel="noopener sponsored">Найти билет на Aviasales</a>
      <span class="ad-mark panel-ad-mark">реклама · партнёрская ссылка, цена не меняется</span>
      <div class="panel-cta-row">
        <a id="panelBlog" class="panel-cta panel-cta-secondary" href="#" hidden>Гид по стране →</a>
        <button id="panelShare" class="panel-cta panel-cta-secondary" type="button">Поделиться</button>
      </div>
    </footer>
  </aside>

  <Footer />
</Layout>

<script>
// Идемпотентная инициализация: на первой загрузке И после каждого SPA-перехода
// ClientRouter (иначе вся интерактивность таблицы умирала при навигации внутри сайта).
function _seasonsInit() {
  const _tb = document.getElementById('tbody');
  if (!_tb || _tb._seasonsReady) return;   // 1 раз на свежий DOM
  _tb._seasonsReady = true;

const MONTH_NAMES = ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];
const MONTH_NAMES_LOCATIVE = ['январе','феврале','марте','апреле','мае','июне','июле','августе','сентябре','октябре','ноябре','декабре'];

let activeMonth = null;
let activeQuery = '';
let panelOpen = false;
let currentShare = null;   // ?country=&m= текущей ячейки — строим ссылку для Share, но НЕ пишем в адрес постоянно

function applyFilter() {
  const rows = document.querySelectorAll('#tbody tr:not(.group-header)');
  const cells = document.querySelectorAll('td.cell');
  const headers = document.querySelectorAll('.month-header');
  const groupHeaders = document.querySelectorAll('#tbody tr.group-header');
  let visibleCount = 0;

  rows.forEach(row => {
    const region = (row.dataset.region || '').toLowerCase();
    const sub = (row.dataset.sub || '').toLowerCase();
    const matchesQuery = !activeQuery || region.includes(activeQuery) || sub.includes(activeQuery);
    if (matchesQuery) {
      row.removeAttribute('hidden');
      visibleCount++;
    } else {
      row.setAttribute('hidden', '');
    }
  });

  cells.forEach(cell => {
    const colIdx = parseInt(cell.dataset.month, 10);
    if (activeMonth === null) {
      cell.classList.remove('dimmed', 'col-highlight');
    } else {
      cell.classList.toggle('dimmed', colIdx !== activeMonth);
      cell.classList.toggle('col-highlight', colIdx === activeMonth);
    }
  });

  headers.forEach((th, i) => {
    th.classList.toggle('col-highlight', activeMonth === i);
  });

  // Скрываем group headers без видимых строк под ними
  groupHeaders.forEach(gh => {
    let next = gh.nextElementSibling;
    let hasVisible = false;
    while (next && !next.classList.contains('group-header')) {
      if (!next.hasAttribute('hidden')) { hasVisible = true; break; }
      next = next.nextElementSibling;
    }
    gh.toggleAttribute('hidden', !hasVisible);
  });

  document.getElementById('emptyState').toggleAttribute('hidden', visibleCount > 0);
}

// Кнопки месяцев
document.querySelectorAll('.month-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const m = parseInt(btn.dataset.month, 10);
    if (activeMonth === m) {
      activeMonth = null;
      btn.classList.remove('active');
      btn.setAttribute('aria-pressed', 'false');
    } else {
      document.querySelectorAll('.month-btn').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      activeMonth = m;
    }
    syncUrl();
    applyFilter();
  });
});

// Reset
document.getElementById('resetBtn').addEventListener('click', () => {
  activeMonth = null;
  activeQuery = '';
  document.getElementById('seasonsSearch').value = '';
  document.querySelectorAll('.month-btn').forEach(b => {
    b.classList.remove('active');
    b.setAttribute('aria-pressed', 'false');
  });
  syncUrl();
  applyFilter();
});

// Search
const searchInput = document.getElementById('seasonsSearch');
let searchTimer = null;
searchInput.addEventListener('input', e => {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => {
    activeQuery = e.target.value.trim().toLowerCase();
    syncUrl();
    applyFilter();
  }, 100);
});

// Hover на ячейке — подсветка колонки. Делегирование на #tbody (1 listener вместо
// 840×2) — канон 2026: минимум JS для хорошего INP.
const tbodyEl = document.getElementById('tbody');
tbodyEl.addEventListener('mouseover', e => {
  const cell = e.target.closest('td.cell');
  if (!cell || activeMonth !== null) return;
  const m = parseInt(cell.dataset.month, 10);
  document.querySelectorAll('.month-header').forEach((th, i) => th.classList.toggle('hover-col', i === m));
});
tbodyEl.addEventListener('mouseout', e => {
  if (e.target.closest('td.cell')) {
    document.querySelectorAll('.month-header.hover-col').forEach(th => th.classList.remove('hover-col'));
  }
});

// Side-panel open
function openPanel(cell) {
  const monthIdx = parseInt(cell.dataset.month, 10);
  const region = cell.dataset.region;
  const sub = cell.dataset.sub;
  const text = cell.dataset.text;
  const event = cell.dataset.event;
  const note = cell.dataset.note;
  const negative = cell.dataset.negative;
  const iata = cell.dataset.iata;
  const blog = cell.dataset.blog;
  const price = cell.dataset.price;
  const visa = cell.dataset.visa;
  const budget = cell.dataset.budget;
  const slug = cell.dataset.slug;
  const isBest = cell.classList.contains('is-best');
  const isWorst = cell.classList.contains('is-worst');

  document.getElementById('panelTitle').textContent = `${region} в ${MONTH_NAMES_LOCATIVE[monthIdx]}`;
  document.getElementById('panelMeta').textContent = sub;

  // Status badge
  const status = document.getElementById('panelStatus');
  let statusText = '';
  if (cell.classList.contains('peak')) statusText = '● Пик сезона';
  else if (cell.classList.contains('good')) statusText = '● Хорошо';
  else if (cell.classList.contains('ok')) statusText = '● Нормально';
  else if (cell.classList.contains('bad')) statusText = '● Плохо';
  else if (cell.classList.contains('off')) statusText = '· Закрыт / нет смысла';
  if (isBest) statusText += ' · ★ Лучший месяц по году';
  if (isWorst && !isBest) statusText += ' · ✕ Худший месяц по году';
  status.textContent = statusText;
  status.className = 'panel-status';
  if (cell.classList.contains('peak')) status.classList.add('s-peak');
  else if (cell.classList.contains('good')) status.classList.add('s-good');
  else if (cell.classList.contains('ok')) status.classList.add('s-ok');
  else if (cell.classList.contains('bad')) status.classList.add('s-bad');
  else if (cell.classList.contains('off')) status.classList.add('s-off');

  document.getElementById('panelText').textContent = text;

  toggleBlock('panelEvent', 'panelEventText', event);
  toggleBlock('panelNote', 'panelNoteText', note);
  toggleBlock('panelNegative', 'panelNegativeText', negative);

  // Price
  const priceBlock = document.getElementById('panelPrice');
  const priceText = document.getElementById('panelPriceText');
  if (price) {
    const priceN = parseInt(price, 10);
    const fmt = priceN.toLocaleString('ru-RU');
    priceText.innerHTML = `от <strong>${fmt} ₽</strong> в одну сторону · обновлено ежедневно`;
    priceBlock.removeAttribute('hidden');
  } else {
    priceBlock.setAttribute('hidden', '');
  }

  // Aviasales
  const avBtn = document.getElementById('panelAviasales');
  if (iata) {
    const yr = monthIdx >= new Date().getMonth() ? new Date().getFullYear() : new Date().getFullYear() + 1;
    const mm = String(monthIdx + 1).padStart(2, '0');
    avBtn.href = `https://www.aviasales.ru/search/MOW15${mm}${iata}1?marker=546042.Zz66f13c16ff6b488883a4127-546042`;
    avBtn.removeAttribute('hidden');
  } else {
    avBtn.setAttribute('hidden', '');
  }

  // Ссылка вглубь сайта — хаб страны (визы, сезоны, бюджет, гайды). Есть у всех 70.
  const guideBtn = document.getElementById('panelBlog');
  if (slug) {
    guideBtn.href = `/${slug}/`;
    guideBtn.textContent = blog ? 'Полный гид по стране →' : 'Виза, сезоны и бюджет →';
    guideBtn.removeAttribute('hidden');
  } else {
    guideBtn.setAttribute('hidden', '');
  }

  // Show panel
  document.getElementById('cellPanel').setAttribute('aria-hidden', 'false');
  document.getElementById('cellPanel').classList.add('is-open');
  document.getElementById('panelOverlay').classList.add('is-open');
  document.body.classList.add('panel-open');
  panelOpen = true;

  // Ссылка для Share строится из текущей ячейки, но НЕ пишется в адрес постоянно —
  // иначе кнопка «назад» в Safari возвращает на /seasons/?country=… и панель
  // автo-переоткрывается (ощущение «назад не работает»).
  currentShare = slug ? `?country=${slug}&m=${monthIdx + 1}` : null;
  syncUrl();
}

function toggleBlock(blockId, textId, content) {
  const block = document.getElementById(blockId);
  if (content && content.trim()) {
    document.getElementById(textId).textContent = content;
    block.removeAttribute('hidden');
  } else {
    block.setAttribute('hidden', '');
  }
}

function closePanel() {
  document.getElementById('cellPanel').setAttribute('aria-hidden', 'true');
  document.getElementById('cellPanel').classList.remove('is-open');
  document.getElementById('panelOverlay').classList.remove('is-open');
  document.body.classList.remove('panel-open');
  panelOpen = false;
  syncUrl();
}

document.getElementById('panelClose').addEventListener('click', closePanel);
document.getElementById('panelOverlay').addEventListener('click', closePanel);
document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && panelOpen) closePanel();
});

// Клик/клавиатура по ячейке — делегирование на #tbody (1 listener вместо 840×2).
tbodyEl.addEventListener('click', e => {
  const cell = e.target.closest('td.cell');
  if (cell) openPanel(cell);
});
tbodyEl.addEventListener('keydown', e => {
  if (e.key === 'Enter' || e.key === ' ') {
    const cell = e.target.closest('td.cell');
    if (cell) { e.preventDefault(); openPanel(cell); }
  }
});

// Share button
document.getElementById('panelShare').addEventListener('click', async () => {
  const url = location.origin + location.pathname + (currentShare || location.search);
  if (navigator.share) {
    try { await navigator.share({ title: document.getElementById('panelTitle').textContent, url }); } catch (e) {}
  } else if (navigator.clipboard) {
    try {
      await navigator.clipboard.writeText(url);
      const btn = document.getElementById('panelShare');
      const original = btn.textContent;
      btn.textContent = 'Скопировано ✓';
      setTimeout(() => { btn.textContent = original; }, 1500);
    } catch (e) {}
  }
});

// URL state
function syncUrl(slug, monthIdx) {
  const params = new URLSearchParams();
  if (activeMonth !== null) params.set('month', String(activeMonth + 1));
  if (activeQuery) params.set('q', activeQuery);
  if (slug !== undefined && monthIdx !== undefined) {
    params.set('country', slug);
    params.set('m', String(monthIdx + 1));
  }
  const qs = params.toString();
  const newUrl = qs ? `?${qs}` : window.location.pathname;
  history.replaceState(null, '', newUrl);
}

// Restore state from URL on load
function restoreFromUrl() {
  const params = new URLSearchParams(window.location.search);
  const month = params.get('month');
  const q = params.get('q');
  const country = params.get('country');
  const m = params.get('m');

  if (month) {
    const idx = parseInt(month, 10) - 1;
    const btn = document.querySelector(`.month-btn[data-month="${idx}"]`);
    if (btn) btn.click();
  }
  if (q) {
    searchInput.value = q;
    activeQuery = q.toLowerCase();
    applyFilter();
  }
  if (country && m) {
    const idx = parseInt(m, 10) - 1;
    const cell = document.querySelector(`td.cell[data-slug="${country}"][data-month="${idx}"]`);
    if (cell) {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      cell.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'nearest', inline: 'center' });
      setTimeout(() => openPanel(cell), reduce ? 50 : 300);
    }
  }
}

restoreFromUrl();

// Safari bfcache: при возврате «назад» страница восстанавливается из кэша с
// открытой панелью (overflow:hidden) — принудительно закрываем, чтобы «назад»
// возвращал на таблицу, а не «застревал» на той же карточке.
window.addEventListener('pageshow', (e) => { if (e.persisted && panelOpen) closePanel(); });
}
if (document.readyState !== 'loading') _seasonsInit();
document.addEventListener('astro:page-load', _seasonsInit);
</script>

<style>
/* ════════ ТАБЛО ВЫЛЕТОВ — страница-терминал ════════
   Переопределяем alias-токены в пределах #main и панели на фиксированную
   тёмную палитру → страница всегда тёмная независимо от темы сайта
   (Nav/Footer следуют теме). Янтарь = акцент вместо золота. */
#main, .cell-panel, .panel-overlay {
  --bg:#f4f2eb; --bg2:#fbfaf5; --bg3:#ece9df;
  --line:#cdc9bd;
  --gold:#8e6618; --gold-dim:#8e6618; --gold-glow:rgba(142,102,24,.10);
  --text:#1b1914; --text-dim:#56524a; --text-faint:#6b685e;   /* WCAG AA на светлом */
  /* мягкие тинты вместо насыщенных блоков — элегантнее на десктопе (текст на ячейках тёмный) */
  --peak:#8fb89c; --good:#9bb4ce; --ok:#dcc089; --bad:#d3a293; --off:#eceadf;
  /* *-text для тегов/статусов — тёмные, контрастные на светлом (WCAG AA) */
  --peak-text:#1f6b40; --good-text:#2a5f86; --ok-text:#8a5e1e; --bad-text:#8f3f2e;
}
#main {
  background: var(--bg); color: var(--text);
  font-family: var(--ff-mono);
  padding-bottom: 3rem;
}
/* длинный текст — обычным шрифтом для читаемости, табло-моно только в «консоли» */
.faq, .faq *, .climate-disclaimer, .table-footer,
.footer-contribute, .footer-contribute *,
.panel-text, .panel-block p { font-family: var(--ff-body); }

.controls {
  max-width: 1400px; margin: 0 auto 2rem; padding: 0 clamp(1rem, 4vw, 3rem);
  display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center;
}
.search-input {
  background: var(--bg2); border: 1px solid var(--line); color: var(--text);
  font-family: var(--ff-body); font-size: 1rem;  /* iOS Safari: ≥16px, иначе zoom при тапе */
  padding: 0.5rem 0.9rem; border-radius: 3px; min-width: 240px;
  transition: border-color 0.2s;
}
.search-input:focus { outline: none; border-color: var(--gold-dim); }
.search-input::placeholder { color: var(--text-faint); }
.controls-label { color: var(--gold-dim); font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0.4rem 0 0.8rem; }
.month-btn, .reset-btn {
  background: transparent; border: 1px solid var(--line); color: var(--text-dim);
  font-family: var(--ff-body); font-size: 0.75rem; letter-spacing: 0.06em; text-transform: uppercase;
  padding: 0.45rem 0.8rem; border-radius: 3px; cursor: pointer; transition: all 0.2s;
}
.month-btn:hover, .reset-btn:hover { border-color: var(--gold-dim); color: var(--text); }
.month-btn.active { background: var(--gold); border-color: var(--gold); color: #fff; font-weight: 500; }
.reset-btn { margin-left: 0.5rem; }

.legend { max-width: 1400px; margin: 0 auto 1.25rem; padding: 0.7rem clamp(1rem, 4vw, 3rem); display: flex; flex-wrap: wrap; gap: 0.5rem 1.1rem; align-items: center; }
.legend-item { display: flex; align-items: center; gap: 0.45rem; font-size: 0.72rem; color: var(--text-dim); }
.legend .dot { width: 14px; height: 14px; border-radius: var(--radius-2); flex-shrink: 0; box-shadow: none; }

.best-mark { color: var(--peak); font-size: 0.85rem; line-height: 1; }
.worst-mark { color: var(--bad); font-size: 0.85rem; line-height: 1; }

.table-wrap {
  max-width: 1400px; margin: 0 auto; overflow: auto; max-height: calc(100vh - 220px);
  border: 1px solid var(--line); border-radius: 4px; background: var(--bg2); position: relative; z-index: 1;
}
table { width: 100%; border-collapse: collapse; font-size: 0.8rem; min-width: 900px; }

thead tr:first-child th {
  position: sticky; top: 0; z-index: 10;
  background: var(--bg3); border-bottom: 1px solid var(--line);
  padding: 1rem 0.6rem; font-weight: 400; font-size: 0.65rem;
  letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-faint);
  cursor: default;
}
thead tr:first-child th:first-child { text-align: left; padding-left: 1.2rem; min-width: 240px; position: sticky; left: 0; z-index: 11; border-right: 1px solid var(--line); box-shadow: 6px 0 10px -8px rgba(0, 0, 0, 0.10); }
.month-header { text-align: center; min-width: 56px; border-left: 1px solid color-mix(in oklch, var(--line) 55%, transparent); transition: background 0.15s, color 0.15s; }
.month-header.is-current { color: var(--gold) !important; background: var(--gold-glow); box-shadow: inset 0 -2px 0 var(--gold); }
.month-header.hover-col { background: rgba(201,151,58,0.06); color: var(--gold-dim); }

tbody tr { border-bottom: 1px solid var(--line); transition: background 0.15s; }
tbody tr:last-child { border-bottom: none; }
tbody tr:hover { background: rgba(201,151,58,0.03); }

.group-header td {
  background: var(--bg3); color: var(--gold); font-family: var(--ff-mono);
  font-size: 0.82rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase;
  padding: 0.7rem 1.2rem; position: sticky; left: 0;
  border-bottom: 1px solid var(--line); border-top: 1px solid var(--line);
}

.region-cell {
  padding: 0.8rem 1rem 0.8rem 1.2rem; color: var(--text); font-weight: 400; line-height: 1.3;
  min-width: 240px; max-width: 260px; vertical-align: middle; position: sticky; left: 0;
  background: var(--bg2); z-index: 2; border-right: 1px solid var(--line);
