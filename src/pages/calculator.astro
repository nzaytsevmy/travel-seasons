---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import BudgetBlock from '../components/BudgetBlock.astro';
import { PRICES } from '../data/prices.js';
import { DIRECTIONS } from '../data/directions.js';
import { VISA_DETAILS } from '../data/visa-details.js';
import realBudgets from '../data/real-budgets-2026.json';
import { DATA_UPDATED, DATA_UPDATED_RU } from '../data/meta.js';
import { TP_LINKS } from '../data/affiliate.js';

const groups: Record<string, Array<{i:number,name:string,iata:string}>> = {};
PRICES.forEach((p, i) => {
  if (!groups[p.g]) groups[p.g] = [];
  groups[p.g].push({ i, name: p.name, iata: p.iata });
});
// Сортировка стран внутри каждой группы по алфавиту (русская локаль)
Object.keys(groups).forEach(g => {
  groups[g].sort((a, b) => a.name.localeCompare(b.name, 'ru'));
});
// Сортировка самих групп по алфавиту
const sortedGroups: Record<string, Array<{i:number,name:string,iata:string}>> = {};
Object.keys(groups).sort((a, b) => a.localeCompare(b, 'ru')).forEach(g => {
  sortedGroups[g] = groups[g];
});

// Маппинг по NAME (а не iata) — потому что разные направления могут шарить iata
// (например, Australia-East и Australia-North в DIRECTIONS оба ссылаются на SYD).
// PRICES — источник истины: у каждого свой name + iata.
const priceIdxToSlug: Record<number, string> = {};
const priceIdxToSeasons: Record<number, any> = {};
const priceIdxToVisa: Record<number, any> = {};
const priceIdxToBudgetSlug: Record<number, string> = {};

PRICES.forEach((p, i) => {
  // Находим DIRECTIONS-запись с тем же name (в price.name внутри directions)
  const dir: any = DIRECTIONS.find((d: any) => d.price?.name === p.name);
  if (!dir) return;
  priceIdxToSlug[i] = dir.slug;
  priceIdxToSeasons[i] = dir.r;
  if ((VISA_DETAILS as any)[dir.slug]) {
    priceIdxToVisa[i] = { ...(VISA_DETAILS as any)[dir.slug], slug: dir.slug };
  }
  if ((realBudgets as any)[dir.slug]) priceIdxToBudgetSlug[i] = dir.slug;
});

const MONTH_NAMES = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
const MONTH_FULL  = ['январе','феврале','марте','апреле','мае','июне','июле','августе','сентябре','октябре','ноябре','декабре'];

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Калькулятор бюджета путешествия 2026",
      "url": "https://traveltribe.ru/calculator/",
      "description": "Интерактивный калькулятор стоимости поездки из Москвы на 2026: 70 направлений, сравнение, сезонный коэффициент по месяцам, виза в расчёте, реальные траты по 12 источникам.",
      "inLanguage": "ru-RU",
      "applicationCategory": "TravelApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "RUB" },
      "featureList": ["70 направлений","Сравнение до 3 стран","Сезонный коэффициент по 12 месяцам","Расчёт 1–4 путешественников","Виза в разбивке","Курс ЦБ РФ","Реальные траты 2026 из 12 источников"],
      "dateModified": DATA_UPDATED,
      "author": { "@id": "https://traveltribe.ru/about/#person" },
      "publisher": { "@id": "https://traveltribe.ru/#org" }
    },
    {
      "@type": "HowTo",
      "name": "Как посчитать бюджет путешествия из Москвы в 2026",
      "totalTime": "PT2M",
      "estimatedCost": { "@type": "MonetaryAmount", "currency": "RUB", "value": "0" },
      "step": [
        { "@type":"HowToStep", "position":1, "name":"Выбрать направление", "text":"Одна из 70 стран. Опционально добавь ещё для сравнения." },
        { "@type":"HowToStep", "position":2, "name":"Указать месяц поездки", "text":"Калькулятор учтёт сезонный коэффициент: пик +30%, не сезон −30%." },
        { "@type":"HowToStep", "position":3, "name":"Длительность и путешественники", "text":"От 1 до 30 дней, от 1 до 4 человек." },
        { "@type":"HowToStep", "position":4, "name":"Уровень комфорта", "text":"Эконом / комфорт / люкс." },
        { "@type":"HowToStep", "position":5, "name":"Скопировать в Telegram", "text":"Готовая сводка для пересылки в чат." }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type":"Question", "name":"Сколько стоит поездка из Москвы в 2026?", "acceptedAnswer":{"@type":"Answer","text":"Зависит от направления и сезона. Турция в комфортном варианте на 7 дней — около 90–110 тысяч ₽ на одного. Грузия — 50–70 тысяч ₽. Бали — 130–180 тысяч ₽."} },
        { "@type":"Question", "name":"Как учитывается сезонность?", "acceptedAnswer":{"@type":"Answer","text":"Каждая страна имеет 12-месячный рейтинг: пик +30%, хорошо ±0%, нормально −15%, не сезон −30%. Подсвечивает лучший месяц."} },
        { "@type":"Question", "name":"Сравнение нескольких направлений?", "acceptedAnswer":{"@type":"Answer","text":"Да, до 3 стран с одинаковыми параметрами."} },
        { "@type":"Question", "name":"Откуда цены?", "acceptedAnswer":{"@type":"Answer","text":"Базовые — вручную по средней Aviasales / медиане Ostrovok. Реальные траты — 12 источников: Самокатус, make-trip, BudgetYourTrip, IndieTraveller и др."} },
        { "@type":"Question", "name":"Учитывает курс рубля?", "acceptedAnswer":{"@type":"Answer","text":"Да, в реальном времени через open exchange rates."} }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type":"ListItem", "position":1, "name":"Главная", "item":"https://traveltribe.ru/" },
        { "@type":"ListItem", "position":2, "name":"Калькулятор", "item":"https://traveltribe.ru/calculator/" }
      ]
    }
  ]
};
---
<Layout
  title="Калькулятор путешествия 2026: бюджет поездки по 70 странам"
  description="Калькулятор путешествия 2026: бюджет поездки из Москвы по 70 странам — перелёт, жильё, еда, виза. Реальные траты из 12 источников, курс ЦБ РФ."
  canonical="https://traveltribe.ru/calculator/"
  ogTitle="Калькулятор бюджета — TravelTribe"
  ogDescription="70 направлений · сравнение · сезон · реальные траты 2026"
  ogType="website"
  ldJson={ldJson}
  noTransitions={true}
>

  <main id="main" class="tc">

    <!-- ───────────── HERO ──────────────────────────────────── -->
    <section class="tc-hero">
      <div class="tc-container">
        <div class="tc-eyebrow">Калькулятор · 2026</div>
        <h1 class="tc-h1">Сколько стоит твоя поездка</h1>
        <p class="tc-lede">70 направлений · сезонный коэффициент по 12 месяцам · сравнение до трёх стран · реальные траты путешественников из 12 источников.</p>
        <p class="tc-byline">
          <a href="/about/" class="tc-byline-author">Никита Зайцев</a> ·
          <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> ·
          <span class="tc-byline-method">методика: базовые цены — медиана Aviasales / Островок, реальные траты — 12 источников (Самокатус, BudgetYourTrip, IndieTraveller и др.), курс ₽ в реальном времени · обновлено {DATA_UPDATED_RU}</span>
        </p>
      </div>
    </section>

    <!-- ───────────── FORM BAR (horizontal, like Google Flights) ─ -->
    <section class="tc-form-section">
      <div class="tc-container">
        <form class="tc-form" id="tcForm" onsubmit="return false">
          <div class="tc-form-grid">
            <div class="tc-field tc-field--country">
              <label class="tc-field-label" for="calcRegion">Направление</label>
              <select class="tc-input tc-input--select" id="calcRegion">
                {Object.entries(sortedGroups).map(([label, items]) => (
                  <optgroup label={label}>
                    {items.map(({ i, name }) => (
                      <option value={i}>{name}</option>
                    ))}
                  </optgroup>
                ))}
              </select>
            </div>

            <div class="tc-field">
              <label class="tc-field-label">Месяц</label>
              <select class="tc-input tc-input--select" id="monthSelect" aria-label="Месяц поездки">
                <option value="0">Любой</option>
                {MONTH_NAMES.map((m, i) => (
                  <option value={i + 1}>{['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'][i]}</option>
                ))}
              </select>
            </div>

            <div class="tc-field">
              <label class="tc-field-label">Дней</label>
              <div class="tc-stepper">
                <button class="tc-stepper-btn" id="daysDown" type="button" aria-label="Меньше дней">−</button>
                <span class="tc-stepper-val" id="calcDaysDisplay">7</span>
                <button class="tc-stepper-btn" id="daysUp" type="button" aria-label="Больше дней">+</button>
                <input type="hidden" id="calcDays" value="7" aria-hidden="true" />
              </div>
            </div>

            <div class="tc-field">
              <label class="tc-field-label">Путешественников</label>
              <div class="tc-stepper">
                <button class="tc-stepper-btn" id="travDown" type="button" aria-label="Меньше людей">−</button>
                <span class="tc-stepper-val" id="travelersDisplay">1</span>
                <button class="tc-stepper-btn" id="travUp" type="button" aria-label="Больше людей">+</button>
              </div>
            </div>

            <div class="tc-field tc-field--level">
              <label class="tc-field-label">Уровень</label>
              <div class="tc-seg" id="levelGroup" role="group" aria-label="Уровень комфорта">
                <button class="tc-seg-btn active" data-lvl="0" aria-pressed="true">Эконом</button>
                <button class="tc-seg-btn" data-lvl="1" aria-pressed="false">Комфорт</button>
                <button class="tc-seg-btn" data-lvl="2" aria-pressed="false">Люкс</button>
              </div>
            </div>

            <div class="tc-field">
              <label class="tc-field-label">Валюта</label>
              <div class="tc-seg tc-seg--small" id="currGroup" role="group" aria-label="Валюта">
                <button class="tc-seg-btn active" data-cur="rub" aria-pressed="true">₽</button>
                <button class="tc-seg-btn" data-cur="usd" aria-pressed="false">$</button>
              </div>
            </div>
          </div>

          <div class="tc-form-extra">
            <select class="tc-add-country" id="addCountrySelect" aria-label="Сравнить с другой страной" hidden>
              <option value="">+ Сравнить с другой страной</option>
              {Object.entries(sortedGroups).map(([label, items]) => (
                <optgroup label={label}>
                  {items.map(({ i, name }) => (
                    <option value={i}>{name}</option>
                  ))}
                </optgroup>
              ))}
            </select>
            <span class="tc-rate" id="calcRateLabel">1 $ = 90 ₽ · загрузка курса…</span>
          </div>
        </form>
      </div>
    </section>

    <!-- ───────────── RESULT — full width hero panel ─────────── -->
    <section class="tc-result-section">
      <div class="tc-container">
        <div id="calcResult" class="tc-result"></div>
      </div>
    </section>

    {/* Авторские туры (YouTravel) — альтернатива самостоятельному расчёту */}
    <section class="tc-section">
      <div class="tc-container">
        <p class="tc-tourcta">Считать и планировать не хочется? <a href={TP_LINKS.youtravel} rel="sponsored noopener" target="_blank"><strong>Авторский тур с экспертом →</strong></a> — бюджет, маршрут и малая группа уже собраны. </p>
      </div>
    </section>

    <!-- ───────────── BUDGET BLOCK (real travelers data) ──────── -->
    <section class="tc-section">
      <div class="tc-container">
        <div id="budgetBlocksHost" class="tc-bb-host">
          {Object.keys(realBudgets).filter(k => k !== '_meta').map((slug) => (
            <div class="tc-bb-wrap" data-slug={slug} hidden>
              <BudgetBlock slug={slug} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────────── TIPS ───────────────────────────────────── -->
    <section class="tc-section tc-tips">
      <div class="tc-container">
        <div class="tc-section-head">
          <span class="tc-section-num">01</span>
          <h2 class="tc-section-title">Полезное при планировании</h2>
        </div>
        <ul class="tc-tips-list">
          <li class="tc-tip-row">
            <h3 class="tc-tip-title">Бронируй за 60+ дней</h3>
            <p class="tc-tip-body">Авиабилеты дешевле на 15–20%. Отели — без разницы.</p>
          </li>
          <li class="tc-tip-row">
            <h3 class="tc-tip-title">Страховка не опция</h3>
            <p class="tc-tip-body">Стоит 2 000 ₽, спасает от $20 000+ медрасходов в Европе или США.</p>
          </li>
          <li class="tc-tip-row">
            <h3 class="tc-tip-title">eSIM вместо роуминга</h3>
            <p class="tc-tip-body">Airalo 1 500 ₽ за 10 ГБ против МТС 5 000 ₽ за неделю.</p>
          </li>
          <li class="tc-tip-row">
            <h3 class="tc-tip-title">Семья экономит</h3>
            <p class="tc-tip-body">Один номер на 2–4 человек. Калькулятор учитывает: перелёт × N, отель × 1.</p>
          </li>
          <li class="tc-tip-row">
            <h3 class="tc-tip-title">Сезон важнее уровня</h3>
            <p class="tc-tip-body">5* в не сезон дешевле, чем 3* в пик. Покрути месяцы первыми.</p>
          </li>
          <li class="tc-tip-row">
            <h3 class="tc-tip-title">Виза не приговор</h3>
            <p class="tc-tip-body">Шенген ~12 000 ₽. На фоне 150–200к поездки — 6–8%, не повод отказывать.</p>
          </li>
        </ul>

        <a href="/blog/pay-abroad-2026/" class="tc-tip-callout">
          <span class="tc-tip-callout-text">
            <strong>Чем платить за границей в 2026</strong>
            <span>Visa/MC РФ не работают, UnionPay из РФ массово отклоняют. Виртуальные USD/EUR-карты, UnionPay от АТБ, банки ЕАЭС, наличные — 4 рабочих способа подробно →</span>
          </span>
        </a>
      </div>
    </section>

    <!-- ───────────── FAQ ────────────────────────────────────── -->
    <section class="tc-section tc-faq">
      <div class="tc-container">
        <div class="tc-section-head">
          <span class="tc-section-num">02</span>
          <h2 class="tc-section-title">Частые вопросы</h2>
        </div>
        <div class="tc-faq-list">
          <details class="tc-faq-item" open>
            <summary>Откуда берутся цены?</summary>
            <p>Базовые цены 70 направлений собраны вручную: перелёт из Москвы туда-обратно по средней цене Aviasales за квартал, отель — по медиане Ostrovok / Booking по уровням 3*/4*/5*, еда — по типовому дню для каждого уровня. Сезонный коэффициент применяется к перелёту: пик +30%, хорошо ±0%, нормально −15%, не сезон −30%.</p>
          </details>
          <details class="tc-faq-item">
            <summary>Реальные траты — откуда?</summary>
            <p>Кросс-источниковая агрегация из 12 ресурсов. Российские: Самокатус, make-trip.ru, howtrip.ru, wrenjapan.com. Англоязычные с переводом: BudgetYourTrip (3000+ городов от 50 000 контрибьюторов), IndieTraveller, SoutheastAsiaBackpacker, Maldives Magazine, Norway Budget Guide, Reddit r/solotravel и др.</p>
          </details>
          <details class="tc-faq-item">
            <summary>Как считается несколько путешественников?</summary>
            <p>Перелёт и питание умножаются на число людей. Отель — нет: один номер вмещает 2-4 человек. Это даёт реалистичную сумму — семья из 2 платит ≈ в 1.6× больше одного, а не в 2×.</p>
          </details>
          <details class="tc-faq-item">
            <summary>Виза включена в итог?</summary>
            <p>Да, если виза платная — в разбивке появляется строка со стоимостью. Если безвиз — «безвиз». По клику открывается детальная страница визы по выбранной стране.</p>
          </details>
          <details class="tc-faq-item">
            <summary>Что такое «лучший месяц»?</summary>
            <p>Калькулятор смотрит 12-месячный рейтинг страны и подсвечивает месяц с минимальным коэффициентом цены и нормальной погодой. «В ноябре та же поездка обойдётся на 28% дешевле».</p>
          </details>
          <details class="tc-faq-item">
            <summary>Учитывает ли курс рубля?</summary>
            <p>Да, в реальном времени через open exchange rates. Переключение ₽/$ одной кнопкой.</p>
          </details>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script is:inline define:vars={{ PRICES, MONTH_NAMES, MONTH_FULL, priceIdxToSeasons, priceIdxToVisa, priceIdxToSlug, priceIdxToBudgetSlug }} data-astro-rerun>
let RUB = 90, calcLevel = 0, calcCurrency = 'rub';
let travelers = 1, selectedMonth = 0;
let compareList = [];

const SEASON_MULT = { P:1.30, G:1.00, O:0.85, B:0.70 };
const SEASON_LABEL = { P:'Пик', G:'Хорошо', O:'Норма', B:'Не сезон' };
const SEASON_CLASS = { P:'peak', G:'good', O:'ok', B:'bad' };

// Aviasales через tpk.mx-обёртку: трекинг кликов (свежий sub-id на клик) + erid + .ru.
// Прямой ?marker со статичным sub-id давал 0 кликов в TP (проверено 2026-06-04).
const AVIASALES_TPK = 'https://aviasales.tpk.mx/JCSPlC17?erid=2Vtzqxkn4LF&u=';
const CHEREHAPA = 'https://cherehapa.tpk.mx/GmVWjhCN?erid=2VtzquZTwb5';
const OSTROVOK = 'https://ostrovok.tpk.mx/xtyTcUcY?erid=2VtzqvE1cv3';
const AIRALO = 'https://airalo.pxf.io/c/1209822/1310283/15608?erid=2VtzqxRWDfm&sharedID=546042_&u=https%3A%2F%2Fairalo.com%2Fru';

const CAT_COLORS = { flight: '#8e6618', hotel: '#1b1914', food: '#6b685e', visa: '#a8a294' };

const calcSel = document.getElementById('calcRegion');
const monthSel = document.getElementById('monthSelect');
const resultEl = document.getElementById('calcResult');
const addSelect = document.getElementById('addCountrySelect');

function readUrlParams() {
  const u = new URL(window.location.href);
  const r = u.searchParams.get('r'), d = u.searchParams.get('d');
  const l = u.searchParams.get('l'), c = u.searchParams.get('c');
  const t = u.searchParams.get('t'), m = u.searchParams.get('m');
  const cmp = u.searchParams.get('cmp');

  if (r !== null && PRICES[+r]) calcSel.value = r;
  if (d !== null) {
    const n = Math.min(90, Math.max(1, parseInt(d) || 7));
    document.getElementById('calcDays').value = n;
    document.getElementById('calcDaysDisplay').textContent = n;
  }
  if (l !== null && (+l >= 0 && +l <= 2)) {
    calcLevel = +l;
    document.querySelectorAll('#levelGroup .tc-seg-btn').forEach(b => {
      const on = +b.dataset.lvl === calcLevel;
      b.classList.toggle('active', on);
      b.setAttribute('aria-pressed', on?'true':'false');
    });
  }
  if (c === 'usd' || c === 'rub') {
    calcCurrency = c;
    document.querySelectorAll('#currGroup .tc-seg-btn').forEach(b => {
      const on = b.dataset.cur === calcCurrency;
      b.classList.toggle('active', on);
      b.setAttribute('aria-pressed', on?'true':'false');
    });
  }
  if (t !== null && +t >= 1 && +t <= 4) {
    travelers = +t;
    document.getElementById('travelersDisplay').textContent = travelers;
  }
  if (m !== null && +m >= 0 && +m <= 12) {
    selectedMonth = +m;
    monthSel.value = String(selectedMonth);
  }
  if (cmp) compareList = cmp.split(',').map(x => parseInt(x)).filter(x => !isNaN(x) && PRICES[x]).slice(0, 3);
}

function writeUrlParams() {
  const u = new URL(window.location.href);
  u.searchParams.set('r', calcSel.value);
  u.searchParams.set('d', document.getElementById('calcDays').value);
  u.searchParams.set('l', String(calcLevel));
  u.searchParams.set('c', calcCurrency);
  u.searchParams.set('t', String(travelers));
  if (selectedMonth > 0) u.searchParams.set('m', String(selectedMonth));
  else u.searchParams.delete('m');
  if (compareList.length > 0) u.searchParams.set('cmp', compareList.join(','));
  else u.searchParams.delete('cmp');
  window.history.replaceState(null, '', u.toString());
}

async function fetchRate() {
  const rateEl = document.getElementById('calcRateLabel');
  try {
    const r = await fetch('https://open.er-api.com/v6/latest/USD');
    const d = await r.json();
    if (d.result === 'success' && d.rates?.RUB) {
      RUB = d.rates.RUB;
      if (rateEl) rateEl.textContent = `1 $ = ${RUB.toFixed(2)} ₽`;
      renderCalc();
      return;
    }
  } catch (e) {}
  if (rateEl) rateEl.textContent = '1 $ ≈ 90 ₽';
}

function fmt(usd) {
  if (!usd || isNaN(usd)) return '—';
  return calcCurrency === 'rub'
    ? Math.round(usd * RUB).toLocaleString('ru-RU') + ' ₽'
    : Math.round(usd).toLocaleString('en-US') + ' $';
}

function aviasalesUrl(iata, monthNum) {
  let inner = 'https://www.aviasales.ru/';
  if (iata) {
    inner += `?origin_iata=MOW&destination_iata=${iata}`;
    if (monthNum && monthNum >= 1 && monthNum <= 12) {
      const now = new Date();
      let y = now.getFullYear();
      if ((monthNum - 1) < now.getMonth()) y += 1;
      inner += `&depart_date=${y}-${String(monthNum).padStart(2,'0')}-15`;
    }
  }
  return AVIASALES_TPK + encodeURIComponent(inner);
}

function computeForPriceIndex(pi) {
  const p = PRICES[pi];
  const days = Math.max(1, parseInt(document.getElementById('calcDays').value) || 1);
  const baseFlight = p.flight[calcLevel];
  const hotel = p.hotel[calcLevel];
  const food = p.food[calcLevel];
  let seasonMult = 1, seasonLabel = '', seasonClass = '';
  const seasonsArr = priceIdxToSeasons[pi];
  if (selectedMonth > 0 && seasonsArr) {
    const rating = seasonsArr[selectedMonth - 1];
    seasonMult = SEASON_MULT[rating] || 1;
    seasonLabel = SEASON_LABEL[rating] || '';
    seasonClass = SEASON_CLASS[rating] || '';
  }
  const flightTotal = baseFlight * seasonMult * travelers;
  const hotelTotal = hotel * days;
  const foodTotal = food * days * travelers;
  const visa = priceIdxToVisa[pi];
  let visaUsd = 0;
  if (visa?.cost) {
    const m1 = visa.cost.match(/\$(\d+)/);
    if (m1) visaUsd = parseInt(m1[1]);
    else {
      const e = visa.cost.match(/€\s?(\d+)/);
      if (e) visaUsd = Math.round(parseInt(e[1]) * 1.08);
    }
  }
  const visaTotal = visaUsd * travelers;
  const grand = flightTotal + hotelTotal + foodTotal + visaTotal;
  return { p, days, travelers, flightTotal, hotelTotal, foodTotal, visa, visaTotal, seasonMult, seasonLabel, seasonClass, grand };
}

function findBestMonth(pi) {
  const ratings = priceIdxToSeasons[pi];
  if (!ratings) return null;
  let bestIdx = -1, bestMult = 999;
  ratings.forEach((r, i) => {
    const mu = SEASON_MULT[r] || 1;
    if (mu < bestMult && r !== 'B') { bestMult = mu; bestIdx = i; }
  });
  if (bestIdx === -1) ratings.forEach((r, i) => { if (r === 'O' && bestIdx === -1) bestIdx = i; });
  if (bestIdx === -1) bestIdx = 0;
  return { monthNum: bestIdx + 1, monthName: MONTH_FULL[bestIdx], mult: SEASON_MULT[ratings[bestIdx]] || 1 };
}

function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

// ─── Render single-country result with category bars ───────────
function renderSingle(pi) {
  const r = computeForPriceIndex(pi);
  const piIdx = pi;
  const aviUrl = aviasalesUrl(r.p.iata, selectedMonth > 0 ? selectedMonth : null);
  const perPerson = r.grand / Math.max(1, r.travelers);
  const perDay = r.grand / Math.max(1, r.days);

  const categories = [
    { name: 'Перелёт', value: r.flightTotal, color: CAT_COLORS.flight, icon: '' },
    { name: 'Отель', value: r.hotelTotal, color: CAT_COLORS.hotel, icon: '' },
    { name: 'Питание', value: r.foodTotal, color: CAT_COLORS.food, icon: '' },
  ];
  if (r.visa && r.visaTotal > 0) categories.push({ name: 'Виза', value: r.visaTotal, color: CAT_COLORS.visa, icon: '' });

  const total = r.grand;

  // Best month nudge
  const best = findBestMonth(pi);
  let nudge = '';
  if (best && selectedMonth > 0 && best.monthNum !== selectedMonth) {
    const saving = Math.round((1 - best.mult / r.seasonMult) * 100);
    if (saving > 5) nudge = `<div class="tc-nudge"><span class="tc-nudge-icon">↘</span> В <strong>${best.monthName}</strong> на <strong>${saving}%</strong> дешевле — лучший месяц года</div>`;
  } else if (best && selectedMonth === 0) {
    nudge = `<div class="tc-nudge tc-nudge--soft"><span class="tc-nudge-icon"></span> Самый дешёвый месяц — <strong>${best.monthName}</strong></div>`;
  }

  // Visa info
  const visaInfo = r.visa
    ? (r.visa.cost === 'бесплатно'
        ? `<a href="/visa/${r.visa.slug}/" class="tc-visa-pill tc-visa-pill--free">Безвиз · детали</a>`
        : `<a href="/visa/${r.visa.slug}/" class="tc-visa-pill">Виза ${escapeHtml(r.visa.cost)} · детали</a>`)
    : '';

  // Season pill
  const seasonPill = r.seasonLabel
    ? `<span class="tc-season-pill tc-season-pill--${r.seasonClass}">${['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'][selectedMonth-1]} · ${r.seasonLabel}</span>`
    : '';

  return `
    <div class="tc-single">
      <header class="tc-result-head">
        <div class="tc-result-head-meta">
          <div class="tc-result-tag">${escapeHtml(r.p.name)}</div>
          <div class="tc-result-pills">
            <span class="tc-meta-pill">${r.days} ${r.days === 1 ? 'день' : (r.days < 5 ? 'дня' : 'дней')} · ${r.travelers} ${r.travelers === 1 ? 'человек' : (r.travelers < 5 ? 'человека' : 'человек')}</span>
            ${seasonPill}
            ${visaInfo}
          </div>
        </div>
      </header>

      <div class="tc-hero-total">
        <div class="tc-hero-label">Итого на поездку</div>
        <div class="tc-hero-amount">${fmt(total)}</div>
        <div class="tc-hero-sub">
          ${r.travelers > 1 ? `<span>${fmt(perPerson)} на человека</span><span class="tc-sep">·</span>` : ''}
          <span>${fmt(perDay)} в день</span>
        </div>
      </div>

      ${nudge}

      <div class="tc-cats">
        ${categories.map(c => {
          const pct = total > 0 ? (c.value / total * 100) : 0;
          return `
            <div class="tc-cat">
              <div class="tc-cat-head">
                <span class="tc-cat-name"><span class="tc-cat-icon">${c.icon}</span> ${c.name}</span>
                <span class="tc-cat-val">${fmt(c.value)}</span>
              </div>
              <div class="tc-cat-bar"><div class="tc-cat-fill" style="--w:${pct}%; --c:${c.color}"></div></div>
              <div class="tc-cat-pct">${pct.toFixed(0)}%</div>
            </div>
          `;
        }).join('')}
      </div>

      <div class="tc-cta-block">
        <a href="${aviUrl}" target="_blank" rel="noopener sponsored" class="tc-cta-primary">
          <span class="tc-cta-icon"></span>
          <span class="tc-cta-text">Найти билет на Aviasales</span>
          <span class="tc-cta-arrow">→</span>
        </a>
        <div class="tc-cta-side-row">
          <a href="${OSTROVOK}" target="_blank" rel="noopener sponsored" class="tc-cta-side">
            <span></span> Отели Ostrovok
          </a>
          <a href="${CHEREHAPA}" target="_blank" rel="noopener sponsored" class="tc-cta-side">
            <span></span> Страховка Cherehapa
          </a>
          <a href="${AIRALO}" target="_blank" rel="noopener sponsored" class="tc-cta-side">
            <span></span> eSIM Airalo
          </a>
        </div>
        
      </div>

      <div class="tc-utility">
        <button class="tc-copy-btn" id="copyTgBtn" type="button">
          <span></span> Скопировать сводку для Telegram
        </button>
      </div>
    </div>
  `;
}

// ─── Render comparison table (full width) ──────────────────────
function renderTable(piList) {
  const rows = piList.map(pi => computeForPriceIndex(pi));
  const cols = rows.length;
  const minTotal = Math.min(...rows.map(r => r.grand));

  let html = `<div class="tc-compare">
    <div class="tc-compare-head">
      <h2 class="tc-compare-title">Сравнение ${cols} направлений</h2>
      <p class="tc-compare-sub">${rows[0].travelers} ${rows[0].travelers===1?'человек':'чел.'} · ${rows[0].days} ${rows[0].days===1?'день':'дней'}${selectedMonth>0?` · ${['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'][selectedMonth-1]}`:''}</p>
    </div>
    <div class="tc-compare-grid" style="grid-template-columns: repeat(${cols}, minmax(0, 1fr))">`;

  rows.forEach((r, idx) => {
    const pi = piList[idx];
    const isMin = r.grand === minTotal;
    const aviUrl = aviasalesUrl(r.p.iata, selectedMonth > 0 ? selectedMonth : null);

    // Сезон-бейдж: всегда показываем (placeholder для равной высоты)
    const seasonPill = r.seasonLabel
      ? `<span class="tc-season-pill tc-season-pill--${r.seasonClass}">${r.seasonLabel}</span>`
      : `<span class="tc-season-pill tc-season-pill--any">Любой месяц</span>`;

    // Виза: используем slug из priceIdxToSlug (а не r.visa.slug), чтобы ссылка
    // была доступна даже когда детальной visa-data нет
    const slug = priceIdxToSlug[pi];
    const visaUrl = slug ? `/visa/${slug}/` : null;
    let visaText, visaLink;
    if (r.visa) {
      visaText = r.visa.cost === 'бесплатно' ? 'безвиз' : escapeHtml(r.visa.cost);
      visaLink = visaUrl;
    } else if (slug) {
      visaText = 'нужна';
      visaLink = visaUrl;
    } else {
      visaText = '—';
      visaLink = null;
    }

    html += `
      <div class="tc-cmp-card ${isMin ? 'tc-cmp-card--best' : ''}">
        ${idx > 0 ? `<button class="tc-cmp-remove" data-remove="${pi}" type="button" aria-label="Убрать">×</button>` : ''}
        ${isMin ? '<div class="tc-cmp-badge">Самое дешёвое</div>' : ''}

        <div class="tc-cmp-head">
          <h3 class="tc-cmp-name">${escapeHtml(r.p.name.split('(')[0].trim())}</h3>
          ${seasonPill}
        </div>

        <div class="tc-cmp-total">
          <div class="tc-cmp-total-label">Итого</div>
          <div class="tc-cmp-total-amount">${fmt(r.grand)}</div>
          <div class="tc-cmp-total-pp">${r.travelers > 1 ? `${fmt(r.grand / r.travelers)} / чел.` : `${fmt(r.grand / r.days)} / день`}</div>
        </div>

        <ul class="tc-cmp-list">
          <li><span class="tc-cmp-key">Перелёт</span><span class="tc-cmp-val">${fmt(r.flightTotal)}</span></li>
          <li><span class="tc-cmp-key">Отель × ${r.days}</span><span class="tc-cmp-val">${fmt(r.hotelTotal)}</span></li>
          <li><span class="tc-cmp-key">Питание</span><span class="tc-cmp-val">${fmt(r.foodTotal)}</span></li>
          <li><span class="tc-cmp-key">Виза</span><span class="tc-cmp-val tc-cmp-visa">${visaLink ? `<a href="${visaLink}" target="_blank" rel="noopener">${visaText} →</a>` : visaText}</span></li>
        </ul>

        <a href="${aviUrl}" target="_blank" rel="noopener sponsored" class="tc-cmp-cta">Найти билет →</a>
      </div>
    `;
  });

  html += `</div>
    <div class="tc-compare-aux">
      <span class="tc-aux-label">Партнёры:</span>
      <a href="${OSTROVOK}" target="_blank" rel="noopener sponsored">Ostrovok</a>
      <a href="${CHEREHAPA}" target="_blank" rel="noopener sponsored">Cherehapa</a>
      <a href="${AIRALO}" target="_blank" rel="noopener sponsored">Airalo</a>
      
    </div>
  </div>

  <div class="tc-utility">
    <button class="tc-copy-btn" id="copyTgBtn" type="button">
      <span></span> Скопировать сводку
    </button>
  </div>`;

  return html;
}

function renderCalc() {
  const primary = parseInt(calcSel.value);
  const all = [primary, ...compareList.filter(x => x !== primary)].slice(0, 3);
  const isCompare = all.length > 1;

  resultEl.innerHTML = isCompare ? renderTable(all) : renderSingle(all[0]);

  // Add country select state
  if (compareList.length < 2 && all.length < 3) {
    addSelect.hidden = false;
    addSelect.value = '';
    Array.from(addSelect.options).forEach(opt => {
      const v = parseInt(opt.value);
      if (isNaN(v)) { opt.disabled = false; return; }
      opt.disabled = (v === primary || compareList.includes(v));
    });
  } else {
    addSelect.hidden = true;
  }

  writeUrlParams();
  showBudgetBlock();
}

function showBudgetBlock() {
  const primary = parseInt(calcSel.value);
  const slug = priceIdxToBudgetSlug[primary];
  document.querySelectorAll('.tc-bb-wrap').forEach(el => {
    el.hidden = el.dataset.slug !== slug;
  });
}

// ─── EVENT HANDLERS ────────────────────────────────────────────
calcSel.addEventListener('change', renderCalc);
monthSel.addEventListener('change', e => {
  selectedMonth = parseInt(e.target.value);
  renderCalc();
});

function setDays(n) {
  n = Math.min(90, Math.max(1, n));
  document.getElementById('calcDays').value = n;
  document.getElementById('calcDaysDisplay').textContent = n;
  renderCalc();
}
document.getElementById('daysDown').addEventListener('click', () => setDays(parseInt(document.getElementById('calcDays').value) - 1));
document.getElementById('daysUp').addEventListener('click', () => setDays(parseInt(document.getElementById('calcDays').value) + 1));

function setTravelers(n) {
  travelers = Math.min(4, Math.max(1, n));
  document.getElementById('travelersDisplay').textContent = travelers;
  renderCalc();
}
document.getElementById('travDown').addEventListener('click', () => setTravelers(travelers - 1));
document.getElementById('travUp').addEventListener('click', () => setTravelers(travelers + 1));

document.getElementById('levelGroup').addEventListener('click', e => {
  const btn = e.target.closest('[data-lvl]');
  if (!btn) return;
  calcLevel = +btn.dataset.lvl;
  document.querySelectorAll('#levelGroup .tc-seg-btn').forEach(b => {
    b.classList.toggle('active', b === btn);
    b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
  });
  renderCalc();
});

document.getElementById('currGroup').addEventListener('click', e => {
  const btn = e.target.closest('[data-cur]');
  if (!btn) return;
  calcCurrency = btn.dataset.cur;
  document.querySelectorAll('#currGroup .tc-seg-btn').forEach(b => {
    b.classList.toggle('active', b === btn);
    b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
  });
  renderCalc();
});

addSelect.addEventListener('change', e => {
  const v = parseInt(e.target.value);
  if (isNaN(v)) return;
  const primary = parseInt(calcSel.value);
  if (v === primary || compareList.includes(v) || compareList.length >= 2) return;
  compareList.push(v);
  renderCalc();
});

resultEl.addEventListener('click', e => {
  const rm = e.target.closest('[data-remove]');
  if (rm) {
    const pi = +rm.dataset.remove;
    compareList = compareList.filter(x => x !== pi);
    renderCalc();
    return;
  }
});

resultEl.addEventListener('click', async e => {
  const btn = e.target.closest('#copyTgBtn');
  if (!btn) return;
  const primary = parseInt(calcSel.value);
  const all = [primary, ...compareList.filter(x => x !== primary)].slice(0, 3);
  const days = +document.getElementById('calcDays').value;
  const lvlNames = ['Эконом', 'Комфорт', 'Люкс'];
  const monthLine = selectedMonth > 0 ? `, в ${MONTH_FULL[selectedMonth - 1]}` : '';
  let text = `Бюджет поездки${monthLine}\n${days} дн · ${travelers} чел · ${lvlNames[calcLevel]}\n─────\n`;
  all.forEach(pi => {
    const r = computeForPriceIndex(pi);
    text += `${r.p.name}\n  ИТОГО: ${fmt(r.grand)}\n  Перелёт: ${fmt(r.flightTotal)}\n  Отель × ${days}: ${fmt(r.hotelTotal)}\n  Еда × ${days}: ${fmt(r.foodTotal)}\n`;
    if (r.visa && r.visaTotal > 0) text += `  Виза: ${fmt(r.visaTotal)} (${r.visa.cost})\n`;
    text += `\n`;
  });
  text += `${window.location.href}\ntraveltribe.ru/calculator/`;
  try {
    await navigator.clipboard.writeText(text);
    const span = btn.querySelector('span:nth-child(2)') || btn.lastChild;
    const orig = btn.innerHTML;
    btn.innerHTML = '<span></span> Скопировано';
    setTimeout(() => { btn.innerHTML = orig; }, 1800);
  } catch (err) { alert('Не удалось'); }
});

readUrlParams();
fetchRate();
renderCalc();

// Astro View Transitions: при back/forward DOM пересоздаётся, а
// замыкания этого скрипта держат ссылки на старые (detached) элементы.
// Если resultEl больше не в документе — страница пришла через
// view-transition: делаем полную перезагрузку (один раз, без цикла).
document.addEventListener('astro:page-load', () => {
  const onCalc = location.pathname.replace(/\/+$/, '') === '/calculator';
  if (!onCalc) return;
  if (!resultEl || !document.contains(resultEl)) {
    window.location.reload();
  }
});

// Safari bfcache: при возврате кнопкой «назад» страница восстанавливается
// из снапшота без выполнения скриптов. event.persisted = true → перезагрузка.
window.addEventListener('pageshow', (e) => {
  if (e.persisted) {
    const onCalc = location.pathname.replace(/\/+$/, '') === '/calculator';
    if (onCalc && (!resultEl || !document.contains(resultEl) || !resultEl.innerHTML.trim())) {
      window.location.reload();
    }
  }
});
</script>

