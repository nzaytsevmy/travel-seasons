---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BudgetBlock from '../components/BudgetBlock.astro';
import { PRICES } from '../data/prices.js';
import { DIRECTIONS } from '../data/directions.js';
import { VISA_DETAILS } from '../data/visa-details.js';
import realBudgets from '../data/real-budgets-2026.json';

// Маппинг PRICES.iata → slug (для подтягивания real-budgets)
const iataToBudgetSlug: Record<string, string> = {};
DIRECTIONS.forEach((d: any) => {
  if (d.price?.iata && (realBudgets as any)[d.slug]) iataToBudgetSlug[d.price.iata] = d.slug;
});

const groups = {};
PRICES.forEach((p, i) => {
  if (!groups[p.g]) groups[p.g] = [];
  groups[p.g].push({ i, name: p.name, iata: p.iata });
});

// iata -> slug map (для подтягивания seasons rating + visa)
const iataToSlug = {};
DIRECTIONS.forEach(d => {
  if (d.price && d.price.iata) iataToSlug[d.price.iata] = d.slug;
});

// iata -> seasons rating (12 месяцев: G/P/O/B)
const iataToSeasons = {};
const iataToSeasonText = {};
DIRECTIONS.forEach(d => {
  if (d.price && d.price.iata) {
    iataToSeasons[d.price.iata] = d.r;
    iataToSeasonText[d.price.iata] = d.t;
  }
});

// iata -> visa info (для inline в breakdown)
const iataToVisa = {};
PRICES.forEach(p => {
  const slug = iataToSlug[p.iata];
  if (slug && VISA_DETAILS[slug]) iataToVisa[p.iata] = { ...VISA_DETAILS[slug], slug };
});

const MONTH_NAMES = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
const MONTH_FULL = ['январе','феврале','марте','апреле','мае','июне','июле','августе','сентябре','октябре','ноябре','декабре'];

// JSON-LD: WebApplication + HowTo + TouristTrip + ItemList + FAQPage + BreadcrumbList
const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Калькулятор бюджета путешествия 2026",
      "url": "https://traveltribe.ru/calculator/",
      "description": "Интерактивный калькулятор стоимости путешествия из Москвы на 2026 год: 70 направлений, сравнение до 3 стран, выбор месяца с сезонным коэффициентом, число путешественников, страховка и eSIM в расчёте, виза в breakdown, копирование сводки в Telegram.",
      "inLanguage": "ru-RU",
      "applicationCategory": "TravelApplication",
      "operatingSystem": "Any",
      "browserRequirements": "JavaScript enabled",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "RUB" },
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "featureList": [
        "70 направлений мира",
        "Сравнение до 3 стран рядом",
        "Сезонный коэффициент перелёта по 12 месяцам",
        "Расчёт для 1–4 путешественников",
        "Виза в breakdown с сроком и стоимостью",
        "Опциональные страховка и eSIM",
        "Курс ЦБ РФ в реальном времени",
        "Копирование сводки в Telegram"
      ],
      "author": { "@type": "Person", "name": "Никита Зайцев", "url": "https://t.me/traveltriberu" }
    },
    {
      "@type": "HowTo",
      "name": "Как посчитать бюджет путешествия из Москвы в 2026 году",
      "description": "Полный расчёт за 5 шагов: страна, месяц, длительность, путешественники, уровень комфорта — с автоматическим учётом сезона, визы, страховки и eSIM.",
      "totalTime": "PT2M",
      "estimatedCost": { "@type": "MonetaryAmount", "currency": "RUB", "value": "0" },
      "tool": [{ "@type": "HowToTool", "name": "Калькулятор TravelTribe" }],
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Выбрать направление", "text": "Выбери одну из 70 стран. Можно добавить до 3 направлений для сравнения." },
        { "@type": "HowToStep", "position": 2, "name": "Указать месяц поездки", "text": "Выбери месяц — калькулятор учтёт сезонный коэффициент: пик +30%, не сезон −30%." },
        { "@type": "HowToStep", "position": 3, "name": "Длительность и путешественники", "text": "Задай число дней (1–30) и сколько человек едет (1–4). Отель не удваивается, перелёт и питание — да." },
        { "@type": "HowToStep", "position": 4, "name": "Уровень комфорта и опции", "text": "Эконом / комфорт / люкс. Включи страховку (~2000 ₽) и eSIM (~1500 ₽), если они нужны в бюджете." },
        { "@type": "HowToStep", "position": 5, "name": "Скопировать в Telegram", "text": "Получи готовую сводку для пересылки в чат или сохранения." }
      ]
    },
    {
      "@type": "TouristTrip",
      "name": "Планирование поездки через калькулятор TravelTribe",
      "description": "Интерактивное планирование 70 направлений 2026 с детальным расчётом по 8 категориям расходов.",
      "touristType": ["Solo", "Couple", "Family", "Backpacker", "Luxury"],
      "subjectOf": { "@id": "https://traveltribe.ru/calculator/" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Сколько стоит поездка из Москвы в 2026 году?",
          "acceptedAnswer": { "@type": "Answer", "text": "Зависит от направления и сезона. Турция в комфортном варианте на 7 дней — около 90–110 тысяч ₽ на одного. Грузия — 50–70 тысяч ₽. Бали — 130–180 тысяч ₽. Точную цифру под твои даты считает калькулятор: учитывает сезонный коэффициент, число путешественников, отель, перелёт, еду, визу, страховку и eSIM." }
        },
        {
          "@type": "Question",
          "name": "Как калькулятор учитывает сезонность?",
          "acceptedAnswer": { "@type": "Answer", "text": "Каждая страна имеет 12-месячный рейтинг: пик (высокий сезон, +30% к перелёту), хорошо (норма), нормально (−15%), не сезон (низкий сезон, −30%). Калькулятор пересчитывает перелёт в зависимости от выбранного месяца и подсказывает, в каком месяце поездка обойдётся дешевле всего." }
        },
        {
          "@type": "Question",
          "name": "Можно ли сравнить несколько направлений?",
          "acceptedAnswer": { "@type": "Answer", "text": "Да. Кнопка «+ Добавить страну» позволяет положить рядом до 3 направлений с одинаковыми параметрами (дни, путешественники, месяц, уровень) — итог считается отдельно для каждой страны." }
        },
        {
          "@type": "Question",
          "name": "Сколько считать на семью из 2–4 человек?",
          "acceptedAnswer": { "@type": "Answer", "text": "Перелёт умножается на число людей, питание тоже, а отель остаётся одинаковым (один номер на всех). Это даёт реалистичную сумму для пары или семьи, которая обычно меньше, чем простое умножение в 2–4 раза." }
        },
        {
          "@type": "Question",
          "name": "Курс рубля к доллару меняется — учитывает ли калькулятор?",
          "acceptedAnswer": { "@type": "Answer", "text": "Да. Курс подтягивается через open exchange rates в реальном времени. Можно переключаться между ₽ и $ одной кнопкой — внутренний расчёт всегда в долларах, отображение по твоему выбору." }
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Калькулятор", "item": "https://traveltribe.ru/calculator/" }
      ]
    }
  ]
};
---
<Layout
  title="Калькулятор бюджета путешествия 2026: 70 стран + сравнение + сезон"
  description="Калькулятор стоимости путешествия 2026: 70 направлений, сравнение до 3 стран рядом, выбор месяца с сезонным коэффициентом, виза, страховка, eSIM, курс ЦБ РФ. Сколько стоит твоя поездка из Москвы — за 30 секунд."
  canonical="https://traveltribe.ru/calculator/"
  ogTitle="Калькулятор бюджета путешествия — TravelTribe"
  ogDescription="70 направлений · сравнение 3 стран · сезонный коэффициент · виза · курс ЦБ РФ"
  ogType="website"
  ldJson={ldJson}
>
  <Nav active="calculator" />

  <main id="main">
    <div class="page">
      <header>
        <div class="eyebrow">// Калькулятор</div>
        <h1>Сколько будет <em>стоить поездка</em></h1>
        <p class="subtitle">70 направлений · сравнение до 3 стран · сезонный коэффициент · виза · страховка · курс ЦБ РФ.</p>
      </header>

      <div class="calc">
        <div class="calc-form">
          <div class="calc-field" style="flex:1;min-width:240px">
            <label>Регион</label>
            <select class="calc-select" id="calcRegion" aria-label="Выберите регион для расчёта бюджета">
              {Object.entries(groups).map(([label, items]) => (
                <optgroup label={label}>
                  {items.map(({ i, name }) => (
                    <option value={i}>{name}</option>
                  ))}
                </optgroup>
              ))}
            </select>
            <select class="add-country-select" id="addCountrySelect" aria-label="Добавить страну для сравнения" hidden>
              <option value="">+ сравнить с другой страной</option>
              {Object.entries(groups).map(([label, items]) => (
                <optgroup label={label}>
                  {items.map(({ i, name }) => (
                    <option value={i}>{name}</option>
                  ))}
                </optgroup>
              ))}
            </select>
          </div>

          <div class="calc-field">
            <label>Путешественников</label>
            <div class="btn-group" id="travelersGroup" role="group" aria-label="Число путешественников">
              <button class="active" data-tr="1" aria-pressed="true">1</button>
              <button data-tr="2" aria-pressed="false">2</button>
              <button data-tr="3" aria-pressed="false">3</button>
              <button data-tr="4" aria-pressed="false">4</button>
            </div>
          </div>

          <div class="calc-field">
            <label>Дней</label>
            <div class="stepper">
              <button class="step-btn" id="daysDown" type="button" aria-label="Уменьшить количество дней">−</button>
              <span class="step-val" id="calcDaysDisplay" aria-live="polite">7</span>
              <button class="step-btn" id="daysUp" type="button" aria-label="Увеличить количество дней">+</button>
              <input type="hidden" id="calcDays" value="7" />
            </div>
            <div class="day-chips" role="group" aria-label="Быстрый выбор дней">
              <button class="chip" type="button" data-d="3">3</button>
              <button class="chip" type="button" data-d="7">7</button>
              <button class="chip" type="button" data-d="10">10</button>
              <button class="chip" type="button" data-d="14">14</button>
              <button class="chip" type="button" data-d="21">21</button>
              <button class="chip" type="button" data-d="30">30</button>
            </div>
          </div>

          <div class="calc-field">
            <label>
              Уровень
              <button class="info-btn" id="levelInfoBtn" type="button" aria-label="Что входит в каждый уровень" aria-expanded="false">?</button>
            </label>
            <div class="btn-group" id="levelGroup" role="group" aria-label="Уровень комфорта">
              <button class="active" data-lvl="0" aria-pressed="true">$ Бюджет</button>
              <button data-lvl="1" aria-pressed="false">$$ Комфорт</button>
              <button data-lvl="2" aria-pressed="false">$$$ Люкс</button>
            </div>
            <div class="info-tip" id="levelInfoTip" hidden>
              <strong>$ Бюджет:</strong> хостел / 3*, чифаньки и комбини, метро.<br>
              <strong>$$ Комфорт:</strong> 4* отель, нормальные рестораны, такси иногда.<br>
              <strong>$$$ Люкс:</strong> 5*+, премиум-кухня, частный транспорт.
            </div>
          </div>

          <div class="calc-field calc-field--full">
            <label>Месяц поездки</label>
            <div class="month-chips" id="monthChips" role="group" aria-label="Выбор месяца">
              {MONTH_NAMES.map((m, i) => (
                <button class="month-chip" type="button" data-m={i + 1} aria-label={`Месяц ${m}, рейтинг загружается`}>
                  <span class="m-name">{m}</span>
                  <span class="m-dot" aria-hidden="true"></span>
                </button>
              ))}
            </div>
            <div class="month-legend" aria-hidden="true">
              <span><i class="lg lg-peak"></i> Пик</span>
              <span><i class="lg lg-good"></i> Хорошо</span>
              <span><i class="lg lg-ok"></i> Нормально</span>
              <span><i class="lg lg-bad"></i> Не сезон</span>
            </div>
          </div>

          <div class="calc-field">
            <label>Валюта</label>
            <div class="btn-group" id="currGroup" role="group" aria-label="Валюта">
              <button class="active" data-cur="rub" aria-pressed="true">₽</button>
              <button data-cur="usd" aria-pressed="false">$</button>
            </div>
          </div>
        </div>

        <div class="calc-result" id="calcResult">
          <!-- Заполняется через JS: 1 страна или сравнение 2–3 -->
        </div>

        <p class="calc-note">
          <span id="calcRateLabel">1 $ = 90 ₽ · загрузка курса...</span>
          &nbsp;·&nbsp; Отель и питание — ориентировочно. Часть ссылок партнёрские, цена для тебя не меняется.
        </p>
      </div>

      <div id="budgetBlocksHost" class="bb-host">
        {Object.keys(realBudgets).filter(k => k !== '_meta').map((slug) => (
          <div class="bb-wrap" data-slug={slug} hidden>
            <BudgetBlock slug={slug} />
          </div>
        ))}
      </div>

      <section class="faq" aria-label="Частые вопросы">
        <h2>Частые вопросы</h2>
        <details class="faq-item" open>
          <summary>Откуда берутся цены?</summary>
          <p>Базовые цены 70 направлений собраны вручную: перелёт из Москвы туда-обратно по средней цене Aviasales за последний квартал, отель — по медиане Ostrovok / Booking по уровням 3*/4*/5*, еда — по типовому дню (завтрак-обед-ужин) для каждого уровня. Сезонный коэффициент применяется к перелёту: пик +30%, хорошо ±0%, нормально −15%, не сезон −30%.</p>
        </details>
        <details class="faq-item">
          <summary>Как считается, когда едет несколько человек?</summary>
          <p>Перелёт умножается на число путешественников. Питание тоже умножается. Отель — нет, потому что один номер вмещает 2–4 человек. Это даёт реалистичную сумму: семья из 2 человек платит примерно в 1.6× больше одного, а не в 2×.</p>
        </details>
        <details class="faq-item">
          <summary>А виза включена в итог?</summary>
          <p>Да, если виза платная. Под breakdown показывается строка с конкретной стоимостью и сроком оформления — например, «€90 + €30 BLS, 10–15 дней». Если у России безвиз — стоит ✓ и виза не добавляется к сумме. По клику — переход на детальную страницу /visa/&lt;страна&gt;/.</p>
        </details>
        <details class="faq-item">
          <summary>Что такое «лучший месяц»?</summary>
          <p>Калькулятор смотрит 12-месячный рейтинг страны и подсвечивает месяцы с минимальным коэффициентом цены и хорошей погодой. Например, «В ноябре та же поездка обойдётся на 28% дешевле — это лучший месяц года для Турции».</p>
        </details>
        <details class="faq-item">
          <summary>Зачем добавлять страховку и eSIM в расчёт?</summary>
          <p>Эти 2 категории — реальные расходы, которые забывают: страховка обязательна для большинства стран (без неё могут не пустить), eSIM экономит на роуминге МТС/Билайн (1500 ₽ vs 5000+ ₽ переплаты). Включи галочки — увидишь полный честный бюджет.</p>
        </details>
        <details class="faq-item">
          <summary>Куда поделиться расчётом?</summary>
          <p>Кнопка «📋 Скопировать для Telegram» — копирует красивую сводку с разбивкой по категориям и партнёрской ссылкой. Можно вставить в чат с попутчиком, в личные заметки или в почту. URL калькулятора содержит все твои параметры — кто перейдёт по ссылке, увидит точно такой же расчёт.</p>
        </details>
      </section>

    </div>
  </main>

  <Footer />
</Layout>

<script define:vars={{ PRICES, MONTH_NAMES, MONTH_FULL, iataToSeasons, iataToVisa, iataToSlug, iataToBudgetSlug }}>
// ─── STATE ────────────────────────────────────────────────────────────
let RUB = 90;
let calcLevel = 0;
let calcCurrency = 'rub';
let travelers = 1;
let selectedMonth = 0;       // 0 = «любой / без сезона», 1..12 = конкретный месяц
let compareList = [];        // массив индексов PRICES для сравнения; 1й элемент — основной из <select>

// Сезонные коэффициенты для перелёта
const SEASON_MULT = { P: 1.30, G: 1.00, O: 0.85, B: 0.70 };
const SEASON_LABEL = { P: 'Пик', G: 'Хорошо', O: 'Нормально', B: 'Не сезон' };
const SEASON_CLASS = { P: 'peak', G: 'good', O: 'ok', B: 'bad' };

const AVIASALES_MARKER = '546042.Zz66f13c16ff6b488883a4127-546042';
const AVIASALES_BASE = `https://www.aviasales.ru/?marker=${AVIASALES_MARKER}&market=ru`;
const CHEREHAPA = 'https://cherehapa.tpk.mx/GmVWjhCN';
const OSTROVOK = 'https://ostrovok.tpk.mx/w4cAS1wZ';
const AIRALO = 'https://ref.airalo.com/k7Wf';

const calcSel = document.getElementById('calcRegion');
const resultEl = document.getElementById('calcResult');
const addSelect = document.getElementById('addCountrySelect');

// ─── URL params ──────────────────────────────────────────────────────
function readUrlParams() {
  const u = new URL(window.location.href);
  const r = u.searchParams.get('r');
  const d = u.searchParams.get('d');
  const l = u.searchParams.get('l');
  const c = u.searchParams.get('c');
  const t = u.searchParams.get('t');
  const m = u.searchParams.get('m');
  const cmp = u.searchParams.get('cmp');

  if (r !== null && PRICES[+r]) calcSel.value = r;
  if (d !== null) {
    const n = Math.min(90, Math.max(1, parseInt(d) || 7));
    document.getElementById('calcDays').value = n;
    document.getElementById('calcDaysDisplay').textContent = n;
  }
  if (l !== null && (+l >= 0 && +l <= 2)) {
    calcLevel = +l;
    document.querySelectorAll('#levelGroup button').forEach(b => {
      const on = +b.dataset.lvl === calcLevel;
      b.classList.toggle('active', on);
      b.setAttribute('aria-pressed', on ? 'true' : 'false');
    });
  }
  if (c === 'usd' || c === 'rub') {
    calcCurrency = c;
    document.querySelectorAll('#currGroup button').forEach(b => {
      const on = b.dataset.cur === calcCurrency;
      b.classList.toggle('active', on);
      b.setAttribute('aria-pressed', on ? 'true' : 'false');
    });
  }
  if (t !== null && +t >= 1 && +t <= 4) {
    travelers = +t;
    document.querySelectorAll('#travelersGroup button').forEach(b => {
      const on = +b.dataset.tr === travelers;
      b.classList.toggle('active', on);
      b.setAttribute('aria-pressed', on ? 'true' : 'false');
    });
  }
  if (m !== null && +m >= 0 && +m <= 12) {
    selectedMonth = +m;
  }

  if (cmp) {
    compareList = cmp.split(',').map(x => parseInt(x)).filter(x => !isNaN(x) && PRICES[x]).slice(0, 3);
  }
}

function writeUrlParams() {
  const u = new URL(window.location.href);
  u.searchParams.set('r', calcSel.value);
  u.searchParams.set('d', document.getElementById('calcDays').value);
  u.searchParams.set('l', String(calcLevel));
  u.searchParams.set('c', calcCurrency);
  u.searchParams.set('t', String(travelers));
  if (selectedMonth > 0) u.searchParams.set('m', String(selectedMonth));
  else u.searchParams.delete('m');
  if (compareList.length > 0) u.searchParams.set('cmp', compareList.join(','));
  else u.searchParams.delete('cmp');
  window.history.replaceState(null, '', u.toString());
}

// ─── Live USD→RUB rate ───────────────────────────────────────────────
async function fetchRate() {
  const rateEl = document.getElementById('calcRateLabel');
  try {
    const r = await fetch('https://open.er-api.com/v6/latest/USD');
    const d = await r.json();
    if (d.result === 'success' && d.rates && d.rates.RUB) {
      RUB = d.rates.RUB;
      if (rateEl) rateEl.textContent = '1 $ = ' + RUB.toFixed(2) + ' ₽ · open exchange rates';
      renderCalc();
      return;
    }
  } catch (e) {}
  if (rateEl) rateEl.textContent = '1 $ ≈ 90 ₽ · курс не загружен, примерный';
}

function fmt(usd) {
  if (!usd || isNaN(usd)) return '—';
  return calcCurrency === 'rub'
    ? Math.round(usd * RUB).toLocaleString('ru-RU') + ' ₽'
    : Math.round(usd).toLocaleString('en-US') + ' $';
}

function aviasalesUrl(iata, monthNum) {
  if (!iata) return AVIASALES_BASE;
  let url = `${AVIASALES_BASE}&origin_iata=MOW&destination_iata=${iata}`;
  if (monthNum && monthNum >= 1 && monthNum <= 12) {
    const year = new Date().getFullYear();
    const targetMonth = monthNum - 1;
    const now = new Date();
    let y = year;
    if (targetMonth < now.getMonth()) y += 1;
    const dateStr = `${y}-${String(monthNum).padStart(2, '0')}-15`;
    url += `&depart_date=${dateStr}`;
  }
  return url;
}

// ─── Расчёт для одной страны ─────────────────────────────────────────
function computeForPriceIndex(pi) {
  const p = PRICES[pi];
  const days = Math.max(1, parseInt(document.getElementById('calcDays').value) || 1);
  const baseFlight = p.flight[calcLevel];
  const hotel = p.hotel[calcLevel];
  const food = p.food[calcLevel];
  // Сезонный множитель
  let seasonMult = 1, seasonLabel = '', seasonClass = '';
  if (selectedMonth > 0 && iataToSeasons[p.iata]) {
    const rating = iataToSeasons[p.iata][selectedMonth - 1];
    seasonMult = SEASON_MULT[rating] || 1;
    seasonLabel = SEASON_LABEL[rating] || '';
    seasonClass = SEASON_CLASS[rating] || '';
  }
  const flightAdjusted = baseFlight * seasonMult;
  const flightTotal = flightAdjusted * travelers;
  const hotelTotal = hotel * days; // отель один номер на всех
  const foodTotal = food * days * travelers;
  // Визa: подтянуть стоимость в долларах если есть
  const visa = iataToVisa[p.iata];
  let visaUsd = 0;
  if (visa && visa.cost) {
    // Парсим типичные форматы: "$30", "€90", "JD 40 (~$56)", "бесплатно", "от $X"
    const m = visa.cost.match(/\$(\d+)/);
    if (m) visaUsd = parseInt(m[1]);
    else {
      const e = visa.cost.match(/€\s?(\d+)/);
      if (e) visaUsd = Math.round(parseInt(e[1]) * 1.08); // EUR→USD приблизительно
    }
  }
  const visaTotal = visaUsd * travelers;
  const grand = flightTotal + hotelTotal + foodTotal + visaTotal;
  return {
    p,
    days,
    travelers,
    baseFlight,
    flightAdjusted,
    flightTotal,
    hotel,
    hotelTotal,
    food,
    foodTotal,
    visa,
    visaUsd,
    visaTotal,
    seasonMult,
    seasonLabel,
    seasonClass,
    grand,
  };
}

// ─── Найти лучший месяц для страны (минимальный коэффициент) ──────────
function findBestMonth(iata) {
  if (!iataToSeasons[iata]) return null;
  const ratings = iataToSeasons[iata];
  let bestIdx = -1, bestMult = 999;
  ratings.forEach((r, i) => {
    const m = SEASON_MULT[r] || 1;
    // Хотим минимальный коэффициент с приемлемой погодой (не B при пляжных)
    if (m < bestMult && r !== 'B') {
      bestMult = m;
      bestIdx = i;
    }
  });
  // Fallback: если все B — берём первый O
  if (bestIdx === -1) ratings.forEach((r, i) => { if (r === 'O' && bestIdx === -1) bestIdx = i; });
  if (bestIdx === -1) bestIdx = 0;
  return { monthNum: bestIdx + 1, monthName: MONTH_FULL[bestIdx], mult: SEASON_MULT[ratings[bestIdx]] || 1, rating: ratings[bestIdx] };
}

// ─── Рендер одной карточки результата (новый дизайн 2026) ─────────────
function renderCard(pi, isPrimary) {
  const r = computeForPriceIndex(pi);
  const aviUrl = aviasalesUrl(r.p.iata, selectedMonth > 0 ? selectedMonth : null);
  const perPerson = r.grand / Math.max(1, r.travelers);

  // Виза — компакт в строке meta
  const visaText = r.visa
    ? (r.visa.cost === 'бесплатно' ? 'безвиз' : escapeHtml(r.visa.cost))
    : null;

  // Best month nudge — inline, маленький
  const best = findBestMonth(r.p.iata);
  let nudge = '';
  if (best && selectedMonth > 0 && best.monthNum !== selectedMonth) {
    const saving = Math.round((1 - best.mult / r.seasonMult) * 100);
    if (saving > 5) {
      nudge = `<div class="nudge"><span>💡</span> Лучший месяц — <strong>${best.monthName}</strong>, поездка будет на <strong>${saving}%</strong> дешевле</div>`;
    }
  } else if (best && selectedMonth === 0) {
    nudge = `<div class="nudge"><span>💡</span> Самый дешёвый месяц для поездки — <strong>${best.monthName}</strong></div>`;
  }

  const seasonBadge = r.seasonLabel
    ? `<span class="season-badge season-${r.seasonClass}">${MONTH_NAMES[selectedMonth - 1]} · ${r.seasonLabel}</span>`
    : '';

  const cityName = r.p.name.split('(')[0].trim();

  return `
    <article class="card${isPrimary ? ' card-primary' : ''}" data-pi="${pi}">
      ${!isPrimary ? `<button class="card-remove" data-remove="${pi}" type="button" aria-label="Убрать из сравнения">×</button>` : ''}

      <div class="card-meta">
        <h3 class="card-title">${escapeHtml(r.p.name)}</h3>
        <div class="card-chips">
          ${seasonBadge}
          <span class="meta-chip">${r.travelers} чел · ${r.days} дн</span>
          ${visaText ? `<a href="/visa/${r.visa.slug}/" class="meta-chip meta-chip--link">🛂 ${visaText}</a>` : ''}
        </div>
      </div>

      <div class="card-hero">
        <div class="hero-label">Итого</div>
        <div class="hero-amount">${r.grand > 0 ? fmt(r.grand) : '—'}</div>
        ${r.travelers > 1 ? `<div class="hero-perperson">≈ ${fmt(perPerson)} на человека</div>` : ''}
        ${nudge}
      </div>

      <details class="breakdown-toggle">
        <summary>Что включено →</summary>
        <div class="calc-breakdown">
          <div class="breakdown-item"><span>✈ Перелёт${r.travelers > 1 ? ' × ' + r.travelers : ''}</span><span>${fmt(r.flightTotal)}</span></div>
          <div class="breakdown-item"><span>🏨 Отель × ${r.days} ноч.</span><span>${fmt(r.hotelTotal)}</span></div>
          <div class="breakdown-item"><span>🍴 Еда${r.travelers > 1 ? ' × ' + r.travelers : ''} × ${r.days} дн</span><span>${fmt(r.foodTotal)}</span></div>
          ${r.visa && r.visaTotal > 0 ? `<div class="breakdown-item"><span>🛂 Виза${r.travelers > 1 ? ' × ' + r.travelers : ''}</span><span>${fmt(r.visaTotal)}</span></div>` : ''}
        </div>
      </details>

      <div class="card-cta">
        <a href="${aviUrl}" target="_blank" rel="noopener sponsored" class="cta-primary">
          <span class="cta-label">Найти билет</span>
          <span class="cta-arrow" aria-hidden="true">→</span>
        </a>
        <div class="cta-row">
          <a href="${OSTROVOK}" target="_blank" rel="noopener sponsored" class="cta-mini" title="Поиск отелей">
            <span>🏨</span> Отель
          </a>
          <a href="${CHEREHAPA}" target="_blank" rel="noopener sponsored" class="cta-mini" title="Страховка от 2 000 ₽">
            <span>🛡</span> Страховка
          </a>
          <a href="${AIRALO}" target="_blank" rel="noopener sponsored" class="cta-mini" title="eSIM мобильный интернет">
            <span>📱</span> eSIM
          </a>
        </div>
      </div>
    </article>
  `;
}

function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

// ─── Главный рендер ──────────────────────────────────────────────────
function renderCalc() {
  const primary = parseInt(calcSel.value);
  const all = [primary, ...compareList.filter(x => x !== primary)].slice(0, 3);
  const isCompare = all.length > 1;

  let html = '<div class="cards' + (isCompare ? ' cards-compare' : '') + '">';
  html += all.map((pi, idx) => renderCard(pi, idx === 0)).join('');
  html += '</div>';

  // Footer: только copy button — компактный
  html += `
    <div class="result-footer">
      <button class="copy-tg" id="copyTgBtn" type="button" aria-label="Скопировать сводку для Telegram">
        📋 Скопировать сводку для Telegram
      </button>
    </div>
  `;

  resultEl.innerHTML = html;

  // Подсветить активный day chip
  const cur = +document.getElementById('calcDays').value;
  document.querySelectorAll('.day-chips .chip').forEach(c => {
    c.classList.toggle('is-active', +c.dataset.d === cur);
  });

  // Селект добавить страну (показывать если < 3 и есть варианты)
  if (compareList.length < 2 && all.length < 3) {
    addSelect.hidden = false;
    addSelect.value = '';
    // Скрыть текущую primary + уже выбранные в compareList из options
    Array.from(addSelect.options).forEach(opt => {
      const v = parseInt(opt.value);
      if (isNaN(v)) { opt.disabled = false; return; }
      opt.disabled = (v === primary || compareList.includes(v));
    });
  } else {
    addSelect.hidden = true;
  }

  writeUrlParams();
  renderMonthChips();
  showBudgetBlock();
}

// Показать BudgetBlock для текущей страны (если есть данные)
function showBudgetBlock() {
  const primary = parseInt(calcSel.value);
  const iata = PRICES[primary]?.iata;
  const slug = iataToBudgetSlug[iata];
  document.querySelectorAll('.bb-wrap').forEach(el => {
    el.hidden = el.dataset.slug !== slug;
  });
}

// ─── Рендер месячных chip с цветными точками ──────────────────────────
function renderMonthChips() {
  const primary = parseInt(calcSel.value);
  const iata = PRICES[primary]?.iata;
  const rating = iata && iataToSeasons[iata] ? iataToSeasons[iata] : null;
  document.querySelectorAll('#monthChips .month-chip').forEach((btn, i) => {
    const m = i + 1;
    btn.classList.toggle('active', selectedMonth === m);
    btn.setAttribute('aria-pressed', selectedMonth === m ? 'true' : 'false');
    const dot = btn.querySelector('.m-dot');
    if (rating && dot) {
      const r = rating[i];
      dot.dataset.r = r;
      btn.setAttribute('aria-label', `${MONTH_NAMES[i]}, ${SEASON_LABEL[r] || ''}`);
    }
  });
}

// ─── EVENT HANDLERS (через делегирование где можно для INP) ──────────
calcSel.addEventListener('change', renderCalc);

document.getElementById('travelersGroup').addEventListener('click', e => {
  const btn = e.target.closest('[data-tr]');
  if (!btn) return;
  travelers = +btn.dataset.tr;
  document.querySelectorAll('#travelersGroup button').forEach(b => {
    const on = b === btn;
    b.classList.toggle('active', on);
    b.setAttribute('aria-pressed', on ? 'true' : 'false');
  });
  renderCalc();
});

function setDays(n) {
  n = Math.min(90, Math.max(1, n));
  document.getElementById('calcDays').value = n;
  document.getElementById('calcDaysDisplay').textContent = n;
  renderCalc();
}
document.getElementById('daysDown').addEventListener('click', () => setDays(parseInt(document.getElementById('calcDays').value) - 1));
document.getElementById('daysUp').addEventListener('click', () => setDays(parseInt(document.getElementById('calcDays').value) + 1));
document.querySelectorAll('.day-chips .chip').forEach(chip => {
  chip.addEventListener('click', () => setDays(+chip.dataset.d));
});

document.getElementById('levelGroup').addEventListener('click', e => {
  const btn = e.target.closest('[data-lvl]');
  if (!btn) return;
  calcLevel = +btn.dataset.lvl;
  document.querySelectorAll('#levelGroup button').forEach(b => {
    b.classList.toggle('active', b === btn);
    b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
  });
  renderCalc();
});

document.getElementById('currGroup').addEventListener('click', e => {
  const btn = e.target.closest('[data-cur]');
  if (!btn) return;
  calcCurrency = btn.dataset.cur;
  document.querySelectorAll('#currGroup button').forEach(b => {
    b.classList.toggle('active', b === btn);
    b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
  });
  renderCalc();
});

document.getElementById('monthChips').addEventListener('click', e => {
  const btn = e.target.closest('[data-m]');
  if (!btn) return;
  const m = +btn.dataset.m;
  selectedMonth = selectedMonth === m ? 0 : m;
  renderCalc();
});

// Select для добавления страны в сравнение — работает на Safari/Chrome одинаково
addSelect.addEventListener('change', e => {
  const v = parseInt(e.target.value);
  if (isNaN(v)) return;
  const primary = parseInt(calcSel.value);
  if (v === primary || compareList.includes(v)) return;
  if (compareList.length >= 2) return;
  compareList.push(v);
  renderCalc();
});

// Удалить карточку из сравнения
resultEl.addEventListener('click', e => {
  const rm = e.target.closest('[data-remove]');
  if (!rm) return;
  const pi = +rm.dataset.remove;
  compareList = compareList.filter(x => x !== pi);
  renderCalc();
});

// Copy to Telegram
resultEl.addEventListener('click', async e => {
  const btn = e.target.closest('#copyTgBtn');
  if (!btn) return;
  const primary = parseInt(calcSel.value);
  const all = [primary, ...compareList.filter(x => x !== primary)].slice(0, 3);
  const days = +document.getElementById('calcDays').value;
  const lvlNames = ['$ Бюджет', '$$ Комфорт', '$$$ Люкс'];
  const monthLine = selectedMonth > 0 ? `, в ${MONTH_FULL[selectedMonth - 1]}` : '';
  let text = `✈ Бюджет поездки${monthLine}\n`;
  text += `${days} дн · ${travelers} чел. · ${lvlNames[calcLevel]}\n`;
  text += `─────\n`;
  all.forEach(pi => {
    const r = computeForPriceIndex(pi);
    text += `${r.p.name}\n`;
    text += `  ИТОГО: ${fmt(r.grand)}\n`;
    text += `  ✈ Перелёт: ${fmt(r.flightTotal)}\n`;
    text += `  🏨 Отель × ${days}: ${fmt(r.hotelTotal)}\n`;
    text += `  🍴 Еда × ${days}: ${fmt(r.foodTotal)}\n`;
    if (r.visa && r.visaTotal > 0) text += `  🛂 Виза: ${fmt(r.visaTotal)} (${r.visa.cost})\n`;
    text += `\n`;
  });
  text += `📎 ${window.location.href}\n`;
  text += `🌍 traveltribe.ru/calculator/`;
  try {
    await navigator.clipboard.writeText(text);
    const orig = btn.querySelector('span').textContent;
    btn.querySelector('span').textContent = '✓ Скопировано';
    setTimeout(() => { btn.querySelector('span').textContent = orig; }, 1800);
  } catch (err) {
    alert('Не удалось скопировать. Скопируй вручную из URL.');
  }
});

// "Что входит" tooltip
const levelInfoBtn = document.getElementById('levelInfoBtn');
const levelInfoTip = document.getElementById('levelInfoTip');
if (levelInfoBtn) {
  levelInfoBtn.addEventListener('click', () => {
    const open = !levelInfoTip.hasAttribute('hidden');
    if (open) levelInfoTip.setAttribute('hidden', '');
    else levelInfoTip.removeAttribute('hidden');
    levelInfoBtn.setAttribute('aria-expanded', String(!open));
  });
}

// ─── INIT ────────────────────────────────────────────────────────────
readUrlParams();
fetchRate();
renderCalc();
</script>

