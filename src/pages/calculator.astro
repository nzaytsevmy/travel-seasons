---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BudgetBlock from '../components/BudgetBlock.astro';
import { PRICES } from '../data/prices.js';
import { DIRECTIONS } from '../data/directions.js';
import { VISA_DETAILS } from '../data/visa-details.js';
import realBudgets from '../data/real-budgets-2026.json';

const groups: Record<string, Array<{i:number,name:string,iata:string}>> = {};
PRICES.forEach((p, i) => {
  if (!groups[p.g]) groups[p.g] = [];
  groups[p.g].push({ i, name: p.name, iata: p.iata });
});

const iataToSlug: Record<string, string> = {};
const iataToSeasons: Record<string, any> = {};
const iataToSeasonText: Record<string, any> = {};
const iataToBudgetSlug: Record<string, string> = {};
DIRECTIONS.forEach((d: any) => {
  if (d.price?.iata) {
    iataToSlug[d.price.iata] = d.slug;
    iataToSeasons[d.price.iata] = d.r;
    iataToSeasonText[d.price.iata] = d.t;
    if ((realBudgets as any)[d.slug]) iataToBudgetSlug[d.price.iata] = d.slug;
  }
});
const iataToVisa: Record<string, any> = {};
PRICES.forEach((p) => {
  const slug = iataToSlug[p.iata];
  if (slug && (VISA_DETAILS as any)[slug]) iataToVisa[p.iata] = { ...(VISA_DETAILS as any)[slug], slug };
});

const MONTH_NAMES = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
const MONTH_FULL  = ['январе','феврале','марте','апреле','мае','июне','июле','августе','сентябре','октябре','ноябре','декабре'];

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Калькулятор бюджета путешествия 2026",
      "url": "https://traveltribe.ru/calculator/",
      "description": "Интерактивный калькулятор стоимости поездки из Москвы на 2026: 70 направлений, сравнение, сезонный коэффициент по месяцам, виза в расчёте, реальные траты по 12 источникам.",
      "inLanguage": "ru-RU",
      "applicationCategory": "TravelApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "RUB" },
      "featureList": ["70 направлений","Сравнение до 3 стран","Сезонный коэффициент по 12 месяцам","Расчёт 1–4 путешественников","Виза в разбивке","Курс ЦБ РФ в реальном времени","Реальные траты 2026 из 12 источников"],
      "author": { "@type": "Person", "name": "Никита Зайцев", "url": "https://t.me/traveltriberu" }
    },
    {
      "@type": "HowTo",
      "name": "Как посчитать бюджет путешествия из Москвы в 2026",
      "totalTime": "PT2M",
      "estimatedCost": { "@type": "MonetaryAmount", "currency": "RUB", "value": "0" },
      "step": [
        { "@type":"HowToStep", "position":1, "name":"Выбрать направление", "text":"Одна из 70 стран. Опционально добавь ещё для сравнения." },
        { "@type":"HowToStep", "position":2, "name":"Указать месяц поездки", "text":"Калькулятор учтёт сезонный коэффициент: пик +30%, не сезон −30%." },
        { "@type":"HowToStep", "position":3, "name":"Длительность и путешественники", "text":"От 1 до 30 дней, от 1 до 4 человек. Отель не удваивается, перелёт и еда — да." },
        { "@type":"HowToStep", "position":4, "name":"Уровень комфорта", "text":"Эконом / комфорт / люкс. Влияет на отель, еду, перелёт." },
        { "@type":"HowToStep", "position":5, "name":"Скопировать в Telegram", "text":"Готовая сводка для пересылки в чат или сохранения." }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type":"Question", "name":"Сколько стоит поездка из Москвы в 2026 году?", "acceptedAnswer":{"@type":"Answer","text":"Зависит от направления и сезона. Турция в комфортном варианте на 7 дней — около 90–110 тысяч ₽ на одного. Грузия — 50–70 тысяч ₽. Бали — 130–180 тысяч ₽. Точную цифру под твои даты считает калькулятор."} },
        { "@type":"Question", "name":"Как калькулятор учитывает сезонность?", "acceptedAnswer":{"@type":"Answer","text":"Каждая страна имеет 12-месячный рейтинг: пик (+30% к перелёту), хорошо (норма), нормально (−15%), не сезон (−30%). Подсказывает, в каком месяце поездка обойдётся дешевле всего."} },
        { "@type":"Question", "name":"Можно ли сравнить несколько направлений?", "acceptedAnswer":{"@type":"Answer","text":"Да, до 3 стран рядом с одинаковыми параметрами — дни, путешественники, месяц, уровень."} },
        { "@type":"Question", "name":"Откуда берутся цены?", "acceptedAnswer":{"@type":"Answer","text":"Базовые цены 70 направлений собраны вручную: перелёт по средней Aviasales, отель по медиане Ostrovok/Booking 3*/4*/5*, еда — типовой день. Реальные траты — агрегация из 12 источников: Самокатус, make-trip, BudgetYourTrip, IndieTraveller и др."} },
        { "@type":"Question", "name":"Курс рубля учитывается?", "acceptedAnswer":{"@type":"Answer","text":"Да. Курс подтягивается через open exchange rates в реальном времени. Переключение ₽/$ одной кнопкой."} }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type":"ListItem", "position":1, "name":"Главная", "item":"https://traveltribe.ru/" },
        { "@type":"ListItem", "position":2, "name":"Калькулятор", "item":"https://traveltribe.ru/calculator/" }
      ]
    }
  ]
};
---
<Layout
  title="Калькулятор бюджета путешествия 2026 — 70 стран, сравнение, реальные траты"
  description="Интерактивный калькулятор стоимости поездки из Москвы на 2026: 70 направлений, сравнение до 3 стран, сезонный коэффициент по месяцам, реальные траты из 12 источников, курс ЦБ РФ. Сколько стоит твоя поездка — за 30 секунд."
  canonical="https://traveltribe.ru/calculator/"
  ogTitle="Калькулятор бюджета — TravelTribe"
  ogDescription="70 направлений · сравнение · сезонный коэффициент · реальные траты 2026"
  ogType="website"
  ldJson={ldJson}
>
  <Nav active="calculator" />

  <main id="main" class="atlas">
    <!-- Decorative grid paper background -->
    <div class="atlas-paper" aria-hidden="true"></div>

    <!-- ───────────── HERO ─────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-eyebrow">
          <span class="eyebrow-dot" aria-hidden="true"></span>
          <span>Calculator · издание 2026</span>
        </div>
        <h1 class="hero-title">
          <span class="hero-line">Сколько</span>
          <span class="hero-line">стоит твоя</span>
          <span class="hero-line"><em>поездка</em></span>
        </h1>
        <p class="hero-deck">
          70 направлений мира · сравнение до трёх стран · сезонный коэффициент по двенадцати месяцам · виза в разбивке · реальные траты путешественников 2026 из двенадцати источников.
        </p>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-num">70</span>
            <span class="stat-label">направлений</span>
          </div>
          <div class="stat">
            <span class="stat-num">12</span>
            <span class="stat-label">источников</span>
          </div>
          <div class="stat">
            <span class="stat-num">2026</span>
            <span class="stat-label">актуально</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────────── EDITORIAL SPLIT: FORM + COMPUTE ────────────── -->
    <section class="spread">
      <div class="spread-inner">
        <!-- LEFT: form column -->
        <div class="form-col">
          <div class="col-marker"><span>01</span> Параметры</div>

          <div class="field">
            <label class="field-label">Направление</label>
            <select class="field-select" id="calcRegion" aria-label="Выберите регион">
              {Object.entries(groups).map(([label, items]) => (
                <optgroup label={label}>
                  {items.map(({ i, name }) => (
                    <option value={i}>{name}</option>
                  ))}
                </optgroup>
              ))}
            </select>
            <select class="field-select field-select--add" id="addCountrySelect" aria-label="Сравнить с другой страной" hidden>
              <option value="">+ сравнить с другой страной</option>
              {Object.entries(groups).map(([label, items]) => (
                <optgroup label={label}>
                  {items.map(({ i, name }) => (
                    <option value={i}>{name}</option>
                  ))}
                </optgroup>
              ))}
            </select>
          </div>

          <div class="field-row">
            <div class="field">
              <label class="field-label">Путешественников</label>
              <div class="seg" id="travelersGroup" role="group" aria-label="Число путешественников">
                <button class="seg-btn active" data-tr="1" aria-pressed="true">1</button>
                <button class="seg-btn" data-tr="2" aria-pressed="false">2</button>
                <button class="seg-btn" data-tr="3" aria-pressed="false">3</button>
                <button class="seg-btn" data-tr="4" aria-pressed="false">4</button>
              </div>
            </div>

            <div class="field">
              <label class="field-label">Дней</label>
              <div class="stepper">
                <button class="stepper-btn" id="daysDown" type="button" aria-label="Меньше дней">−</button>
                <span class="stepper-val" id="calcDaysDisplay" aria-live="polite">7</span>
                <button class="stepper-btn" id="daysUp" type="button" aria-label="Больше дней">+</button>
                <input type="hidden" id="calcDays" value="7" />
              </div>
              <div class="quick-days" role="group" aria-label="Быстрый выбор дней">
                <button class="qd-chip" type="button" data-d="3">3</button>
                <button class="qd-chip" type="button" data-d="7">7</button>
                <button class="qd-chip" type="button" data-d="10">10</button>
                <button class="qd-chip" type="button" data-d="14">14</button>
                <button class="qd-chip" type="button" data-d="21">21</button>
                <button class="qd-chip" type="button" data-d="30">30</button>
              </div>
            </div>
          </div>

          <div class="field">
            <label class="field-label">
              Уровень комфорта
              <button class="lvl-info" id="levelInfoBtn" type="button" aria-label="Подробнее об уровнях" aria-expanded="false">i</button>
            </label>
            <div class="seg seg--wide" id="levelGroup" role="group">
              <button class="seg-btn active" data-lvl="0" aria-pressed="true">Эконом</button>
              <button class="seg-btn" data-lvl="1" aria-pressed="false">Комфорт</button>
              <button class="seg-btn" data-lvl="2" aria-pressed="false">Люкс</button>
            </div>
            <div class="lvl-tip" id="levelInfoTip" hidden>
              <strong>Эконом:</strong> хостел / 3*, локальная еда, метро.<br>
              <strong>Комфорт:</strong> 4* отель, рестораны, такси.<br>
              <strong>Люкс:</strong> 5*+, премиум-кухня, частный транспорт.
            </div>
          </div>

          <div class="field">
            <label class="field-label">Месяц поездки</label>
            <div class="months" id="monthChips" role="group" aria-label="Выбор месяца">
              {MONTH_NAMES.map((m, i) => (
                <button class="month" type="button" data-m={i + 1} aria-label={`${m}`}>
                  <span class="m-num">{String(i+1).padStart(2,'0')}</span>
                  <span class="m-name">{m}</span>
                  <span class="m-dot" aria-hidden="true"></span>
                </button>
              ))}
            </div>
            <div class="month-legend" aria-hidden="true">
              <span class="lg-item"><i class="lg-dot lg-peak"></i> Пик</span>
              <span class="lg-item"><i class="lg-dot lg-good"></i> Хорошо</span>
              <span class="lg-item"><i class="lg-dot lg-ok"></i> Норма</span>
              <span class="lg-item"><i class="lg-dot lg-bad"></i> Не сезон</span>
            </div>
          </div>

          <div class="field">
            <label class="field-label">Валюта</label>
            <div class="seg" id="currGroup" role="group">
              <button class="seg-btn active" data-cur="rub" aria-pressed="true">₽ рубли</button>
              <button class="seg-btn" data-cur="usd" aria-pressed="false">$ доллары</button>
            </div>
          </div>
        </div>

        <!-- RIGHT: compute column (sticky on desktop) -->
        <aside class="compute-col" id="computeCol">
          <div class="compute-marker"><span>02</span> Итог</div>
          <div id="calcResult" class="compute-result"></div>
          <p class="rate-line"><span id="calcRateLabel">1 $ = 90 ₽ · загрузка курса…</span></p>
        </aside>
      </div>
    </section>

    <!-- ─────────── BUDGET BLOCK (real traveler data) ──────────── -->
    <section class="real-section">
      <div class="real-marker"><span>03</span> Что говорит интернет</div>
      <div id="budgetBlocksHost" class="bb-host">
        {Object.keys(realBudgets).filter(k => k !== '_meta').map((slug) => (
          <div class="bb-wrap" data-slug={slug} hidden>
            <BudgetBlock slug={slug} />
          </div>
        ))}
      </div>
    </section>

    <!-- ─────────── EDITORIAL TIPS ─────────────────────────────── -->
    <section class="tips-section">
      <div class="tips-marker"><span>04</span> Дельные советы</div>
      <div class="tips-grid">
        <article class="tip">
          <div class="tip-num">i</div>
          <h3 class="tip-title">Бронируй за 60+ дней</h3>
          <p class="tip-body">Авиа дешевле на 15-20% если присматриваться заранее. Отели — без разницы, в последнюю минуту даже выгоднее.</p>
        </article>
        <article class="tip">
          <div class="tip-num">ii</div>
          <h3 class="tip-title">Страховка не опция</h3>
          <p class="tip-body">Для безвизовых тоже. Стоит 2 000 ₽, спасает от $20 000+ медрасходов в Европе или США. Cherehapa принимает рубли.</p>
        </article>
        <article class="tip">
          <div class="tip-num">iii</div>
          <h3 class="tip-title">eSIM вместо роуминга</h3>
          <p class="tip-body">МТС/Билайн в Европе — 5 000 ₽ за неделю. eSIM Airalo — 1 500 ₽ за 10 ГБ. Активируется до вылета QR-кодом.</p>
        </article>
        <article class="tip">
          <div class="tip-num">iv</div>
          <h3 class="tip-title">Семья экономит на отеле</h3>
          <p class="tip-body">Один номер на 2-4 человека вместо двух. Калькулятор учитывает это автоматически: перелёт × N, отель × 1.</p>
        </article>
        <article class="tip">
          <div class="tip-num">v</div>
          <h3 class="tip-title">Сезонность важнее уровня</h3>
          <p class="tip-body">Поездка в не сезон в 5* дешевле, чем в пик в 3*. Покрути месяцы перед уровнем — сэкономишь больше.</p>
        </article>
        <article class="tip">
          <div class="tip-num">vi</div>
          <h3 class="tip-title">Виза — не приговор</h3>
          <p class="tip-body">Шенген из РФ стоит €90 + €30 BLS = ~12 000 ₽. На фоне поездки в 150-200 тыс. это 6-8%. Не повод отказываться.</p>
        </article>
      </div>
    </section>

    <!-- ─────────── FAQ ───────────────────────────────────────── -->
    <section class="faq-section">
      <div class="faq-marker"><span>05</span> Частые вопросы</div>
      <div class="faq-list">
        <details class="faq-item" open>
          <summary>Откуда берутся цены?</summary>
          <p>Базовые цены 70 направлений собраны вручную: перелёт из Москвы туда-обратно по средней цене Aviasales за последний квартал, отель — по медиане Ostrovok / Booking по уровням 3*/4*/5*, еда — по типовому дню (завтрак-обед-ужин) для каждого уровня. Сезонный коэффициент применяется к перелёту: пик +30%, хорошо ±0%, нормально −15%, не сезон −30%.</p>
        </details>
        <details class="faq-item">
          <summary>Реальные траты из интернета — откуда?</summary>
          <p>Кросс-источниковая агрегация по 12 ресурсам: Самокатус (русский Travel Budget раздел), make-trip.ru, howtrip.ru, wrenjapan.com — российские. BudgetYourTrip (3000+ городов от 50 000 контрибьюторов), IndieTraveller, SoutheastAsiaBackpacker, NeverEndingFootsteps, Holafly, Maldives Magazine, Norway Budget Guide, Reddit r/solotravel — англоязычные с переводом.</p>
        </details>
        <details class="faq-item">
          <summary>Как считается несколько путешественников?</summary>
          <p>Перелёт умножается на число людей. Питание тоже. Отель — нет: один номер вмещает 2–4 человек. Это даёт реалистичную сумму: семья из 2 платит примерно в 1.6× больше одного, а не в 2×.</p>
        </details>
        <details class="faq-item">
          <summary>А виза включена в итог?</summary>
          <p>Да, если виза платная. В разбивке появляется строка с конкретной стоимостью и сроком — «€90 + €30 BLS, 10–15 дней». Если безвиз — стоит ✓ и виза не добавляется. По клику — переход на детальную страницу /visa/&lt;страна&gt;/.</p>
        </details>
        <details class="faq-item">
          <summary>Что такое «лучший месяц»?</summary>
          <p>Калькулятор смотрит 12-месячный рейтинг страны и подсвечивает месяц с минимальным коэффициентом цены и нормальной погодой. Например: «В ноябре та же поездка обойдётся на 28% дешевле — лучший месяц года для Турции».</p>
        </details>
        <details class="faq-item">
          <summary>Курс рубля меняется — учитывает?</summary>
          <p>Да. Курс подтягивается через open exchange rates в реальном времени. Переключение ₽/$ одной кнопкой — внутренний расчёт в долларах, отображение по выбору.</p>
        </details>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script define:vars={{ PRICES, MONTH_NAMES, MONTH_FULL, iataToSeasons, iataToVisa, iataToSlug, iataToBudgetSlug }}>
// ─── STATE ───────────────────────────────────────────────────────────
let RUB = 90;
let calcLevel = 0;
let calcCurrency = 'rub';
let travelers = 1;
let selectedMonth = 0;
let compareList = [];

const SEASON_MULT = { P: 1.30, G: 1.00, O: 0.85, B: 0.70 };
const SEASON_LABEL = { P: 'Пик', G: 'Хорошо', O: 'Норма', B: 'Не сезон' };
const SEASON_CLASS = { P: 'peak', G: 'good', O: 'ok', B: 'bad' };

const AVIASALES_MARKER = '546042.Zz66f13c16ff6b488883a4127-546042';
const AVIASALES_BASE = `https://www.aviasales.ru/?marker=${AVIASALES_MARKER}&market=ru`;
const CHEREHAPA = 'https://cherehapa.tpk.mx/GmVWjhCN';
const OSTROVOK = 'https://ostrovok.tpk.mx/w4cAS1wZ';
const AIRALO = 'https://ref.airalo.com/k7Wf';

const calcSel = document.getElementById('calcRegion');
const resultEl = document.getElementById('calcResult');
const addSelect = document.getElementById('addCountrySelect');

// ─── URL params ─────────────────────────────────────────────────────
function readUrlParams() {
  const u = new URL(window.location.href);
  const r = u.searchParams.get('r');
  const d = u.searchParams.get('d');
  const l = u.searchParams.get('l');
  const c = u.searchParams.get('c');
  const t = u.searchParams.get('t');
  const m = u.searchParams.get('m');
  const cmp = u.searchParams.get('cmp');

  if (r !== null && PRICES[+r]) calcSel.value = r;
  if (d !== null) {
    const n = Math.min(90, Math.max(1, parseInt(d) || 7));
    document.getElementById('calcDays').value = n;
    document.getElementById('calcDaysDisplay').textContent = n;
  }
  if (l !== null && (+l >= 0 && +l <= 2)) {
    calcLevel = +l;
    document.querySelectorAll('#levelGroup .seg-btn').forEach(b => {
      const on = +b.dataset.lvl === calcLevel;
      b.classList.toggle('active', on);
      b.setAttribute('aria-pressed', on ? 'true' : 'false');
    });
  }
  if (c === 'usd' || c === 'rub') {
    calcCurrency = c;
    document.querySelectorAll('#currGroup .seg-btn').forEach(b => {
      const on = b.dataset.cur === calcCurrency;
      b.classList.toggle('active', on);
      b.setAttribute('aria-pressed', on ? 'true' : 'false');
    });
  }
  if (t !== null && +t >= 1 && +t <= 4) {
    travelers = +t;
    document.querySelectorAll('#travelersGroup .seg-btn').forEach(b => {
      const on = +b.dataset.tr === travelers;
      b.classList.toggle('active', on);
      b.setAttribute('aria-pressed', on ? 'true' : 'false');
    });
  }
  if (m !== null && +m >= 0 && +m <= 12) selectedMonth = +m;
  if (cmp) compareList = cmp.split(',').map(x => parseInt(x)).filter(x => !isNaN(x) && PRICES[x]).slice(0, 3);
}

function writeUrlParams() {
  const u = new URL(window.location.href);
  u.searchParams.set('r', calcSel.value);
  u.searchParams.set('d', document.getElementById('calcDays').value);
  u.searchParams.set('l', String(calcLevel));
  u.searchParams.set('c', calcCurrency);
  u.searchParams.set('t', String(travelers));
  if (selectedMonth > 0) u.searchParams.set('m', String(selectedMonth));
  else u.searchParams.delete('m');
  if (compareList.length > 0) u.searchParams.set('cmp', compareList.join(','));
  else u.searchParams.delete('cmp');
  window.history.replaceState(null, '', u.toString());
}

// ─── Rate ──────────────────────────────────────────────────────────
async function fetchRate() {
  const rateEl = document.getElementById('calcRateLabel');
  try {
    const r = await fetch('https://open.er-api.com/v6/latest/USD');
    const d = await r.json();
    if (d.result === 'success' && d.rates && d.rates.RUB) {
      RUB = d.rates.RUB;
      if (rateEl) rateEl.textContent = '1 $ = ' + RUB.toFixed(2) + ' ₽ · open exchange rates';
      renderCalc();
      return;
    }
  } catch (e) {}
  if (rateEl) rateEl.textContent = '1 $ ≈ 90 ₽ · курс не загружен';
}

function fmt(usd) {
  if (!usd || isNaN(usd)) return '—';
  return calcCurrency === 'rub'
    ? Math.round(usd * RUB).toLocaleString('ru-RU') + ' ₽'
    : Math.round(usd).toLocaleString('en-US') + ' $';
}

function aviasalesUrl(iata, monthNum) {
  if (!iata) return AVIASALES_BASE;
  let url = `${AVIASALES_BASE}&origin_iata=MOW&destination_iata=${iata}`;
  if (monthNum && monthNum >= 1 && monthNum <= 12) {
    const year = new Date().getFullYear();
    const now = new Date();
    let y = year;
    if ((monthNum - 1) < now.getMonth()) y += 1;
    url += `&depart_date=${y}-${String(monthNum).padStart(2,'0')}-15`;
  }
  return url;
}

// ─── Compute ─────────────────────────────────────────────────────
function computeForPriceIndex(pi) {
  const p = PRICES[pi];
  const days = Math.max(1, parseInt(document.getElementById('calcDays').value) || 1);
  const baseFlight = p.flight[calcLevel];
  const hotel = p.hotel[calcLevel];
  const food = p.food[calcLevel];

  let seasonMult = 1, seasonLabel = '', seasonClass = '';
  if (selectedMonth > 0 && iataToSeasons[p.iata]) {
    const rating = iataToSeasons[p.iata][selectedMonth - 1];
    seasonMult = SEASON_MULT[rating] || 1;
    seasonLabel = SEASON_LABEL[rating] || '';
    seasonClass = SEASON_CLASS[rating] || '';
  }
  const flightAdjusted = baseFlight * seasonMult;
  const flightTotal = flightAdjusted * travelers;
  const hotelTotal = hotel * days;
  const foodTotal = food * days * travelers;
  const visa = iataToVisa[p.iata];
  let visaUsd = 0;
  if (visa && visa.cost) {
    const m1 = visa.cost.match(/\$(\d+)/);
    if (m1) visaUsd = parseInt(m1[1]);
    else {
      const e = visa.cost.match(/€\s?(\d+)/);
      if (e) visaUsd = Math.round(parseInt(e[1]) * 1.08);
    }
  }
  const visaTotal = visaUsd * travelers;
  const grand = flightTotal + hotelTotal + foodTotal + visaTotal;
  return { p, days, travelers, flightTotal, hotelTotal, foodTotal, visa, visaTotal, seasonMult, seasonLabel, seasonClass, grand };
}

function findBestMonth(iata) {
  if (!iataToSeasons[iata]) return null;
  const ratings = iataToSeasons[iata];
  let bestIdx = -1, bestMult = 999;
  ratings.forEach((r, i) => {
    const mu = SEASON_MULT[r] || 1;
    if (mu < bestMult && r !== 'B') { bestMult = mu; bestIdx = i; }
  });
  if (bestIdx === -1) ratings.forEach((r, i) => { if (r === 'O' && bestIdx === -1) bestIdx = i; });
  if (bestIdx === -1) bestIdx = 0;
  return { monthNum: bestIdx + 1, monthName: MONTH_FULL[bestIdx], mult: SEASON_MULT[ratings[bestIdx]] || 1 };
}

function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

// ─── Render compute card (editorial style) ──────────────────────
function renderCard(pi, isPrimary, index) {
  const r = computeForPriceIndex(pi);
  const aviUrl = aviasalesUrl(r.p.iata, selectedMonth > 0 ? selectedMonth : null);
  const perPerson = r.grand / Math.max(1, r.travelers);
  const cityShort = r.p.name.split('(')[0].trim();

  const best = findBestMonth(r.p.iata);
  let nudge = '';
  if (best && selectedMonth > 0 && best.monthNum !== selectedMonth) {
    const saving = Math.round((1 - best.mult / r.seasonMult) * 100);
    if (saving > 5) nudge = `<div class="cc-nudge"><span class="cc-nudge-mark">↘</span> В <strong>${best.monthName}</strong> на <strong>${saving}%</strong> дешевле</div>`;
  } else if (best && selectedMonth === 0) {
    nudge = `<div class="cc-nudge"><span class="cc-nudge-mark">↘</span> Самый дешёвый месяц — <strong>${best.monthName}</strong></div>`;
  }

  const visaChip = r.visa ? (r.visa.cost === 'бесплатно' ? '✓ безвиз' : escapeHtml(r.visa.cost)) : '';

  return `
    <article class="cc${isPrimary ? ' cc-primary' : ''}" data-pi="${pi}" style="--cc-i:${index}">
      ${!isPrimary ? `<button class="cc-remove" data-remove="${pi}" type="button" aria-label="Убрать из сравнения">×</button>` : ''}

      <header class="cc-head">
        <div class="cc-tag">${escapeHtml(cityShort)}</div>
        ${r.seasonLabel ? `<div class="cc-season cc-season--${r.seasonClass}">${MONTH_NAMES[selectedMonth - 1]} · ${r.seasonLabel}</div>` : ''}
      </header>

      <div class="cc-hero">
        <div class="cc-label">ИТОГО</div>
        <div class="cc-amount">${r.grand > 0 ? fmt(r.grand) : '—'}</div>
        ${r.travelers > 1 ? `<div class="cc-per">≈ ${fmt(perPerson)} <span>на человека</span></div>` : ''}
      </div>

      ${nudge}

      <div class="cc-rows">
        <div class="cc-row">
          <span class="cc-row-key">Перелёт${r.travelers > 1 ? ' × ' + r.travelers : ''}</span>
          <span class="cc-dots" aria-hidden="true"></span>
          <span class="cc-row-val">${fmt(r.flightTotal)}</span>
        </div>
        <div class="cc-row">
          <span class="cc-row-key">Отель · ${r.days} ноч.</span>
          <span class="cc-dots" aria-hidden="true"></span>
          <span class="cc-row-val">${fmt(r.hotelTotal)}</span>
        </div>
        <div class="cc-row">
          <span class="cc-row-key">Питание${r.travelers > 1 ? ' × ' + r.travelers : ''}</span>
          <span class="cc-dots" aria-hidden="true"></span>
          <span class="cc-row-val">${fmt(r.foodTotal)}</span>
        </div>
        ${visaChip ? `<div class="cc-row cc-row--visa">
          <span class="cc-row-key">Виза</span>
          <span class="cc-dots" aria-hidden="true"></span>
          <span class="cc-row-val">${r.visaTotal > 0 ? fmt(r.visaTotal) + ' · ' : ''}${visaChip}</span>
          ${r.visa ? `<a class="cc-visa-link" href="/visa/${r.visa.slug}/" aria-label="Детали визы">детали →</a>` : ''}
        </div>` : ''}
      </div>

      <div class="cc-cta">
        <a href="${aviUrl}" target="_blank" rel="noopener sponsored" class="cta-main">
          <span>Найти билет</span>
          <span class="cta-arrow" aria-hidden="true">→</span>
        </a>
        <div class="cta-row">
          <a href="${OSTROVOK}" target="_blank" rel="noopener sponsored" class="cta-side">Отель</a>
          <a href="${CHEREHAPA}" target="_blank" rel="noopener sponsored" class="cta-side">Страховка</a>
          <a href="${AIRALO}" target="_blank" rel="noopener sponsored" class="cta-side">eSIM</a>
        </div>
      </div>
    </article>
  `;
}

function renderCalc() {
  const primary = parseInt(calcSel.value);
  const all = [primary, ...compareList.filter(x => x !== primary)].slice(0, 3);
  const isCompare = all.length > 1;

  let html = `<div class="cc-stack${isCompare ? ' cc-stack--compare' : ''}">`;
  html += all.map((pi, idx) => renderCard(pi, idx === 0, idx)).join('');
  html += `</div>`;

  html += `<div class="cc-footer">
    <button class="copy-btn" id="copyTgBtn" type="button" aria-label="Копировать сводку">
      <span class="copy-icon" aria-hidden="true">⌘</span>
      <span>Скопировать сводку для Telegram</span>
    </button>
  </div>`;

  resultEl.innerHTML = html;

  // Подсветить активный day chip
  const cur = +document.getElementById('calcDays').value;
  document.querySelectorAll('.quick-days .qd-chip').forEach(c => {
    c.classList.toggle('active', +c.dataset.d === cur);
  });

  // Селект для сравнения
  if (compareList.length < 2 && all.length < 3) {
    addSelect.hidden = false;
    addSelect.value = '';
    Array.from(addSelect.options).forEach(opt => {
      const v = parseInt(opt.value);
      if (isNaN(v)) { opt.disabled = false; return; }
      opt.disabled = (v === primary || compareList.includes(v));
    });
  } else {
    addSelect.hidden = true;
  }

  writeUrlParams();
  renderMonthChips();
  showBudgetBlock();
}

function showBudgetBlock() {
  const primary = parseInt(calcSel.value);
  const iata = PRICES[primary]?.iata;
  const slug = iataToBudgetSlug[iata];
  document.querySelectorAll('.bb-wrap').forEach(el => {
    el.hidden = el.dataset.slug !== slug;
  });
}

function renderMonthChips() {
  const primary = parseInt(calcSel.value);
  const iata = PRICES[primary]?.iata;
  const rating = iata && iataToSeasons[iata] ? iataToSeasons[iata] : null;
  document.querySelectorAll('#monthChips .month').forEach((btn, i) => {
    const m = i + 1;
    btn.classList.toggle('active', selectedMonth === m);
    btn.setAttribute('aria-pressed', selectedMonth === m ? 'true' : 'false');
    const dot = btn.querySelector('.m-dot');
    if (rating && dot) {
      const r = rating[i];
      dot.dataset.r = r;
      btn.setAttribute('aria-label', `${MONTH_NAMES[i]} · ${SEASON_LABEL[r] || ''}`);
    }
  });
}

// ─── EVENT LISTENERS ────────────────────────────────────────────────
calcSel.addEventListener('change', renderCalc);

document.getElementById('travelersGroup').addEventListener('click', e => {
  const btn = e.target.closest('[data-tr]');
  if (!btn) return;
  travelers = +btn.dataset.tr;
  document.querySelectorAll('#travelersGroup .seg-btn').forEach(b => {
    b.classList.toggle('active', b === btn);
    b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
  });
  renderCalc();
});

function setDays(n) {
  n = Math.min(90, Math.max(1, n));
  document.getElementById('calcDays').value = n;
  document.getElementById('calcDaysDisplay').textContent = n;
  renderCalc();
}
document.getElementById('daysDown').addEventListener('click', () => setDays(parseInt(document.getElementById('calcDays').value) - 1));
document.getElementById('daysUp').addEventListener('click', () => setDays(parseInt(document.getElementById('calcDays').value) + 1));
document.querySelectorAll('.quick-days .qd-chip').forEach(chip => {
  chip.addEventListener('click', () => setDays(+chip.dataset.d));
});

document.getElementById('levelGroup').addEventListener('click', e => {
  const btn = e.target.closest('[data-lvl]');
  if (!btn) return;
  calcLevel = +btn.dataset.lvl;
  document.querySelectorAll('#levelGroup .seg-btn').forEach(b => {
    b.classList.toggle('active', b === btn);
    b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
  });
  renderCalc();
});

document.getElementById('currGroup').addEventListener('click', e => {
  const btn = e.target.closest('[data-cur]');
  if (!btn) return;
  calcCurrency = btn.dataset.cur;
  document.querySelectorAll('#currGroup .seg-btn').forEach(b => {
    b.classList.toggle('active', b === btn);
    b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
  });
  renderCalc();
});

document.getElementById('monthChips').addEventListener('click', e => {
  const btn = e.target.closest('[data-m]');
  if (!btn) return;
  const m = +btn.dataset.m;
  selectedMonth = selectedMonth === m ? 0 : m;
  renderCalc();
});

addSelect.addEventListener('change', e => {
  const v = parseInt(e.target.value);
  if (isNaN(v)) return;
  const primary = parseInt(calcSel.value);
  if (v === primary || compareList.includes(v)) return;
  if (compareList.length >= 2) return;
  compareList.push(v);
  renderCalc();
});

resultEl.addEventListener('click', e => {
  const rm = e.target.closest('[data-remove]');
  if (rm) {
    const pi = +rm.dataset.remove;
    compareList = compareList.filter(x => x !== pi);
    renderCalc();
    return;
  }
});

resultEl.addEventListener('click', async e => {
  const btn = e.target.closest('#copyTgBtn');
  if (!btn) return;
  const primary = parseInt(calcSel.value);
  const all = [primary, ...compareList.filter(x => x !== primary)].slice(0, 3);
  const days = +document.getElementById('calcDays').value;
  const lvlNames = ['Эконом', 'Комфорт', 'Люкс'];
  const monthLine = selectedMonth > 0 ? `, в ${MONTH_FULL[selectedMonth - 1]}` : '';
  let text = `✈ Бюджет поездки${monthLine}\n${days} дн · ${travelers} чел · ${lvlNames[calcLevel]}\n─────\n`;
  all.forEach(pi => {
    const r = computeForPriceIndex(pi);
    text += `${r.p.name}\n  ИТОГО: ${fmt(r.grand)}\n  ✈ Перелёт: ${fmt(r.flightTotal)}\n  🏨 Отель × ${days}: ${fmt(r.hotelTotal)}\n  🍴 Еда × ${days}: ${fmt(r.foodTotal)}\n`;
    if (r.visa && r.visaTotal > 0) text += `  🛂 Виза: ${fmt(r.visaTotal)} (${r.visa.cost})\n`;
    text += `\n`;
  });
  text += `📎 ${window.location.href}\n🌍 traveltribe.ru/calculator/`;
  try {
    await navigator.clipboard.writeText(text);
    const span = btn.querySelector('span:not(.copy-icon)');
    const orig = span.textContent;
    span.textContent = '✓ Скопировано';
    setTimeout(() => { span.textContent = orig; }, 1800);
  } catch (err) {
    alert('Не удалось скопировать');
  }
});

const lvlInfoBtn = document.getElementById('levelInfoBtn');
const lvlInfoTip = document.getElementById('levelInfoTip');
if (lvlInfoBtn) {
  lvlInfoBtn.addEventListener('click', () => {
    const open = !lvlInfoTip.hasAttribute('hidden');
    if (open) lvlInfoTip.setAttribute('hidden', '');
    else lvlInfoTip.removeAttribute('hidden');
    lvlInfoBtn.setAttribute('aria-expanded', String(!open));
  });
}

// ─── INIT ───────────────────────────────────────────────────────────
readUrlParams();
fetchRate();
renderCalc();
</script>

