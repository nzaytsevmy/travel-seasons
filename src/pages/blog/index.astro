---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Footer from '../../components/Footer.astro';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = allPosts[0];
const rest = allPosts.slice(1);

function readingTime(body: string) {
  return Math.max(1, Math.ceil(body.trim().split(/\s+/).length / 200));
}

const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))];

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Blog",
      "@id": "https://traveltribe.ru/blog/#blog",
      "url": "https://traveltribe.ru/blog/",
      "name": "Блог TravelTribe",
      "description": "Личный опыт поездок: Япония, Африка, Бали, Новая Зеландия. Цены, маршруты, лайфхаки.",
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "blogPost": allPosts.map(p => ({
        "@type": "BlogPosting",
        "headline": p.data.title,
        "url": `https://traveltribe.ru/blog/${p.slug}/`,
        "datePublished": p.data.pubDate.toISOString(),
        "author": { "@type": "Person", "name": p.data.author }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Блог", "item": "https://traveltribe.ru/blog/" }
      ]
    }
  ]
};
---
<Layout
  title="Блог TravelTribe — опыт и маршруты"
  description="Личный опыт поездок: Япония, Африка, Бали, Новая Зеландия. Цены, маршруты, лайфхаки для путешественников из России."
  canonical="https://traveltribe.ru/blog/"
  ldJson={ldJson}
>
  <script is:inline>document.body.classList.add('blog-index')</script>
  <Nav active="blog" />
  <Breadcrumbs crumbs={[{ label: 'Блог' }]} />

  <main id="main" class="blog-wrap">
    <header class="blog-header">
      <div class="hero-tag">// Личный опыт</div>
      <h1>Блог <em>путешественника</em></h1>
      <p class="blog-lead">Реальные поездки, живые цены, без воды. {allPosts.length} {allPosts.length === 1 ? 'статья' : allPosts.length < 5 ? 'статьи' : 'статей'}.</p>
    </header>

    {allTags.length > 0 && (
      <div class="tag-filter" role="navigation" aria-label="Фильтр по тегам">
        {allTags.map(tag => (
          <a href={`/blog/tag/${tag}/`} class="tag-pill">{tag}</a>
        ))}
      </div>
    )}

    {featured && (
      <section class="featured-section">
        <div class="section-label">// Свежее</div>
        <a href={`/blog/${featured.slug}/`} class="featured-card">
          <div class="featured-img">
            <Image
              src={featured.data.coverImage}
              alt={featured.data.title}
              widths={[400, 600, 860]}
              sizes="(max-width: 680px) 100vw, 480px"
              format="webp"
              quality={82}
              loading="eager"
              fetchpriority="high"
            />
            <div class="featured-overlay"></div>
          </div>
          <div class="featured-body">
            <div class="post-tags">
              {featured.data.tags.map(t => (
                <span class="ptag">{t}</span>
              ))}
            </div>
            <h2 class="featured-title">{featured.data.title}</h2>
            <p class="featured-desc">{featured.data.description}</p>
            <div class="post-meta">
              <span>{featured.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
              <span class="meta-sep">·</span>
              <span>{readingTime(featured.body)} мин</span>
            </div>
            <span class="featured-cta">Читать →</span>
          </div>
        </a>
      </section>
    )}

    {rest.length > 0 && (
      <section class="more-section">
        <div class="section-label">// Ещё статьи</div>
        <div class="posts-grid" data-count={rest.length + (rest.length % 2 === 0 ? 0 : 1)}>
          {rest.map(post => (
            <a href={`/blog/${post.slug}/`} class="post-card">
              <div class="post-thumb">
                <Image
                  src={post.data.coverImage}
                  alt={post.data.title}
                  widths={[300, 600]}
                  sizes="(max-width: 680px) 100vw, 480px"
                  format="webp"
                  quality={80}
                  loading="lazy"
                />
              </div>
              <div class="post-body">
                <div class="post-tags">
                  {post.data.tags.map(t => <span class="ptag">{t}</span>)}
                </div>
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-desc">{post.data.description}</p>
                <div class="post-meta">
                  <span>{post.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                  <span class="meta-sep">·</span>
                  <span>{readingTime(post.body)} мин</span>
                </div>
              </div>
            </a>
          ))}
          {rest.length % 2 !== 0 && (
            <a href="https://t.me/traveltriberu" target="_blank" rel="noopener" class="post-card promo-card">
              <div class="promo-inner">
                <div class="promo-icon" aria-hidden="true">📲</div>
                <h3 class="promo-title">Подпишись на @traveltriberu</h3>
                <p class="promo-desc">Личные истории из поездок, оперативные обновления по визам и спонтанные разборы стран. Без воды.</p>
                <span class="promo-cta">Открыть в Telegram →</span>
              </div>
            </a>
          )}
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<style>
/* ── Layout ── */
.blog-wrap { max-width: 960px; margin: 0 auto; padding: 2.5rem 2rem 6rem; }

/* ── Header ── */
.blog-header { margin-bottom: 2rem; }
.hero-tag {
  display: inline-flex; font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--gold); border: 1px solid rgba(201,151,58,0.3);
  background: rgba(201,151,58,0.08); padding: 0.28rem 0.8rem; border-radius: 20px; margin-bottom: 1rem;
}
.blog-header h1 {
  font-family: var(--ff-display); font-size: clamp(2.2rem,5vw,3.6rem);
  font-weight: 300; line-height: 1.1; margin-bottom: 0.4rem;
}
.blog-header h1 em { color: var(--gold); font-style: italic; }
.blog-lead { color: var(--text-dim); font-size: 0.9rem; }

/* ── Tag filter ── */
.tag-filter {
  display: flex; flex-wrap: wrap; gap: 0.5rem;
  margin-bottom: 2.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--line);
}
.tag-pill {
  font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--text-dim); border: 1px solid var(--line);
  padding: 0.3rem 0.75rem; border-radius: 20px;
  transition: color 0.2s, border-color 0.2s, background 0.2s;
}
.tag-pill:hover { color: var(--gold); border-color: rgba(201,151,58,0.5); background: rgba(201,151,58,0.07); }

/* ── Section labels ── */
.section-label {
  font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--gold-dim); margin-bottom: 1rem;
}

/* ── Featured card ── */
.featured-section { margin-bottom: 3rem; }
.featured-card {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  border: 1px solid var(--line);
  border-radius: 4px;
  overflow: hidden;
  transition: border-color 0.25s;
  max-height: 440px;
}
.featured-card:hover { border-color: rgba(201,151,58,0.4); }

.featured-img { position: relative; overflow: hidden; }
.featured-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s ease; }
.featured-card:hover .featured-img img { transform: scale(1.03); }
.featured-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to right, transparent 70%, var(--bg) 100%);
  pointer-events: none;
}

.featured-body {
  padding: 1.75rem 1.6rem;
  display: flex; flex-direction: column; gap: 0.6rem;
  background: var(--bg2);
  overflow: hidden;
}
.featured-title {
  font-family: var(--ff-display);
  font-size: clamp(1.3rem, 2.2vw, 1.7rem);
  font-weight: 400; line-height: 1.2;
}
.featured-desc {
  color: var(--text-dim); font-size: 0.85rem; line-height: 1.55; flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.featured-cta {
  display: inline-block; margin-top: 0.5rem;
  font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--gold); transition: letter-spacing 0.2s;
}
.featured-card:hover .featured-cta { letter-spacing: 0.16em; }

/* ── More posts grid ── */
.more-section { }
.posts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
  gap: 1.25rem;
}

.post-card {
  display: flex; flex-direction: column;
  background: var(--bg);
  border: 1px solid var(--line);
  border-radius: 4px;
  overflow: hidden;
  transition: background 0.2s, border-color 0.2s;
}
.post-card:hover { background: var(--bg2); border-color: rgba(201,151,58,0.4); }

.post-thumb { overflow: hidden; aspect-ratio: 16/9; }
.post-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
.post-card:hover .post-thumb img { transform: scale(1.04); }

.post-body { padding: 1.25rem; display: flex; flex-direction: column; gap: 0.45rem; flex: 1; }

/* ── Shared ── */
.post-tags { display: flex; gap: 0.3rem; flex-wrap: wrap; }
.ptag {
  font-size: 0.58rem; letter-spacing: 0.06em; text-transform: uppercase;
  color: var(--gold); border: 1px solid rgba(201,151,58,0.3);
  padding: 0.12rem 0.4rem; border-radius: 2px;
}
.post-title { font-family: var(--ff-display); font-size: 1.15rem; font-weight: 400; line-height: 1.25; }
.post-desc { color: var(--text-dim); font-size: 0.8rem; line-height: 1.6; flex: 1; }
.post-meta {
  display: flex; align-items: center; gap: 0.4rem;
  font-size: 0.63rem; color: var(--text-faint); letter-spacing: 0.03em; margin-top: auto; padding-top: 0.5rem;
}
.meta-sep { color: var(--gold-dim); }

/* ── Promo card (filler when post count is odd) ── */
.promo-card {
  background: linear-gradient(135deg, rgba(201,151,58,0.08) 0%, var(--bg2) 60%);
  display: flex; align-items: center; justify-content: center;
  padding: 2rem 1.5rem;
  position: relative; overflow: hidden;
  transition: background 0.25s, border-color 0.25s;
}
.promo-card::before {
  content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  opacity: 0.4;
}
.promo-card:hover { background: linear-gradient(135deg, rgba(201,151,58,0.14) 0%, var(--bg3) 60%); }
.promo-inner {
  text-align: center; max-width: 320px;
  display: flex; flex-direction: column; gap: 0.7rem; align-items: center;
}
.promo-icon { font-size: 2rem; line-height: 1; }
.promo-title {
  font-family: var(--ff-display); font-size: 1.3rem; font-weight: 400; line-height: 1.25;
  color: var(--text);
}
.promo-desc { color: var(--text-dim); font-size: 0.82rem; line-height: 1.6; }
.promo-cta {
  font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--gold); transition: letter-spacing 0.2s;
  margin-top: 0.4rem;
}
.promo-card:hover .promo-cta { letter-spacing: 0.16em; }

/* ── Mobile ── */
@media (max-width: 680px) {
  .featured-card { grid-template-columns: 1fr; max-height: none; }
  .featured-img { aspect-ratio: 16/10; }
  .featured-overlay { background: linear-gradient(to bottom, transparent 70%, var(--bg) 100%); }
  .featured-body { padding: 1.5rem; }
  .featured-desc { -webkit-line-clamp: unset; display: block; }
  .posts-grid { grid-template-columns: 1fr; }
  .promo-card { padding: 2.5rem 1.5rem; }
}
</style>
