---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<Layout
  title="Блог TravelTribe — опыт и маршруты"
  description="Личный опыт поездок: Япония, Африка, Бали, Новая Зеландия. Цены, маршруты, лайфхаки для путешественников из России."
  canonical="https://traveltribe.ru/blog"
>
  <Nav />
  <main class="blog-wrap">
    <header class="blog-header">
      <div class="hero-tag">// Личный опыт</div>
      <h1>Блог <em>путешественника</em></h1>
      <p class="blog-lead">Реальные поездки, живые цены, без воды.</p>
    </header>

    <div class="posts">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="post-card">
          <div class="post-thumb">
            <Image
              src={post.data.coverImage}
              alt={post.data.title}
              width={800}
              height={420}
              format="webp"
              quality={60}
              loading="lazy"
            />
          </div>
          <div class="post-body">
            <div class="post-tags">
              {post.data.tags.map(t => <span class="ptag">{t}</span>)}
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-desc">{post.data.description}</p>
            <div class="post-meta">
              {post.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</Layout>

<style>
.blog-wrap { max-width: 900px; margin: 0 auto; padding: 3rem 2rem 5rem; }
.blog-header { margin-bottom: 3rem; }
.hero-tag {
  display: inline-flex; font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--gold); border: 1px solid rgba(201,151,58,0.3);
  background: rgba(201,151,58,0.08); padding: 0.3rem 0.85rem; border-radius: 20px; margin-bottom: 1.2rem;
}
.blog-header h1 { font-family: var(--ff-display); font-size: clamp(2.5rem,5vw,4rem); font-weight: 300; line-height: 1.1; }
.blog-header h1 em { color: var(--gold); font-style: italic; }
.blog-lead { color: var(--text-dim); font-size: 0.95rem; margin-top: 0.5rem; }

.posts { display: flex; flex-direction: column; gap: 1px; background: var(--line); }

.post-card { display: grid; grid-template-columns: 280px 1fr; background: var(--bg); }
.post-card:hover { background: var(--bg3); }

.post-thumb { overflow: hidden; height: 180px; }
.post-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
.post-card:hover .post-thumb img { transform: scale(1.04); }

.post-body { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
.post-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }
.ptag { font-size: 0.6rem; letter-spacing: 0.05em; text-transform: uppercase; color: var(--gold); border: 1px solid rgba(201,151,58,0.3); padding: 0.15rem 0.45rem; border-radius: 2px; }
.post-title { font-family: var(--ff-display); font-size: 1.4rem; font-weight: 400; line-height: 1.2; }
.post-desc { color: var(--text-dim); font-size: 0.82rem; line-height: 1.6; flex: 1; }
.post-meta { font-size: 0.65rem; color: var(--text-faint); letter-spacing: 0.04em; margin-top: auto; }

@media (max-width: 640px) {
  .post-card { grid-template-columns: 1fr; }
  .post-thumb { height: 200px; }
}
</style>
