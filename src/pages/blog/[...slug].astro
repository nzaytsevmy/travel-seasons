---
import { getCollection, getEntry } from 'astro:content';
import { Image, Picture, getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Footer from '../../components/Footer.astro';
import TableOfContents from '../../components/post/TableOfContents.astro';
import authorPhoto from '../../assets/author/nikita.jpg';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const url = `https://traveltribe.ru/blog/${post.slug}/`;
const coverUrl = typeof post.data.coverImage === 'string' ? post.data.coverImage : `https://traveltribe.ru${post.data.coverImage.src}`;

// Preload mobile-sized hero cover для LCP <2.5s (тот же 640px webp,
// который Picture сам выберет на mobile-vh — попадание в кэш).
const heroPreload = typeof post.data.coverImage === 'string' ? null : await getImage({
  src: post.data.coverImage,
  width: 640,
  format: 'webp',
  quality: 65,
});
const ogImageUrl = `https://traveltribe.ru/og/${post.slug}.png`;
const wordCount = post.body.trim().split(/\s+/).length;

function stripMd(s: string): string {
  return s
    .replace(/!\[[^\]]*\]\([^)]+\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/\*\*([^*]+)\*\*/g, '$1')
    .replace(/\*([^*]+)\*/g, '$1')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/\s+/g, ' ')
    .trim();
}

function extractFAQs(body: string): Array<{ q: string; a: string }> {
  const sectionMatch = body.match(/\n##\s+[^\n]*FAQ[^\n]*\n([\s\S]*?)(?=\n##\s|\n---\s*\n)/);
  if (!sectionMatch) return [];
  const block = sectionMatch[1];

  const h3Count = (block.match(/^###\s+/gm) || []).length;
  const boldCount = (block.match(/^\*\*[^\n*]+\*\*\s*$/gm) || []).length;

  let mode: 'h3' | 'bold' | null = null;
  if (h3Count >= 2) mode = 'h3';
  else if (boldCount >= 2) mode = 'bold';
  else return [];

  const matchQ = (line: string): string | null => {
    if (mode === 'h3') {
      const m = line.match(/^###\s+(.+?)\s*$/);
      return m ? m[1].trim() : null;
    }
    const m = line.match(/^\*\*([^\n*]+?)\*\*\s*$/);
    return m ? m[1].trim() : null;
  };

  const groups: Array<{ q: string; a: string[] }> = [];
  let current: { q: string; a: string[] } | null = null;
  for (const line of block.split('\n')) {
    const q = matchQ(line);
    if (q) {
      if (current) groups.push(current);
      current = { q, a: [] };
    } else if (current) {
      current.a.push(line);
    }
  }
  if (current) groups.push(current);

  return groups
    .map(g => ({
      q: g.q.replace(/\?*$/, '?').replace(/\?+/, '?'),
      a: stripMd(g.a.join('\n').trim())
    }))
    .filter(g => g.q && g.a);
}

const faqs = extractFAQs(post.body);

const ldJson: any = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      "@id": `${url}#article`,
      "isPartOf": { "@id": "https://traveltribe.ru/blog/#blog" },
      "headline": post.data.title,
      "description": post.data.description,
      "image": coverUrl,
      "author": {
        "@type": "Person",
        "@id": "https://traveltribe.ru/about/#person",
        "name": post.data.author,
        "url": "https://traveltribe.ru/about/",
        "image": "https://traveltribe.ru/og-image.png",
        "jobTitle": "Travel writer",
        "knowsAbout": ["Путешествия", "Визы", "Travel-бюджет", "Сезоны", "Фотография"],
        "sameAs": ["https://t.me/traveltriberu", "https://www.linkedin.com/in/nzaytsev/", "https://github.com/nzaytsevmy"]
      },
      "datePublished": post.data.pubDate.toISOString(),
      "dateModified": (post.data.updatedDate ?? post.data.pubDate).toISOString(),
      "publisher": { "@id": "https://traveltribe.ru/#org" },
      "mainEntityOfPage": { "@type": "WebPage", "@id": url },
      "inLanguage": "ru-RU",
      "wordCount": wordCount,
      "articleSection": post.data.tags[0] ?? "Travel",
      "keywords": post.data.tags.join(', '),
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", ".prose blockquote:first-of-type", ".prose p:first-of-type"] },
      ...(post.data.tripPlace ? { "contentLocation": { "@type": "Place", "name": post.data.tripPlace } } : {}),
      ...(post.data.tripDate ? { "dateCreated": post.data.tripDate } : {})
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Блог", "item": "https://traveltribe.ru/blog/" },
        { "@type": "ListItem", "position": 3, "name": post.data.title, "item": url }
      ]
    }
  ]
};

if (faqs.length >= 2) {
  ldJson["@graph"].push({
    "@type": "FAQPage",
    "@id": `${url}#faq`,
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  });
}

if (post.data.howto) {
  const h = post.data.howto;
  ldJson["@graph"].push({
    "@type": "HowTo",
    "@id": `${url}#howto`,
    "name": h.name,
    ...(h.description ? { "description": h.description } : {}),
    ...(h.totalTime ? { "totalTime": h.totalTime } : {}),
    ...(h.estimatedCost ? { "estimatedCost": { "@type": "MonetaryAmount", "currency": h.estimatedCost.currency, "value": h.estimatedCost.value } } : {}),
    "step": h.steps.map((s, i) => ({
      "@type": "HowToStep",
      "position": i + 1,
      "name": s.name,
      "text": s.text,
    })),
  });
}
---
<Layout
  title={post.data.title}
  description={post.data.description}
  canonical={url}
  ogType="article"
  ogTitle={post.data.title}
  ogDescription={post.data.description}
  ogImage={ogImageUrl}
  ogImageAlt={post.data.title}
  ldJson={ldJson}
  preloadImage={heroPreload?.src}
>
  <script is:inline>document.body.classList.add('post-page')</script>
  <Breadcrumbs crumbs={[{ label: 'Блог', href: '/blog/' }, { label: post.data.title }]} />
  <main id="main" class="post-page">
    <div class="post-cover">
      <Picture
        src={post.data.coverImage}
        alt={post.data.title}
        widths={[640, 960, 1280]}
        sizes="100vw"
        formats={['webp']}
        fallbackFormat="jpg"
        quality={65}
        loading="eager"
        fetchpriority="high"
        pictureAttributes={{ style: `display:block;` }}
        style={`object-position: ${post.data.coverPosition};`}
      />
      <div class="cover-overlay"></div>
    </div>

    <article class="post-content">
      <div class="post-meta-top">
        <div class="post-tags">
          {post.data.tags.map(t => <a href={`/blog/tag/${t}/`} class="ptag">{t}</a>)}
        </div>
        <time class="post-date" datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        {post.data.updatedDate && post.data.updatedDate.valueOf() !== post.data.pubDate.valueOf() && (
          <time class="post-updated" datetime={post.data.updatedDate.toISOString()}>
            · обновлено {post.data.updatedDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
        )}
      </div>

      <h1>{post.data.title}</h1>
      <p class="post-author">
        <a href="/about/" class="author-link">
          <Image src={authorPhoto} alt="Никита Зайцев" width={28} height={28} format="webp" quality={75} class="author-mini" />
          <span>Никита Зайцев</span>
        </a>
        · <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a>
      </p>

      {post.data.tripDate && post.data.tripPlace && (
        <p class="trip-marker">
          <span class="trip-icon" aria-hidden="true">✓</span>
          Был лично — {post.data.tripPlace}, {post.data.tripDate}
        </p>
      )}

      {post.data.sourceType === 'compilation' && (
        <aside class="source-disclaimer" role="note">
          <strong>Как написан этот пост.</strong> Это обзор по официальным источникам — сайтам консульств, статистике, форумам туристов. Лично эту визу/маршрут я в 2026 не оформлял, но сверил факты на актуальность. Если вы только что прошли — поправьте через <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">Telegram-канал</a>, обновлю.
        </aside>
      )}

      <TableOfContents headings={headings} />

      <div class="prose">
        <Content />
      </div>

      <aside class="author-bio" aria-label="Об авторе">
        <Image src={authorPhoto} alt="Никита Зайцев — автор TravelTribe" width={96} height={96} format="webp" quality={80} class="bio-avatar-img" />
        <div class="bio-text">
          <strong>Никита Зайцев</strong> — был на всех 7 континентах, включая Антарктиду, посетил 60+ стран. В блоге — реальные цены 2026, личный опыт поездок и без воды. Рассказываю про путешествия в <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">Telegram-канале @traveltriberu</a>. <a href="/about/">Подробнее об авторе →</a>
        </div>
      </aside>

      <div class="post-footer">
        <a href="/blog/" class="back-link">← Все статьи</a>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
/* TJ-style: cover full-bleed, текст 720px по центру, широкие figures внутри текста */
.post-page { padding-bottom: 5rem; }

.post-cover {
  position: relative;
  width: 100%;
  height: clamp(360px, 56dvh, 620px);
  overflow: hidden;
  margin-bottom: 0;
}
.post-cover picture { width: 100%; height: 100%; display: block; }
.post-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
.cover-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 40%, var(--bg) 100%); }

.post-content {
  max-width: 720px;
  margin: 0 auto;
  padding: 2.4rem 1.4rem 0;
  overflow-wrap: break-word;
  /* Custom property для full-bleed элементов внутри (figure-wide,
     table-wide, pricing-cards). Безопасно в Safari/Chrome/Firefox 2026. */
  --bleed: max((100vw - 720px) / 2 - 1.4rem, 0px);
}

/* Inline figures внутри статьи: full-bleed при class="figure-wide".
   Используем CSS custom property --bleed (определена в .post-content) —
   надёжный pattern для Safari/Chrome/Firefox без transform-hacks. */
.prose :is(figure, img).figure-wide,
.prose :is(figure, img).full-bleed {
  margin-left: calc(-1 * min(var(--bleed), 240px));
  margin-right: calc(-1 * min(var(--bleed), 240px));
  width: auto;
  max-width: calc(100% + 2 * min(var(--bleed), 240px));
  margin-top: 2rem;
  margin-bottom: 2rem;
  border-radius: 8px;
  overflow: hidden;
}
.prose figure.figure-wide img,
.prose figure.full-bleed img { width: 100%; height: auto; display: block; border-radius: 0; }
.prose figure.figure-wide figcaption,
.prose figure.full-bleed figcaption {
  padding: 0.6rem 0.2rem 0;
  font-size: 0.85rem;
  color: var(--text-faint);
  text-align: center;
}

/* PricingCards: full-bleed через --bleed (без transform). Лимит 190px
   с каждой стороны = max 1100px на десктопе при 720px text. */
.prose :global(.pricing-cards) {
  margin-left: calc(-1 * min(var(--bleed), 190px));
  margin-right: calc(-1 * min(var(--bleed), 190px));
  margin-top: 2rem;
  margin-bottom: 2.5rem;
}

/* Wide-таблицы (4+ колонок) — в ширине текста (720px), как обычные.
   На десктопе колонки распределяются по auto-layout, на мобиле card-stack.
   Если в широкой таблице (6+ колонок) текст не помещается — горизонтальный
   скролл через .table-wrap overflow-x: auto. */
.prose :global(.table-wrap.table-wide) {
  width: 100%;
  font-size: 0.88rem;
  margin-top: 2rem;
  margin-bottom: 2rem;
}
@media (max-width: 720px) {
  /* Editorial stacked pattern (как FlightRoutes): первая колонка = серифный
     заголовок Newsreader, остальные колонки — compact rows с тонким uppercase
     label сверху, золотой bullet слева. Без рамок и backgrounds — никаких
     «карточек». */
  .prose :global(.table-wrap.table-wide table),
  .prose :global(.table-wrap.table-wide thead),
  .prose :global(.table-wrap.table-wide tbody),
  .prose :global(.table-wrap.table-wide tr),
  .prose :global(.table-wrap.table-wide th),
  .prose :global(.table-wrap.table-wide td) {
    display: block;
  }
  .prose :global(.table-wrap.table-wide thead) {
    position: absolute;
    top: -9999px;
    left: -9999px;
  }
  .prose :global(.table-wrap.table-wide tbody) {
    border-top: 1px solid var(--line);
  }
  .prose :global(.table-wrap.table-wide tr) {
    padding: 1.4rem 0 1.2rem;
    border-bottom: 1px solid var(--line);
    background: transparent;
  }
  .prose :global(.table-wrap.table-wide tr:last-child) {
    border-bottom: none;
  }
  /* Первая колонка — серифный заголовок Newsreader, как в FlightRoutes */
  .prose :global(.table-wrap.table-wide tbody td:first-child) {
    font-family: var(--ff-display, 'Newsreader Variable', 'Newsreader', Georgia, serif);
    font-size: 1.35rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 0.85rem;
    padding: 0;
  }
  .prose :global(.table-wrap.table-wide tbody td:first-child::before) {
    content: none;
  }
  /* Остальные колонки — золотой bullet, тихий uppercase label сверху, текст ниже */
  .prose :global(.table-wrap.table-wide tbody td:not(:first-child)) {
    padding: 0 0 0 0.9rem;
    margin-top: 0.55rem;
    border: none;
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.5;
    position: relative;
  }
  .prose :global(.table-wrap.table-wide tbody td:not(:first-child))::before {
    /* Bullet + label сверху */
    content: attr(data-label);
    display: block;
    font-size: 0.62rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    margin-bottom: 0.15rem;
    padding-left: 0;
  }
  .prose :global(.table-wrap.table-wide tbody td:not(:first-child))::after {
    /* Золотой bullet слева */
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gold-dim, #c9973a);
    opacity: 0.55;
  }
}

.post-meta-top { display: flex; justify-content: center; align-items: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem; max-width: 100%; }
.post-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; justify-content: center; max-width: 100%; }
.ptag { font-size: 0.6rem; letter-spacing: 0.05em; text-transform: uppercase; color: var(--gold); border: 1px solid rgba(201,151,58,0.3); padding: 0.15rem 0.45rem; border-radius: 2px; white-space: nowrap; }
.ptag:hover { background: rgba(201,151,58,0.12); }
.post-date { font-size: 0.7rem; color: var(--text-faint); letter-spacing: 0.04em; }
.post-updated { font-size: 0.7rem; color: var(--gold-dim); letter-spacing: 0.04em; margin-left: 0.4rem; }
.author-bio {
  display: flex; gap: 1rem; align-items: flex-start;
  margin-top: 3rem; padding: 1.4rem;
  background: var(--bg2); border: 1px solid var(--line); border-radius: 4px;
}
.bio-avatar-img {
  flex: 0 0 auto;
  width: 72px; height: 72px; border-radius: 50%;
  object-fit: cover; object-position: center 30%;
  border: 2px solid rgba(201,151,58,0.4);
}
.bio-text { font-size: 0.85rem; line-height: 1.7; color: var(--text-dim); }
.bio-text strong { color: var(--text); font-weight: 600; }
.bio-text a { color: var(--gold); text-decoration: underline; text-decoration-color: rgba(201,151,58,0.5); text-underline-offset: 3px; }
@media (max-width: 600px) {
  .author-bio { flex-direction: column; padding: 1rem; gap: 0.7rem; }
}

h1 {
  font-family: var(--ff-body);
  font-size: clamp(1.7rem, 4vw, 3rem);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.03em;
  margin-bottom: 1rem;
  text-align: center;
  text-wrap: balance;
  word-break: normal;
  overflow-wrap: break-word;
  hyphens: auto;
  max-width: 100%;
}
.post-author { font-size: 0.85rem; color: var(--text-faint); margin-bottom: 1.5rem; text-align: center; display: flex; align-items: center; justify-content: center; gap: 0.4rem; flex-wrap: wrap; }
.post-author a { color: var(--gold); text-decoration: underline; text-decoration-color: rgba(201,151,58,0.5); text-underline-offset: 3px; }
.post-author .author-link { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--text); text-decoration: none; }
.post-author .author-link:hover span { color: var(--gold); }
.author-mini { width: 28px; height: 28px; border-radius: 50%; object-fit: cover; object-position: center 30%; border: 1px solid rgba(201,151,58,0.4); }

.trip-marker {
  display: inline-flex; align-items: center; gap: 0.5rem;
  font-size: 0.78rem; color: var(--gold);
  background: rgba(201,151,58,0.08); border: 1px solid rgba(201,151,58,0.25);
  padding: 0.4rem 0.85rem; border-radius: 999px;
  margin: 0 auto 2.5rem; width: fit-content;
}
.trip-marker .trip-icon { font-weight: 700; color: var(--gold); }

.source-disclaimer {
  font-size: 0.85rem; line-height: 1.65; color: var(--text-dim);
  background: var(--bg2); border-left: 3px solid var(--gold-dim);
  padding: 1rem 1.2rem; margin: 0 0 2.5rem; border-radius: 2px;
}
.source-disclaimer strong { color: var(--text); }
.source-disclaimer a { color: var(--gold); }

.prose { color: var(--text); line-height: 1.85; font-size: 1rem; }
.prose :global(h2) {
  font-family: var(--ff-body); font-size: 1.5rem; font-weight: 700;
  color: var(--text); line-height: 1.3; letter-spacing: -0.02em;
  margin: 2rem 0 1.5rem; text-align: center;
}
.prose :global(h2) :global(.emoji), .prose :global(h2)::first-letter {
  display: inline-block;
}
.prose :global(p) { margin-bottom: 1.2rem; color: var(--text-dim); }
.prose :global(strong) { color: var(--text); font-weight: 500; }
.prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; margin-bottom: 1.2rem; }
.prose :global(li) { margin-bottom: 0.5rem; color: var(--text-dim); }
.prose :global(li strong) { color: var(--text); }
.prose :global(a) { color: var(--gold); text-decoration: underline; text-decoration-color: rgba(201,151,58,0.5); text-underline-offset: 3px; }
.prose :global(a:hover) { text-decoration-color: var(--gold); }
.prose :global(img) {
  display: block;
  max-width: 100%;
  width: auto;
  max-height: 600px;
  height: auto;
  margin: 2rem auto;
  border-radius: 6px;
}
/* Tables styled globally in src/styles/global.css under .prose .table-wrap */
.prose :global(hr) {
  border: none; margin: 2.5rem 0; position: relative;
  text-align: center; height: 1px; overflow: visible;
  background: linear-gradient(90deg, transparent, var(--line) 20%, var(--line) 80%, transparent);
}
.prose :global(hr)::after {
  content: '✦';
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  background: var(--bg); padding: 0 0.8rem;
  color: var(--gold-dim); font-size: 0.55rem; letter-spacing: 0.4em;
  line-height: 1;
}

.post-footer { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--line); }
.back-link { font-size: 0.82rem; color: var(--text-dim); letter-spacing: 0.04em; }
.back-link:hover { color: var(--gold); }
</style>
