---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { DIRECTIONS, MONTHS } from '../../data/directions.js';
import { VISA_DETAILS } from '../../data/visa-details.js';
import { regionsRich } from '../../data/regions-rich.js';
import { regionMeta } from '../../data/regions-meta.js';
import { getBucket } from '../../data/packing-weather-buckets.js';
import { ACTIVITY_TAGS, ACTIVITY_LABEL, ACTIVITY_GEAR } from '../../data/country-activity-tags.js';
import { PLUG_TYPES, plugAdvice } from '../../data/country-plug-types.js';
import { getWeatherBucket } from '../../data/country-month-bucket.js';
import { DATA_UPDATED_RU } from '../../data/meta.js';
import { TP_LINKS } from '../../data/affiliate.js';

export async function getStaticPaths() {
  return DIRECTIONS.map((d) => ({ params: { country: d.slug }, props: { d } }));
}

const { d } = Astro.props;
const url = `https://traveltribe.ru/packing/${d.slug}/`;

// ── Упаковка по СЕЗОНАМ: группируем 12 месяцев по weather-бакету (исключая закрытые X) ──
const MA = ['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек'];
const cap = (s) => s.charAt(0).toUpperCase() + s.slice(1);
const groups = new Map(); // bucketKey -> [monthIdx]
for (let i = 0; i < 12; i++) {
  if (d.r[i] === 'X') continue;
  const key = getWeatherBucket(d.slug, i);
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key).push(i);
}
function rangeLabel(idxs) {
  const s = [...idxs].sort((a, b) => a - b);
  const ranges = [];
  let start = s[0], prev = s[0];
  for (let k = 1; k < s.length; k++) {
    if (s[k] === prev + 1) prev = s[k];
    else { ranges.push([start, prev]); start = s[k]; prev = s[k]; }
  }
  ranges.push([start, prev]);
  // склейка через декабрь→январь (ноя–фев)
  if (ranges.length > 1 && ranges[0][0] === 0 && ranges[ranges.length - 1][1] === 11) {
    const last = ranges.pop(); ranges[0][0] = last[0];
  }
  return ranges.map(([a, b]) => (a === b ? cap(MA[a]) : `${cap(MA[a])}–${MA[b]}`)).join(', ');
}
const seasons = [...groups.entries()]
  .map(([key, idxs]) => ({ idxs, range: rangeLabel(idxs), bucket: getBucket(key), first: Math.min(...idxs) }))
  .sort((a, b) => a.first - b.first);

// ── Страновые данные (один раз) ──
const visa = VISA_DETAILS[d.slug];
const needsVisa = d.visa !== 'free';
const plug = PLUG_TYPES[d.slug];
const tags = ACTIVITY_TAGS[d.slug] || [];
const hasActivity = tags.some((t) => ACTIVITY_GEAR[t]);

const blogSlug = Object.values(regionMeta).find((rm) => rm.slug === d.slug)?.blogSlug;
const rich = regionsRich[d.slug];
let personalTip = null;
if (blogSlug && rich?.notes) { const any = rich.notes.find((n) => n); if (any) personalTip = any; }
const pillarUrl = blogSlug ? `/blog/${blogSlug}/` : null;

// ── SEO ──
const titleBase = `Что взять в ${d.cases.acc} — чек-лист по сезонам`;
const title = titleBase.length <= 55 ? `Что взять в ${d.cases.acc} 2026 — чек-лист` : titleBase;
const description = `Что взять ${d.cases.vP} в 2026: одежда по сезонам, документы, аптечка, техника, деньги. Реальный опыт + источники, обновлено ${DATA_UPDATED_RU}.`;

const FAQS = [
  { q: `Нужны ли прививки ${d.cases.vP} в 2026?`,
    a: `Обязательных прививок для въезда ${d.cases.vP} обычно нет, кроме приезда из стран жёлтой лихорадки. Проверь рекомендации Роспотребнадзора и сделай базовый набор (АДС, гепатит А/Б) у врача-инфекциониста минимум за 3 недели до вылета.` },
  { q: `Сколько багажа брать ${d.cases.vP}?`,
    a: `Для поездки 7–14 дней достаточно ручной клади 10 кг + сдаваемый чемодан 20 кг. Меньше багажа = больше свободы; постирать одежду в отеле/прачечной обычно дешевле, чем платить за перевес.` },
  { q: `Что НЕ ввезёшь ${d.cases.vP}?`,
    a: `Стандартные запреты: наркотики, оружие, дроны без разрешения, продукты животноводства, валюта свыше нормы (обычно $10 000). Уточни специфику ${d.cases.prep}: некоторые страны ограничивают лекарства, e-сигареты, vape. Источник — таможенная декларация на въезде.` },
  { q: `Нужна ли страховка ${d.cases.vP}?`,
    a: needsVisa
      ? `Да, страховка обязательна для визы ${d.cases.prep} (покрытие минимум €30 000 или эквивалент). Без полиса визу могут не выдать. Покупай заранее — на границе дороже и без гарантии покрытия предыдущих дней.`
      : `Формально не обязательна, но настоятельно рекомендую. Медпомощь иностранцам ${d.cases.loc} обычно платная (от $200 за визит до десятков тысяч за госпитализацию). Полис на 14 дней ≈ 1 500 ₽ — несравнимо с риском.` },
];

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "CollectionPage", "@id": `${url}#page`, "name": title, "description": description, "url": url, "inLanguage": "ru-RU" },
    { "@type": "FAQPage", "@id": `${url}#faq`, "mainEntity": FAQS.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
    { "@type": "BreadcrumbList", "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
      { "@type": "ListItem", "position": 2, "name": "Чек-листы", "item": "https://traveltribe.ru/packing/" },
      { "@type": "ListItem", "position": 3, "name": d.cases.nom, "item": url },
    ] },
  ],
};
---
<Layout title={title} description={description} canonical={url} ldJson={ldJson}>
  <Breadcrumbs crumbs={[
    { label: 'Чек-листы', href: '/packing/' },
    { label: d.cases.nom },
  ]} />

  <main id="main" class="pack-wrap">
    <div class="pack-hero" style={`--g1:${d.visual.g1}; --g2:${d.visual.g2};`}>
      <span class="pack-emoji" aria-hidden="true">{d.visual.emoji}</span>
    </div>

    <header class="pack-header">
      <p class="pack-eyebrow">Чек-лист · {d.region}</p>
      <h1>Что взять <em>{d.cases.vP}</em></h1>
      <p class="pack-byline">
        <a href="/about/" class="byline-author">Никита Зайцев</a> ·
        <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> ·
        <span class="byline-fresh">обновлено {DATA_UPDATED_RU}</span>
      </p>
    </header>

    <section class="tldr">
      <p>Полный чек-лист {d.cases.vP}: одежда под каждый сезон, документы, аптечка, техника и деньги. Когда лучше ехать — в <a href="/seasons/">таблице сезонов по месяцам</a>.</p>
    </section>

    <section class="pack-block">
      <h2>Документы</h2>
      <ul class="pack-list">
        <li><strong>Загранпаспорт</strong> — срок действия 6+ месяцев на момент въезда.</li>
        {needsVisa && visa && (<li><strong>Виза/eVisa:</strong> {visa.duration}, {visa.cost}, {visa.timing}. Детали — <a href={`/visa/${d.slug}/`}>на странице визы {d.cases.prep}</a>.</li>)}
        {!needsVisa && (<li><strong>Виза не нужна</strong> — {visa?.duration || 'безвизовый въезд'}, {visa?.timing || 'штамп на границе'}.</li>)}
        <li><strong>Обратный билет</strong> или бронь выезда (часто проверяют на регистрации). Поиск рейсов — <a href={TP_LINKS.aviasales} target="_blank" rel="sponsored noopener">Aviasales</a> <span class="ad-mark">Реклама</span>.</li>
        <li><strong>Страховка</strong> {needsVisa ? '(обязательна для визы)' : '(рекомендую — медпомощь платная)'}. Оформить — <a href={TP_LINKS.cherehapa} target="_blank" rel="sponsored noopener">Cherehapa</a> <span class="ad-mark">Реклама</span>.</li>
        <li><strong>Копии</strong> паспорта и виз в облаке + бумажные отдельно от оригиналов.</li>
      </ul>
    </section>

    <section class="pack-block">
      <h2>Одежда и аптечка — по сезонам</h2>
      {seasons.map((s) => (
        <div class="pack-season">
          <h3>{s.range} · {s.bucket.label}</h3>
          <p class="pack-weather">{s.bucket.summary}.</p>
          <p class="pack-sub">Одежда</p>
          <ul class="pack-list">{s.bucket.clothing.map((item) => <li>{item}</li>)}</ul>
          <p class="pack-sub">Аптечка и здоровье</p>
          <ul class="pack-list">{s.bucket.health.map((item) => <li>{item}</li>)}</ul>
          {s.bucket.gear?.length > 0 && (<>
            <p class="pack-sub">Снаряжение</p>
            <ul class="pack-list">{s.bucket.gear.map((item) => <li>{item}</li>)}</ul>
          </>)}
        </div>
      ))}
      <p class="pack-disclaimer">⚠ Аптечка — общий список. Перед поездкой — у врача. Источники: <a href="https://www.rospotrebnadzor.ru/" target="_blank" rel="noopener">Роспотребнадзор</a>, <a href="https://www.who.int/" target="_blank" rel="noopener">ВОЗ</a>.</p>
    </section>

    <section class="pack-block">
      <h2>Техника: связь, переходники, заряд</h2>
      <ul class="pack-list">
        {plug && (<li><strong>Переходник Type {plug.types}</strong> · {plug.voltage} · {plug.hz}. {plugAdvice(plug)}</li>)}
        <li><strong>Повербанк</strong> 10 000 мА·ч (в ручную кладь, не в багаж) + кабели.</li>
        <li><strong>eSIM вместо роуминга</strong> — настройка за 5 минут, от $5 за неделю. Обзор: <a href="/blog/esim-zagranicey-2026/">eSIM за границей 2026</a>. <a href={TP_LINKS.airalo} target="_blank" rel="sponsored noopener">Airalo</a> <span class="ad-mark">Реклама</span>.</li>
      </ul>
    </section>

    <section class="pack-block">
      <h2>Деньги: какие карты работают</h2>
      <p>Российские Visa/MC за границей не работают. Уточни статус МИР, UnionPay и иностранных карт {d.cases.loc} в <a href="/cards/">карте платёжных систем по 40 странам</a>.</p>
      <p>Минимум наличных $200–300 (USD/EUR) на непредвиденные — обмен лучше в стране.</p>
    </section>

    {hasActivity && (
      <section class="pack-block">
        <h2>Что взять под местные занятия</h2>
        {tags.map((tag) => {
          const gear = ACTIVITY_GEAR[tag];
          if (!gear) return null;
          return (
            <div class="pack-activity">
              <p class="pack-activity-label">— {ACTIVITY_LABEL[tag]}:</p>
              <ul class="pack-list">{gear.map((item) => <li>{item}</li>)}</ul>
            </div>
          );
        })}
      </section>
    )}

    {personalTip && pillarUrl && (
      <section class="pack-block pack-personal">
        <h2>Личный совет от Никиты {d.cases.loc}</h2>
        <p>{personalTip}</p>
        <p class="pack-personal-link">Подробный гайд: <a href={pillarUrl}>{d.cases.nom} — авторский разбор</a>.</p>
      </section>
    )}

    <section class="pack-block pack-months-block">
      <h2>Что взять {d.cases.vP} по месяцам</h2>
      <p class="pack-months-lead">Точный список под погоду и события конкретного месяца — что докинуть в чемодан.</p>
      <ul class="pack-months-grid">
        {MONTHS.map((mo) => (
          <li><a href={`/packing/${d.slug}/${mo.slug}/`}>{mo.nom}</a></li>
        ))}
      </ul>
    </section>

    <section class="pack-block">
      <h2>Частые вопросы</h2>
      <div class="pack-faq">
        {FAQS.map((f) => (
          <details class="pack-faq-row">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="pack-block pack-related">
      <h2>Связанные страницы</h2>
      <ul class="pack-list">
        <li><a href={`/${d.slug}/`}>Карточка {d.cases.prep} — виза, цены, сезоны</a></li>
        <li><a href={`/visa/${d.slug}/`}>Виза {d.cases.prep} для россиян 2026</a></li>
        <li><a href="/seasons/">Сезоны по месяцам — когда ехать</a></li>
        {pillarUrl && <li><a href={pillarUrl}>Авторский гайд {d.cases.prep}</a></li>}
        <li><a href="/packing/">Все чек-листы по странам</a></li>
      </ul>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.pack-wrap { max-width: 720px; margin: 0 auto; padding: 0 2rem 5rem; }
.pack-hero {
  position: relative; height: clamp(160px, 24vw, 240px); margin: 0 -2rem 0;
  background: linear-gradient(135deg, var(--g1) 0%, var(--g2) 100%);
  display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.pack-hero::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(circle at 20% 30%, rgba(255,255,255,0.4), transparent 50%), radial-gradient(circle at 80% 70%, rgba(0,0,0,0.06), transparent 50%);
  pointer-events: none;
}
.pack-emoji { font-size: clamp(4.5rem, 11vw, 7rem); filter: drop-shadow(0 6px 18px rgba(0,0,0,0.18)); z-index: 1; }
@media (min-width: 760px) { .pack-hero { margin-left: 0; margin-right: 0; border-radius: var(--radius-4, 8px); margin-top: 1rem; } }

.pack-header { text-align: center; margin: 2rem 0 1.5rem; }
.pack-eyebrow { font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.5rem; }
.pack-header h1 { font-family: var(--ff-display); font-size: clamp(1.9rem, 4.5vw, 2.8rem); font-weight: 300; line-height: 1.15; margin: 0; }
.pack-header h1 em { color: var(--gold); font-style: italic; }
.pack-byline { margin: 0.8rem 0 0; font-size: 0.78rem; color: var(--text-dim); letter-spacing: 0.02em; }
.pack-byline a { color: var(--gold); text-decoration: none; }
.pack-byline a:hover { text-decoration: underline; }
.byline-fresh { color: var(--text-faint); }

.tldr { background: var(--bg2); border-left: 3px solid var(--gold); padding: 1.2rem 1.4rem; border-radius: 4px; margin: 1.5rem 0 2.5rem; }
.tldr p { margin: 0; color: var(--text); line-height: 1.75; font-size: 1rem; }

.pack-block { margin-bottom: 2.5rem; }
.pack-block h2 { font-family: var(--ff-display); font-size: 1.4rem; font-weight: 400; color: var(--gold); margin-bottom: 1rem; }
.pack-block p { color: var(--text-dim); line-height: 1.75; font-size: 0.95rem; margin-bottom: 0.7rem; }
.pack-block a { color: var(--gold); text-decoration: underline; text-decoration-color: rgba(201,151,58,0.5); text-underline-offset: 3px; }

.pack-season { margin-bottom: 2rem; padding-bottom: 1.6rem; border-bottom: 1px solid var(--line); }
.pack-season:last-of-type { border-bottom: none; }
.pack-season h3 { font-family: var(--ff-display); font-size: 1.15rem; font-weight: 400; color: var(--text); margin: 0 0 0.4rem; }
.pack-weather { color: var(--text-dim); font-size: 0.9rem; margin-bottom: 0.8rem; }
.pack-sub { font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); margin: 0.9rem 0 0.2rem; font-weight: 500; }

.pack-list { padding-left: 1.4rem; margin: 0.4rem 0 0.8rem; }
.pack-list li { color: var(--text-dim); line-height: 1.8; margin-bottom: 0.5rem; font-size: 0.95rem; }
.pack-list li strong { color: var(--text); }

.pack-activity { margin-bottom: 1rem; }
.pack-activity-label { font-weight: 500; color: var(--text); margin-bottom: 0.3rem; }

.pack-personal { background: var(--bg2); border-left: 3px solid var(--gold); padding: 1.2rem 1.4rem; border-radius: 4px; }
.pack-personal h2 { font-size: 1.2rem; margin-top: 0; }
.pack-personal p { color: var(--text); margin-bottom: 0.5rem; }
.pack-personal-link { font-size: 0.85rem; color: var(--text-faint); margin-bottom: 0; }

.pack-disclaimer { font-size: 0.8rem; color: var(--text-faint); background: rgba(201,151,58,0.05); padding: 0.7rem 1rem; border-radius: 4px; border-left: 2px solid var(--gold-dim); margin-top: 0.8rem; }

.pack-faq { margin: 0.5rem 0 0; border-top: 1px solid var(--line); }
.pack-faq-row { border-bottom: 1px solid var(--line); background: transparent; }
.pack-faq-row summary { cursor: pointer; list-style: none; color: var(--text); font-size: 1rem; font-weight: 500; line-height: 1.45; padding: 1rem 2.5rem 1rem 0; position: relative; transition: color 0.15s ease; }
.pack-faq-row summary::-webkit-details-marker { display: none; }
.pack-faq-row summary:hover, .pack-faq-row[open] summary { color: var(--gold); }
.pack-faq-row summary::after { content: ''; position: absolute; right: 0.2rem; top: 50%; width: 12px; height: 12px; margin-top: -6px; background-image: linear-gradient(currentColor, currentColor), linear-gradient(currentColor, currentColor); background-size: 12px 1.4px, 1.4px 12px; background-position: center, center; background-repeat: no-repeat; color: var(--gold); transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1); }
.pack-faq-row[open] summary::after { transform: rotate(45deg); }
.pack-faq-row p { margin: 0 0 1rem; color: var(--text-dim); line-height: 1.75; font-size: 0.95rem; max-width: 95%; }

.ad-mark { display: inline-block; font-size: 0.65rem; color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.05em; padding: 0 0.4rem; border: 1px solid var(--line); border-radius: 2px; margin-left: 0.3rem; vertical-align: middle; }

.pack-months-lead { color: var(--text-dim); font-size: 0.95rem; line-height: 1.7; margin: 0 0 1rem; }
.pack-months-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(116px, 1fr)); gap: 0.5rem; }
.pack-months-grid a { display: flex; align-items: center; min-height: 44px; padding: 0.6rem 0.9rem; border: 1px solid var(--line); color: var(--text); font-size: 0.92rem; text-transform: capitalize; transition: border-color 0.15s ease, color 0.15s ease; }
.pack-months-grid a:hover { border-color: var(--gold); color: var(--gold); }
</style>
