---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { DIRECTIONS, MONTHS } from '../../../data/directions.js';
import { VISA_DETAILS } from '../../../data/visa-details.js';
import { regionsRich } from '../../../data/regions-rich.js';
import { regionMeta } from '../../../data/regions-meta.js';
import { WEATHER_BUCKETS, getBucket } from '../../../data/packing-weather-buckets.js';
import { ACTIVITY_TAGS, ACTIVITY_LABEL, ACTIVITY_GEAR } from '../../../data/country-activity-tags.js';
import { PLUG_TYPES, plugAdvice } from '../../../data/country-plug-types.js';
import { getWeatherBucket } from '../../../data/country-month-bucket.js';
import { DATA_UPDATED_RU } from '../../../data/meta.js';
import { TP_LINKS } from '../../../data/affiliate.js';

export async function getStaticPaths() {
  const paths = [];
  for (const m of MONTHS) {
    const mi = MONTHS.findIndex(x => x.slug === m.slug);
    for (const d of DIRECTIONS) {
      // Закрытое направление в этом месяце — не генерим
      if (d.r[mi] === 'X') continue;
      paths.push({ params: { country: d.slug, month: m.slug }, props: { m, d } });
    }
  }
  return paths;
}

const { m, d } = Astro.props;
const monthIdx = MONTHS.findIndex((x) => x.slug === m.slug);
const url = `https://traveltribe.ru/packing/${d.slug}/${m.slug}/`;
const monthCap = m.nom.charAt(0).toUpperCase() + m.nom.slice(1);

// Главный bucket
const bucketKey = getWeatherBucket(d.slug, monthIdx);
const bucket = getBucket(bucketKey);

// Активности страны
const tags = ACTIVITY_TAGS[d.slug] || [];
const activityItems = tags.flatMap(t => (ACTIVITY_GEAR[t] || []).map(item => ({ tag: t, item })));

// Plug type
const plug = PLUG_TYPES[d.slug];

// Visa данные
const visa = VISA_DETAILS[d.slug];
const needsVisa = d.visa !== 'free';

// Personal-tip (строгий контракт — feedback_no_fabrication)
let personalTip = null;
const blogSlug = Object.values(regionMeta).find(rm => rm.slug === d.slug)?.blogSlug;
const rich = regionsRich[d.slug];
const monthNote = rich?.notes?.[monthIdx];
if (blogSlug) {
  // Если есть pillar — пытаемся найти точечный month-note или любой non-null
  if (monthNote) {
    personalTip = monthNote;
  } else if (rich?.notes) {
    const any = rich.notes.find(n => n);
    if (any) personalTip = any;
  }
}
const pillarUrl = blogSlug ? `/blog/${blogSlug}/` : null;

// TL;DR (answer-first 40–60 слов)
const tldr = `${bucket.summary}. Главное по чек-листу: ${bucket.clothing[0].split(' (')[0]}, ${bucket.health[0].split(' (')[0]}. ${needsVisa ? `Виза: ${visa?.duration || '—'}, ${visa?.cost || '—'}.` : 'Виза не нужна.'}`;

// Title и description (≤60 / ≤155)
const title = `Что взять в ${d.cases.acc} в ${m.prep} 2026 — чек-лист`;
const description = `Чек-лист для поездки ${d.cases.vP} в ${m.prep} 2026: одежда по погоде (${bucket.label}), документы, аптечка, техника. Реальный опыт + источники.`;

// FAQ авто-генерация (4 Q/A)
const FAQS = [
  {
    q: `Нужны ли прививки ${d.cases.vP} в 2026?`,
    a: `Обязательных прививок для въезда ${d.cases.vP} обычно нет, кроме случаев приезда из стран жёлтой лихорадки. Перед поездкой проверь рекомендации Роспотребнадзора и сделай базовый набор (АДС, гепатит А/Б) у врача-инфекциониста минимум за 3 недели до вылета.`
  },
  {
    q: `Сколько багажа брать ${d.cases.vP}?`,
    a: `Для ${bucket.label.toLowerCase()} достаточно ручной клади 10 кг + 1 предмет на борт. Для поездки 7–14 дней — чемодан 20 кг сдаваемый. Меньше багажа = больше свободы передвижения; постирать одежду в отеле/прачечной обычно дешевле, чем платить за перевес.`
  },
  {
    q: `Что НЕ ввезёшь ${d.cases.vP}?`,
    a: `Стандартные запреты: наркотики, оружие, дроны без разрешения, продукты животноводства, валюта свыше декларируемой нормы (обычно $10 000). Уточни специфику ${d.cases.prep}: некоторые страны ограничивают лекарства, e-сигареты, vape. Источник — таможенная декларация на въезде.`
  },
  {
    q: `Нужна ли страховка ${d.cases.vP}?`,
    a: needsVisa
      ? `Да, страховка обязательна для визы ${d.cases.prep} (покрытие минимум €30 000 или эквивалент). Без полиса визу могут не выдать. Покупай заранее — на границе или в стране дороже и без гарантии покрытия предыдущих дней.`
      : `Формально не обязательна, но настоятельно рекомендую. Медпомощь иностранцам ${d.cases.loc} обычно платная (от $200 за визит к врачу до десятков тысяч за госпитализацию). Полис на 14 дней ≈ 1 500 ₽ — несравнимо с риском.`
  },
];

// JSON-LD: HowTo + FAQPage + BreadcrumbList
const howToSteps = [
  { name: 'Документы', text: `Паспорт со сроком 6+ месяцев, ${needsVisa ? 'виза/eVisa' : 'безвиз'}, обратный билет или выписка, страховка, копии документов отдельно от оригиналов.` },
  { name: 'Одежда по погоде', text: bucket.clothing.slice(0, 4).join('. ') },
  { name: 'Аптечка', text: bucket.health.slice(0, 3).join('. ') },
  { name: 'Техника и связь', text: bucket.tech.concat([plug ? `Переходник Type ${plug.types} (${plug.voltage}).` : '']).filter(Boolean).join(' ') },
  { name: 'Снаряжение', text: bucket.gear.join('. ') },
];

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HowTo",
      "@id": `${url}#howto`,
      "name": title,
      "description": description,
      "totalTime": "PT1H",
      "step": howToSteps.map((s, i) => ({
        "@type": "HowToStep",
        "position": i + 1,
        "name": s.name,
        "text": s.text,
      })),
    },
    {
      "@type": "FAQPage",
      "@id": `${url}#faq`,
      "mainEntity": FAQS.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Чек-листы", "item": "https://traveltribe.ru/packing/" },
        { "@type": "ListItem", "position": 3, "name": d.cases.nom, "item": `https://traveltribe.ru/packing/${d.slug}/` },
        { "@type": "ListItem", "position": 4, "name": monthCap, "item": url },
      ],
    },
  ],
};
---
<Layout
  title={title}
  description={description}
  canonical={url}
  ogType="article"
  ogTitle={title}
  ogDescription={description}
  ldJson={ldJson}
>
  <Nav active="packing" />
  <Breadcrumbs crumbs={[
    { label: 'Чек-листы', href: '/packing/' },
    { label: d.cases.nom, href: `/packing/${d.slug}/` },
    { label: monthCap },
  ]} />

  <main id="main" class="pack-wrap">
    <div class="pack-hero" style={`--g1:${d.visual.g1}; --g2:${d.visual.g2};`}>
      <span class="pack-emoji" aria-hidden="true">{d.visual.emoji}</span>
    </div>

    <header class="pack-header">
      <p class="pack-eyebrow">Чек-лист · {d.region}</p>
      <h1>Что взять <em>{d.cases.vP}</em> в {m.prep} 2026</h1>
      <p class="pack-byline">
        <a href="/about/" class="byline-author">Никита Зайцев</a> ·
        <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> ·
        <span class="byline-fresh">обновлено {DATA_UPDATED_RU}</span>
      </p>
    </header>

    <section class="tldr" id="tldr">
      <p>{tldr}</p>
    </section>

    <section class="pack-block">
      <h2>Какая погода {d.cases.loc} в {m.prep}?</h2>
      <p><strong>{bucket.label}.</strong> {bucket.summary}.</p>
      <p>{d.t[monthIdx]}. Подробная таблица — <a href="/seasons/">сезоны по 70 направлениям</a>.</p>
    </section>

    <section class="pack-block">
      <h2>Какие документы нужны?</h2>
      <ul class="pack-list">
        <li><strong>Загранпаспорт</strong> — срок действия 6+ месяцев на момент въезда.</li>
        {needsVisa && visa && (
          <li><strong>Виза/eVisa:</strong> {visa.duration}, {visa.cost}, {visa.timing}. Детали — <a href={`/visa/${d.slug}/`}>на странице визы {d.cases.prep}</a>.</li>
        )}
        {!needsVisa && (
          <li><strong>Виза не нужна</strong> — {visa?.duration || 'безвизовый въезд'}, {visa?.timing || 'штамп на границе'}.</li>
        )}
        <li><strong>Обратный билет</strong> или бронь выезда (часто проверяют на стойке регистрации).</li>
        <li><strong>Страховка</strong> {needsVisa ? '(обязательна для визы)' : '(рекомендую — медпомощь платная)'}.</li>
        <li><strong>Копии</strong> паспорта и виз в облаке + бумажные — отдельно от оригиналов.</li>
      </ul>
    </section>

    <section class="pack-block">
      <h2>Одежда: что положить</h2>
      <ul class="pack-list">
        {bucket.clothing.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="pack-block">
      <h2>Аптечка и здоровье</h2>
      <ul class="pack-list">
        {bucket.health.map((item) => <li>{item}</li>)}
      </ul>
      <p class="pack-disclaimer">⚠ Список общий. Перед поездкой — у врача. Источники: <a href="https://www.rospotrebnadzor.ru/" target="_blank" rel="noopener">Роспотребнадзор</a>, <a href="https://www.who.int/" target="_blank" rel="noopener">ВОЗ</a>.</p>
    </section>

    <section class="pack-block">
      <h2>Техника: связь, переходники, заряд</h2>
      <ul class="pack-list">
        {bucket.tech.map((item) => <li>{item}</li>)}
        {plug && (
          <li><strong>Переходник Type {plug.types}</strong> · {plug.voltage} · {plug.hz}. {plugAdvice(plug)}</li>
        )}
        <li><strong>eSIM вместо роуминга</strong> — настройка за 5 минут, цены от $5 за неделю. Обзор: <a href="/blog/esim-zagranicey-2026/">eSIM за границей 2026</a>. <a href={TP_LINKS.airalo} target="_blank" rel="sponsored noopener">Airalo</a> <span class="ad-mark">Реклама</span>.</li>
      </ul>
    </section>

    <section class="pack-block">
      <h2>Деньги: какие карты работают</h2>
      <p>Российские Visa/MC за границей не работают. Уточни статус МИР, UnionPay и иностранных карт {d.cases.loc} в <a href="/cards/">карте платёжных систем по 40 странам</a>.</p>
      <p>Минимум наличных $200–300 (USD/EUR) на непредвиденные — обмен лучше в стране.</p>
    </section>

    {activityItems.length > 0 && (
      <section class="pack-block">
        <h2>Что взять под местные занятия</h2>
        {tags.map((tag) => {
          const gear = ACTIVITY_GEAR[tag];
          if (!gear) return null;
          return (
            <div class="pack-activity">
              <p class="pack-activity-label">— {ACTIVITY_LABEL[tag]}:</p>
              <ul class="pack-list">
                {gear.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          );
        })}
      </section>
    )}

    {personalTip && pillarUrl && (
      <section class="pack-block pack-personal">
        <h2>Личный совет от Никиты {d.cases.loc}</h2>
        <p>{personalTip}</p>
        <p class="pack-personal-link">Подробный гайд: <a href={pillarUrl}>{d.cases.nom} — авторский разбор</a>.</p>
      </section>
    )}

    <section class="pack-block">
      <h2>Частые вопросы</h2>
      <div class="faq-list">
        {FAQS.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="pack-block pack-related">
      <h2>Связанные страницы</h2>
      <ul class="pack-list">
        <li><a href={`/${d.slug}/`}>Карточка {d.cases.prep} — виза, цены, сезоны</a></li>
        <li><a href={`/visa/${d.slug}/`}>Виза {d.cases.prep} для россиян 2026</a></li>
        <li><a href={`/trips/${m.slug}/${d.slug}/`}>Стоит ли ехать {d.cases.vP} в {m.prep} 2026</a></li>
        {pillarUrl && <li><a href={pillarUrl}>Авторский гайд {d.cases.prep}</a></li>}
        <li><a href="/seasons/">Таблица сезонов 70×12</a></li>
      </ul>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.pack-wrap { max-width: 720px; margin: 0 auto; padding: 0 2rem 5rem; }
.pack-hero {
  position: relative;
  height: clamp(160px, 24vw, 240px);
  margin: 0 -2rem 0;
  background: linear-gradient(135deg, var(--g1) 0%, var(--g2) 100%);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.pack-hero::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,0.4), transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(0,0,0,0.06), transparent 50%);
  pointer-events: none;
}
.pack-emoji {
  font-size: clamp(4.5rem, 11vw, 7rem);
  filter: drop-shadow(0 6px 18px rgba(0,0,0,0.18));
  z-index: 1;
}
@media (min-width: 760px) {
  .pack-hero { margin-left: 0; margin-right: 0; border-radius: var(--radius-4, 8px); margin-top: 1rem; }
}

.pack-header { text-align: center; margin: 2rem 0 1.5rem; }
.pack-eyebrow {
  font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 0.5rem;
}
.pack-header h1 {
  font-family: var(--ff-display); font-size: clamp(1.9rem, 4.5vw, 2.8rem);
  font-weight: 300; line-height: 1.15; margin: 0;
}
.pack-header h1 em { color: var(--gold); font-style: italic; }
.pack-byline {
  margin: 0.8rem 0 0;
  font-size: 0.78rem; color: var(--text-dim); letter-spacing: 0.02em;
}
.pack-byline a { color: var(--gold); text-decoration: none; }
.pack-byline a:hover { text-decoration: underline; }
.byline-fresh { color: var(--text-faint); }

.tldr {
  background: var(--bg2); border-left: 3px solid var(--gold);
  padding: 1.2rem 1.4rem; border-radius: 4px;
  margin: 1.5rem 0 2.5rem;
}
.tldr p { margin: 0; color: var(--text); line-height: 1.75; font-size: 1rem; }

.pack-block { margin-bottom: 2.5rem; }
.pack-block h2 {
  font-family: var(--ff-display); font-size: 1.4rem; font-weight: 400;
  color: var(--gold); margin-bottom: 1rem;
}
.pack-block p { color: var(--text-dim); line-height: 1.75; font-size: 0.95rem; margin-bottom: 0.7rem; }
.pack-block a { color: var(--gold); text-decoration: underline; text-decoration-color: rgba(201,151,58,0.5); text-underline-offset: 3px; }

.pack-list { padding-left: 1.4rem; margin: 0.8rem 0; }
.pack-list li {
  color: var(--text-dim); line-height: 1.8; margin-bottom: 0.5rem; font-size: 0.95rem;
}
.pack-list li strong { color: var(--text); }

.pack-activity { margin-bottom: 1rem; }
.pack-activity-label { font-weight: 500; color: var(--text); margin-bottom: 0.3rem; }

.pack-personal {
  background: var(--bg2); border-left: 3px solid var(--gold);
  padding: 1.2rem 1.4rem; border-radius: 4px;
}
.pack-personal h2 { font-size: 1.2rem; margin-top: 0; }
.pack-personal p { color: var(--text); margin-bottom: 0.5rem; }
.pack-personal-link { font-size: 0.85rem; color: var(--text-faint); margin-bottom: 0; }

.pack-disclaimer {
  font-size: 0.8rem; color: var(--text-faint);
  background: rgba(201,151,58,0.05);
  padding: 0.7rem 1rem; border-radius: 4px;
  border-left: 2px solid var(--gold-dim);
  margin-top: 0.8rem;
}

.faq-list { margin: 0.5rem 0; }
.faq-item {
  border-bottom: 1px solid var(--line); padding: 0.8rem 0;
}
.faq-item summary {
  cursor: pointer; color: var(--text); font-size: 0.98rem; font-weight: 500;
  list-style: none; padding-right: 1.5rem; position: relative;
}
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary::after {
  content: '+'; position: absolute; right: 0; top: 0;
  color: var(--gold); font-size: 1.2rem; line-height: 1;
}
.faq-item[open] summary::after { content: '−'; }
.faq-item p {
  margin: 0.5rem 0 0; color: var(--text-dim); line-height: 1.75; font-size: 0.95rem;
}

.ad-mark {
  display: inline-block;
  font-size: 0.65rem;
  color: var(--text-faint);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0 0.4rem;
  border: 1px solid var(--line);
  border-radius: 2px;
  margin-left: 0.3rem;
  vertical-align: middle;
}
</style>
