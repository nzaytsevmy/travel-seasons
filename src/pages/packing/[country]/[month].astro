      </ul>
      <p class="pmu-cta">
        <a class="pmu-aff" href={TP_LINKS.airalo} rel="sponsored noopener" target="_blank">Купить eSIM {d.cases.vP}</a>
        
        <span class="pmu-trust">от $5/нед · оплата картами РФ</span>
      </p>
    </section>

    {/* АКТИВНОСТИ */}
    {tags.filter((t) => ACTIVITY_GEAR[t]).length > 0 && (
      <section class="pmu-section">
        <div class="pmu-shead"><h2>Под местные занятия</h2></div>
        {tags.map((tag) => {
          const gear = ACTIVITY_GEAR[tag];
          if (!gear) return null;
          return (
            <div class="pmu-activity">
              <div class="pmu-activity-label">{ACTIVITY_LABEL[tag]}:</div>
              <ul class="pmu-list">{gear.map((item) => <li>{item}</li>)}</ul>
            </div>
          );
        })}
      </section>
    )}

    {/* НАВИГАЦИЯ МЕСЯЦЕВ — соседние + альт */}
    <section class="pmu-section">
      <div class="pmu-shead"><h2>Другие месяцы {d.cases.gen || d.cases.nom}</h2></div>
      <div class="pmu-monthnav">
        <a class="pmu-monthnav-side" href={`/packing/${d.slug}/${MONTHS[prevIdx].slug}/`}>
          <span class="pmu-monthnav-dir">← {MONTHS[prevIdx].nom}</span>
          <span class="pmu-monthnav-stat">{RANK[d.r[prevIdx]]?.label || ''}</span>
        </a>
        <a class="pmu-monthnav-side pmu-monthnav-side--right" href={`/packing/${d.slug}/${MONTHS[nextIdx].slug}/`}>
          <span class="pmu-monthnav-dir">{MONTHS[nextIdx].nom} →</span>
          <span class="pmu-monthnav-stat">{RANK[d.r[nextIdx]]?.label || ''}</span>
        </a>
      </div>
      {altMonths.length > 0 && (
        <p class="pmu-alt">
          <b>Лучшие месяцы {d.cases.gen || d.cases.nom}:</b>
          {altMonths.map((a, i) => (
            <>
              {i > 0 && ' · '}
              <a href={`/packing/${d.slug}/${a.slug}/`} class="pmu-link">{a.nom}</a>
            </>
          ))}
        </p>
      )}
    </section>

    {/* FAQ */}
    <section class="pmu-section">
      <div class="pmu-shead"><h2>FAQ</h2></div>
      <div class="pmu-faq">
        {FAQS.map((f) => (
          <details class="pmu-faq-i">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    {/* СВЯЗАННЫЕ */}
    <section class="pmu-section">
      <div class="pmu-shead"><h2>Что почитать дальше</h2></div>
      <ul class="pmu-related">
        <li><a href={`/packing/${d.slug}/`}><b>Полный чек-лист {d.cases.gen || d.cases.nom}</b></a><span>все 12 месяцев на одной странице</span></li>
        <li><a href={`/${d.slug}/`}><b>{d.cases.nom} 2026 — виза, бюджет, маршруты</b></a><span>главная карточка страны</span></li>
        <li><a href={`/trips/${m.slug}/${d.slug}/`}><b>{d.cases.nom} в {m.prep} 2026</b></a><span>отдельный гайд по поездке</span></li>
        <li><a href={`/visa/${d.slug}/`}><b>Виза {d.cases.vP} для россиян 2026</b></a><span>документы, сроки, стоимость</span></li>
        <li><a href="/seasons/"><b>Таблица сезонов 70+ направлений</b></a><span>где ещё хорошо в {m.prep}</span></li>
        <li><a href="/packing/"><b>Все чек-листы по странам</b></a><span>70+ направлений</span></li>
      </ul>
    </section>

    <p class="pmu-updated">Актуально на: {DATA_UPDATED_RU}</p>
  </main>

  <StickyCta href={cherehapaTravel(`packing_${d.slug.replaceAll('-', '_')}`)} label={`Страховка ${d.cases.vP} — под даты`} />

  <Footer />
</Layout>

