---
// /packing/<country>/<month>/ — что взять в страну в конкретный месяц.
// Swiss-канон BRANDBOOK.md (только hairlines, gold accent, без border-radius/shadow).
// Уникальность ≥50% на страницу: status+text+events+season-multiplier+bucket+alt-months.

import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { Image, getImage } from 'astro:assets';
import { DIRECTIONS, MONTHS } from '../../../data/directions.js';
import { VISA_DETAILS } from '../../../data/visa-details.js';
import { getBucket } from '../../../data/packing-weather-buckets.js';
import { getWeatherBucket } from '../../../data/country-month-bucket.js';
import { ACTIVITY_TAGS, ACTIVITY_LABEL, ACTIVITY_GEAR } from '../../../data/country-activity-tags.js';
import { PLUG_TYPES, plugAdvice } from '../../../data/country-plug-types.js';
import { DATA_UPDATED_RU } from '../../../data/meta.js';
import { TP_LINKS, aviasalesRoute, cherehapaTravel } from '../../../data/affiliate.js';
import StickyCta from '../../../components/StickyCta.astro';
import { getHolidaysByMonth } from '../../../data/country-holidays.js';
import { getMonthlyWeather } from '../../../data/country-monthly-weather.js';
import { regionsRich } from '../../../data/regions-rich.js';
import { getGuide } from '../../../data/country-guides.js';
import PackingChecklist from '../../../components/PackingChecklist.astro';

// Cover photos для страны — те же что используются на /<slug>/
const destPhotos = import.meta.glob('../../../assets/destinations/*.jpg', {
  eager: true,
  import: 'default',
});

export async function getStaticPaths() {
  const paths = [];
  for (const d of DIRECTIONS) {
    for (let i = 0; i < 12; i++) {
      paths.push({
        params: { country: d.slug, month: MONTHS[i].slug },
        props: { d, m: MONTHS[i], monthIdx: i },
      });
    }
  }
  return paths;
}

const { d, m, monthIdx } = Astro.props;
const url = `https://traveltribe.ru/packing/${d.slug}/${m.slug}/`;

const status = d.r[monthIdx];                             // P/G/O/B/X
const monthText = d.t[monthIdx];                          // авторский текст для месяца
const bucketKey = getWeatherBucket(d.slug, monthIdx);
const bucket = getBucket(bucketKey);
const monthEvents = getHolidaysByMonth(d.slug)[monthIdx + 1] || [];  // 1-12 индексация
const monthWeather = getMonthlyWeather(d.slug, monthIdx); // реальные min/max + rain для топ-15

// Cover-photo страны (если есть в assets/destinations/<slug>.jpg)
const coverPath = `../../../assets/destinations/${d.slug}.jpg`;
const coverImage = destPhotos[coverPath];

// Реальный авторский опыт (E-E-A-T) — берём ТОЛЬКО что уже есть в repo, не выдумываем
const rich = regionsRich[d.slug];
const personalMonthNote = rich?.notes?.[monthIdx] || null;  // конкретный комментарий под месяц
const guide = getGuide(d.slug);
const authorOverall = guide?.authorNote || null;             // общий «был сам» по стране
const visitedThisMonth = Boolean(personalMonthNote);
const HERO_WIDTHS = [512, 768, 1024, 1600];
const heroPreload = coverImage
  ? await getImage({ src: coverImage, widths: HERO_WIDTHS, formats: ['webp'], quality: 70 })
  : null;

const RANK = {
  P: { label: 'Пик сезона',     tone: 'peak',   tldr: 'идеальное время — лучший месяц года',           price: 'Цены на пике: авиа и отели ×1.5–2 vs низкий сезон.' },
  G: { label: 'Хорошо',         tone: 'good',   tldr: 'отличный сезон — погода и цены сбалансированы', price: 'Цены средние: между пиком и низким сезоном.' },
  O: { label: 'Нормально',      tone: 'off',    tldr: 'не пик, но ехать можно',                        price: 'Цены ниже пика на 20–30%, погода с нюансами.' },
  B: { label: 'Не лучший месяц', tone: 'bad',   tldr: 'есть нюансы — внутри подсказки как обойти',     price: 'Цены минимальные за год — низкий сезон.' },
  X: { label: 'Закрыто',        tone: 'closed', tldr: 'не рекомендуется — лучше выбрать другой месяц', price: 'Туристическая инфраструктура частично закрыта.' },
};
const rank = RANK[status] || RANK.O;

const visa = VISA_DETAILS[d.slug];
const needsVisa = d.visa !== 'free';
const plug = PLUG_TYPES[d.slug];
const tags = ACTIVITY_TAGS[d.slug] || [];

// Пресет интерактивного чек-листа: холодный бакет → зима, пляжная страна → море, иначе универсал.
const PACK_COLD = ['temperate-cold', 'cold-extreme'];
const checklistPreset = PACK_COLD.includes(bucketKey) ? 'winter' : (tags.includes('beach') ? 'sea' : 'any');

// Лучшие альтернативные месяцы (P+G), исключая текущий
const altMonths = (d.r || [])
  .map((s, i) => ({ s, i }))
  .filter(({ s, i }) => (s === 'P' || s === 'G') && i !== monthIdx)
  .map(({ i }) => ({ slug: MONTHS[i].slug, nom: MONTHS[i].nom }))
  .slice(0, 3);

// Соседние месяцы для логичной навигации
const prevIdx = (monthIdx + 11) % 12;
const nextIdx = (monthIdx + 1) % 12;
const monthCap = m.nom.charAt(0).toUpperCase() + m.nom.slice(1);

// Минимальный перелёт из prices (массив [low, avg, high])
const flightLow = d.price?.flight?.[0];
const flightAvg = d.price?.flight?.[1];

// Sezon-multiplier для конкретного месяца: P (peak) ×1.7 / G ×1.2 / O ×1.0 / B ×0.7 / X null
const SEASONAL_MULT = { P: 1.7, G: 1.2, O: 1.0, B: 0.7, X: null };
const monthMult = SEASONAL_MULT[status];
const flightMonth = (flightLow && monthMult)
  ? Math.round(flightLow * monthMult / 10) * 10  // округление до десятков
  : null;

// SEO
const title = `Что взять ${d.cases.vP} в ${m.prep} 2026 — чек-лист`;
const description = `Что брать ${d.cases.vP} в ${m.prep}: ${bucket.summary.split(',')[0].toLowerCase()}. Сезон — ${rank.tldr}.${monthEvents.length ? ' События: ' + monthEvents.map(e => e.name).slice(0,2).join(', ') + '.' : ''}`.slice(0, 155);

const FAQS = [
  {
    q: `Какая погода ${d.cases.vP} в ${m.prep} 2026?`,
    a: monthWeather
      ? `${monthCap} ${d.cases.loc} — температура ${monthWeather.temp}, осадки ${monthWeather.rain}. ${monthText || ''}`.trim()
      : `${monthText || `${monthCap} ${d.cases.loc} — ${bucket.label.toLowerCase()}.`} По бакету: ${bucket.summary}.`,
  },
  {
    q: `Стоит ли ехать ${d.cases.vP} в ${m.prep}?`,
    a: status === 'X'
      ? `Не рекомендуется — ${rank.tldr}. ${altMonths.length ? `Лучшие месяцы: ${altMonths.map(a=>a.nom).join(', ')}.` : ''}`
      : status === 'B'
        ? `Можно, но с нюансами — ${rank.tldr}. ${altMonths.length ? `Если гибкие даты, рассмотри ${altMonths.map(a=>a.nom).join(', ')}.` : ''}`.trim()
        : `Да, ${rank.tldr}. Сезонная стратегия по ценам: ${rank.price.toLowerCase()}`,
  },
  {
    q: `Какие события и праздники ${d.cases.loc} в ${m.prep}?`,
    a: monthEvents.length
      ? monthEvents.map(e => `${e.name}${e.dates ? ' (' + e.dates + ')' : ''}${e.note ? ' — ' + e.note : ''}`).join('. ')
      : `В ${m.prep} ${d.cases.loc} нет крупных гос. праздников или фестивалей, важных для туристов. Смотри помесячный календарь ${d.cases.gen || d.cases.nom}.`,
  },
  {
    q: `Сколько стоит перелёт ${d.cases.vP} в ${m.prep}?`,
    a: flightMonth
      ? `Ориентир для ${m.prep}: от $${flightMonth} в одну сторону из Москвы (база $${flightLow} × сезонный множитель ${monthMult}). В ${m.prep} ${d.cases.loc} ${(status==='P'?'пик сезона, цены на максимуме':status==='G'?'хороший сезон, цены средние':status==='B'?'низкий сезон, минимум за год':status==='O'?'нормальный сезон':'инфраструктура частично закрыта')}. Конкретно под даты — в калькуляторе.`
      : flightLow
        ? `Минимум — от $${flightLow} в одну сторону из Москвы. ${rank.price}`
        : `Цены варьируются по сезону. ${rank.price} Поиск — Aviasales.`,
  },
  {
    q: `Нужна ли страховка ${d.cases.vP}?`,
    a: needsVisa
      ? `Да, обязательна для визы ${d.cases.prep} (минимум €30 000). Без полиса визу не дадут.`
      : `Не обязательна, но настоятельно рекомендую: медпомощь иностранцам ${d.cases.loc} платная, полис на 14 дней ≈ 1 500 ₽.`,
  },
  {
    q: `Что НЕ ввезёшь ${d.cases.vP}?`,
    a: `Базовые запреты: наркотики, оружие, дроны без разрешения, продукты животноводства, валюта свыше $10 000. Подробнее — на странице страны ${d.cases.gen || d.cases.nom} в разделе «Бытовая практика».`,
  },
];

const SITE = 'https://traveltribe.ru';
const imageNode = coverImage ? [{
  "@type": "ImageObject",
  "url": `${SITE}${coverImage.src}`,
  "width": coverImage.width,
  "height": coverImage.height,
}] : null;

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#page`,
      "name": title,
      "description": description,
      "url": url,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "about": { "@type": "Country", "name": d.cases.nom },
      ...(imageNode ? { "image": imageNode, "primaryImageOfPage": imageNode[0] } : {}),
      "datePublished": "2026-05-27",
      "dateModified": "2026-05-27",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", ".pmu-tldr"] },
    },
    // ItemList: одежда из bucket — AEO любит структурированные списки для long-tail
    {
      "@type": "ItemList",
      "@id": `${url}#packing-list`,
      "name": `Что взять ${d.cases.vP} в ${m.prep} — список одежды`,
      "itemListElement": bucket.clothing.map((item, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": item,
      })),
    },
    {
      "@type": "FAQPage",
      "@id": `${url}#faq`,
      "mainEntity": FAQS.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Чек-листы", "item": "https://traveltribe.ru/packing/" },
        { "@type": "ListItem", "position": 3, "name": d.cases.nom, "item": `https://traveltribe.ru/packing/${d.slug}/` },
        { "@type": "ListItem", "position": 4, "name": monthCap, "item": url },
      ],
    },
  ],
};

const noindex = status === 'X';

const TAG_LABEL = { closed: 'выходные', fest: 'фестиваль', culture: 'сезонное' };
---
<Layout
  title={title}
  description={description}
  canonical={url}
  ldJson={ldJson}
  noindex={noindex}
  preloadImageSrcset={heroPreload?.srcSet?.attribute}
  preloadImageSizes="100vw"
>
  <Breadcrumbs crumbs={[
    { label: 'Чек-листы', href: '/packing/' },
    { label: d.cases.nom, href: `/packing/${d.slug}/` },
    { label: monthCap },
  ]} />

  <main id="main" class="pmu">
    {/* COVER PHOTO — Swiss-канон: full-bleed, лёгкий filter, без overlay */}
    {coverImage && (
      <section class="pmu-cover">
        <Image
          src={coverImage}
          alt={`${d.cases.nom} — пейзаж страны`}
          widths={HERO_WIDTHS}
          sizes="100vw"
          formats={['webp']}
          quality={70}
          loading="eager"
          fetchpriority="high"
        />
      </section>
    )}

    {/* MANIFEST */}
    <section class="pmu-manifest">
      <div class="pmu-meta">{d.region}<br /><b>Обновлено {DATA_UPDATED_RU}</b></div>
      <h1 class="pmu-h1">Что взять {d.cases.vP} <span class="rd">в {m.prep}</span></h1>
      <p class="pmu-tldr">
        <b class={`pmu-mark pmu-mark--${rank.tone}`}>{rank.label}</b> {rank.tldr}.
        {monthText && <> {monthText}</>}
      </p>
      <p class="pmu-byline">
        <a href="/about/" class="byline-author">Никита Зайцев</a> ·
        <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> ·
        <span class="byline-fresh">обновлено {DATA_UPDATED_RU}</span>
      </p>
    </section>

    {/* QUICK FACTS — 4 ячейки */}
    <section class="pmu-section">
      <div class="pmu-shead"><h2>Главное о {m.prep} {d.cases.loc}</h2></div>
      <div class="pmu-vlist">
        <div class="pmu-vi"><span><b>01</b> Сезон</span><div>{rank.label}</div></div>
        <div class="pmu-vi"><span><b>02</b> Погода</span><div>{bucket.label}</div></div>
        {flightLow && <div class="pmu-vi"><span><b>03</b> Перелёт от</span><div>${flightLow}</div></div>}
        <div class="pmu-vi"><span><b>04</b> Виза</span><div>{needsVisa ? (visa?.cost || 'Нужна') : 'Не нужна'}</div></div>
      </div>
    </section>

    {/* ИНТЕРАКТИВНЫЙ ЧЕК-ЛИСТ — отметить, что собрано */}
    <section class="pmu-section">
      <div class="pmu-shead"><h2>Собрать чемодан: чек-лист с галочками</h2></div>
      <p class="pmu-answer">
        Отметьте, что уже сложили — список подстраивается под длительность, кто едет и транспорт,
        а отметки сохраняются в браузере.
        {checklistPreset === 'sea' && <> Полный разбор по категориям — в гайде <a href="/blog/chto-vzyat-na-more-2026/" class="pmu-link">что взять на море</a>.</>}
      </p>
      <PackingChecklist preset={checklistPreset} schema={false} storageKey={`pmu-${d.slug}-${m.slug}`} />
    </section>

    {/* ПОГОДА — реальные цифры для топ-15, generic для остальных */}
    <section class="pmu-section">
      <div class="pmu-shead"><h2>Погода {d.cases.loc} в {m.prep}</h2></div>
      {monthWeather ? (
        <>
          <div class="pmu-weather-grid">
            <div class="pmu-w-cell"><span class="pmu-w-k">Температура</span><div class="pmu-w-v">{monthWeather.temp}</div></div>
            <div class="pmu-w-cell"><span class="pmu-w-k">Осадки</span><div class="pmu-w-v">{monthWeather.rain}</div></div>
            <div class="pmu-w-cell"><span class="pmu-w-k">Тип климата</span><div class="pmu-w-v">{bucket.label}</div></div>
          </div>
          <p class="pmu-weather-note">{bucket.summary}. Замер по {monthWeather.city}. Источник: {monthWeather.source}.</p>
        </>
      ) : (
        <p class="pmu-answer">{bucket.summary}. Конкретные температуры — см. <a href="/seasons/" class="pmu-link">таблицу сезонов 70+ стран</a>.</p>
      )}
    </section>

    {/* SEZON-PRICE — конкретная цифра под месяц */}
    {flightMonth && d.price?.iata && (
      <section class="pmu-section">
        <div class="pmu-shead"><h2>Перелёт Москва — {d.cases.nom} в {m.prep}</h2></div>
        <div class="pmu-price">
          <div class="pmu-price-main">от <b>${flightMonth}</b> в одну сторону</div>
          <div class="pmu-price-meta">База ${flightLow} × сезонный множитель {monthMult} ({rank.label.toLowerCase()})</div>
        </div>
        <p class="pmu-cta">
          <a class="pmu-aff" href={aviasalesRoute('MOW', d.price.iata, `packing_${d.slug.replaceAll('-', '_')}`)} rel="sponsored noopener" target="_blank">Найти билет Москва — {d.cases.nom}</a>
          
          <span class="pmu-trust">актуальные цены под твои даты · оплата картами РФ</span>
        </p>
      </section>
    )}

    {/* ЛИЧНЫЙ ОПЫТ — только если notes[monthIdx] или authorNote реально есть в repo */}
    {(personalMonthNote || authorOverall) && (
      <section class="pmu-section">
        <div class="pmu-shead"><h2>Личный опыт автора</h2></div>
        <div class="pmu-personal">
          {personalMonthNote && (
            <p class="pmu-personal-month">
              <b class="pmu-personal-mark">★ {monthCap} {d.cases.loc}, был лично</b><br />
              {personalMonthNote}
            </p>
          )}
          {!personalMonthNote && authorOverall && (
            <p class="pmu-personal-overall">
              <b class="pmu-personal-mark">★ {d.cases.nom} — личный опыт</b><br />
              {authorOverall}
            </p>
          )}
        </div>
      </section>
    )}

    {/* СОБЫТИЯ МЕСЯЦА — главный month-specific блок */}
    {monthEvents.length > 0 && (
      <section class="pmu-section">
        <div class="pmu-shead"><h2>События и праздники в {m.prep}</h2></div>
        <ul class="pmu-events">
          {monthEvents.map((e) => (
            <li class={`pmu-ev pmu-ev--${e.tag}`}>
              <span class={`pmu-tag pmu-tag--${e.tag}`}>{TAG_LABEL[e.tag] || e.tag}</span>
              <b class="pmu-ev-name">{e.name}</b>
              {e.dates && <span class="pmu-ev-dates"> · {e.dates}</span>}
              {e.note && <div class="pmu-ev-note">{e.note}</div>}
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* ОДЕЖДА */}
    <section class="pmu-section">
      <div class="pmu-shead"><h2>Одежда под погоду</h2></div>
      <ul class="pmu-list">
        {bucket.clothing.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    {/* АПТЕЧКА */}
    <section class="pmu-section">
      <div class="pmu-shead"><h2>Аптечка</h2></div>
      <ul class="pmu-list">
        {bucket.health.map((item) => <li>{item}</li>)}
      </ul>
      <p class="pmu-note">Общий список — детали у врача за 3+ недели до вылета. Источники: <a href="https://www.rospotrebnadzor.ru/" target="_blank" rel="noopener">Роспотребнадзор</a>, <a href="https://www.who.int/" target="_blank" rel="noopener">ВОЗ</a>.</p>
    </section>

    {/* СНАРЯЖЕНИЕ */}
    {bucket.gear?.length > 0 && (
      <section class="pmu-section">
        <div class="pmu-shead"><h2>Снаряжение</h2></div>
        <ul class="pmu-list">
          {bucket.gear.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    )}

    {/* ДОКУМЕНТЫ + CTA */}
    <section class="pmu-section">
      <div class="pmu-shead"><h2>Документы и деньги</h2></div>
      <ul class="pmu-list">
        <li><b>Загранпаспорт</b> — срок действия 6+ месяцев на момент въезда.</li>
        {needsVisa && visa && (<li><b>Виза:</b> {visa.duration}, {visa.cost}, {visa.timing}. <a href={`/visa/${d.slug}/`} class="pmu-link">детали визы</a></li>)}
        {!needsVisa && (<li><b>Виза не нужна</b> — {visa?.duration || 'безвизовый въезд'}.</li>)}
        <li><b>Карты:</b> Visa/MC российских банков не работают. UnionPay / МИР / иностранные — <a href="/cards/" class="pmu-link">карта платёжных систем</a>.</li>
        <li><b>Наличные:</b> $200–300 USD/EUR на непредвиденные.</li>
      </ul>
      {flightLow && d.price?.iata && (
        <p class="pmu-cta">
          <a class="pmu-aff" href={aviasalesRoute('MOW', d.price.iata, `packing_${d.slug.replaceAll('-', '_')}`)} rel="sponsored noopener" target="_blank">Найти билет Москва — {d.cases.nom} от ${flightLow}</a>
          
          <span class="pmu-trust">все авиакомпании в одной выдаче · оплата картами РФ</span>
        </p>
      )}
      <p class="pmu-cta">
        <a class="pmu-aff" href={TP_LINKS.cherehapa} rel="sponsored noopener" target="_blank">Оформить страховку {d.cases.vP}</a>
        
        <span class="pmu-trust">сравнение цен · оплата картами РФ</span>
      </p>
    </section>

    {/* ТЕХНИКА И СВЯЗЬ */}
    <section class="pmu-section">
      <div class="pmu-shead"><h2>Техника и связь</h2></div>
      <ul class="pmu-list">
        {plug && (<li><b>Переходник Type {plug.types}</b> · {plug.voltage} · {plug.hz}. {plugAdvice(plug)}</li>)}
        <li><b>Повербанк</b> 10 000 мА·ч в ручную кладь.</li>
