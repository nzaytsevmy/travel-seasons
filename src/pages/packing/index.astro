---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { DIRECTIONS } from '../../data/directions.js';
import { DATA_UPDATED_RU } from '../../data/meta.js';

const url = 'https://traveltribe.ru/packing/';
const title = 'Что взять в поездку 2026 — чек-листы по 70 странам';
const description = 'Чек-листы по странам и месяцам: одежда по погоде, документы, аптечка, техника. Реальные данные сезонов, виз и партнёрских ссылок. Обновлено ' + DATA_UPDATED_RU + '.';

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#page`,
      "name": title,
      "description": description,
      "url": url,
      "inLanguage": "ru-RU",
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Чек-листы", "item": url },
      ],
    },
  ],
};

// Группируем страны по `group`, считаем «лучшие» месяцы (P+G) для подсказки
const grouped = {};
for (const d of DIRECTIONS) {
  const g = d.group || 'Прочее';
  if (!grouped[g]) grouped[g] = [];
  const bestMonths = d.r.filter(s => s === 'P' || s === 'G').length;
  grouped[g].push({ ...d, bestMonths });
}
// Отсортируем страны внутри группы по числу «хороших» месяцев убыванию (релевантность)
for (const g in grouped) grouped[g].sort((a, b) => b.bestMonths - a.bestMonths || a.cases.nom.localeCompare(b.cases.nom));

const groupOrder = ['Азия', 'Юго-Восточная Азия', 'Океания', 'Африка', 'Ближний Восток', 'Европа', 'Северная Америка', 'Латинская Америка', 'Южная Америка', 'Полярные'];
const sortedGroups = Object.keys(grouped).sort((a, b) => {
  const ia = groupOrder.indexOf(a), ib = groupOrder.indexOf(b);
  return (ia === -1 ? 99 : ia) - (ib === -1 ? 99 : ib);
});
const totalCountries = DIRECTIONS.length;
---
<Layout title={title} description={description} canonical={url} ldJson={ldJson}>
  <Nav active="packing" />
  <Breadcrumbs crumbs={[{ label: 'Чек-листы' }]} />

  <main id="main" class="pl-wrap">
    <header class="pl-hero">
      <p class="pl-eyebrow">// Чек-листы</p>
      <h1 class="pl-h1">Что взять в поездку</h1>
      <p class="pl-lead">
        <strong>{totalCountries} стран × 12 месяцев</strong> — конкретный список под твою погоду:
        одежда, документы, аптечка, техника, переходник под розетку. Без воды.
      </p>
      <p class="pl-fresh">Обновлено {DATA_UPDATED_RU}.</p>
    </header>

    {sortedGroups.map((g) => (
      <section class="pl-group">
        <div class="pl-group-head">
          <span class="pl-group-label">{g}</span>
          <span class="pl-group-count">{grouped[g].length}</span>
        </div>
        <ul class="pl-countries">
          {grouped[g].map((d) => (
            <li class="pl-country">
              <a href={`/packing/${d.slug}/`}>
                <span class="pl-flag" aria-hidden="true">{d.visual.emoji}</span>
                <span class="pl-name">{d.cases.nom}</span>
                <span class="pl-meta">{d.bestMonths > 0 ? `${d.bestMonths} мес` : '—'}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </main>

  <Footer />
</Layout>

<style>
.pl-wrap { max-width: 980px; margin: 0 auto; padding: 0 2rem 5rem; }

/* Hero — editorial, без картинки */
.pl-hero { text-align: center; margin: 2.5rem 0 3rem; padding-bottom: 2.5rem; border-bottom: 1px solid var(--line); }
.pl-eyebrow {
  font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 0.6rem;
}
.pl-h1 {
  font-family: var(--ff-display);
  font-size: clamp(2.4rem, 5.5vw, 3.8rem);
  font-weight: 300; line-height: 1.05; letter-spacing: -0.02em;
  margin: 0;
}
.pl-lead {
  color: var(--text-dim); font-size: 1.05rem; line-height: 1.65;
  max-width: 620px; margin: 1.2rem auto 0;
}
.pl-lead strong { color: var(--text); font-weight: 600; }
.pl-fresh { color: var(--text-faint); font-size: 0.85rem; margin: 0.5rem 0 0; }

/* Groups — editorial с small-caps eyebrow */
.pl-group { margin-bottom: 2.5rem; }
.pl-group-head {
  display: flex; align-items: baseline; justify-content: space-between;
  border-bottom: 1px solid var(--line); padding-bottom: 0.5rem;
  margin-bottom: 0.5rem;
}
.pl-group-label {
  font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--gold);
}
.pl-group-count {
  font-family: var(--ff-mono);
  font-size: 0.7rem; color: var(--text-faint);
}

/* Country list — hairline-grid, без gradient-cards */
.pl-countries {
  list-style: none; padding: 0; margin: 0;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}
.pl-country { margin: 0; }
.pl-country a {
  display: grid;
  grid-template-columns: 1.6rem 1fr auto;
  align-items: center;
  gap: 0.7rem;
  padding: 0.7rem 0.8rem 0.7rem 0.2rem;
  border-bottom: 1px solid var(--line);
  text-decoration: none;
  color: var(--text);
  transition: background 0.12s, padding-left 0.12s;
}
.pl-country a:hover {
  background: rgba(201, 151, 58, 0.04);
  padding-left: 0.5rem;
}
.pl-flag { font-size: 1.05rem; line-height: 1; opacity: 0.85; }
.pl-name { font-size: 0.95rem; font-weight: 500; line-height: 1.3; }
.pl-meta {
  font-family: var(--ff-mono);
  font-size: 0.72rem; color: var(--text-faint);
}
.pl-country a:hover .pl-meta { color: var(--gold); }

@media (min-width: 720px) {
  .pl-countries > li + li { border-left: 1px solid var(--line); }
  .pl-countries > li:nth-child(2n+1) { border-left: none; }
}
@media (min-width: 980px) {
  .pl-countries { grid-template-columns: repeat(3, 1fr); }
  .pl-countries > li:nth-child(3n+1) { border-left: none; }
  .pl-countries > li:nth-child(3n+2) { border-left: 1px solid var(--line); }
  .pl-countries > li:nth-child(3n+3) { border-left: 1px solid var(--line); }
}
</style>
