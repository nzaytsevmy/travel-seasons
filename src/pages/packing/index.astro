---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { DIRECTIONS } from '../../data/directions.js';
import { DATA_UPDATED_RU } from '../../data/meta.js';
import { getWeatherBucket } from '../../data/country-month-bucket.js';
import { WEATHER_BUCKETS } from '../../data/packing-weather-buckets.js';
import { PLUG_TYPES } from '../../data/country-plug-types.js';

const url = 'https://traveltribe.ru/packing/';
const title = 'Что взять в поездку 2026 — чек-листы по 70 странам';
const description = 'Готовые чек-листы упаковки: одежда под климат, документы, аптечка, техника — по 70 направлениям. Превью пунктов прямо на странице. Обновлено ' + DATA_UPDATED_RU + '.';

// Топ-10 направлений 2026 (по трафику @traveltriberu + общему спросу россиян)
const TOP_SLUGS = ['japan', 'thailand', 'georgia', 'turkey', 'uae', 'bali', 'sri-lanka', 'uzbekistan', 'vietnam', 'maldives'];

// Bucket → короткий tag для пилюли на карточке
const BUCKET_TAG = {
  'tropical-rainy':   'Тропики, дождь',
  'tropical-dry':     'Тропики, сухо',
  'tropical-jungle':  'Джунгли, сафари',
  'desert-hot':       'Пустыня, жара',
  'desert-cool':      'Пустыня, прохладно',
  'temperate-warm':   'Умеренный, тепло',
  'temperate-cold':   'Умеренный, холод',
  'cold-extreme':     'Полярный холод',
  'mountain-altitude':'Высокогорье',
};

const VISA_LABEL = {
  'free':     'Без визы',
  'evisa':    'E-виза',
  'arrival':  'По прилёте',
  'required': 'Виза',
};
const BUDGET_LABEL = { 'low': '₽', 'mid': '₽₽', 'high': '₽₽₽' };

// Для страны — primary bucket (по peak/good месяцу). Если ничего нет — июль.
function getPrimaryBucket(d) {
  let idx = d.r ? d.r.findIndex(s => s === 'P') : -1;
  if (idx < 0 && d.r) idx = d.r.findIndex(s => s === 'G');
  if (idx < 0) idx = 6;
  const key = getWeatherBucket(d.slug, idx);
  return { key, bucket: WEATHER_BUCKETS[key] || WEATHER_BUCKETS['temperate-warm'], monthIdx: idx };
}

// Превью: по одному пункту из 4 категорий + сокращение объяснения
function trimItem(s) {
  return s
    .replace(/^[⚠️\s]+/u, '')                  // снять ⚠️ в начале
    .replace(/\s*\([^)]*\)\s*$/, '')           // (пояснение) в конце
    .replace(/\s*—\s.*$/, '')                  // — комментарий
    .trim();
}
function getPreview(bucket, slug) {
  const out = [];
  if (bucket.clothing?.[0]) out.push({ cat: 'Одежда',     text: trimItem(bucket.clothing[0]) });
  if (bucket.gear?.[0])     out.push({ cat: 'Снаряжение', text: trimItem(bucket.gear[0]) });
  if (bucket.health?.[0])   out.push({ cat: 'Аптечка',    text: trimItem(bucket.health[0]) });
  // Техника — country-specific (тип розетки), уникальна для каждой страны
  const plug = PLUG_TYPES[slug];
  if (plug?.types) {
    const voltageHint = plug.voltage && plug.voltage !== '230 V' ? `, ${plug.voltage}` : '';
    out.push({ cat: 'Техника', text: `Адаптер тип ${plug.types}${voltageHint} + power bank` });
  } else if (bucket.tech?.[0]) {
    out.push({ cat: 'Техника', text: trimItem(bucket.tech[0]) });
  }
  return out;
}

// Топ-10 с превью
const top10 = TOP_SLUGS
  .map(slug => DIRECTIONS.find(d => d.slug === slug))
  .filter(Boolean)
  .map(d => {
    const { key, bucket } = getPrimaryBucket(d);
    return { d, bucketKey: key, tag: BUCKET_TAG[key] || '', preview: getPreview(bucket, d.slug) };
  });

// Все 70 — алфавит, для search-фильтра
const allCountries = DIRECTIONS
  .map(d => {
    const { key } = getPrimaryBucket(d);
    return {
      slug: d.slug,
      name: d.cases?.nom || d.region,
      visa: d.visa || '',
      budget: d.budget || '',
      tag: BUCKET_TAG[key] || '',
      bucketKey: key,
    };
  })
  .sort((a, b) => a.name.localeCompare(b.name, 'ru'));

const totalCountries = DIRECTIONS.length;

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#page`,
      "name": title,
      "description": description,
      "url": url,
      "inLanguage": "ru-RU",
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Чек-листы", "item": url },
      ],
    },
    {
      "@type": "ItemList",
      "@id": `${url}#top10`,
      "name": "Топ-10 направлений 2026",
      "itemListElement": top10.map((t, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": t.d.cases.nom,
        "url": `https://traveltribe.ru/packing/${t.d.slug}/`,
      })),
    },
  ],
};
---
<Layout title={title} description={description} canonical={url} ldJson={ldJson}>
  <Nav active="packing" />
  <Breadcrumbs crumbs={[{ label: 'Чек-листы' }]} />

  <main id="main" class="pl-wrap">
    <header class="pl-hero">
      <h1 class="pl-h1">Что взять в поездку</h1>
      <p class="pl-deck">
        Готовые чек-листы упаковки по <strong>{totalCountries} направлениям</strong>:
        одежда под климат конкретного месяца, документы, аптечка, техника.
        Собирал из своих маршрутов — что реально доставал из чемодана, что осталось лежать.
      </p>
      <p class="pl-fresh">Обновлено {DATA_UPDATED_RU}</p>
    </header>

    <nav class="pl-crosslinks" aria-label="Смежные задачи">
      <a href="/seasons/" class="pl-crosslink">
        <span class="pl-crosslink-q">Куда ехать в этом месяце?</span>
        <span class="pl-crosslink-a">Календарь сезонов</span>
      </a>
      <a href="/calculator/" class="pl-crosslink">
        <span class="pl-crosslink-q">Сколько стоит поездка?</span>
        <span class="pl-crosslink-a">Калькулятор бюджета</span>
      </a>
      <a href="/visa/" class="pl-crosslink">
        <span class="pl-crosslink-q">Нужна ли виза?</span>
        <span class="pl-crosslink-a">База виз 2026</span>
      </a>
    </nav>

    <section class="pl-section">
      <header class="pl-section-head">
        <h2 class="pl-section-title editorial-h2">Топ-10 направлений</h2>
        <p class="pl-section-meta">Самые частые запросы — с превью чек-листа</p>
      </header>

      <ul class="pl-top-grid">
        {top10.map(({ d, tag, preview }) => (
          <li>
            <a href={`/packing/${d.slug}/`} class="pl-top-card">
              <div class="pl-top-head">
                <h3 class="pl-top-name">{d.cases.nom}</h3>
                <span class="pl-top-tag">{tag}</span>
              </div>
              <ul class="pl-top-preview">
                {preview.map(p => (
                  <li class="pl-top-preview-item">
                    <span class="pl-preview-cat">{p.cat}</span>
                    <span class="pl-preview-text">{p.text}</span>
                  </li>
                ))}
              </ul>
              <span class="pl-top-cta">Полный чек-лист<span class="pl-arr" aria-hidden="true">→</span></span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="pl-section pl-all">
      <header class="pl-section-head">
        <h2 class="pl-section-title editorial-h2">Все {totalCountries} направлений</h2>
        <p class="pl-section-meta">По алфавиту, с поиском</p>
      </header>

      <label class="pl-search" for="pl-search-input">
        <svg class="pl-search-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
          <circle cx="7" cy="7" r="5" fill="none" stroke="currentColor" stroke-width="1.5"/>
          <line x1="11" y1="11" x2="15" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <input
          id="pl-search-input"
          type="search"
          class="pl-search-input"
          placeholder="Найти страну: Япония, Бали, Грузия…"
          aria-label="Поиск страны"
          autocomplete="off"
          spellcheck="false"
        />
        <span class="pl-search-count" id="pl-search-count">{allCountries.length} стран</span>
      </label>

      <ul class="pl-all-list" id="pl-all-list">
        {allCountries.map(c => (
          <li class="pl-all-item" data-name={c.name.toLowerCase().replace(/ё/g, 'е')}>
            <a href={`/packing/${c.slug}/`} class="pl-all-link">
              <span class="pl-all-name">{c.name}</span>
              <span class="pl-all-tag">{c.tag}</span>
              <span class="pl-all-badges">
                {c.visa && <span class={`pl-badge pl-badge-visa pl-badge-visa-${c.visa}`}>{VISA_LABEL[c.visa] || c.visa}</span>}
                {c.budget && BUDGET_LABEL[c.budget] && <span class="pl-badge pl-badge-budget">{BUDGET_LABEL[c.budget]}</span>}
              </span>
            </a>
          </li>
        ))}
      </ul>
      <p class="pl-empty" id="pl-empty" hidden>
        Не нашёл подходящего. Проверь раскладку или короче запрос.
        Если страны нет — напиши в <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a>.
      </p>
    </section>

    <aside class="pl-footnote">
      <p>
        Чек-листы собраны по моим заметкам с маршрутов и базе климата
        (Open-Meteo). Один лист = одна страна + конкретный месяц поездки —
        упаковка под Японию в декабре сильно отличается от Японии в апреле.
      </p>
    </aside>
  </main>

  <script is:inline>
    (() => {
      const input  = document.getElementById('pl-search-input');
      const list   = document.getElementById('pl-all-list');
      const count  = document.getElementById('pl-search-count');
      const empty  = document.getElementById('pl-empty');
      if (!input || !list || !count || !empty) return;
      const items = Array.from(list.querySelectorAll('.pl-all-item'));
      const total = items.length;

      function normalize(s) {
        return s.toLowerCase().replace(/ё/g, 'е').trim();
      }

      function applyFilter() {
        const q = normalize(input.value);
        let visible = 0;
        for (const item of items) {
          const match = !q || item.dataset.name.includes(q);
          item.hidden = !match;
          if (match) visible++;
        }
        count.textContent = visible === total ? `${total} стран` : `${visible} из ${total}`;
        empty.hidden = visible > 0;
      }

      input.addEventListener('input', applyFilter);
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') { input.value = ''; applyFilter(); input.blur(); }
      });

      // "/" фокусит поиск (как в GitHub/Wikipedia)
      document.addEventListener('keydown', (e) => {
        if (e.key === '/' && document.activeElement !== input &&
            !['INPUT','TEXTAREA'].includes(document.activeElement?.tagName)) {
          e.preventDefault(); input.focus();
        }
      });
    })();
  </script>

  <Footer />
</Layout>

<style>
.pl-wrap { max-width: 1080px; margin: 0 auto; padding: 0 var(--container-edge) 5rem; }

/* ─── HERO ─── editorial, light-weight display serif */
.pl-hero {
  margin: 2.5rem 0 2.5rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--line);
}
.pl-h1 {
  font-family: var(--ff-display);
  font-size: clamp(2.6rem, 6vw, 4.2rem);
  font-weight: 300;
  line-height: 1.02;
  letter-spacing: -0.025em;
  margin: 0;
  color: var(--text);
}
.pl-deck {
  color: var(--text-dim);
  font-size: 1.05rem;
  line-height: 1.65;
  max-width: 62ch;
  margin: 1.2rem 0 0;
}
.pl-deck strong { color: var(--text); font-weight: 600; }
.pl-fresh {
  color: var(--text-faint);
  font-family: var(--ff-mono);
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin: 1.2rem 0 0;
}

/* ─── CROSS-LINKS ─── 3 carded "это другая задача" */
.pl-crosslinks {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.65rem;
  margin: 0 0 3rem;
}
@media (min-width: 720px) {
  .pl-crosslinks { grid-template-columns: repeat(3, 1fr); }
}
.pl-crosslink {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  padding: 0.95rem 1.1rem;
  background: rgba(201, 151, 58, 0.04);
  border: 1px solid var(--line);
  border-left: 3px solid var(--gold);
  border-radius: 4px;
  text-decoration: none;
  color: var(--text);
  transition: background 0.15s var(--ease-out), transform 0.15s var(--ease-out);
}
.pl-crosslink:hover {
  background: rgba(201, 151, 58, 0.09);
  transform: translateX(2px);
}
.pl-crosslink-q { font-size: 0.95rem; font-weight: 500; color: var(--text); line-height: 1.3; }
.pl-crosslink-a {
  font-family: var(--ff-mono);
  font-size: 0.7rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--gold);
}

/* ─── SECTION head ─── editorial h2 + meta */
.pl-section { margin: 3rem 0 0; scroll-margin-top: 90px; }
.pl-section-head {
  margin-bottom: 1.2rem;
  padding-bottom: 0.7rem;
  border-bottom: 1px solid var(--line);
}
.pl-section-title {
  font-family: var(--ff-display);
  font-size: clamp(1.5rem, 2.6vw, 1.9rem);
  font-weight: 400;
  letter-spacing: -0.01em;
  line-height: 1.15;
  margin: 0;
  color: var(--text);
}
.pl-section-meta {
  font-family: var(--ff-mono);
  font-size: 0.7rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-faint);
  margin: 0.4rem 0 0;
}

/* ─── TOP-10 GRID ─── большие карточки с превью списка */
.pl-top-grid {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.5rem;
}
@media (min-width: 720px) {
  .pl-top-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 980px) {
  .pl-top-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem 1rem;
  }
}
.pl-top-grid > li { margin: 0; display: flex; }

.pl-top-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
  padding: 1.4rem 1.4rem 1.2rem;
  background: rgba(255, 251, 240, 0.55);
  border: 1px solid var(--line);
  border-radius: 4px;
  text-decoration: none;
  color: var(--text);
  transition: background 0.18s var(--ease-out), border-color 0.18s var(--ease-out), transform 0.18s var(--ease-out);
  position: relative;
}
.pl-top-card:hover {
  background: rgba(201, 151, 58, 0.06);
  border-color: rgba(201, 151, 58, 0.4);
  transform: translateY(-2px);
}

.pl-top-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  border-bottom: 1px solid var(--line);
  padding-bottom: 0.7rem;
}
.pl-top-name {
  font-family: var(--ff-display);
  font-size: 1.45rem;
  font-weight: 400;
  letter-spacing: -0.01em;
  line-height: 1.15;
  margin: 0;
  color: var(--text);
}
.pl-top-tag {
  font-family: var(--ff-mono);
  font-size: 0.66rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--gold);
  white-space: nowrap;
  text-align: right;
}

.pl-top-preview {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.pl-top-preview-item {
  display: grid;
  grid-template-columns: 88px 1fr;
  gap: 0.7rem;
  align-items: start;
  font-size: 0.88rem;
  line-height: 1.45;
}
.pl-preview-cat {
  font-family: var(--ff-mono);
  font-size: 0.66rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-faint);
  padding-top: 0.15rem;
}
.pl-preview-text { color: var(--text-dim); }

.pl-top-cta {
  margin-top: auto;
  padding-top: 0.6rem;
  font-family: var(--ff-mono);
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--gold);
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  border-top: 1px dashed var(--line);
}
.pl-arr { transition: transform 0.18s var(--ease-out); display: inline-block; }
.pl-top-card:hover .pl-arr { transform: translateX(3px); }

/* ─── SEARCH ─── чистый input с иконкой, без shadow */
.pl-search {
  display: flex;
  align-items: center;
  gap: 0.7rem;
  padding: 0.85rem 1rem;
  background: rgba(255, 251, 240, 0.7);
  border: 1px solid var(--line);
  border-radius: 4px;
  margin-bottom: 1rem;
  transition: border-color 0.15s var(--ease-out);
}
.pl-search:focus-within {
  border-color: var(--gold);
  background: rgba(255, 251, 240, 1);
}
.pl-search-icon { color: var(--text-faint); flex-shrink: 0; }
.pl-search-input {
  flex: 1;
  border: 0;
  outline: 0;
  background: transparent;
  font-family: var(--ff-sans);
  font-size: 1rem;
  color: var(--text);
  min-width: 0;
}
.pl-search-input::placeholder { color: var(--text-faint); }
.pl-search-input::-webkit-search-cancel-button { -webkit-appearance: none; appearance: none; }
.pl-search-count {
  font-family: var(--ff-mono);
  font-size: 0.7rem;
  letter-spacing: 0.04em;
  color: var(--text-faint);
  white-space: nowrap;
}

/* ─── ALL-LIST ─── компактный, без strip, со значками визы/бюджета */
.pl-all-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: 1fr;
  border-top: 1px solid var(--line);
}
.pl-all-item {
  margin: 0;
  border-bottom: 1px solid var(--line);
  display: flex;
}
/* HTML hidden attribute должен побеждать display: flex для search-filter */
.pl-all-item[hidden] { display: none !important; }
@media (min-width: 720px) {
  .pl-all-list { grid-template-columns: 1fr 1fr; }
  .pl-all-item:nth-child(odd)  { border-right: 1px solid var(--line); }
}
@media (min-width: 980px) {
  .pl-all-list { grid-template-columns: repeat(3, 1fr); }
  .pl-all-item:nth-child(odd)  { border-right: none; }
  .pl-all-item:not(:nth-child(3n)) { border-right: 1px solid var(--line); }
}

.pl-all-link {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr auto;
  grid-template-rows: auto auto;
  gap: 0.15rem 0.7rem;
  padding: 0.85rem 1.1rem;
  text-decoration: none;
  color: var(--text);
  transition: background 0.15s var(--ease-out);
}
.pl-all-link:hover { background: rgba(201, 151, 58, 0.05); }
.pl-all-name {
  font-size: 0.95rem;
  font-weight: 500;
  line-height: 1.3;
  color: var(--text);
}
.pl-all-tag {
  grid-column: 1;
  grid-row: 2;
  font-size: 0.74rem;
  color: var(--text-faint);
  line-height: 1.3;
}
.pl-all-badges {
  grid-column: 2;
  grid-row: 1 / span 2;
  display: inline-flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.2rem;
}
.pl-badge {
  font-family: var(--ff-mono);
  font-size: 0.62rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  padding: 0.15rem 0.4rem;
  border-radius: 2px;
  white-space: nowrap;
  line-height: 1.2;
}
.pl-badge-visa-free     { background: rgba(34, 197, 94, 0.12); color: #15803d; }
.pl-badge-visa-evisa    { background: rgba(74, 158, 255, 0.12); color: #1e40af; }
.pl-badge-visa-arrival  { background: rgba(74, 158, 255, 0.12); color: #1e40af; }
.pl-badge-visa-required { background: rgba(245, 158, 11, 0.14); color: #92400e; }
.pl-badge-budget {
  background: transparent;
  color: var(--text-faint);
  font-size: 0.7rem;
  letter-spacing: 0.02em;
  padding: 0.15rem 0;
}

