---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { DIRECTIONS } from '../../data/directions.js';
import { DATA_UPDATED_RU } from '../../data/meta.js';

const url = 'https://traveltribe.ru/packing/';
const title = 'Что взять в поездку 2026 — чек-листы по 70 странам';
const description = 'Чек-листы по странам и месяцам: одежда по погоде, документы, аптечка, техника. Реальные данные сезонов, виз и партнёрских ссылок. Обновлено ' + DATA_UPDATED_RU + '.';

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#page`,
      "name": title,
      "description": description,
      "url": url,
      "inLanguage": "ru-RU",
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Чек-листы", "item": url },
      ],
    },
  ],
};

// Группируем страны по `group`
const grouped = {};
for (const d of DIRECTIONS) {
  const g = d.group || 'Прочее';
  if (!grouped[g]) grouped[g] = [];
  grouped[g].push(d);
}
const groupOrder = ['Азия', 'Юго-Восточная Азия', 'Океания', 'Африка', 'Ближний Восток', 'Европа', 'Северная Америка', 'Латинская Америка', 'Южная Америка', 'Полярные'];
const sortedGroups = Object.keys(grouped).sort((a, b) => {
  const ia = groupOrder.indexOf(a), ib = groupOrder.indexOf(b);
  return (ia === -1 ? 99 : ia) - (ib === -1 ? 99 : ib);
});
---
<Layout title={title} description={description} canonical={url} ldJson={ldJson}>
  <Nav active="packing" />
  <Breadcrumbs crumbs={[{ label: 'Чек-листы' }]} />

  <main id="main" class="pack-landing">
    <header class="pack-landing-header">
      <p class="pack-eyebrow">// Чек-листы</p>
      <h1>Что взять в поездку</h1>
      <p class="lead">Выбери страну → потом месяц. Получишь конкретный чек-лист под погоду и активности: одежда, аптечка, техника, документы. <span class="fresh">Обновлено {DATA_UPDATED_RU}.</span></p>
    </header>

    {sortedGroups.map((g) => (
      <section class="pack-group">
        <h2>{g}</h2>
        <ul class="pack-cards">
          {grouped[g].map((d) => (
            <li class="pack-card">
              <a href={`/packing/${d.slug}/`} style={`--g1:${d.visual.g1}; --g2:${d.visual.g2};`}>
                <span class="card-emoji" aria-hidden="true">{d.visual.emoji}</span>
                <span class="card-name">{d.cases.nom}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </main>

  <Footer />
</Layout>

<style>
.pack-landing { max-width: 980px; margin: 0 auto; padding: 0 2rem 5rem; }
.pack-landing-header { text-align: center; margin: 2.5rem 0 2.5rem; }
.pack-eyebrow {
  font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 0.5rem;
}
.pack-landing-header h1 {
  font-family: var(--ff-display); font-size: clamp(2.2rem, 5vw, 3.6rem);
  font-weight: 300; line-height: 1.1; margin: 0;
}
.lead { color: var(--text-dim); font-size: 1rem; line-height: 1.7; max-width: 600px; margin: 1rem auto 0; }
.fresh { color: var(--text-faint); }

.pack-group { margin-bottom: 2.5rem; }
.pack-group h2 {
  font-family: var(--ff-display); font-size: 1.2rem; font-weight: 400;
  color: var(--gold); margin-bottom: 1rem;
  text-transform: uppercase; letter-spacing: 0.06em;
}
.pack-cards {
  list-style: none; padding: 0; margin: 0;
  display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.7rem;
}
.pack-card a {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 100px; padding: 0.6rem; gap: 0.4rem;
  background: linear-gradient(135deg, var(--g1) 0%, var(--g2) 100%);
  border-radius: 6px; text-decoration: none;
  position: relative; overflow: hidden;
  transition: transform 0.15s;
}
.pack-card a::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.25), transparent 60%);
}
.pack-card a:hover { transform: translateY(-2px); }
.card-emoji { font-size: 1.8rem; z-index: 1; filter: drop-shadow(0 2px 6px rgba(0,0,0,0.15)); }
.card-name { z-index: 1; color: rgba(0,0,0,0.85); font-size: 0.85rem; font-weight: 500; text-align: center; }
</style>
