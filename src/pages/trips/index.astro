---
// Хаб «Куда поехать по месяцам» — Swiss / International Typographic по BRANDBOOK.md.
// Самодостаточный scoped-визуал: свои токены, только hairlines, один акцент gold, без эмодзи.
import '@fontsource-variable/golos-text/index.css';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { DIRECTIONS } from '../../data/directions.js';
import { DATA_UPDATED_RU } from '../../data/meta.js';

const MONTHS = [
  { slug: 'january',   nom: 'Январь',   prep: 'январе',   short: 'Янв' },
  { slug: 'february',  nom: 'Февраль',  prep: 'феврале',  short: 'Фев' },
  { slug: 'march',     nom: 'Март',     prep: 'марте',    short: 'Мар' },
  { slug: 'april',     nom: 'Апрель',   prep: 'апреле',   short: 'Апр' },
  { slug: 'may',       nom: 'Май',      prep: 'мае',      short: 'Май' },
  { slug: 'june',      nom: 'Июнь',     prep: 'июне',     short: 'Июн' },
  { slug: 'july',      nom: 'Июль',     prep: 'июле',     short: 'Июл' },
  { slug: 'august',    nom: 'Август',   prep: 'августе',  short: 'Авг' },
  { slug: 'september', nom: 'Сентябрь', prep: 'сентябре', short: 'Сен' },
  { slug: 'october',   nom: 'Октябрь',  prep: 'октябре',  short: 'Окт' },
  { slug: 'november',  nom: 'Ноябрь',   prep: 'ноябре',   short: 'Ноя' },
  { slug: 'december',  nom: 'Декабрь',  prep: 'декабре',  short: 'Дек' },
];

const plural = (n) => (n % 10 === 1 && n % 100 !== 11 ? 'направление' : (n % 10 >= 2 && n % 10 <= 4 && (n % 100 < 10 || n % 100 >= 20) ? 'направления' : 'направлений'));

// Для каждого месяца: топ-пик-направления (имена) + сколько всего в сезоне (P или G).
const monthSummary = MONTHS.map((m, i) => {
  const peak = DIRECTIONS.filter(d => d.r[i] === 'P').map(d => d.cases.nom);
  const totalGood = DIRECTIONS.filter(d => d.r[i] === 'P' || d.r[i] === 'G').length;
  return { ...m, peak, totalGood };
});

const curIdx = new Date().getMonth();   // месяц сборки = «сейчас»
const cur = monthSummary[curIdx];

const faqs = [
  {
    q: 'Как выбрать месяц для поездки в 2026?',
    a: 'Открой нужный месяц — для каждого собраны направления с пиком сезона, хорошей погодой, ценой перелёта из Москвы и визовым режимом для россиян. Сначала смотри блок «Пик сезона»: там погода и инфраструктура работают на 100%.',
  },
  {
    q: 'В каком месяце дешевле всего путешествовать?',
    a: 'Цена зависит не от месяца вообще, а от связки направление + сезон: низкий сезон в конкретной стране даёт перелёт и отели на 20–30% дешевле пика. На странице каждого месяца дешёвые перелёты подсвечены.',
  },
  {
    q: 'Где смотреть визу и бюджет по месяцу?',
    a: 'На странице месяца у каждого направления указан визовый режим для россиян и ориентир бюджета на день. Точную сумму под свои даты считает калькулятор бюджета.',
  },
];

const url = 'https://traveltribe.ru/trips/';
const title = 'Куда поехать по месяцам 2026 — календарь';
const description = 'Календарь поездок 2026: где сезон в каждом месяце года для россиян. 70 направлений, актуальные цены, виза и бюджет — выбери свой месяц.';

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${url}#webpage`,
      "url": url,
      "name": title,
      "description": description,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Календарь поездок", "item": url }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    },
    {
      "@type": "ItemList",
      "name": "Месяцы для путешествий 2026",
      "numberOfItems": 12,
      "itemListElement": MONTHS.map((m, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": `Куда поехать в ${m.prep}`,
        "url": `https://traveltribe.ru/trips/${m.slug}/`
      }))
    }
  ]
};
---
<Layout
  title={title}
  description={description}
  canonical={url}
  ogTitle="Календарь поездок 2026 — куда лететь по месяцам"
  ogDescription={description}
  ldJson={ldJson}
>
  <Breadcrumbs crumbs={[{ label: 'Календарь поездок' }]} />

  <main id="main" class="sw">
    <div class="wrap">
      <header class="hero grid">
        <div class="idx">Календарь поездок<b>12 месяцев · 2026</b></div>
        <div class="meta">Сезоны и визы<br><b>актуальны на {DATA_UPDATED_RU}</b></div>
        <h1 class="h1">Куда поехать <span class="rd">по месяцам</span></h1>
        <p class="sub">Отпуск в марте? Планируешь декабрь? Выбери месяц — покажу, где сейчас пик сезона, цены на перелёт из Москвы и какая нужна виза. 70 направлений, реальные данные.</p>
        <p class="byl">
          <a href="/about/" class="byl-a">Никита Зайцев</a> ·
          <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> ·
          <span>был лично на 7 континентах</span>
        </p>
      </header>

      <section class="sec">
        <div class="shead">
          <h2><span class="no">00</span>Сейчас — {cur.nom} 2026</h2>
          <a href={`/trips/${cur.slug}/`}>Все направления {cur.prep} →</a>
        </div>
        <p class="lead"><b>{cur.totalGood}</b> {plural(cur.totalGood)} в сезоне {cur.prep}.{cur.peak.length ? ` На пике: ${cur.peak.slice(0, 6).join(', ')}.` : ''}</p>
      </section>

      <section class="sec">
        <div class="shead">
          <h2><span class="no">01</span>Все 12 месяцев</h2>
          <span class="cap">Сезон · виза · цены внутри</span>
        </div>
        <table class="mtbl">
          <thead><tr><th>Месяц</th><th class="num">В сезоне</th><th>На пике сезона</th><th class="r" aria-hidden="true"></th></tr></thead>
          <tbody>
            {monthSummary.map((m) => (
              <tr class={m.slug === cur.slug ? 'now' : undefined}>
                <td class="mname"><a href={`/trips/${m.slug}/`}>{m.nom}</a>{m.slug === cur.slug && <span class="tag">сейчас</span>}</td>
                <td class="num" data-l="В сезоне"><b>{m.totalGood}</b> <small>напр.</small></td>
                <td class="mpeak" data-l="Пик">{m.peak.slice(0, 4).join(', ') || '—'}</td>
                <td class="r"><a class="go" href={`/trips/${m.slug}/`}>Смотреть →</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section class="sec">
        <div class="shead"><h2><span class="no">02</span>Частые вопросы</h2></div>
        <div class="faq">
          {faqs.map(f => (
            <details class="fi">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </section>

      <section class="sec">
        <div class="shead"><h2><span class="no">03</span>Что ещё посмотреть</h2></div>
        <ul class="vl">
          <li><a href="/seasons/">Полная таблица сезонов</a><span>70 направлений × 12 месяцев в одной интерактивной таблице</span></li>
          <li><a href="/calculator/">Калькулятор бюджета</a><span>посчитать поездку с актуальным курсом ЦБ РФ</span></li>
          <li><a href="/packing/">Чек-листы поездок</a><span>что взять в каждую страну по сезону</span></li>
          <li><a href="/blog/schengen-visa-2026/">Шенгенская виза 2026</a><span>куда дают и где меньше отказов</span></li>
          <li><a href="/blog/hainan-guide-2026/">Хайнань без визы</a><span>гайд по Китаю с безвизом до 14.09.2026</span></li>
          <li><a href="/blog/japan-guide-2026/">Япония 2026</a><span>полный гайд по поездке</span></li>
        </ul>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Swiss-страница: тёплый фон только на этом маршруте */
  body { background: #f4f2eb; }
</style>

<style>
.sw{--paper:#f4f2eb;--ink:#1b1914;--mid:#6b685e;--line:#23211a;--hair:#cdc9bd;--gold:#8e6618;
  --ff:'Golos Text Variable','Golos Text',Helvetica,Arial,sans-serif;--edge:clamp(1.1rem,3vw,2.6rem);
  background:var(--paper);color:var(--ink);font-family:var(--ff);font-weight:400;line-height:1.4;
  font-variant-numeric:tabular-nums lining-nums;-webkit-font-smoothing:antialiased;padding-bottom:clamp(3rem,6vw,5rem)}
:where(.sw) :where(h1,h2,h3,h4,p,ul,li){margin:0}
.sw :where(h1,h2,h3,h4){font-family:var(--ff);color:var(--ink)}
.sw a{color:inherit;text-decoration:none}
.sw :focus-visible{outline:2px solid var(--gold);outline-offset:3px}
.wrap{max-width:1280px;margin-inline:auto;padding-inline:var(--edge)}
.grid{display:grid;grid-template-columns:repeat(12,minmax(0,1fr));gap:0 clamp(.8rem,2vw,1.6rem)}

/* Hero — асимметрия, flush-left */
.hero{padding:clamp(2rem,5vw,4rem) 0 clamp(1.2rem,2.5vw,2rem)}
.idx{grid-column:1/6;grid-row:1;font-size:.74rem;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--gold)}
.idx b{display:block;color:var(--ink);font-size:.74rem;font-weight:500;margin-top:.2rem}
.meta{grid-column:8/13;grid-row:1;text-align:right;align-self:start;font-size:.8rem;color:var(--mid);line-height:1.5}
.meta b{color:var(--ink);font-weight:500}
.h1{grid-column:1/13;grid-row:2;font-weight:700;font-size:clamp(2.4rem,7vw,6.4rem);line-height:1.02;letter-spacing:-.035em;margin-top:clamp(1.2rem,2.5vw,2rem);padding-bottom:.06em}
.h1 .rd{color:var(--gold)}
.sub{grid-column:1/9;grid-row:3;font-size:clamp(1rem,1.3vw,1.18rem);color:var(--ink);margin-top:clamp(1.4rem,2vw,1.8rem);max-width:52ch;line-height:1.55}
.byl{grid-column:1/13;grid-row:4;margin-top:1.4rem;font-size:.78rem;color:var(--mid)}
.byl a{color:var(--mid)}
.byl .byl-a{color:var(--gold);text-decoration:2px underline var(--gold);text-underline-offset:3px}

/* Секции */
.sec{padding:clamp(2.2rem,4.5vw,3.4rem) 0 0}
.shead{display:flex;align-items:center;justify-content:space-between;gap:1rem;border-top:2px solid var(--line);padding-top:.8rem;margin-bottom:1.2rem}
.shead h2{font-weight:700;font-size:clamp(1.4rem,2.6vw,2rem);letter-spacing:-.02em;display:flex;align-items:baseline;gap:.6rem}
.no{font-size:.74rem;font-weight:700;color:var(--gold);letter-spacing:.04em}
.shead a{font-size:.72rem;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--gold);text-decoration:2px underline var(--gold);text-underline-offset:4px;display:inline-flex;align-items:center;min-height:44px;white-space:nowrap}
.shead .cap{font-size:.64rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--mid)}
.lead{font-size:1.05rem;color:var(--ink);max-width:70ch;line-height:1.5}.lead b{color:var(--gold);font-weight:700}

/* Таблица месяцев */
.mtbl{width:100%;border-collapse:collapse;font-size:.92rem}
.mtbl thead th{font-size:.64rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--mid);text-align:left;padding:.5rem .8rem .55rem 0;border-bottom:1px solid var(--line)}
.mtbl thead th.num{width:8rem}.mtbl thead th.r{text-align:right;padding-right:0}
.mtbl td{padding:.9rem .8rem;border-bottom:1px solid var(--hair);vertical-align:baseline}
.mtbl td:first-child,.mtbl th:first-child{padding-left:0}
.mtbl td.r{text-align:right;padding-right:0}
.mtbl tr:last-child td{border-bottom:none}
@media(hover:hover){.mtbl tbody tr:hover td{background:rgba(142,102,24,.07)}}
.mname a{font-weight:700;font-size:1.15rem;letter-spacing:-.01em;color:var(--ink)}
.mname a:hover{color:var(--gold);text-decoration:2px underline var(--gold);text-underline-offset:3px}
.tag{margin-left:.55rem;font-size:.58rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--gold);vertical-align:1px}
.mtbl td.num{font-weight:700;font-size:1.05rem;color:var(--ink)}.mtbl td.num small{font-size:.7rem;color:var(--mid);font-weight:500}
.mpeak{color:var(--mid);font-size:.86rem;line-height:1.4}
.go{color:var(--ink);font-weight:600;white-space:nowrap;text-decoration:2px underline transparent;text-underline-offset:3px}
.go:hover{color:var(--gold);text-decoration-color:var(--gold)}
.mtbl tr.now td{background:rgba(142,102,24,.05)}
.mtbl tr.now .mname a{color:var(--gold)}

/* FAQ — hairline, не подушки */
.faq{border-top:1px solid var(--line)}
.fi{border-bottom:1px solid var(--hair)}
.fi summary{font-weight:600;font-size:1rem;color:var(--ink);padding:1rem 2rem 1rem 0;cursor:pointer;list-style:none;position:relative;line-height:1.4}
.fi summary::-webkit-details-marker{display:none}
.fi summary::after{content:'+';position:absolute;right:.2rem;top:.9rem;color:var(--gold);font-size:1.3rem;line-height:1}
.fi[open] summary::after{content:'−'}
.fi p{padding:0 0 1.1rem;color:var(--mid);line-height:1.7;font-size:.95rem;max-width:74ch}

/* Value-list «что ещё» */
.vl{list-style:none;border-top:1px solid var(--line)}
.vl li{display:flex;flex-wrap:wrap;align-items:baseline;gap:.2rem .7rem;padding:.85rem 0;border-bottom:1px solid var(--hair)}
.vl li:last-child{border-bottom:none}
.vl a{font-weight:600;font-size:1.02rem;color:var(--ink);text-decoration:2px underline var(--gold);text-underline-offset:3px}
.vl a:hover{color:var(--gold)}
.vl span{color:var(--mid);font-size:.86rem}

@media(max-width:760px){
  .idx,.h1,.sub,.meta,.byl{grid-column:1/-1;grid-row:auto}
  .meta{text-align:left;margin-top:.6rem}
  .h1{margin-top:1.1rem}
  /* Таблица месяцев → блоки */
  .mtbl thead{position:absolute;left:-9999px}
  .mtbl,.mtbl tbody,.mtbl tr,.mtbl td{display:block;width:100%}
  .mtbl tr{border-bottom:1px solid var(--hair);padding:.9rem 0}
  .mtbl tr:last-child{border-bottom:none}
  .mtbl td{border:none;padding:.1rem 0}
  .mtbl td.num{display:inline-block;font-size:.92rem}
  .mtbl td.num small{font-size:.7rem}
  .mtbl td.r{text-align:left;margin-top:.35rem}
  .mtbl tr.now td,.mtbl tr:hover td{background:none}
}
</style>
