---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { data as regions } from '../../data/regions.js';
import { PRICES } from '../../data/prices.js';
import fs from 'node:fs';
import path from 'node:path';

const MONTHS = [
  { slug: 'january',   name: 'январе',   nameNom: 'Январь',   short: 'Янв', en: 'January' },
  { slug: 'february',  name: 'феврале',  nameNom: 'Февраль',  short: 'Фев', en: 'February' },
  { slug: 'march',     name: 'марте',    nameNom: 'Март',     short: 'Мар', en: 'March' },
  { slug: 'april',     name: 'апреле',   nameNom: 'Апрель',   short: 'Апр', en: 'April' },
  { slug: 'may',       name: 'мае',      nameNom: 'Май',      short: 'Май', en: 'May' },
  { slug: 'june',      name: 'июне',     nameNom: 'Июнь',     short: 'Июн', en: 'June' },
  { slug: 'july',      name: 'июле',     nameNom: 'Июль',     short: 'Июл', en: 'July' },
  { slug: 'august',    name: 'августе',  nameNom: 'Август',   short: 'Авг', en: 'August' },
  { slug: 'september', name: 'сентябре', nameNom: 'Сентябрь', short: 'Сен', en: 'September' },
  { slug: 'october',   name: 'октябре',  nameNom: 'Октябрь',  short: 'Окт', en: 'October' },
  { slug: 'november',  name: 'ноябре',   nameNom: 'Ноябрь',   short: 'Ноя', en: 'November' },
  { slug: 'december',  name: 'декабре',  nameNom: 'Декабрь',  short: 'Дек', en: 'December' },
];

export async function getStaticPaths() {
  return [
    'january','february','march','april','may','june',
    'july','august','september','october','november','december'
  ].map(slug => ({ params: { month: slug } }));
}

const { month } = Astro.params;
const monthIdx = MONTHS.findIndex(m => m.slug === month);
const M = MONTHS[monthIdx];

const SCORE = { P: 4, G: 3, O: 2, B: 1, X: 0 };
const SCORE_LABEL = { P: 'Пик сезона', G: 'Хорошо', O: 'Терпимо', B: 'Плохо', X: 'Закрыто' };
const SCORE_CLASS = { P: 'peak', G: 'good', O: 'ok', B: 'bad', X: 'off' };
const VISA_LABEL = { free: 'Без визы', evisa: 'eVisa', required: 'Виза' };
const VISA_CLASS = { free: 'tag-free', evisa: 'tag-evisa', required: 'tag-visa' };
const BUDGET_LABEL = { low: '$ Дёшево', mid: '$$ Средне', high: '$$$ Дорого' };
const BUDGET_CLASS = { low: 'tag-low', mid: 'tag-mid', high: 'tag-high' };

// Match regions to PRICES by name fragment to get IATA + flight
const directions = regions.filter(r => !r.group);

// Read live prices at build time (public/ is accessible via fs)
let livePrices = {};
try {
  const pjson = JSON.parse(fs.readFileSync(path.resolve('./public/prices.json'), 'utf8'));
  livePrices = pjson.prices || {};
} catch (e) { /* fallback to estimates */ }

// Match each direction to PRICES[i] (best-effort by name)
function findPrice(d) {
  const norm = (s) => s.toLowerCase().replace(/[^a-zа-я0-9]/gi, '');
  const dn = norm(d.region) + norm(d.sub);
  return PRICES.find(p => {
    const pn = norm(p.name);
    return dn.includes(norm(p.name.split(' ')[0])) || pn.includes(norm(d.region));
  });
}

const enriched = directions.map(d => {
  const score = d.r[monthIdx];
  const text = d.t[monthIdx];
  const price = findPrice(d);
  const liveFlight = price?.iata && livePrices[price.iata];
  return {
    ...d,
    score,
    text,
    iata: price?.iata,
    flight: liveFlight || price?.flight?.[0],
    isLive: !!liveFlight,
  };
}).filter(d => d.score === 'P' || d.score === 'G' || d.score === 'O')
  .sort((a, b) => {
    const sA = SCORE[a.score], sB = SCORE[b.score];
    if (sA !== sB) return sB - sA;
    return (a.flight || 9999) - (b.flight || 9999);
  });

const peak = enriched.filter(d => d.score === 'P');
const good = enriched.filter(d => d.score === 'G');
const ok = enriched.filter(d => d.score === 'O');
const top = enriched.slice(0, 15);
const cheapest = [...enriched].filter(d => d.flight).sort((a, b) => a.flight - b.flight).slice(0, 5);
const visaFree = enriched.filter(d => d.visa === 'free').slice(0, 5);

// SEO
const title = `Куда поехать в ${M.name} 2026 — топ направлений`;
const description = `Куда лететь в ${M.name} 2026: ${peak.length} направлений с пиком сезона, актуальные цены на перелёт из Москвы, виза для россиян, бюджет на день. Без воды.`;
const url = `https://traveltribe.ru/trips/${month}/`;

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${url}#webpage`,
      "url": url,
      "name": title,
      "description": description,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "datePublished": "2026-04-30",
      "dateModified": "2026-04-30"
    },
    {
      "@type": "ItemList",
      "@id": `${url}#list`,
      "name": `Лучшие направления для путешествия в ${M.name} 2026`,
      "numberOfItems": top.length,
      "itemListElement": top.map((d, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "TouristDestination",
          "name": d.region,
          "description": d.sub
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Календарь поездок", "item": "https://traveltribe.ru/trips/" },
        { "@type": "ListItem", "position": 3, "name": M.nameNom, "item": url }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": `Куда лучше всего поехать в ${M.name} 2026?`,
          "acceptedAnswer": { "@type": "Answer", "text": `В пиковом сезоне сейчас ${peak.length} направлений: ${peak.slice(0, 5).map(d => d.region).join(', ')} и другие. Полный список с ценами и визами — на этой странице.` }
        },
        {
          "@type": "Question",
          "name": `Куда дешевле всего лететь в ${M.name}?`,
          "acceptedAnswer": { "@type": "Answer", "text": `Самые дешёвые перелёты из Москвы в ${M.name}: ${cheapest.slice(0, 3).map(d => `${d.region} от $${d.flight}`).join(', ')}. Цены обновляются ежедневно через TravelPayouts.` }
        },
        {
          "@type": "Question",
          "name": `Куда без визы в ${M.name}?`,
          "acceptedAnswer": { "@type": "Answer", "text": `Безвизовые направления для россиян с хорошим сезоном в ${M.name}: ${visaFree.slice(0, 5).map(d => d.region).join(', ')}.` }
        }
      ]
    }
  ]
};
---
<Layout
  title={title}
  description={description}
  canonical={url}
  ogTitle={`Куда поехать в ${M.name} 2026`}
  ogDescription={description}
  ldJson={ldJson}
>
  <Nav active="trips" />
  <Breadcrumbs crumbs={[
    { label: 'Календарь', href: '/trips/' },
    { label: M.nameNom }
  ]} />

  <main id="main" class="trips-wrap">
    <header class="trips-header">
      <div class="hero-tag">// Календарь · {M.nameNom} 2026</div>
      <h1>Куда поехать в <em>{M.name}</em></h1>
      <p class="trips-sub">{peak.length} направлений с пиком сезона · {good.length} с хорошей погодой · цены на перелёт обновлены {new Date().toLocaleDateString('ru-RU')}</p>
    </header>

    {peak.length > 0 && (
      <section class="trips-section">
        <h2>🔥 Пик сезона</h2>
        <p class="section-desc">Идеальная погода, всё открыто. Может быть многолюдно и дороже.</p>
        <div class="trips-grid">
          {peak.map(d => (
            <article class={`trip-card score-${SCORE_CLASS[d.score]}`}>
              <div class="trip-head">
                <h3>{d.region}</h3>
                <span class="score-pill">{SCORE_LABEL[d.score]}</span>
              </div>
              <p class="trip-sub">{d.sub}</p>
              <p class="trip-text">{d.text}</p>
              <div class="trip-tags">
                <span class={`tag ${VISA_CLASS[d.visa]}`}>{VISA_LABEL[d.visa]}</span>
                <span class={`tag ${BUDGET_CLASS[d.budget]}`}>{BUDGET_LABEL[d.budget]}</span>
                {d.flight && (
                  <span class="tag tag-flight">
                    {d.isLive ? '✈ ' : '~ '}от ${d.flight}
                  </span>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {good.length > 0 && (
      <section class="trips-section">
        <h2>✅ Хорошая погода</h2>
        <p class="section-desc">Комфортно, меньше туристов, ниже цены чем в пик.</p>
        <div class="trips-grid">
          {good.map(d => (
            <article class={`trip-card score-${SCORE_CLASS[d.score]}`}>
              <div class="trip-head">
                <h3>{d.region}</h3>
                <span class="score-pill">{SCORE_LABEL[d.score]}</span>
              </div>
              <p class="trip-sub">{d.sub}</p>
              <p class="trip-text">{d.text}</p>
              <div class="trip-tags">
                <span class={`tag ${VISA_CLASS[d.visa]}`}>{VISA_LABEL[d.visa]}</span>
                <span class={`tag ${BUDGET_CLASS[d.budget]}`}>{BUDGET_LABEL[d.budget]}</span>
                {d.flight && (
                  <span class="tag tag-flight">
                    {d.isLive ? '✈ ' : '~ '}от ${d.flight}
                  </span>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {ok.length > 0 && (
      <section class="trips-section">
        <h2>👌 Можно ехать</h2>
        <p class="section-desc">Сезон не идеальный, но если вы там по другим причинам — норм.</p>
        <div class="trips-grid">
          {ok.slice(0, 8).map(d => (
            <article class={`trip-card score-${SCORE_CLASS[d.score]}`}>
              <div class="trip-head">
                <h3>{d.region}</h3>
                <span class="score-pill">{SCORE_LABEL[d.score]}</span>
              </div>
              <p class="trip-sub">{d.sub}</p>
              <p class="trip-text">{d.text}</p>
              <div class="trip-tags">
                <span class={`tag ${VISA_CLASS[d.visa]}`}>{VISA_LABEL[d.visa]}</span>
                <span class={`tag ${BUDGET_CLASS[d.budget]}`}>{BUDGET_LABEL[d.budget]}</span>
                {d.flight && (
                  <span class="tag tag-flight">
                    {d.isLive ? '✈ ' : '~ '}от ${d.flight}
                  </span>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <section class="trips-section quick-picks">
      <h2>⚡️ Быстрый выбор</h2>
      <div class="picks-grid">
        <div class="pick-card">
          <h3>💸 Самые дешёвые</h3>
          <ul>
            {cheapest.map(d => (
              <li><strong>{d.region}</strong> — от ${d.flight}</li>
            ))}
          </ul>
        </div>
        <div class="pick-card">
          <h3>🛂 Без визы для россиян</h3>
          <ul>
            {visaFree.map(d => (
              <li><strong>{d.region}</strong> — {d.sub}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="trips-cta">
      <h2>Что делать дальше</h2>
      <ul class="cta-list">
        <li>📅 <a href="/trips/">Календарь на все 12 месяцев</a> — выбери другой месяц</li>
        <li>📊 <a href="/seasons/">Полная таблица сезонов</a> — все 39 направлений × 12 месяцев</li>
        <li>💸 <a href="/calculator/">Калькулятор бюджета</a> — посчитай поездку с актуальным курсом</li>
        <li>📲 <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> — оперативные обновления по визам и направлениям</li>
      </ul>
    </section>

    <nav class="month-nav" aria-label="Другие месяцы">
      <p class="month-nav-label">// Другие месяцы:</p>
      <div class="month-pills">
        {MONTHS.map((m, i) => (
          <a
            href={`/trips/${m.slug}/`}
            class={`month-pill ${m.slug === month ? 'active' : ''}`}
            aria-current={m.slug === month ? 'page' : undefined}
          >
            {m.short}
          </a>
        ))}
      </div>
    </nav>
  </main>

  <Footer />
</Layout>

<style>
.trips-wrap { max-width: 1200px; margin: 0 auto; padding: 0 1.2rem 5rem; }
.trips-header { text-align: center; padding: 3rem 0 2.5rem; }
.hero-tag { font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
.trips-header h1 { font-family: var(--ff-body); font-size: clamp(2.2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 1rem; }
.trips-header h1 em { color: var(--gold); font-style: italic; }
.trips-sub { color: var(--text-dim); font-size: 0.95rem; max-width: 640px; margin: 0 auto; line-height: 1.6; }

.trips-section { margin: 3rem 0 2.5rem; }
.trips-section h2 { font-family: var(--ff-body); font-size: 1.4rem; font-weight: 700; margin-bottom: 0.4rem; letter-spacing: -0.01em; }
.section-desc { color: var(--text-dim); font-size: 0.85rem; margin-bottom: 1.4rem; max-width: 640px; }

.trips-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }

.trip-card {
  background: var(--bg2); border: 1px solid var(--line); border-radius: 4px;
  padding: 1.2rem; position: relative; overflow: hidden;
  transition: transform 0.2s ease, border-color 0.25s ease;
}
.trip-card:hover { transform: translateY(-2px); border-color: var(--gold-dim); }
.trip-card.score-peak { border-left: 3px solid var(--peak); }
.trip-card.score-good { border-left: 3px solid var(--good); }
.trip-card.score-ok   { border-left: 3px solid var(--ok); }

.trip-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.6rem; margin-bottom: 0.3rem; }
.trip-head h3 { font-family: var(--ff-body); font-size: 1.05rem; font-weight: 700; letter-spacing: -0.01em; line-height: 1.2; }
.score-pill {
  font-size: 0.6rem; letter-spacing: 0.06em; text-transform: uppercase;
  padding: 0.2rem 0.45rem; border-radius: 2px; white-space: nowrap;
  border: 1px solid;
}
.score-peak .score-pill { color: var(--peak-text); background: rgba(34,197,94,0.10); border-color: rgba(34,197,94,0.3); }
.score-good .score-pill { color: var(--good-text); background: rgba(74,158,255,0.10); border-color: rgba(74,158,255,0.3); }
.score-ok   .score-pill { color: var(--ok-text);   background: rgba(245,158,11,0.10); border-color: rgba(245,158,11,0.3); }

.trip-sub { color: var(--text-faint); font-size: 0.72rem; letter-spacing: 0.04em; margin-bottom: 0.7rem; }
.trip-text { color: var(--text-dim); font-size: 0.85rem; line-height: 1.5; margin-bottom: 1rem; }
.trip-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }
.tag { font-size: 0.6rem; font-weight: 500; padding: 0.18rem 0.5rem; border-radius: 2px; letter-spacing: 0.05em; text-transform: uppercase; border: 1px solid; }
.tag-flight { color: var(--gold); background: rgba(201,151,58,0.07); border-color: rgba(201,151,58,0.3); }

.quick-picks { background: var(--bg2); border: 1px solid var(--line); border-radius: 4px; padding: 1.5rem; margin-top: 2.5rem; }
.picks-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 1rem; }
.pick-card h3 { font-family: var(--ff-body); font-size: 0.95rem; font-weight: 600; margin-bottom: 0.6rem; color: var(--text); }
.pick-card ul { list-style: none; padding: 0; }
.pick-card li { font-size: 0.85rem; color: var(--text-dim); padding: 0.35rem 0; border-bottom: 1px solid var(--line); }
.pick-card li:last-child { border-bottom: none; }
.pick-card li strong { color: var(--text); font-weight: 500; }

.trips-cta { background: var(--bg2); border: 1px solid var(--line); border-radius: 4px; padding: 1.5rem; margin-top: 2.5rem; }
.trips-cta h2 { margin-bottom: 1rem; }
.cta-list { list-style: none; padding: 0; }
.cta-list li { padding: 0.5rem 0; font-size: 0.95rem; color: var(--text-dim); border-bottom: 1px solid var(--line); }
.cta-list li:last-child { border-bottom: none; }
.cta-list a { color: var(--gold); text-decoration: underline; text-decoration-color: rgba(201,151,58,0.4); text-underline-offset: 3px; }
.cta-list a:hover { text-decoration-color: var(--gold); }

.month-nav { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--line); }
.month-nav-label { font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-faint); margin-bottom: 0.8rem; }
.month-pills { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.month-pill {
  font-size: 0.78rem; padding: 0.4rem 0.85rem; border-radius: 3px;
  border: 1px solid var(--line); color: var(--text-dim); letter-spacing: 0.04em;
  transition: border-color 0.2s ease, color 0.2s ease;
}
.month-pill:hover { border-color: var(--gold-dim); color: var(--text); }
.month-pill.active { border-color: var(--gold); color: var(--gold); background: var(--gold-glow); }

@media (max-width: 600px) {
  .trips-header { padding: 2rem 0 1.5rem; }
  .trips-grid { grid-template-columns: 1fr; }
}
</style>
