---
// Страница месяца «Куда поехать в <месяце>» — Swiss / International Typographic по BRANDBOOK.md.
// Формат «редакционный индекс»: сезонные секции (H2) из hairline Index-Row с микро-описанием.
// IATA для Aviasales — канонический из regionMeta (не нечёткий PRICES-матч). Цена — one-way оценка.
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { data as regions } from '../../data/regions.js';
import { PRICES } from '../../data/prices.js';
import { regionMeta } from '../../data/regions-meta.js';
import { DATA_UPDATED_RU, yearForMonth } from '../../data/meta.js';
import { aviasalesRoute } from '../../data/affiliate.js';

const MONTHS = [
  { slug: 'january',   name: 'январе',   nameNom: 'Январь',   short: 'Янв' },
  { slug: 'february',  name: 'феврале',  nameNom: 'Февраль',  short: 'Фев' },
  { slug: 'march',     name: 'марте',    nameNom: 'Март',     short: 'Мар' },
  { slug: 'april',     name: 'апреле',   nameNom: 'Апрель',   short: 'Апр' },
  { slug: 'may',       name: 'мае',      nameNom: 'Май',      short: 'Май' },
  { slug: 'june',      name: 'июне',     nameNom: 'Июнь',     short: 'Июн' },
  { slug: 'july',      name: 'июле',     nameNom: 'Июль',     short: 'Июл' },
  { slug: 'august',    name: 'августе',  nameNom: 'Август',   short: 'Авг' },
  { slug: 'september', name: 'сентябре', nameNom: 'Сентябрь', short: 'Сен' },
  { slug: 'october',   name: 'октябре',  nameNom: 'Октябрь',  short: 'Окт' },
  { slug: 'november',  name: 'ноябре',   nameNom: 'Ноябрь',   short: 'Ноя' },
  { slug: 'december',  name: 'декабре',  nameNom: 'Декабрь',  short: 'Дек' },
];

export async function getStaticPaths() {
  return [
    'january','february','march','april','may','june',
    'july','august','september','october','november','december'
  ].map(slug => ({ params: { month: slug } }));
}

const { month } = Astro.params;
const monthIdx = MONTHS.findIndex(m => m.slug === month);
const M = MONTHS[monthIdx];
const yr = yearForMonth(monthIdx + 1);

const SCORE = { P: 4, G: 3, O: 2, B: 1, X: 0 };
const VISA_LABEL = { free: 'Безвиз', evisa: 'e-Visa', required: 'Виза' };
const VISA_CLS = { free: 'free', evisa: 'evisa', required: 'visa' };
const BUDGET_SYM = { low: '$', mid: '$$', high: '$$$' };
const BUDGET_WORD = { low: 'бюджетно, до $80 в день', mid: 'средний бюджет, $80–250 в день', high: 'дорого, от $250 в день' };

const directions = regions.filter(r => !r.group);
const plural = (n) => (n % 10 === 1 && n % 100 !== 11 ? 'направление' : (n % 10 >= 2 && n % 10 <= 4 && (n % 100 < 10 || n % 100 >= 20) ? 'направления' : 'направлений'));

// Цена: точный матч PRICES по каноническому regionMeta.iata, иначе нечёткий fallback.
function findPrice(d) {
  const metaIata = regionMeta[d.sub]?.iata;
  if (metaIata) {
    const exact = PRICES.find(p => p.iata === metaIata);
    if (exact) return exact;
  }
  const norm = (s) => (s || '').toLowerCase().replace(/[^a-zа-я0-9]/gi, '');
  const dn = norm(d.region) + norm(d.sub);
  return PRICES.find(p => {
    const pn = norm(p.name);
    return dn.includes(norm(p.name.split(' ')[0])) || pn.includes(norm(d.region));
  });
}

const enriched = directions.map(d => {
  const meta = regionMeta[d.sub] || {};
  const price = findPrice(d);
  return {
    ...d,
    score: d.r[monthIdx],
    text: d.t[monthIdx],
    slug: meta.slug || '',
    iata: meta.iata || price?.iata,             // канон. город для ссылки
    flight: price?.flight?.[0],                 // оценка one-way (как на странице страны)
  };
}).filter(d => d.score === 'P' || d.score === 'G' || d.score === 'O')
  .sort((a, b) => {
    const sA = SCORE[a.score], sB = SCORE[b.score];
    if (sA !== sB) return sB - sA;
    return (a.flight || 9999) - (b.flight || 9999);
  });

const peak = enriched.filter(d => d.score === 'P');
const good = enriched.filter(d => d.score === 'G');
const ok = enriched.filter(d => d.score === 'O').slice(0, 8);
const top = enriched.slice(0, 15);
const cheapest = [...enriched].filter(d => d.flight).sort((a, b) => a.flight - b.flight).slice(0, 5);
const visaFree = enriched.filter(d => d.visa === 'free').slice(0, 5);

// Секции — только непустые
const SECTIONS = [
  { key: 'P', title: `Пик сезона в ${M.name}`,   intro: 'Погода и инфраструктура работают на 100%. Дороже и многолюднее — берите, если даты гибкие.', rows: peak },
  { key: 'G', title: 'Хорошая погода',            intro: 'Комфортно, туристов меньше, цены ниже пика. Оптимальный баланс «погода / деньги».',          rows: good },
  { key: 'O', title: 'Можно ехать',               intro: 'Сезон не идеальный, но если едете по другим причинам (события, маршрут) — терпимо.',          rows: ok },
].filter(s => s.rows.length > 0);

// SEO
const title = `Куда поехать в ${M.name} ${yr} — топ направлений`;
const description = `Куда лететь в ${M.name} ${yr}: ${peak.length} направлений с пиком сезона, актуальные цены на перелёт из Москвы, виза для россиян, бюджет на день. Без воды.`;
const url = `https://traveltribe.ru/trips/${month}/`;

const faqs = [
  {
    q: `Куда лучше всего поехать в ${M.name} ${yr}?`,
    a: `В пиковом сезоне сейчас ${peak.length} направлений: ${peak.slice(0, 5).map(d => d.region).join(', ')} и другие. Полный список с ценами и визами — на этой странице.`,
  },
  {
    q: `Куда дешевле всего лететь в ${M.name}?`,
    a: `Самые дешёвые перелёты из Москвы в ${M.name}: ${cheapest.slice(0, 3).map(d => `${d.region} от $${d.flight}`).join(', ')}. Цена — ориентир в одну сторону по медиане сезона.`,
  },
  {
    q: `Куда без визы в ${M.name}?`,
    a: `Безвизовые направления для россиян с хорошим сезоном в ${M.name}: ${visaFree.slice(0, 5).map(d => d.region).join(', ')}.`,
  },
];

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${url}#webpage`,
      "url": url,
      "name": title,
      "description": description,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "datePublished": "2026-04-30",
      "dateModified": "2026-04-30"
    },
    {
      "@type": "ItemList",
      "@id": `${url}#list`,
      "name": `Лучшие направления для путешествия в ${M.name} ${yr}`,
      "numberOfItems": top.length,
      "itemListElement": top.map((d, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": { "@type": "TouristDestination", "name": d.region, "description": d.sub }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Календарь поездок", "item": "https://traveltribe.ru/trips/" },
        { "@type": "ListItem", "position": 3, "name": M.nameNom, "item": url }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};

---
<Layout
  title={title}
  description={description}
  canonical={url}
  ogTitle={`Куда поехать в ${M.name} ${yr}`}
  ogDescription={description}
  ldJson={ldJson}
>
  <Breadcrumbs crumbs={[
    { label: 'Календарь', href: '/trips/' },
    { label: M.nameNom }
  ]} />

  <main id="main" class="sw">
    <div class="wrap">
      <header class="hero grid">
        <div class="meta">Сезоны и визы<br><b>актуальны на {DATA_UPDATED_RU}</b></div>
        <h1 class="h1">Куда поехать <span class="rd">в {M.name}</span></h1>
        <p class="sub"><b>{peak.length}</b> направлений с пиком сезона, <b>{good.length}</b> с хорошей погодой. Цены на перелёт из Москвы, виза для россиян и бюджет на день — по каждому направлению.</p>
        <p class="byl">
          <a href="/about/" class="byl-a">Никита Зайцев</a> ·
          <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> ·
          <span>был лично на 7 континентах</span>
        </p>
      </header>

      <p class="legend">
        <b>Виза:</b> <span class="visa free">Безвиз</span> — без визы для россиян · <span class="visa evisa">e-Visa</span> — онлайн · <span class="visa visa">Виза</span> — консульство.
        <b>Бюджет на день:</b> <b class="bsym">$</b> до $80 · <b class="bsym">$$</b> $80–250 · <b class="bsym">$$$</b> от $250.
        <b>Перелёт</b> — ориентир в одну сторону из Москвы; «найти» открывает Aviasales. 
      </p>

      {SECTIONS.map((s, si) => (
        <section class="sec">
          <div class="shead">
            <h2>{s.title}</h2>
            <span class="cap">{s.rows.length} {plural(s.rows.length)}</span>
          </div>
          <p class="sintro">{s.intro}</p>
          <ul class="rows">
            {s.rows.map(d => (
              <li class="irow">
                <div class="ileft">
                  <p class="inm">
                    {d.slug
                      ? <a href={`/trips/${month}/${d.slug}/`}>{d.region}</a>
                      : <span>{d.region}</span>}
                    <span class="isub">{d.sub}</span>
                  </p>
                  {d.text && <p class="idesc">{d.text}</p>}
                </div>
                <div class="iright">
                  <span class={`visa ${VISA_CLS[d.visa]}`}>{VISA_LABEL[d.visa]}</span>
                  <span class="bud" title={BUDGET_WORD[d.budget]}><span aria-hidden="true">{BUDGET_SYM[d.budget]}</span><span class="vh">{BUDGET_WORD[d.budget]}</span></span>
                  {d.flight && d.iata
                    ? <a class="find" href={aviasalesRoute('MOW', d.iata)} rel="sponsored noopener" target="_blank" aria-label={`Найти перелёт Москва — ${d.region} на Aviasales`}>от ${d.flight} · найти билет</a>
                    : (d.flight ? <span class="fprice">от ${d.flight}</span> : <span class="fdash" aria-hidden="true">—</span>)}
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))}

      <section class="sec">
        <div class="shead"><h2>Быстрый выбор</h2></div>
        <div class="picks">
          <div class="pick">
            <h3>Самые дешёвые перелёты</h3>
            <ul class="vl">
              {cheapest.map(d => (
                <li>
                  <span class="pk-n">{d.region}</span>
                  {d.iata
                    ? <a class="find" href={aviasalesRoute('MOW', d.iata)} rel="sponsored noopener" target="_blank" aria-label={`Найти перелёт Москва — ${d.region} на Aviasales`}>от ${d.flight} · найти билет</a>
                    : <span class="fprice">от ${d.flight}</span>}
                </li>
              ))}
            </ul>
            <p class="adm-row">цены через Aviasales</p>
          </div>
          <div class="pick">
            <h3>Без визы для россиян</h3>
            <ul class="vl">
              {visaFree.map(d => (
                <li>
                  {d.slug
                    ? <a class="pk-l" href={`/trips/${month}/${d.slug}/`}>{d.region}</a>
                    : <span class="pk-n">{d.region}</span>}
                  <span class="pk-s">{d.sub}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section class="sec">
        <div class="shead"><h2>Частые вопросы — {M.nameNom} {yr}</h2></div>
        <div class="faq">
          {faqs.map(f => (
            <details class="fi">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </section>

      <section class="sec">
        <div class="shead"><h2>Что делать дальше</h2></div>
        <ul class="vl wide">
          <li><a href="/seasons/">Полная таблица сезонов</a><span>все 70+ направлений × 12 месяцев</span></li>
          <li><a href="/calculator/">Калькулятор бюджета</a><span>посчитать поездку под свои даты и курс</span></li>
          <li><a href={`/events/${M.slug}/`}>События и праздники в {M.name}</a><span>что закрыто, какие фестивали стоит успеть</span></li>
          <li><a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a><span>оперативные обновления по визам и направлениям</span></li>
        </ul>
      </section>

      <nav class="mnav" aria-label="Другие месяцы">
        <span class="mnav-l">Другие месяцы:</span>
        <span class="mnav-t">
          {MONTHS.map((m) => (
            <a href={`/trips/${m.slug}/`} class={`t ${m.slug === month ? 'on' : ''}`} aria-current={m.slug === month ? 'page' : undefined}>{m.short}</a>
          ))}
        </span>
      </nav>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  body { background: #f4f2eb; }
</style>

<style>
.sw{--paper:#f4f2eb;--ink:#1b1914;--mid:#6b685e;--line:#23211a;--hair:#cdc9bd;--gold:#8e6618;
  --ff:'Golos Text Variable','Golos Text',Helvetica,Arial,sans-serif;--edge:clamp(1.1rem,3vw,2.6rem);
  background:var(--paper);color:var(--ink);font-family:var(--ff);font-weight:400;line-height:1.4;
  font-variant-numeric:tabular-nums lining-nums;-webkit-font-smoothing:antialiased;padding-bottom:clamp(3rem,6vw,5rem)}
:where(.sw) :where(h1,h2,h3,h4,p,ul,li){margin:0}
.sw :where(h1,h2,h3,h4){font-family:var(--ff);color:var(--ink)}
.sw a{color:inherit;text-decoration:none}
.sw :focus-visible{outline:2px solid var(--gold);outline-offset:3px}
.vh{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0}
.wrap{max-width:1280px;margin-inline:auto;padding-inline:var(--edge)}
.grid{display:grid;grid-template-columns:repeat(12,minmax(0,1fr));gap:0 clamp(.8rem,2vw,1.6rem)}

.hero{padding:clamp(2rem,5vw,4rem) 0 clamp(1.2rem,2.5vw,2rem)}
.meta{grid-column:8/13;grid-row:1;text-align:right;align-self:start;font-size:.8rem;color:var(--mid);line-height:1.5}
.meta b{color:var(--ink);font-weight:500}
.h1{grid-column:1/13;grid-row:2;font-weight:700;font-size:clamp(2.4rem,7vw,6.4rem);line-height:1.02;letter-spacing:-.035em;overflow-wrap:break-word;margin-top:clamp(1.2rem,2.5vw,2rem);padding-bottom:.06em}
.h1 .rd{color:var(--gold)}
.sub{grid-column:1/10;grid-row:3;font-size:clamp(1rem,1.3vw,1.18rem);color:var(--ink);margin-top:clamp(1.4rem,2vw,1.8rem);max-width:60ch;line-height:1.55}
.sub b{color:var(--gold);font-weight:700}
.byl{grid-column:1/13;grid-row:4;margin-top:1.4rem;font-size:.78rem;color:var(--mid)}
.byl a{color:var(--mid)}
.byl .byl-a{color:var(--gold);text-decoration:underline 1px var(--gold);text-underline-offset:.22em}

/* Легенда */
.legend{margin-top:.5rem;padding:.8rem 0;border-top:1px solid var(--hair);border-bottom:1px solid var(--hair);font-size:.8rem;color:var(--mid);line-height:1.7;max-width:96ch}
.legend b{color:var(--ink);font-weight:600}
.legend .bsym{color:var(--ink);font-weight:700;letter-spacing:.03em}
.legend .visa{margin:0 .1rem}
.adm{font-size:.6rem;font-weight:500;letter-spacing:.06em;text-transform:uppercase;color:var(--mid)}

.sec{padding:clamp(2rem,4vw,3rem) 0 0}
.shead{display:flex;align-items:center;justify-content:space-between;gap:1rem;border-top:2px solid var(--line);padding-top:.8rem;margin-bottom:.5rem}
.shead h2{font-weight:700;font-size:clamp(1.4rem,2.6vw,2rem);letter-spacing:-.02em;display:flex;align-items:baseline;gap:.6rem}
.shead .cap{font-size:.78rem;font-weight:500;color:var(--mid)}
.sintro{font-size:.92rem;color:var(--mid);line-height:1.55;max-width:74ch;margin-bottom:1.1rem}

/* Index-rows (не карточки): широкая левая колонка + узкая правая мета */
.rows{list-style:none;border-top:1px solid var(--line)}
.irow{display:grid;grid-template-columns:1fr auto;gap:.4rem 1.6rem;padding:1rem 0;border-bottom:1px solid var(--hair);align-items:baseline}
.irow:last-child{border-bottom:none}
@media(hover:hover){.irow:hover{background:rgba(142,102,24,.05)}}
.ileft{min-width:0}
.inm{font-weight:700;font-size:1.15rem;letter-spacing:-.01em;line-height:1.2}
.inm a:hover{color:var(--gold);text-decoration:underline 1px var(--gold);text-underline-offset:.22em}
.isub{font-weight:400;font-size:.78rem;color:var(--mid);margin-left:.5rem;letter-spacing:0}
.idesc{color:var(--mid);font-size:.9rem;line-height:1.5;margin-top:.35rem;max-width:70ch}
.iright{display:flex;align-items:baseline;gap:1.1rem;justify-self:end;white-space:nowrap}
.visa{font-size:.72rem;font-weight:600;letter-spacing:.02em;text-transform:uppercase}
.visa.free{color:var(--gold)}.visa.evisa{color:var(--ink)}.visa.visa{color:#56534c}
.bud{font-weight:700;color:var(--ink);letter-spacing:.05em;font-size:.95rem}
.find{color:var(--ink);font-weight:600;text-decoration:underline 1px var(--gold);text-underline-offset:.22em}
.find:hover{color:var(--gold)}
.fprice{color:var(--mid);font-weight:600}
.fdash{color:var(--hair)}

/* Быстрый выбор */
.picks{display:grid;grid-template-columns:1fr 1fr;gap:clamp(1.4rem,3vw,2.4rem);margin-top:.6rem}
.pick h3{font-size:.7rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--mid);margin-bottom:.4rem}
.vl{list-style:none;border-top:1px solid var(--line)}
.vl li{display:flex;flex-wrap:wrap;align-items:baseline;justify-content:space-between;gap:.2rem .7rem;padding:.7rem 0;border-bottom:1px solid var(--hair)}
.vl li:last-child{border-bottom:none}
.pk-n,.pk-l{font-weight:600;font-size:1rem;color:var(--ink)}
.pk-l{text-decoration:underline 1px var(--gold);text-underline-offset:.22em}
.pk-l:hover{color:var(--gold)}
.pk-s{color:var(--mid);font-size:.8rem}
.adm-row{margin-top:.5rem;font-size:.66rem;color:var(--mid)}
.vl.wide li{justify-content:flex-start}
.vl.wide a{font-weight:600;font-size:1.02rem;color:var(--ink);text-decoration:underline 1px var(--gold);text-underline-offset:.22em}
.vl.wide a:hover{color:var(--gold)}
.vl.wide span{color:var(--mid);font-size:.86rem}

/* FAQ */
.faq{border-top:1px solid var(--line)}
.fi{border-bottom:1px solid var(--hair)}
.fi summary{font-weight:600;font-size:1rem;color:var(--ink);padding:1rem 2rem 1rem 0;cursor:pointer;list-style:none;position:relative;line-height:1.4}
.fi summary::-webkit-details-marker{display:none}
.fi summary::after{content:'+';position:absolute;right:.2rem;top:.9rem;color:var(--gold);font-size:1.3rem;line-height:1}
.fi[open] summary::after{content:'−'}
.fi p{padding:0 0 1.1rem;color:var(--mid);line-height:1.7;font-size:.95rem;max-width:74ch}

/* Навигация по месяцам — текст-тогглы */
.mnav{margin-top:clamp(2.2rem,4.5vw,3.4rem);padding-top:.9rem;border-top:1px solid var(--line);display:flex;flex-wrap:wrap;align-items:center;gap:.3rem 1.1rem}
.mnav-l{font-size:.64rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--mid)}
.mnav-t{display:flex;flex-wrap:wrap;gap:.2rem 1rem}
.t{font-size:.9rem;font-weight:600;color:var(--ink);min-height:44px;display:inline-flex;align-items:center;text-decoration:underline 1px transparent;text-underline-offset:.22em}
.t:hover{text-decoration-color:var(--hair)}
.t.on{color:var(--gold);text-decoration-color:var(--gold)}

@media(max-width:760px){
  .h1,.sub,.meta,.byl{grid-column:1/-1;grid-row:auto}
  .meta{text-align:left;margin-top:.6rem}
  .h1{margin-top:1.1rem}
  .picks{grid-template-columns:1fr;gap:1.6rem}
