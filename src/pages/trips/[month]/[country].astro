---
// Страница «направление × месяц» — Swiss / International Typographic по BRANDBOOK.md.
// Типографический hero (без градиента/эмодзи), hairline-таблицы, сезон передан весом/золотом.
import '@fontsource-variable/golos-text/index.css';
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { DIRECTIONS, MONTHS } from '../../../data/directions.js';
import { COUNTRIES as RICH_COUNTRIES } from '../../../data/programmatic-seasons.js';
import { NICHE_TRIPS } from '../../../data/niche-trips.js';
import { TP_LINKS, aviasalesRoute } from '../../../data/affiliate.js';
import { DATA_UPDATED_RU, yearForMonth } from '../../../data/meta.js';
import TripSaveButton from '../../../components/TripSaveButton.astro';

export async function getStaticPaths() {
  const paths = [];
  for (const m of MONTHS) {
    for (const d of DIRECTIONS) {
      paths.push({ params: { month: m.slug, country: d.slug }, props: { m, d } });
    }
  }
  return paths;
}

const { m, d } = Astro.props;
const url = `https://traveltribe.ru/trips/${m.slug}/${d.slug}/`;
const monthIdx = MONTHS.findIndex((x) => x.slug === m.slug);

// Погодный рефрейм — ПИЛОТ (Рост Фаза 4, 2026-07-05). Данные: weather-интент на этих
// страницах даёт показы без кликов (виджет выдачи отвечает сам; у /trips/july/turkey/
// 740 показов и CTR 0.4%), decision-интент «стоит ли ехать» виджет НЕ закрывает.
// Топ-10 страниц по показам GSC: рефрейм title/H1 → замер CTR через 2-3 недели →
// раскат на все trips при подтверждении. Остальные страницы = контрольная группа.
const WEATHER_REFRAME_PILOT = new Set([
  'july/turkey', 'july/italy-north', 'july/japan', 'july/spain', 'july/italy-south',
  'july/norway', 'august/japan', 'june/greece', 'june/armenia', 'december/new-zealand',
]);
const reframe = WEATHER_REFRAME_PILOT.has(`${m.slug}/${d.slug}`);
const yr = yearForMonth(monthIdx + 1);
const status = d.r[monthIdx];
const text = d.t[monthIdx];
// Богатые данные по месяцу (погода/события/что смотреть) — есть для части стран
// (programmatic-seasons.js, источники meteoblue/climate-data). Где есть — выводим
// реальный уникальный контент вместо общего шаблона. Не выдумываем там, где нет.
const rich = RICH_COUNTRIES[d.slug]?.months?.[m.slug] || null;

const STATUS_LABEL = {
  P: { tag: 'Пик сезона',      verdict: 'Лучший месяц для поездки',                cls: 'peak' },
  G: { tag: 'Хороший месяц',   verdict: 'Отличное время — погода и цены работают', cls: 'good' },
  O: { tag: 'Так себе',        verdict: 'Можно ехать, но есть месяцы получше',     cls: 'off' },
  B: { tag: 'Не лучшее время', verdict: 'Лучше выбрать другой месяц',              cls: 'bad' },
  X: { tag: 'Закрыто',         verdict: 'Направление закрыто в этом месяце',       cls: 'closed' },
};
const lbl = STATUS_LABEL[status] || STATUS_LABEL.O;

const VISA_LABEL = { free: 'Без визы', evisa: 'eVisa', required: 'Виза обязательна' };
const BUDGET_LABEL = {
  low: '$ — до $80/день',
  mid: '$$ — $80–250/день',
  high: '$$$ — от $250/день',
};

// Лучшие месяцы для направления (P > G)
const rank = { P: 4, G: 3, O: 2, B: 1, X: 0 };
const bestMonths = MONTHS
  .map((x, i) => ({ ...x, status: d.r[i], rank: rank[d.r[i]] || 0 }))
  .filter((x) => x.rank >= 3 && x.slug !== m.slug)
  .slice(0, 4);

const iata = d.iata || d.price?.iata;   // канон. IATA из regionMeta (через directions.js)
const flightTiers = d.price?.flight || [0,0,0];
const hotelTiers = d.price?.hotel || [0,0,0];
const foodTiers = d.price?.food || [0,0,0];
const flightFrom = flightTiers[0];
const hotelFrom = hotelTiers[0];
const foodFrom = foodTiers[0];
const dailyFrom = (hotelFrom || 0) + (foodFrom || 0);
const weekTotal = flightFrom ? flightFrom + dailyFrom * 7 : null;

function budgetFor(days, tier) {
  const f = flightTiers[tier] || 0;
  const daily = (hotelTiers[tier] || 0) + (foodTiers[tier] || 0);
  return f + daily * days;
}
const hasPrices = flightTiers[0] > 0;
const budgetGrid = hasPrices ? [7, 14, 21].map(d_ => ({
  days: d_,
  low: budgetFor(d_, 0),
  mid: budgetFor(d_, 1),
  high: budgetFor(d_, 2),
})) : [];

// 12-месячная сводка — типографикой, без эмодзи/цвета-светофора
const MONTH_META = MONTHS.map((mm, i) => {
  const st = d.r[i];
  const meta = { P: { cls: 's-peak', label: 'пик' },
                 G: { cls: 's-good', label: 'хороший' },
                 O: { cls: 's-ok',   label: 'так себе' },
                 B: { cls: 's-ok',   label: 'не лучшее' },
                 X: { cls: 's-off',  label: 'закрыто' } }[st] || { cls: 's-ok', label: '—' };
  return { ...mm, status: st, ...meta, isCurrent: mm.slug === m.slug };
});

const visaLine = ({
  free: 'Без визы для российского паспорта',
  evisa: 'Электронная виза (eVisa) — оформляется онлайн',
  required: 'Виза обязательна — оформление в консульстве',
}[d.visa]) || 'Виза — уточнить';
const bestMonthsAll = MONTH_META.filter(mm => mm.status === 'P' || mm.status === 'G').map(mm => mm.nom);
const bestMonthsStr = bestMonthsAll.length ? bestMonthsAll.join(', ') : 'нет ярко выраженного пика — едут круглый год';
const verdictForMonth = lbl.verdict + (status === 'P' || status === 'G' ? '.' : '. ' + (bestMonthsAll.length ? 'Лучше выбрать: ' + bestMonthsAll.slice(0,3).join(', ') + '.' : ''));
const budgetSummary = hasPrices && weekTotal
  ? `Перелёт из Москвы от $${flightFrom}, отель эконом от $${hotelFrom}/ночь, еда от $${foodFrom}/день. Бюджет на неделю эконом — от $${weekTotal} на человека.`
  : 'Точные цены — в калькуляторе поездки.';

const FAQS = [
  { q: `Стоит ли ехать ${d.cases.vP} в ${m.prep} ${yr}?`, a: `${verdictForMonth} ${text}`.trim() },
  { q: `Сколько стоит неделя ${d.cases.loc} в ${m.prep} ${yr}?`, a: budgetSummary },
  { q: `Какая виза нужна россиянам ${d.cases.vP} в ${yr}?`, a: `${visaLine}. Детали — на странице визы.` },
  { q: `Когда лучше ехать ${d.cases.vP}?`, a: `Лучшие месяцы для поездки: ${bestMonthsStr}. Сравнить все 12 месяцев — таблица ниже.` },
];

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${url}#article`,
      "url": url,
      "headline": `${d.cases.nom} в ${m.prep} ${yr}: погода, цены, виза`,
      "description": `Стоит ли ехать ${d.cases.vP} в ${m.prep} ${yr}: погода, цены на перелёт и отель, виза для россиян. ${lbl.verdict}.`,
      "inLanguage": "ru-RU",
      "datePublished": "2026-05-10",
      "author": { "@type": "Person", "name": "Никита Зайцев", "url": "https://traveltribe.ru/about/" },
      "publisher": { "@id": "https://traveltribe.ru/#org" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Календарь", "item": "https://traveltribe.ru/trips/" },
        { "@type": "ListItem", "position": 3, "name": m.nom.charAt(0).toUpperCase() + m.nom.slice(1), "item": `https://traveltribe.ru/trips/${m.slug}/` },
        { "@type": "ListItem", "position": 4, "name": d.cases.nom, "item": url },
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${url}#faq`,
      "mainEntity": FAQS.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    }
  ]
};

const monthCap = m.nom.charAt(0).toUpperCase() + m.nom.slice(1);
---
<Layout
  title={reframe ? `Стоит ли ехать ${d.cases.vP} в ${m.prep} ${yr}: цены, толпы, что взять` : `${d.cases.nom} в ${m.prep} ${yr}: погода, цены, виза`}
  description={`Стоит ли ехать ${d.cases.vP} в ${m.prep} ${yr} — погода, цены, виза для россиян, бюджет на неделю. ${lbl.verdict}.`}
  canonical={url}
  noindex={status === 'X' || NICHE_TRIPS.has(d.slug)}
  ogTitle={`${d.cases.nom} в ${m.prep} ${yr}`}
  ogDescription={`${lbl.tag}. ${text.slice(0, 130)}`}
  ogType="article"
  ldJson={ldJson}
>
  <Breadcrumbs crumbs={[
    { label: 'Календарь', href: '/trips/' },
    { label: monthCap, href: `/trips/${m.slug}/` },
    { label: d.cases.nom }
  ]} />

  <main id="main" class="sw">
    <div class="wrap">
      <header class="hero grid">
        <div class="idx"><span class={`st st-${lbl.cls}`}>{lbl.tag}</span><b>{monthCap} {yr}</b></div>
        <div class="meta">Сезоны и визы<br><b>актуальны на {DATA_UPDATED_RU}</b></div>
        <h1 class="h1">{reframe ? <>Стоит ли ехать {d.cases.vP}{' '}<span class="rd">в {m.prep}</span>{' '}{yr}</> : <>{d.cases.nom} <span class="rd">в {m.prep}</span> {yr}</>}</h1>
        <p class="sub">{lbl.verdict}. {d.region} — {d.sub}.</p>
        <p class="byl">
          <a href="/about/" class="byl-a">Никита Зайцев</a> ·
          <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> ·
          <span>был лично на 7 континентах</span>
        </p>
        <TripSaveButton slug={d.slug} nom={d.cases.nom} monthIdx={monthIdx} />
      </header>

      <p class="lead">{text}</p>

      <section class="sec">
        <div class="shead"><h2><span class="no">01</span>Кратко: формат поездки</h2></div>
        <ul class="facts">
          <li><span class="fk">Виза</span><span class="fv"><a href={`/visa/${d.slug}/`}>{VISA_LABEL[d.visa]}</a></span></li>
          <li><span class="fk">Бюджет</span><span class="fv">{BUDGET_LABEL[d.budget]}</span></li>
          {flightFrom > 0 && <li><span class="fk">Перелёт из Москвы</span><span class="fv">от ${flightFrom} в одну сторону</span></li>}
          {hotelFrom > 0 && <li><span class="fk">Отель эконом</span><span class="fv">от ${hotelFrom}/ночь</span></li>}
          {weekTotal && <li><span class="fk">Неделя эконом</span><span class="fv">от ${weekTotal} на человека</span></li>}
        </ul>
        {flightFrom > 0 && iata && (
          <p class="findcta"><a class="find" href={aviasalesRoute('MOW', iata)} rel="sponsored noopener" target="_blank">Найти перелёт Москва → {iata} от ${flightFrom} →</a> </p>
        )}
      </section>

      {hasPrices && (
        <section class="sec">
          <div class="shead"><h2><span class="no">02</span>Сколько стоит поездка {d.cases.vP} в {m.prep}</h2></div>
          <table class="dt">
            <thead><tr><th>Длительность</th><th>Эконом</th><th>Средний</th><th>Комфорт</th></tr></thead>
            <tbody>
              {budgetGrid.map((b) => (
                <tr>
                  <td class="bd" data-l="Длительность"><b>{b.days} дней</b></td>
                  <td data-l="Эконом">от ${b.low}</td>
                  <td data-l="Средний">${b.mid}</td>
                  <td data-l="Комфорт">${b.high}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="tnote">Перелёт из Москвы ${flightTiers[0]}–${flightTiers[2]}, отель ${hotelTiers[0]}–${hotelTiers[2]}/ночь, еда ${foodTiers[0]}–${foodTiers[2]}/день. Точный расчёт под маршрут — в <a href="/calculator/">калькуляторе поездки</a>.</p>
          <p class="findcta"><a class="find" href={TP_LINKS.ostrovok} rel="sponsored noopener" target="_blank">Подобрать жильё {d.cases.loc}</a> — оплата картой РФ, бесплатная отмена · <a class="find" href={TP_LINKS.cherehapa} rel="sponsored noopener" target="_blank">страховка под визу</a> </p>
        </section>
      )}

      <section class="sec">
        <a href={`/packing/${d.slug}/`} class="cta-row">
          <span class="cta-t"><b>Что взять {d.cases.vP}</b><span>Чек-лист по сезонам: одежда, документы, аптечка, техника</span></span>
          <span class="cta-ar">→</span>
        </a>
      </section>

      <section class="sec">
        <div class="shead"><h2><span class="no">03</span>Когда ехать {d.cases.vP}: все 12 месяцев</h2></div>
        <ul class="mgrid">
          {MONTH_META.map((mm) => (
            <li class={`mg ${mm.isCurrent ? 'mg-now' : ''}`}>
              <a href={`/trips/${mm.slug}/${d.slug}/`} aria-current={mm.isCurrent ? 'page' : undefined}>
                <span class="mg-n">{mm.nom.charAt(0).toUpperCase() + mm.nom.slice(1)}</span>
                <span class={`mg-s ${mm.cls}`}>{mm.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="sec">
        <div class="shead"><h2><span class="no">04</span>Частые вопросы {d.cases.vP} в {m.prep}</h2></div>
        <div class="faq">
          {FAQS.map((f) => (
            <details class="fi">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </section>

      {rich && (
        <section class="sec">
          <div class="shead"><h2>{d.cases.nom} в {m.prep}: погода и что смотреть</h2></div>
          <p class="txt">{rich.weatherDesc}</p>
          {rich.highlights?.length > 0 && (
            <ul class="vl wide">
              {rich.highlights.map((h) => <li>{h}</li>)}
            </ul>
          )}
          {rich.events?.length > 0 && (
            <p class="txt"><strong>События в {m.prep}:</strong> {rich.events.map((e) => `${e.name} (${e.dates}) — ${e.note}`).join('; ')}.</p>
          )}
          {rich.warnings?.length > 0 && (
            <p class="txt"><strong>Стоит учесть:</strong> {rich.warnings.join('; ')}.</p>
          )}
        </section>
      )}

      {(status === 'P' || status === 'G') && !rich && (
        <section class="sec">
          <div class="shead"><h2><span class="no">05</span>Что делать {d.cases.loc} в {m.prep}</h2></div>
          <p class="txt">{monthCap} {yr} — один из лучших месяцев для поездки {d.cases.vP}. Погода и цены сходятся в окне комфорта. Закладывайте 7–14 дней, бронировать минимум за 2 месяца до вылета — на пиковые даты места разлетаются быстро.</p>
          <p class="txt">Сравнить с другими месяцами можно в <a href="/seasons/">таблице сезонов</a>, посчитать точный бюджет — в <a href="/calculator/">калькуляторе поездки</a>.</p>
        </section>
      )}

      {(status === 'O' || status === 'B') && bestMonths.length > 0 && (
        <section class="sec">
          <div class="shead"><h2><span class="no">05</span>Когда лучше ехать {d.cases.vP}</h2></div>
          <p class="txt">{monthCap} — не лучший месяц для этого направления. Оптимальные окна:</p>
          <ul class="vl wide">
            {bestMonths.map((bm) => (
              <li><a href={`/trips/${bm.slug}/${d.slug}/`}>{bm.nom.charAt(0).toUpperCase() + bm.nom.slice(1)}</a><span>{bm.status === 'P' ? 'пик сезона' : 'хороший месяц'}</span></li>
            ))}
          </ul>
        </section>
      )}

      {status === 'X' && (
        <section class="sec">
          <div class="shead"><h2><span class="no">05</span>Направление закрыто</h2></div>
          <p class="txt">{d.cases.nom} в {m.prep} физически недоступна для туристов: либо погодные условия, либо все туры остановлены до сезона. Возвращайтесь в подходящие месяцы — {bestMonths.map((bm) => bm.nom).join(', ')}.</p>
        </section>
      )}

      <section class="sec">
        <div class="shead"><h2><span class="no">06</span>Поехать с экспертом</h2></div>
        <a href={TP_LINKS.youtravel} class="cta-row" rel="sponsored noopener" target="_blank">
          <span class="cta-t"><b>Авторские туры {d.cases.vP}</b><span>Готовый маршрут, логистика и малая группа с экспертом — не планировать самому</span></span>
          <span class="cta-ar">→</span>
        </a>
        <p class="adm-row">YouTravel.me</p>
      </section>

      {d.relatedPosts.length > 0 && (
        <section class="sec">
          <div class="shead"><h2><span class="no">07</span>Подробные гайды о {d.cases.prep}</h2></div>
          <ul class="vl wide">
            {d.relatedPosts.map((p) => (
              <li><a href={`/blog/${p.slug}/`}>{p.title}</a><span>{p.kind === 'visa' ? 'про визу' : p.kind === 'season' ? 'про конкретный сезон' : 'личный опыт'}</span></li>
            ))}
          </ul>
        </section>
      )}

      <section class="sec">
        <div class="shead">
          <h2><span class="no">08</span>{monthCap} {yr} — другие направления</h2>
          <a href={`/trips/${m.slug}/`}>Все направления {m.prep} →</a>
        </div>
        <p class="txt">Что ещё работает в {m.prep} {yr} — смотри <a href={`/trips/${m.slug}/`}>обзор всех направлений {m.prep}</a> с ценами и визами.</p>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  body { background: #f4f2eb; }
</style>

<style>
.sw{--paper:#f4f2eb;--ink:#1b1914;--mid:#6b685e;--line:#23211a;--hair:#cdc9bd;--gold:#8e6618;
  --ff:'Golos Text Variable','Golos Text',Helvetica,Arial,sans-serif;--edge:clamp(1.1rem,3vw,2.6rem);
  background:var(--paper);color:var(--ink);font-family:var(--ff);font-weight:400;line-height:1.4;
  font-variant-numeric:tabular-nums lining-nums;-webkit-font-smoothing:antialiased;padding-bottom:clamp(3rem,6vw,5rem)}
:where(.sw) :where(h1,h2,h3,h4,p,ul,li){margin:0}
.sw :where(h1,h2,h3,h4){font-family:var(--ff);color:var(--ink)}
.sw a{color:inherit;text-decoration:none}
.sw :focus-visible{outline:2px solid var(--gold);outline-offset:3px}
.wrap{max-width:1280px;margin-inline:auto;padding-inline:var(--edge)}
.grid{display:grid;grid-template-columns:repeat(12,minmax(0,1fr));gap:0 clamp(.8rem,2vw,1.6rem)}

.hero{padding:clamp(2rem,5vw,4rem) 0 clamp(1rem,2vw,1.6rem)}
.idx{grid-column:1/7;grid-row:1;font-size:.74rem;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--mid)}
.idx .st{font-weight:700}
.st-peak{color:var(--gold)}.st-good{color:var(--ink)}.st-off,.st-bad,.st-closed{color:var(--mid)}
.idx b{display:block;color:var(--ink);font-size:.74rem;font-weight:500;margin-top:.2rem}
.meta{grid-column:8/13;grid-row:1;text-align:right;align-self:start;font-size:.8rem;color:var(--mid);line-height:1.5}
.meta b{color:var(--ink);font-weight:500}
.h1{grid-column:1/13;grid-row:2;font-weight:700;font-size:clamp(2.2rem,6.2vw,5.4rem);line-height:1.03;letter-spacing:-.03em;margin-top:clamp(1.2rem,2.5vw,1.8rem);padding-bottom:.06em}
.h1 .rd{color:var(--gold)}
.sub{grid-column:1/11;grid-row:3;font-size:clamp(1rem,1.3vw,1.18rem);color:var(--ink);margin-top:clamp(1.2rem,2vw,1.6rem);max-width:62ch;line-height:1.5}
.byl{grid-column:1/13;grid-row:4;margin-top:1.3rem;font-size:.78rem;color:var(--mid)}
.byl a{color:var(--mid)}
.byl .byl-a{color:var(--gold);text-decoration:2px underline var(--gold);text-underline-offset:3px}

.lead{font-size:clamp(1.05rem,1.4vw,1.25rem);line-height:1.6;color:var(--ink);max-width:68ch;margin-top:clamp(1.4rem,2.5vw,2rem);padding-left:1rem;border-left:3px solid var(--gold)}

.sec{padding:clamp(2rem,4vw,3rem) 0 0}
