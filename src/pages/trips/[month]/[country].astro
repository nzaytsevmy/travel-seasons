---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { DIRECTIONS, MONTHS } from '../../../data/directions.js';

export async function getStaticPaths() {
  const paths = [];
  for (const m of MONTHS) {
    for (const d of DIRECTIONS) {
      paths.push({ params: { month: m.slug, country: d.slug }, props: { m, d } });
    }
  }
  return paths;
}

const { m, d } = Astro.props;
const url = `https://traveltribe.ru/trips/${m.slug}/${d.slug}/`;
const monthIdx = MONTHS.findIndex((x) => x.slug === m.slug);
const status = d.r[monthIdx];
const text = d.t[monthIdx];

const STATUS_LABEL = {
  P: { tag: '🔥 Пик сезона', verdict: 'Лучший месяц для поездки', cls: 'peak' },
  G: { tag: '✅ Хороший месяц', verdict: 'Отличное время — погода и цены работают', cls: 'good' },
  O: { tag: '🟡 Так себе', verdict: 'Можно ехать, но есть месяцы получше', cls: 'off' },
  B: { tag: '⛔ Не лучшее время', verdict: 'Лучше выбрать другой месяц', cls: 'bad' },
  X: { tag: '❄️ Закрыто', verdict: 'Направление закрыто в этом месяце', cls: 'closed' },
};
const lbl = STATUS_LABEL[status] || STATUS_LABEL.O;

const VISA_LABEL = { free: 'Без визы', evisa: 'eVisa', required: 'Виза обязательна' };
const BUDGET_LABEL = {
  low: '$ — до $80/день',
  mid: '$$ — $80–250/день',
  high: '$$$ — от $250/день',
};

// Find best months for this destination (rank P > G > O)
const rank = { P: 4, G: 3, O: 2, B: 1, X: 0 };
const bestMonths = MONTHS
  .map((x, i) => ({ ...x, status: d.r[i], rank: rank[d.r[i]] || 0 }))
  .filter((x) => x.rank >= 3 && x.slug !== m.slug)
  .slice(0, 4);

const flightTiers = d.price?.flight || [0,0,0];
const hotelTiers = d.price?.hotel || [0,0,0];
const foodTiers = d.price?.food || [0,0,0];
const flightFrom = flightTiers[0];
const hotelFrom = hotelTiers[0];
const foodFrom = foodTiers[0];
const dailyFrom = (hotelFrom || 0) + (foodFrom || 0);
const weekTotal = flightFrom ? flightFrom + dailyFrom * 7 : null;

// Бюджет по тирам × длительность (для таблицы)
function budgetFor(days, tier) {
  const f = flightTiers[tier] || 0;
  const daily = (hotelTiers[tier] || 0) + (foodTiers[tier] || 0);
  return f + daily * days;
}
const hasPrices = flightTiers[0] > 0;
const budgetGrid = hasPrices ? [7, 14, 21].map(d_ => ({
  days: d_,
  low: budgetFor(d_, 0),
  mid: budgetFor(d_, 1),
  high: budgetFor(d_, 2),
})) : [];

// 12-месячная таблица — для блока «когда ехать»
const MONTH_META = MONTHS.map((mm, i) => {
  const st = d.r[i];
  const meta = { P: { emoji: '🔥', cls: 'peak', label: 'пик' },
                 G: { emoji: '✅', cls: 'good', label: 'хороший' },
                 O: { emoji: '🟡', cls: 'off', label: 'так себе' },
                 B: { emoji: '⛔', cls: 'bad', label: 'не лучшее' },
                 X: { emoji: '❄️', cls: 'closed', label: 'закрыто' } }[st] || { emoji: '🟡', cls: 'off', label: '—' };
  return { ...mm, status: st, ...meta, text: d.t[i] || '', isCurrent: mm.slug === m.slug };
});

// FAQ — авто-генерация (4 Q/A) для FAQPage schema и видимого блока
const visaLine = ({
  free: 'Без визы для российского паспорта',
  evisa: 'Электронная виза (eVisa) — оформляется онлайн',
  required: 'Виза обязательна — оформление в консульстве',
}[d.visa]) || 'Виза — уточнить';
const bestMonthsAll = MONTH_META.filter(mm => mm.status === 'P' || mm.status === 'G')
  .map(mm => mm.nom);
const bestMonthsStr = bestMonthsAll.length ? bestMonthsAll.join(', ') : 'нет ярко выраженного пика — едут круглый год';
const verdictForMonth = lbl.verdict + (status === 'P' || status === 'G' ? '.' : '. ' + (bestMonthsAll.length ? 'Лучше выбрать: ' + bestMonthsAll.slice(0,3).join(', ') + '.' : ''));
const budgetSummary = hasPrices && weekTotal
  ? `Перелёт из Москвы от $${flightFrom}, отель эконом от $${hotelFrom}/ночь, еда от $${foodFrom}/день. Бюджет на неделю эконом — от $${weekTotal} на человека.`
  : 'Точные цены — в калькуляторе поездки.';

const FAQS = [
  {
    q: `Стоит ли ехать ${d.cases.vP} в ${m.prep} 2026?`,
    a: `${verdictForMonth} ${text}`.trim(),
  },
  {
    q: `Сколько стоит неделя ${d.cases.loc} в ${m.prep} 2026?`,
    a: budgetSummary,
  },
  {
    q: `Какая виза нужна россиянам ${d.cases.vP} в 2026?`,
    a: `${visaLine}. Детали — на странице визы.`,
  },
  {
    q: `Когда лучше ехать ${d.cases.vP}?`,
    a: `Лучшие месяцы для поездки: ${bestMonthsStr}. Сравнить все 12 месяцев — таблица ниже.`,
  },
];

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${url}#article`,
      "url": url,
      "headline": `${d.cases.nom} в ${m.prep} 2026: погода, цены, виза`,
      "description": `Стоит ли ехать ${d.cases.vP} в ${m.prep} 2026: погода, цены на перелёт и отель, виза для россиян. ${lbl.verdict}.`,
      "inLanguage": "ru-RU",
      "datePublished": "2026-05-10",
      "author": { "@type": "Person", "name": "Никита Зайцев", "url": "https://traveltribe.ru/about/" },
      "publisher": { "@id": "https://traveltribe.ru/#org" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "Календарь", "item": "https://traveltribe.ru/trips/" },
        { "@type": "ListItem", "position": 3, "name": m.nom.charAt(0).toUpperCase() + m.nom.slice(1), "item": `https://traveltribe.ru/trips/${m.slug}/` },
        { "@type": "ListItem", "position": 4, "name": d.cases.nom, "item": url },
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${url}#faq`,
      "mainEntity": FAQS.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    }
  ]
};

const monthCap = m.nom.charAt(0).toUpperCase() + m.nom.slice(1);
---
<Layout
  title={`${d.cases.nom} в ${m.prep} 2026: погода, цены, виза`}
  description={`Стоит ли ехать ${d.cases.vP} в ${m.prep} 2026 — погода, цены, виза для россиян, бюджет на неделю. ${lbl.verdict}.`}
  canonical={url}
  noindex={status === 'X'}
  ogTitle={`${d.cases.nom} в ${m.prep} 2026`}
  ogDescription={`${lbl.tag}. ${text.slice(0, 130)}`}
  ogType="article"
  ldJson={ldJson}
>
  <Nav active="trips" />
  <Breadcrumbs crumbs={[
    { label: 'Календарь', href: '/trips/' },
    { label: monthCap, href: `/trips/${m.slug}/` },
    { label: d.cases.nom }
  ]} />

  <main id="main" class="season-wrap">
    <div class="dest-hero" style={`--g1:${d.visual.g1}; --g2:${d.visual.g2};`}>
      <span class="dest-emoji" aria-hidden="true">{d.visual.emoji}</span>
    </div>
    <header class="season-header">
      <div class={`season-tag season-tag--${lbl.cls}`}>{lbl.tag}</div>
      <h1>{d.cases.nom} <em>в {m.prep}</em> 2026</h1>
      <p class="season-sub">{lbl.verdict}. {d.region} — {d.sub}.</p>
    </header>

    <section class="season-summary">
      <p class="season-text">{text}</p>
    </section>

    <section class="season-block">
      <h2>Кратко: формат поездки</h2>
      <ul class="season-facts">
        <li><strong>Виза:</strong> <a href={`/visa/${d.slug}/`}>{VISA_LABEL[d.visa]}</a></li>
        <li><strong>Бюджет:</strong> {BUDGET_LABEL[d.budget]}</li>
        {flightFrom && <li><strong>Перелёт из Москвы от:</strong> ${flightFrom} в одну сторону</li>}
        {hotelFrom && <li><strong>Отель эконом от:</strong> ${hotelFrom}/ночь</li>}
        {weekTotal && <li><strong>Бюджет на неделю эконом:</strong> от ${weekTotal} на человека</li>}
      </ul>
    </section>

    {hasPrices && (
      <section class="season-block">
        <h2>Сколько стоит поездка {d.cases.vP} в {m.prep} 2026</h2>
        <table class="budget-table">
          <thead>
            <tr><th>Длительность</th><th>Эконом</th><th>Средний</th><th>Комфорт</th></tr>
          </thead>
          <tbody>
            {budgetGrid.map((b) => (
              <tr>
                <td><strong>{b.days} дней</strong></td>
                <td>от ${b.low}</td>
                <td>${b.mid}</td>
                <td>${b.high}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="budget-note">Перелёт из Москвы ${flightTiers[0]}–${flightTiers[2]}, отель ${hotelTiers[0]}–${hotelTiers[2]}/ночь, еда ${foodTiers[0]}–${foodTiers[2]}/день. Точный расчёт под маршрут — в <a href="/calculator/">калькуляторе поездки</a>.</p>
      </section>
    )}

    <section class="season-block">
      <h2>Когда ехать {d.cases.vP}: все 12 месяцев</h2>
      <ul class="months-grid">
        {MONTH_META.map((mm) => (
          <li class={`mg-item mg-item--${mm.cls}${mm.isCurrent ? ' mg-item--current' : ''}`}>
            <a href={`/trips/${mm.slug}/${d.slug}/`} aria-current={mm.isCurrent ? 'page' : undefined}>
              <span class="mg-emoji" aria-hidden="true">{mm.emoji}</span>
              <span class="mg-name">{mm.nom.charAt(0).toUpperCase() + mm.nom.slice(1)}</span>
              <span class="mg-status">{mm.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="season-block">
      <h2>Частые вопросы {d.cases.vP} в {m.prep}</h2>
      <div class="faq-list">
        {FAQS.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    {(status === 'P' || status === 'G') && (
      <section class="season-block">
        <h2>Что делать {d.cases.loc} в {m.prep}</h2>
        <p>{m.prep.charAt(0).toUpperCase() + m.prep.slice(1)} 2026 — один из лучших месяцев для поездки {d.cases.vP}. Погода и цены сходятся в окне комфорта. Закладывайте 7–14 дней, бронировать минимум за 2 месяца до вылета — на пиковые даты места разлетаются быстро.</p>
        <p>Сравнить с другими месяцами можно в <a href="/seasons/">таблице сезонов</a>, посчитать точный бюджет — в <a href="/calculator/">калькуляторе поездки</a>.</p>
      </section>
    )}

    {(status === 'O' || status === 'B') && bestMonths.length > 0 && (
      <section class="season-block">
        <h2>Когда лучше ехать {d.cases.vP}</h2>
        <p>{m.prep.charAt(0).toUpperCase() + m.prep.slice(1)} — не лучший месяц для этого направления. Оптимальные окна:</p>
        <ul class="season-list">
          {bestMonths.map((bm) => (
            <li><a href={`/trips/${bm.slug}/${d.slug}/`}><strong>{bm.nom}</strong></a> — {bm.status === 'P' ? 'пик сезона' : 'хороший месяц'}</li>
          ))}
        </ul>
      </section>
    )}

    {status === 'X' && (
      <section class="season-block">
        <h2>Направление закрыто</h2>
        <p>{d.cases.nom} в {m.prep} физически недоступна для туристов: либо погодные условия (зима в Антарктиде), либо все туры остановлены до сезона. Возвращайтесь к этому окну в подходящие месяцы — {bestMonths.map((bm) => bm.nom).join(', ')}.</p>
      </section>
    )}

    {d.relatedPosts.length > 0 && (
      <section class="season-block">
        <h2>Подробные гайды {d.cases.loc}</h2>
        <ul class="season-list">
          {d.relatedPosts.map((p) => (
            <li><a href={`/blog/${p.slug}/`}><strong>{p.title}</strong></a> — {p.kind === 'visa' ? 'про визу' : p.kind === 'season' ? 'про конкретный сезон' : 'личный опыт'}</li>
          ))}
        </ul>
      </section>
    )}

    <section class="season-block">
      <h2>{monthCap} 2026 — другие направления</h2>
      <p>Что ещё работает {m.prep === 'мае' ? 'в мае' : `в ${m.prep}`} 2026 — смотри <a href={`/trips/${m.slug}/`}>обзор всех направлений {m.prep}</a>.</p>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.season-wrap { max-width: 720px; margin: 0 auto; padding: 0 2rem 5rem; }
.dest-hero {
  position: relative;
  height: clamp(180px, 28vw, 280px);
  margin: 0 -2rem 0;
  background: linear-gradient(135deg, var(--g1) 0%, var(--g2) 100%);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.dest-hero::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,0.4), transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(0,0,0,0.06), transparent 50%);
  pointer-events: none;
}
.dest-emoji {
  font-size: clamp(5rem, 12vw, 8rem);
  filter: drop-shadow(0 6px 18px rgba(0,0,0,0.18));
  z-index: 1;
}
@media (min-width: 760px) {
  .dest-hero { margin-left: 0; margin-right: 0; border-radius: var(--radius-4, 8px); margin-top: 1rem; }
}

.season-header { text-align: center; margin: 2.5rem 0 2rem; }
.season-tag {
  display: inline-flex; align-items: center;
  font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
  border: 1px solid var(--line); padding: 0.3rem 0.85rem; border-radius: 20px;
  margin-bottom: 1.2rem;
}
.season-tag--peak { color: #22c55e; border-color: rgba(34,197,94,0.4); background: rgba(34,197,94,0.07); }
.season-tag--good { color: #4a9eff; border-color: rgba(74,158,255,0.4); background: rgba(74,158,255,0.07); }
.season-tag--off  { color: #f59e0b; border-color: rgba(245,158,11,0.4); background: rgba(245,158,11,0.07); }
.season-tag--bad  { color: #ef4444; border-color: rgba(239,68,68,0.4); background: rgba(239,68,68,0.07); }
.season-tag--closed { color: var(--text-faint); }

.season-header h1 {
  font-family: var(--ff-display); font-size: clamp(2.2rem, 5vw, 3.6rem);
  font-weight: 300; line-height: 1.1;
}
.season-header h1 em { color: var(--gold); font-style: italic; }
.season-sub { color: var(--text-dim); font-size: 1rem; line-height: 1.7; margin: 1rem auto 0; max-width: 560px; }

.season-summary {
  background: var(--bg2); border-left: 3px solid var(--gold);
  padding: 1.2rem 1.4rem; border-radius: 4px;
  margin-bottom: 2.5rem;
}
.season-text { color: var(--text); line-height: 1.75; font-size: 1rem; margin: 0; }

.season-block { margin-bottom: 2.5rem; }
.season-block h2 {
  font-family: var(--ff-display); font-size: 1.4rem; font-weight: 400;
  color: var(--gold); margin-bottom: 1rem;
}
.season-block p { color: var(--text-dim); line-height: 1.8; font-size: 0.95rem; margin-bottom: 0.8rem; }
.season-block a { color: var(--gold); text-decoration: underline; text-decoration-color: rgba(201,151,58,0.5); text-underline-offset: 3px; }

.season-facts, .season-list { padding-left: 1.4rem; }
.season-facts li, .season-list li {
  color: var(--text-dim); line-height: 1.8; margin-bottom: 0.45rem; font-size: 0.95rem;
}
.season-facts li strong, .season-list li strong { color: var(--text); }

/* Budget table */
.budget-table {
  width: 100%; border-collapse: collapse; margin: 1rem 0;
  font-size: 0.95rem; color: var(--text-dim);
}
.budget-table th, .budget-table td {
  text-align: left; padding: 0.6rem 0.8rem; border-bottom: 1px solid var(--line);
}
.budget-table th { font-weight: 500; color: var(--text); border-bottom-color: var(--gold); }
.budget-table tr:last-child td { border-bottom: none; }
.budget-table td:first-child { color: var(--text); }
.budget-note { font-size: 0.85rem; color: var(--text-faint); margin-top: 0.5rem; }

/* 12-month grid */
.months-grid {
  list-style: none; padding: 0; margin: 1rem 0;
  display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 0.5rem;
}
.mg-item { margin: 0; }
.mg-item a {
  display: flex; flex-direction: column; align-items: center;
  padding: 0.7rem 0.5rem; border: 1px solid var(--line); border-radius: 6px;
  text-decoration: none; color: var(--text);
  transition: border-color 0.15s, background 0.15s;
}
.mg-item a:hover { border-color: var(--gold); background: rgba(201,151,58,0.05); }
.mg-emoji { font-size: 1.2rem; line-height: 1; margin-bottom: 0.3rem; }
.mg-name { font-size: 0.9rem; font-weight: 500; }
.mg-status { font-size: 0.7rem; color: var(--text-faint); margin-top: 0.15rem; }
.mg-item--current a { border-color: var(--gold); background: rgba(201,151,58,0.08); font-weight: 600; }
.mg-item--peak .mg-status { color: #22c55e; }
.mg-item--good .mg-status { color: #4a9eff; }
.mg-item--off  .mg-status { color: #f59e0b; }
.mg-item--bad  .mg-status { color: #ef4444; }
.mg-item--closed .mg-status { color: var(--text-faint); }

/* FAQ accordion */
.faq-list { margin: 1rem 0; }
.faq-item {
  border-bottom: 1px solid var(--line); padding: 0.8rem 0;
}
.faq-item summary {
  cursor: pointer; color: var(--text); font-size: 1rem; font-weight: 500;
  list-style: none; padding-right: 1.5rem; position: relative;
}
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary::after {
  content: '+'; position: absolute; right: 0; top: 0;
  color: var(--gold); font-size: 1.3rem; line-height: 1;
  transition: transform 0.2s;
}
.faq-item[open] summary::after { content: '−'; }
.faq-item p {
  margin: 0.6rem 0 0; color: var(--text-dim); line-height: 1.7; font-size: 0.95rem;
}
</style>
