---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import authorPhoto from '../assets/author/nikita.jpg';

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      "url": "https://traveltribe.ru/about/",
      "name": "О проекте TravelTribe и авторе",
      "description": "TravelTribe — авторский тревел-блог Никиты Зайцева о путешествиях из России. Методология, источники данных, опыт автора.",
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://traveltribe.ru/#website" },
      "about": { "@id": "https://traveltribe.ru/about/#person" },
      "mainEntity": { "@id": "https://traveltribe.ru/about/#person" }
    },
    {
      "@type": "Person",
      "@id": "https://traveltribe.ru/about/#person",
      "name": "Никита Зайцев",
      "alternateName": "Nikita Zaytsev",
      "url": "https://traveltribe.ru/about/",
      "image": "https://traveltribe.ru/og-image.png",
      "jobTitle": "Travel writer · Product Manager",
      "description": "Путешественник, был на всех 7 континентах, посетил 60+ стран. Автор Telegram-канала @traveltriberu о путешествиях из России.",
      "knowsAbout": [
        "Путешествия из России",
        "Визы и пограничные правила",
        "Travel-бюджет и сезоны",
        "Тревел-фотография",
        "Африка", "Япония", "Новая Зеландия", "Австралия", "Антарктида", "США", "Бали"
      ],
      "nationality": { "@type": "Country", "name": "Россия" },
      "sameAs": [
        "https://t.me/traveltriberu",
        "https://www.linkedin.com/in/nzaytsev/",
        "https://github.com/nzaytsevmy"
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://traveltribe.ru/" },
        { "@type": "ListItem", "position": 2, "name": "О проекте", "item": "https://traveltribe.ru/about/" }
      ]
    }
  ]
};
---
<Layout
  title="Об авторе и проекте TravelTribe — Никита Зайцев"
  description="Никита Зайцев — был на всех 7 континентах, посетил 60+ стран. Автор тревел-блога TravelTribe и Telegram-канала @traveltriberu. Методология, источники данных, контакты."
  canonical="https://traveltribe.ru/about/"
  ogTitle="Об авторе и проекте TravelTribe"
  ogDescription="Никита Зайцев — 7 континентов, 60+ стран. Авторский блог о путешествиях из России."
  ldJson={ldJson}
>

  <main id="main" class="about-wrap">
    <header class="about-header">
      <div class="hero-tag">// Об авторе</div>
      <div class="author-hero">
        <Image
          src={authorPhoto}
          alt="Никита Зайцев в Фусими, Япония, ноябрь 2023"
          width={220}
          height={220}
          format="webp"
          quality={82}
          loading="eager"
          class="author-photo"
        />
        <div class="author-intro">
          <h1>Никита <em>Зайцев</em></h1>
          <p class="author-tagline">Travel-блогер · 7 континентов · 60+ стран · 13 лет в продуктах</p>
          <ul class="author-cred" aria-label="Социальные ссылки">
            <li><a href="https://t.me/traveltriberu" target="_blank" rel="noopener">Telegram @traveltriberu</a></li>
            <li><a href="https://www.linkedin.com/in/nzaytsev/" target="_blank" rel="noopener">LinkedIn /in/nzaytsev</a></li>
            <li><a href="https://github.com/nzaytsevmy" target="_blank" rel="noopener">GitHub</a></li>
            <li><a class="email-link" href="#contact" data-u="nzaytsev.my" data-d="gmail.com">Email →</a></li>
          </ul>
        </div>
      </div>
    </header>

    <div class="about-body">
      <section>
        <h2>Кто пишет</h2>
        <p>Меня зовут Никита, мне 35. По профессии — Product Manager, 13+ лет в финтехе и интернет-продуктах. Путешествия — не работа, а главное хобби: на момент мая 2026 — побывал на всех 7 континентах (включая Антарктиду), в 60+ странах. Часть поездок — длинные, по 2-4 недели; часть — короткие точечные за конкретным опытом (горные гориллы, южное сияние, момидзи в Киото).</p>
      </section>

      <section>
        <h2>Что в блоге</h2>
        <p>Я делю посты на две категории и явно помечаю их в начале:</p>
        <ul class="post-types">
          <li><strong>Личные отчёты</strong> — пишу там, где был сам. Конкретные сцены, цены из чека, фото с поездки. Маркер «<span class="trip-marker-inline">✓ Был лично</span>» под заголовком.</li>
          <li><strong>Обзоры по источникам</strong> — компиляции по визам, погранпорядкам, ценам новых направлений. Источники: сайты консульств, статистика, форумы туристов. Помечаю явно: «как написан этот пост». Если вы только что были — поправьте через Telegram, обновлю.</li>
        </ul>
        <p>Это честно по двум причинам: (1) я не могу физически быть в 70 направленийх каждый сезон; (2) Google и Яндекс в 2026 ценят прозрачность авторства выше идеальной картинки.</p>
      </section>

      <section>
        <h2>Как считается бюджет</h2>
        <p>На карточках и в таблице — ориентировочная стоимость недели на одного: перелёт + проживание + питание. Категории: <strong>$</strong> — до ~$1 500/нед, <strong>$$</strong> — $1 500–3 000/нед, <strong>$$$</strong> — от $3 000/нед. Цены усреднены по высокому и низкому сезону, обновляются вручную в <code>prices.json</code>.</p>
      </section>

      <section>
        <h2>Источники данных</h2>
        <p>Цены на перелёты — из агрегаторов (Aviasales, Google Flights). Курс валют — ЦБ РФ на дату обновления. Визовая информация — сайты консульств и официальная статистика, актуальна на 2026 год для граждан России. <strong>Перед поездкой всегда проверяйте на сайте консульства</strong> — правила меняются быстрее, чем я успеваю обновлять.</p>
      </section>

      <section>
        <h2>Open Source</h2>
        <p>Сайт построен на Astro, исходный код открыт на <a href="https://github.com/nzaytsevmy/travel-seasons" target="_blank" rel="noopener">GitHub</a>. Принимаются PR с правками визовой информации, цен, новыми направлениями. Никакой рекламы, никакой подписки, никакого сбора персональных данных кроме обязательной аналитики (Я.Метрика + Ahrefs).</p>
      </section>

      <section>
        <h2>Контакт</h2>
        <p>Telegram: <a href="https://t.me/traveltriberu" target="_blank" rel="noopener">@traveltriberu</a> — основной канал, там пишу про текущие поездки. Email для серьёзных вопросов: <a class="email-link" href="#contact" data-u="nzaytsev.my" data-d="gmail.com">показать email</a>.</p>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<style>
.about-wrap { max-width: var(--container-prose, 760px); margin: 0 auto; padding: var(--space-12, 3rem) var(--container-edge, 2rem) var(--space-16, 5rem); }

.about-header { margin-bottom: 3rem; }
.hero-tag {
  display: inline-flex; align-items: center;
  font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--gold); border: 1px solid rgba(201,151,58,0.3);
  background: rgba(201,151,58,0.08); padding: 0.3rem 0.85rem; border-radius: 20px;
  margin-bottom: 1.5rem;
}

.author-hero {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 2rem;
  align-items: center;
}
.author-photo {
  width: 220px; height: 220px;
  border-radius: 50%;
  object-fit: cover;
  object-position: center 30%;
  border: 3px solid rgba(201,151,58,0.4);
  box-shadow: 0 12px 40px rgba(0,0,0,0.4);
}
.author-intro h1 {
  font-family: var(--ff-display); font-size: clamp(2.4rem, 5vw, 3.6rem);
  font-weight: 300; line-height: 1.05;
  margin-bottom: 0.6rem;
}
.author-intro h1 em { color: var(--gold); font-style: italic; }
.author-tagline {
  font-size: 0.95rem; color: var(--text-dim);
  margin-bottom: 1rem;
}
.author-cred { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.35rem; font-size: 0.88rem; }
.author-cred a { color: var(--gold); border-bottom: 1px solid rgba(201,151,58,0.3); }
.author-cred a:hover { border-color: var(--gold); }

@media (max-width: 600px) {
  .author-hero { grid-template-columns: 1fr; text-align: center; gap: 1.2rem; }
  .author-photo { width: 160px; height: 160px; margin: 0 auto; }
  .author-cred { align-items: center; }
}

.about-body { display: flex; flex-direction: column; gap: 2.5rem; }

section h2 {
  font-family: var(--ff-display); font-size: 1.4rem; font-weight: 400;
  color: var(--gold); margin-bottom: 0.75rem;
}
section p {
  color: var(--text-dim); line-height: 1.8; font-size: 0.95rem;
}
section a { color: var(--gold); border-bottom: 1px solid rgba(201,151,58,0.3); }
section a:hover { border-color: var(--gold); }
code {
  font-size: 0.82rem; background: var(--bg2); border: 1px solid var(--line);
  padding: 0.1rem 0.4rem; border-radius: 3px; color: var(--text-dim);
}

.post-types { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.8rem; margin: 1rem 0 1.2rem; }
.post-types li { color: var(--text-dim); line-height: 1.7; padding-left: 1.2rem; position: relative; font-size: 0.95rem; }
.post-types li::before { content: '—'; position: absolute; left: 0; color: var(--gold); }
.post-types strong { color: var(--text); font-weight: 600; }
.trip-marker-inline {
  display: inline-block;
  font-size: 0.78rem; color: var(--gold);
  background: rgba(201,151,58,0.1); border: 1px solid rgba(201,151,58,0.25);
  padding: 0.1rem 0.5rem; border-radius: 999px;
}
</style>

<script is:inline>
  // Email anti-scraper: собираем mailto и видимый текст на клиенте.
  // Боты, не выполняющие JS, видят только "Email →" / "показать email" без адреса.
  // Запуск на первой загрузке И после SPA-перехода ClientRouter (DOMContentLoaded
   // при SPA не срабатывает). data-u снимается после обработки → идемпотентно.
  function _initEmails() {
    document.querySelectorAll('a.email-link').forEach(function (a) {
      var u = a.getAttribute('data-u');
      var d = a.getAttribute('data-d');
      if (!u || !d) return;
      var addr = u + '@' + d;
      a.setAttribute('href', 'mailto:' + addr);
      a.removeAttribute('data-u');
      a.removeAttribute('data-d');
      var revealed = false;
      function reveal(e) {
        if (revealed) return;
        revealed = true;
        a.textContent = addr;
      }
      a.addEventListener('mouseenter', reveal);
      a.addEventListener('focus', reveal);
      a.addEventListener('click', reveal);
    });
  }
  if (document.readyState !== 'loading') _initEmails();
  document.addEventListener('astro:page-load', _initEmails);
</script>
